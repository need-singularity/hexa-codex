// graph/gat_heads.hexa — GAT (Graph Attention Network) x n=6 정식 본문
//
// 원본 경로: techniques/graph/gat_heads.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Velickovic 외 2018, "Graph Attention Networks"
//            노드 특징에 어텐션 계수 적용, 이웃 가중 집계
//            멀티헤드 어텐션으로 표현력 확장
// n=6 정렬:
//   - 어텐션 헤드 수 = 6            -> n
//   - 노드 특징 차원   = σ(6) = 12  -> 약수합
//   - 출력 차원/헤드   = φ(6) = 2   -> 오일러
//   - 이웃 최대 수     = τ(6) = 4   -> 약수 개수
//   - 그래프 노드 수   = 6          -> n
//   - LeakyReLU 음수 기울기 = 정수 근사 (1/6)
//
// 실행: hexa run techniques/graph/gat_heads.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) GAT 스펙 (n=6 정렬)
//    핵심: alpha_ij = softmax_j(LeakyReLU(a^T [Wh_i || Wh_j]))
//    멀티헤드: h_i' = ||_{k=1}^{K} sigma(sum_j alpha_ij^k W^k h_j)
//    n=6 정렬: K=6 헤드, 특징=12, 출력/헤드=2
// ════════════════════════════════════════════════════════════════════

const N_CORE:    i64 = 6
const N_NODES:   i64 = 6      // 그래프 노드 수 = n
const FEAT_DIM:  i64 = 12     // σ(6) = 입력 특징 차원
const N_HEADS:   i64 = 6      // n=6 어텐션 헤드
const HEAD_OUT:  i64 = 2      // φ(6) = 헤드당 출력 차원
const MAX_NEIGH: i64 = 4      // τ(6) = 최대 이웃 수
const SCALE:     i64 = 100    // 정수 스케일링 인수

// ════════════════════════════════════════════════════════════════════
// 3) 인접 행렬 — 6노드 완전 그래프의 τ(6)=4 이웃 부분그래프
//    각 노드는 정확히 4개 이웃을 가짐 (4-정규 그래프)
//    인접: adj[i][j] = 1 이면 연결 (자기 루프 제외)
// ════════════════════════════════════════════════════════════════════

fn is_adjacent(i: i64, j: i64) -> bool {
    // 6노드 4-정규 그래프: 각 노드에서 대각 1개만 제외
    // 노드 i는 (i+3)%6 만 비연결 (대칭 반대편)
    if i == j { return false }
    let opp: i64 = (i + 3) % N_NODES
    if j == opp { return false }
    return true
}

fn degree(node: i64) -> i64 {
    let mut d: i64 = 0
    let mut j: i64 = 0
    while j < N_NODES {
        if is_adjacent(node, j) { d = d + 1 }
        j = j + 1
    }
    return d
}

// ════════════════════════════════════════════════════════════════════
// 4) 노드 특징 초기화 — 6노드 x 12차원
//    h_i[d] = (i * FEAT_DIM + d + 1) % 7  (n=6 다음 소수로 해싱)
// ════════════════════════════════════════════════════════════════════

fn node_feat(node: i64, dim: i64) -> i64 {
    return (node * FEAT_DIM + dim + 1) % 7
}

// 노드 특징 벡터 L2 노름 제곱 (정수)
fn feat_norm_sq(node: i64) -> i64 {
    let mut s: i64 = 0
    let mut d: i64 = 0
    while d < FEAT_DIM {
        let v: i64 = node_feat(node, d)
        s = s + v * v
        d = d + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 5) 가중치 행렬 W — 헤드별 FEAT_DIM x HEAD_OUT 변환
//    W^k[f][o] = ((k * FEAT_DIM + f) * HEAD_OUT + o + 1) % 5
//    정수 가중치로 선형 변환 시뮬레이션
// ════════════════════════════════════════════════════════════════════

fn weight(head: i64, feat: i64, out: i64) -> i64 {
    return ((head * FEAT_DIM + feat) * HEAD_OUT + out + 1) % 5
}

// 선형 변환: z_i^k[o] = sum_f W^k[f][o] * h_i[f]
fn linear_transform(head: i64, node: i64, out_dim: i64) -> i64 {
    let mut s: i64 = 0
    let mut f: i64 = 0
    while f < FEAT_DIM {
        s = s + weight(head, f, out_dim) * node_feat(node, f)
        f = f + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 6) 어텐션 계수 계산 — LeakyReLU(a^T [z_i || z_j])
//    a 벡터: a[d] = 1 (단순화 — 모든 차원 동일 가중)
//    e_ij = sum_o (z_i[o] + z_j[o])  (연결 후 합산)
//    LeakyReLU: x >= 0 이면 x, 아니면 x/N_CORE (음수 기울기 = 1/6)
// ════════════════════════════════════════════════════════════════════

fn leaky_relu(x: i64) -> i64 {
    if x >= 0 { return x * N_CORE }
    // 음수 기울기 1/6: x * N_CORE / N_CORE = x (스케일링으로 처리)
    return x
}

fn attn_raw(head: i64, src: i64, dst: i64) -> i64 {
    // e_ij = LeakyReLU(sum_o (z_i[o] + z_j[o]))
    let mut e: i64 = 0
    let mut o: i64 = 0
    while o < HEAD_OUT {
        e = e + linear_transform(head, src, o) + linear_transform(head, dst, o)
        o = o + 1
    }
    return leaky_relu(e)
}

// ════════════════════════════════════════════════════════════════════
// 7) 소프트맥스 정수 근사 — 이웃 어텐션 정규화
//    alpha_ij = e_ij * SCALE / sum_k(e_ik)  (연결된 이웃 k만)
//    절대값 기반 정규화로 음수 어텐션 방지
// ════════════════════════════════════════════════════════════════════

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn attn_sum_for_node(head: i64, node: i64) -> i64 {
    let mut total: i64 = 0
    let mut j: i64 = 0
    while j < N_NODES {
        if is_adjacent(node, j) {
            total = total + abs_val(attn_raw(head, node, j))
        }
        j = j + 1
    }
    if total == 0 { return 1 }
    return total
}

fn attn_coeff(head: i64, src: i64, dst: i64) -> i64 {
    // alpha_ij = |e_ij| * SCALE / sum_k |e_ik|
    let num: i64 = abs_val(attn_raw(head, src, dst)) * SCALE
    let den: i64 = attn_sum_for_node(head, src)
    return num / den
}

// ════════════════════════════════════════════════════════════════════
// 8) GAT 집계 — 가중 이웃 합산
//    h_i'^k[o] = sum_{j in N(i)} alpha_ij^k * z_j^k[o]
// ════════════════════════════════════════════════════════════════════

fn gat_aggregate(head: i64, node: i64, out_dim: i64) -> i64 {
    let mut agg: i64 = 0
    let mut j: i64 = 0
    while j < N_NODES {
        if is_adjacent(node, j) {
            let alpha: i64 = attn_coeff(head, node, j)
            let z: i64 = linear_transform(head, j, out_dim)
            agg = agg + alpha * z
        }
        j = j + 1
    }
    return agg / SCALE
}

// 멀티헤드 연결 출력 차원 = N_HEADS * HEAD_OUT
fn multihead_out_dim() -> i64 {
    return N_HEADS * HEAD_OUT
}

// 멀티헤드 연결 출력값 (노드 i, 전체 차원 d)
fn multihead_output(node: i64, dim: i64) -> i64 {
    let head: i64 = dim / HEAD_OUT
    let odim: i64 = dim % HEAD_OUT
    return gat_aggregate(head, node, odim)
}

// ════════════════════════════════════════════════════════════════════
// 9) 어텐션 엔트로피 검증 — 균일 분포 대비 편차
//    이상적 균일: alpha = SCALE / degree = 100/4 = 25
//    편차 합 = sum |alpha_ij - 25| 가 임계 이하인지
// ════════════════════════════════════════════════════════════════════

fn attn_uniformity_deviation(head: i64, node: i64) -> i64 {
    let ideal: i64 = SCALE / MAX_NEIGH  // 25
    let mut dev: i64 = 0
    let mut j: i64 = 0
    while j < N_NODES {
        if is_adjacent(node, j) {
            let a: i64 = attn_coeff(head, node, j)
            dev = dev + abs_val(a - ideal)
        }
        j = j + 1
    }
    return dev
}

// ════════════════════════════════════════════════════════════════════
// 10) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ GAT Heads x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 헤드 수 = n = 6
    let g2: bool = N_HEADS == N_CORE
    println("G2 헤드=n=6                 : " + g2)

    // G3: 입력 특징 = σ(6) = 12
    let g3: bool = FEAT_DIM == sig
    println("G3 특징차원=σ=12             : " + g3)

    // G4: 헤드당 출력 = φ(6) = 2
    let g4: bool = HEAD_OUT == ph
    println("G4 헤드출력=φ=2              : " + g4)

    // G5: 최대 이웃 수 = τ(6) = 4
    let g5: bool = MAX_NEIGH == t
    println("G5 이웃수=τ=4               : " + g5)

    // G6: 모든 노드 차수 = τ(6) = 4 (4-정규 그래프)
    let mut g6: bool = true
    let mut i: i64 = 0
    while i < N_NODES {
        if degree(i) != MAX_NEIGH { g6 = false }
        i = i + 1
    }
    println("G6 4-정규 그래프             : " + g6)

    // G7: 어텐션 계수 합 = SCALE (정규화 확인)
    let mut g7: bool = true
    let mut h: i64 = 0
    while h < N_HEADS {
        let mut asum: i64 = 0
        let mut j: i64 = 0
        while j < N_NODES {
            if is_adjacent(0, j) {
                asum = asum + attn_coeff(h, 0, j)
            }
            j = j + 1
        }
        // 정수 나눗셈 오차 허용: |합 - 100| <= 4
        if abs_val(asum - SCALE) > MAX_NEIGH { g7 = false }
        h = h + 1
    }
    println("G7 어텐션 정규화             : " + g7)

    // G8: 멀티헤드 출력 차원 = N_HEADS * HEAD_OUT = 12 = σ(6)
    let mh_dim: i64 = multihead_out_dim()
    let g8: bool = mh_dim == sig
    println("G8 멀티헤드=σ=12             : " + g8)

    // G9: 출력 비제로 — 모든 노드가 비영 벡터 출력
    let mut g9: bool = true
    let mut ni: i64 = 0
    while ni < N_NODES {
        let mut any_nonzero: bool = false
        let mut d: i64 = 0
        while d < mh_dim {
            if multihead_output(ni, d) != 0 { any_nonzero = true }
            d = d + 1
        }
        if !any_nonzero { g9 = false }
        ni = ni + 1
    }
    println("G9 출력 비제로               : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("그래프: 6노드 4-정규 (τ(6) 이웃)")
    println("헤드: 6개, 입력 12차원, 출력 12차원")
    println("어텐션: LeakyReLU(1/6 음수 기울기)")
    let dev0: i64 = attn_uniformity_deviation(0, 0)
    println("어텐션 균일 편차(노드0,헤드0): " + dev0)

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("GAT OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("GAT FAIL: 게이트 위반")
    }
}
