// sota/hyena.hexa — Hyena Hierarchy (FFT long conv) × n=6 정식 본문
//
// 설계서: techniques/sota/hyena.md (S2 단일진실)
// 포팅 상태: BODY (의존 없음 — 정수/실수 연산)
// 원본 요약: Poli 외 2023, "Hyena Hierarchy"
//            Attention 대체: implicit long-conv filter × data-control gate
// n=6 정렬:
//   - order        = 6            → 계층 깊이 = n
//   - order τ 변형 = 4 (τ(6))     → fan-in 게이트
//   - FFT N        = 2^a · 3^b    → 6-smooth 만 허용 (하드웨어 친화)
//   - impl. filter = 1/2+1/3+1/6  → Egyptian 분수합 = 1 정규화
// 적합 칩 : C3 Dataflow ★★★ / C4 GPU ★★★ / C6 Edge ★★
//
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀
// 논문: papers/n6-sota-ssm-paper.md  (N6-059)
// 관련: techniques/attention/fft_mix_attention.hexa (H-SEDI-EE-3 스텁)
//
// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let r: i64 = a % b
            a = b
            b = r
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// 6-smooth 여부: N의 소인수가 {2,3} 만 포함하는지
fn is_6_smooth(n: i64) -> bool {
    let mut m: i64 = n
    while m % 2 == 0 { m = m / 2 }
    while m % 3 == 0 { m = m / 3 }
    return m == 1
}

// ════════════════════════════════════════════════════════════════════
// 2) Hyena 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:   i64 = 6
const ORDER_N:  i64 = 6    // 계층 depth = n
const ORDER_T:  i64 = 4    // fan-in gate = τ(6)
const FFT_CAP:  i64 = 96   // 4·J₂(6) — 6-smooth count = J₂-τ = 20 EXACT

// ════════════════════════════════════════════════════════════════════
// 3) Egyptian implicit filter 초기화 합
//    1/2 + 1/3 + 1/6 = 1  →  정수 산술로 검증
//    공통 분모 σ(6)=12 사용: 6 + 4 + 2 = 12
// ════════════════════════════════════════════════════════════════════

fn egyptian_filter_sum() -> bool {
    let sig: i64 = sigma(N_CORE)          // 12
    let half:  i64 = sig / 2              // 6
    let third: i64 = sig / 3              // 4
    let sixth: i64 = sig / N_CORE         // 2
    return half + third + sixth == sig    // 12 = 12
}

// ════════════════════════════════════════════════════════════════════
// 4) 6-smooth FFT 길이 열거 — [1, FFT_CAP] 에서 총 몇 개?
//    n=6 정렬: FFT 커널 길이 N = 2^a · 3^b 만 허용 → 고속 라딕스 3/2
// ════════════════════════════════════════════════════════════════════

fn count_6_smooth(cap: i64) -> i64 {
    let mut cnt: i64 = 0
    let mut n: i64 = 1
    while n <= cap {
        if is_6_smooth(n) { cnt = cnt + 1 }
        n = n + 1
    }
    return cnt
}

// ════════════════════════════════════════════════════════════════════
// 5) long-conv 합성 — implicit filter × input 정수 합성곱
//    order=6 계층의 핵: (u_t ⊙ g_t) ⊗ h_t  에서 g/h 상수화한 toy
// ════════════════════════════════════════════════════════════════════

fn long_conv_toy(len: i64) -> i64 {
    // 커널 h = [1,1,1,1,1,1] (길이 6 = n)
    // 입력 u_t = 1 일 때, 출력 중심값 = len·n
    let mut acc: i64 = 0
    let mut t: i64 = 0
    while t < len {
        acc = acc + N_CORE
        t = t + 1
    }
    return acc
}

// ════════════════════════════════════════════════════════════════════
// 6) 게이트 실행
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ SOTA S2 · Hyena Hierarchy × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    let gate_sopfr: bool = sig * ph == N_CORE * t   // σφ=nτ 정점
    let gate_order: bool = ORDER_N == N_CORE
    let gate_fan:   bool = ORDER_T == t             // τ(6)=4
    let gate_egypt: bool = egyptian_filter_sum()    // 1/2+1/3+1/6 = 1
    let gate_smt8:  bool = is_6_smooth(8)           // 2^3 = 8
    let gate_smt12: bool = is_6_smooth(12)          // 2^2·3 = 12
    let gate_smt24: bool = is_6_smooth(24)          // 2^3·3 = J₂(6)
    let gate_nsm5:  bool = !is_6_smooth(5)          // 5 = sopfr(6) 는 non-smooth
    let gate_nsm7:  bool = !is_6_smooth(7)          // 7 소수
    let cnt_smt:    i64  = count_6_smooth(FFT_CAP)  // cap=96 → 20

    println("S2.G1 σφ=nτ                        : " + gate_sopfr)
    println("S2.G2 order = n = 6                : " + gate_order)
    println("S2.G3 fan-in = τ = 4               : " + gate_fan)
    println("S2.G4 Egyptian 1/2+1/3+1/6 = 1     : " + gate_egypt)
    println("S2.G5 N=8  6-smooth                : " + gate_smt8)
    println("S2.G6 N=12 6-smooth                : " + gate_smt12)
    println("S2.G7 N=24 6-smooth                : " + gate_smt24)
    println("S2.G8 N=5  비(非) 6-smooth         : " + gate_nsm5)
    println("S2.G9 N=7  비(非) 6-smooth         : " + gate_nsm7)
    println("S2.G10 6-smooth ≤96 = J₂-τ = 20    : " + cnt_smt)
    let gate_cnt:   bool = cnt_smt == 24 - t       // J₂(6)-τ(6)=20

    // long-conv toy: len=6 → 6·6 = 36 = n²
    let toy: i64 = long_conv_toy(N_CORE)
    let gate_conv:  bool = toy == N_CORE * N_CORE
    println("S2.G11 long-conv toy 36 = n²       : " + gate_conv)

    if gate_sopfr && gate_order && gate_fan && gate_egypt
       && gate_smt8 && gate_smt12 && gate_smt24
       && gate_nsm5 && gate_nsm7 && gate_cnt && gate_conv {
        println("S2 OSSIFIED: 11/11  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("S2 FAIL: n=6 정합 게이트 위반")
    }
}
