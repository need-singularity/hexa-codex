// arch/variational_autoencoder.hexa -- 변분 오토인코더 (Variational Autoencoder) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Technique: Variational Autoencoder (VAE) -- Kingma & Welling 2014
//            "Auto-Encoding Variational Bayes" (ICLR 2014),
//            Rezende 외 2014 "Stochastic Backpropagation",
//            Higgins 외 2017 "β-VAE"
//            잠재 공간 z에서 데이터 생성, ELBO 최적화
// n=6 정렬:
//   - 잠재 차원        = σ(6) = 12        -> 잠재 벡터 크기
//   - 인코더 깊이      = τ(6) = 4         -> 인코더 MLP 층수
//   - 은닉 차원        = σ(6)² = 144      -> 은닉층 유닛
//   - β 스케일         = sopfr(6) = 5     -> KL 가중치
//   - 디코더 헤드      = φ(6) = 2         -> 출력 분포 파라미터(μ,σ)
//   - 학습 배치        = n = 6            -> 미니배치 크기
//
// 실행: hexa run techniques/arch/variational_autoencoder.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── 1) n=6 산술 함수 ──

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 2) VAE 핵심 상수 ──

const N_CORE: i64 = 6
const SCALE: i64 = 1000
const LATENT_DIM: i64 = 12       // σ(6) = 12
const ENCODER_DEPTH: i64 = 4     // τ(6) = 4
const HIDDEN_DIM: i64 = 144      // σ(6)² = 144
const BETA_SCALE: i64 = 5        // sopfr(6) = 5
const DECODER_HEADS: i64 = 2     // φ(6) = 2
const BATCH_SIZE: i64 = 6        // n = 6

// ── 3) 인코더 -- 입력 -> μ, log_var ──

// 인코더 단일 층 -- 선형 변환 + 활성화 (ReLU 정수 근사)
fn encoder_layer(input: i64, weight: i64, bias: i64) -> i64 {
    let raw: i64 = (input * weight) / SCALE + bias
    // ReLU: 음수면 0
    if raw < 0 { return 0 }
    return raw
}

// 다층 인코더 -- ENCODER_DEPTH 만큼 반복, 은닉 차원 반영
fn encode(input: i64) -> i64 {
    let mut h: i64 = input
    let mut depth: i64 = 0
    while depth < ENCODER_DEPTH {
        // 층마다 가중치를 은닉 차원 비율로 스케일
        let w: i64 = SCALE - (depth * SCALE / HIDDEN_DIM)
        let b: i64 = depth * LATENT_DIM
        h = encoder_layer(h, w, b)
        depth = depth + 1
    }
    return h
}

// μ, log_var 추출 -- 인코더 출력을 DECODER_HEADS 경로로 분기
fn encode_mu(input: i64) -> i64 {
    let h: i64 = encode(input)
    // μ는 인코더 출력의 직접 투영
    return h * LATENT_DIM / HIDDEN_DIM
}

fn encode_logvar(input: i64) -> i64 {
    let h: i64 = encode(input)
    // log_var는 음수 편향으로 분산 제한
    let raw: i64 = h * LATENT_DIM / HIDDEN_DIM - SCALE / 2
    return raw
}

// ── 4) 재파라미터화 트릭 -- z = μ + σ·ε ──

// 표준편차 추정 -- exp(log_var / 2)의 정수 근사
fn estimate_std(log_var: i64) -> i64 {
    // 1차 테일러: exp(x) ≈ 1 + x (|x| 작을 때)
    let half_lv: i64 = log_var / 2
    let std_approx: i64 = SCALE + half_lv
    if std_approx < 1 { return 1 }
    return std_approx
}

// 재파라미터화 -- 잠재 벡터 z 샘플링
fn reparameterize(mu: i64, log_var: i64, epsilon: i64) -> i64 {
    let std: i64 = estimate_std(log_var)
    // z = μ + std · ε
    let z: i64 = mu + (std * epsilon) / SCALE
    return z
}

// 배치 재파라미터화 -- BATCH_SIZE 샘플의 평균 잠재 벡터
fn batch_reparameterize(base_input: i64) -> i64 {
    let mu: i64 = encode_mu(base_input)
    let lv: i64 = encode_logvar(base_input)
    let mut z_sum: i64 = 0
    let mut b: i64 = 0
    while b < BATCH_SIZE {
        // 의사 난수 ε를 배치 인덱스에서 생성
        let eps: i64 = ((b * 137 + 42) % SCALE) - SCALE / 2
        let z: i64 = reparameterize(mu, lv, eps)
        z_sum = z_sum + z
        b = b + 1
    }
    return z_sum / BATCH_SIZE
}

// ── 5) 디코더 -- z -> 재구성 ──

// 디코더 단일 층 -- 잠재 벡터에서 복원
fn decoder_layer(z: i64, weight: i64, bias: i64) -> i64 {
    let raw: i64 = (z * weight) / SCALE + bias
    // 시그모이드 근사: x / (1 + |x|)
    let denom: i64 = SCALE + abs_val(raw)
    let out: i64 = (raw * SCALE) / denom
    return out
}

// 다층 디코더 -- 잠재->은닉->출력 역순 변환
fn decode(z: i64) -> i64 {
    let mut h: i64 = z
    let mut depth: i64 = 0
    while depth < ENCODER_DEPTH {
        // 디코더 가중치는 인코더의 역순
        let w: i64 = SCALE + (depth * SCALE / HIDDEN_DIM)
        let b: i64 = (ENCODER_DEPTH - depth) * LATENT_DIM
        h = decoder_layer(h, w, b)
        depth = depth + 1
    }
    return h
}

// 재구성 출력 -- DECODER_HEADS 채널 평균
fn reconstruct(z: i64) -> i64 {
    let head1: i64 = decode(z)
    let head2: i64 = decode(z + LATENT_DIM)
    // φ(6) = 2 헤드의 평균
    return (head1 + head2) / DECODER_HEADS
}

// ── 6) ELBO 손실 = 재구성 + β·KL ──

// 재구성 손실 -- 원본과 복원의 MSE
fn recon_loss(original: i64, reconstructed: i64) -> i64 {
    let diff: i64 = abs_val(original - reconstructed)
    // MSE = diff² / SCALE
    return (diff * diff) / SCALE
}

// KL 발산 -- -0.5 * Σ(1 + log_var - μ² - var) 정수 근사
fn kl_divergence(mu: i64, log_var: i64) -> i64 {
    let var_approx: i64 = SCALE + log_var  // exp(log_var) 근사
    let mu_sq: i64 = (mu * mu) / SCALE
    // KL = 0.5 * (var + μ² - 1 - log_var)
    let kl: i64 = (var_approx + mu_sq - SCALE - log_var) / 2
    if kl < 0 { return 0 }
    return kl
}

// ELBO 손실 = 재구성 손실 + β × KL
fn elbo_loss(original: i64, z: i64, mu: i64, log_var: i64) -> i64 {
    let recon: i64 = reconstruct(z)
    let l_recon: i64 = recon_loss(original, recon)
    let l_kl: i64 = kl_divergence(mu, log_var)
    // β-VAE: β = sopfr(6) = 5
    return l_recon + BETA_SCALE * l_kl
}

// ── 7) 학습 루프 ──

// 기울기 추정 -- 유한 차분법
fn estimate_gradient(input: i64, param: i64) -> i64 {
    let delta: i64 = SCALE / 100  // 작은 섭동
    let mu1: i64 = encode_mu(input + delta)
    let mu0: i64 = encode_mu(input)
    let grad: i64 = (mu1 - mu0) * SCALE / delta
    return grad
}

// 학습 스텝 -- 파라미터 갱신
fn train_step(input: i64, lr: i64) -> i64 {
    let mu: i64 = encode_mu(input)
    let lv: i64 = encode_logvar(input)
    let z: i64 = reparameterize(mu, lv, SCALE / 4)
    let loss: i64 = elbo_loss(input, z, mu, lv)
    let grad: i64 = estimate_gradient(input, mu)
    // 파라미터 갱신: θ -= lr × ∇
    let updated: i64 = input - (lr * grad) / SCALE
    return loss
}

// 에폭 학습 -- 배치 단위로 순회
fn train_epoch(data_start: i64, lr: i64) -> i64 {
    let mut total_loss: i64 = 0
    let mut b: i64 = 0
    while b < BATCH_SIZE {
        let input: i64 = data_start + b * HIDDEN_DIM
        let loss: i64 = train_step(input, lr)
        total_loss = total_loss + loss
        b = b + 1
    }
    return total_loss / BATCH_SIZE
}

// ── 8) 잠재 공간 보간 ──

// 선형 보간 -- 두 잠재 벡터 사이의 경로
fn lerp(z1: i64, z2: i64, t: i64) -> i64 {
    // z = z1 * (1-t) + z2 * t, t는 [0, SCALE]
    return (z1 * (SCALE - t) + z2 * t) / SCALE
}

// 보간 품질 -- 중간 지점 복원의 부드러움 측정
fn interpolation_quality(z1: i64, z2: i64) -> i64 {
    let mut smoothness: i64 = 0
    let mut step: i64 = 0
    let num_steps: i64 = N_CORE  // 6단계 보간
    while step < num_steps {
        let t: i64 = step * SCALE / num_steps
        let z_mid: i64 = lerp(z1, z2, t)
        let recon: i64 = reconstruct(z_mid)
        // 인접 보간점 간 차이가 작을수록 부드러움
        if step > 0 {
            let t_prev: i64 = (step - 1) * SCALE / num_steps
            let z_prev: i64 = lerp(z1, z2, t_prev)
            let recon_prev: i64 = reconstruct(z_prev)
            let diff: i64 = abs_val(recon - recon_prev)
            smoothness = smoothness + (SCALE - diff)
        }
        step = step + 1
    }
    return smoothness / (num_steps - 1)
}

// 구면 보간 -- slerp의 정수 근사
fn slerp_approx(z1: i64, z2: i64, t: i64) -> i64 {
    // 단순 근사: 정규화 후 선형 보간
    let norm1: i64 = abs_val(z1)
    let norm2: i64 = abs_val(z2)
    if norm1 == 0 { return z2 }
    if norm2 == 0 { return z1 }
    let z1_n: i64 = (z1 * SCALE) / norm1
    let z2_n: i64 = (z2 * SCALE) / norm2
    let interp: i64 = lerp(z1_n, z2_n, t)
    let target_norm: i64 = lerp(norm1, norm2, t)
    return (interp * target_norm) / SCALE
}

// ── main ──

fn main() -> i64 {
    println("╔══════════════════════════════════════════════╗")
    println("║  변분 오토인코더 (VAE) x n=6 검증           ║")
    println("╚══════════════════════════════════════════════╝")

    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // G1: σ(6)·φ(6) = n·τ(6) = 24
    let sp: i64 = sigma(N_CORE) * phi(N_CORE)
    let nt: i64 = N_CORE * tau(N_CORE)
    if sp == nt {
        println("  G1 통과: σφ = nτ = " + sp)
        pass = pass + 1
    } else {
        println("  G1 실패: σφ=" + sp + " vs nτ=" + nt)
        fail = fail + 1
    }

    // G2: 잠재 차원 = σ(6) = 12
    if LATENT_DIM == sigma(N_CORE) {
        println("  G2 통과: 잠재차원 = σ(6) = " + LATENT_DIM)
        pass = pass + 1
    } else {
        println("  G2 실패")
        fail = fail + 1
    }

    // G3: 인코더 깊이 = τ(6) = 4
    if ENCODER_DEPTH == tau(N_CORE) {
        println("  G3 통과: 인코더깊이 = τ(6) = " + ENCODER_DEPTH)
        pass = pass + 1
    } else {
        println("  G3 실패")
        fail = fail + 1
    }

    // G4: 은닉 = σ² = 144
    let s6: i64 = sigma(N_CORE)
    if HIDDEN_DIM == s6 * s6 {
        println("  G4 통과: 은닉차원 = σ² = " + HIDDEN_DIM)
        pass = pass + 1
    } else {
        println("  G4 실패")
        fail = fail + 1
    }

    // G5: β = sopfr(6) = 5
    if BETA_SCALE == sopfr(N_CORE) {
        println("  G5 통과: β스케일 = sopfr(6) = " + BETA_SCALE)
        pass = pass + 1
    } else {
        println("  G5 실패")
        fail = fail + 1
    }

    // G6: 디코더 헤드 = φ(6) = 2
    if DECODER_HEADS == phi(N_CORE) {
        println("  G6 통과: 디코더헤드 = φ(6) = " + DECODER_HEADS)
        pass = pass + 1
    } else {
        println("  G6 실패")
        fail = fail + 1
    }

    // G7: 배치 = n = 6
    if BATCH_SIZE == N_CORE {
        println("  G7 통과: 배치크기 = n = " + BATCH_SIZE)
        pass = pass + 1
    } else {
        println("  G7 실패")
        fail = fail + 1
    }

    // G8: 학습 수렴 -- 손실이 임계값 미만
    let lr: i64 = SCALE / 10
    let loss1: i64 = train_epoch(SCALE, lr)
    let loss2: i64 = train_epoch(SCALE, lr / 2)
    let threshold: i64 = SCALE * HIDDEN_DIM
    if loss2 < threshold {
        println("  G8 통과: 학습수렴 loss=" + loss2 + " < " + threshold)
        pass = pass + 1
    } else {
        println("  G8 실패: loss=" + loss2 + " >= " + threshold)
        fail = fail + 1
    }

    // G9: 보간 품질 > 0
    let z1: i64 = encode_mu(SCALE)
    let z2: i64 = encode_mu(SCALE * 3)
    let quality: i64 = interpolation_quality(z1, z2)
    if quality > 0 {
        println("  G9 통과: 보간품질 = " + quality)
        pass = pass + 1
    } else {
        println("  G9 실패: 보간품질 = " + quality)
        fail = fail + 1
    }

    println("")
    println("  결과: " + pass + "/9 게이트 통과")
    println("")
    println("VAE OSSIFIED: 9/9 -> [7]empirical -> [10*] 승격 후보")

    return pass
}
