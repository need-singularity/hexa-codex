// arch/yolo_nms.hexa — YOLO NMS x n=6 정식 본문
//
// 원본 경로: techniques/arch/yolo_nms.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 28: YOLO NMS Thresholds (Redmon 외 2016)
//            τ(6)=4 기반 NMS 임계값, n=6 탐지 설계
// n=6 정렬:
//   - 그리드        = 6x6         -> n x n 탐지 그리드
//   - 박스/셀       = τ(6) = 4    -> 셀당 4개 바운딩 박스
//   - 클래스        = 6           -> n 클래스
//   - IoU 임계값    = τ(6)/σ(6) = 4/12 = 1/3 (정수: 분자4 분모12)
//   - 신뢰 임계값   = φ(6)/n = 2/6 = 1/3
//   - 총 예측       = 36*4 = 144 = σ(6)^2
//
// 실행: hexa run techniques/arch/yolo_nms.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn min_val(a: i64, b: i64) -> i64 {
    if a < b { return a }
    return b
}

fn max_val(a: i64, b: i64) -> i64 {
    if a > b { return a }
    return b
}

// ════════════════════════════════════════════════════════════════════
// 2) YOLO 스펙 (n=6 정렬)
//    6x6 그리드, 셀당 τ(6)=4 박스
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const GRID_SIZE:    i64 = 6    // n=6 그리드
const BOXES_PER_CELL: i64 = 4  // τ(6) = 4 박스/셀
const N_CLASSES:    i64 = 6    // n = 6 클래스
const IOU_NUM:      i64 = 4    // IoU 임계값 분자 = τ(6)
const IOU_DEN:      i64 = 12   // IoU 임계값 분모 = σ(6)
const CONF_NUM:     i64 = 2    // 신뢰 임계값 분자 = φ(6)
const CONF_DEN:     i64 = 6    // 신뢰 임계값 분모 = n

// ════════════════════════════════════════════════════════════════════
// 3) 바운딩 박스 정의 — 셀(r,c)의 박스 b
//    cx = c * 100 + b * 20 (정수 좌표, 스케일 100)
//    cy = r * 100 + b * 15
//    w  = 30 + b * 10
//    h  = 30 + b * 10
//    conf = (r + c + b) % 10 + 1 (1~10, 분모 10)
// ════════════════════════════════════════════════════════════════════

fn box_cx(r: i64, c: i64, b: i64) -> i64 {
    return c * 100 + b * 20
}

fn box_cy(r: i64, c: i64, b: i64) -> i64 {
    return r * 100 + b * 15
}

fn box_w(b: i64) -> i64 {
    return 30 + b * 10
}

fn box_h(b: i64) -> i64 {
    return 30 + b * 10
}

fn box_conf(r: i64, c: i64, b: i64) -> i64 {
    // 신뢰도 [1, 10] (분모 10 스케일)
    return (r + c + b) % 10 + 1
}

// ════════════════════════════════════════════════════════════════════
// 4) IoU 계산 — 두 박스의 교집합/합집합
//    정수 연산: 좌표를 직접 사용
// ════════════════════════════════════════════════════════════════════

fn iou_scaled(r1: i64, c1: i64, b1: i64,
              r2: i64, c2: i64, b2: i64) -> i64 {
    // 박스1 경계
    let x1_min: i64 = box_cx(r1, c1, b1) - box_w(b1) / 2
    let x1_max: i64 = box_cx(r1, c1, b1) + box_w(b1) / 2
    let y1_min: i64 = box_cy(r1, c1, b1) - box_h(b1) / 2
    let y1_max: i64 = box_cy(r1, c1, b1) + box_h(b1) / 2

    // 박스2 경계
    let x2_min: i64 = box_cx(r2, c2, b2) - box_w(b2) / 2
    let x2_max: i64 = box_cx(r2, c2, b2) + box_w(b2) / 2
    let y2_min: i64 = box_cy(r2, c2, b2) - box_h(b2) / 2
    let y2_max: i64 = box_cy(r2, c2, b2) + box_h(b2) / 2

    // 교집합
    let ix_min: i64 = max_val(x1_min, x2_min)
    let ix_max: i64 = min_val(x1_max, x2_max)
    let iy_min: i64 = max_val(y1_min, y2_min)
    let iy_max: i64 = min_val(y1_max, y2_max)

    let iw: i64 = max_val(0, ix_max - ix_min)
    let ih: i64 = max_val(0, iy_max - iy_min)
    let inter: i64 = iw * ih

    // 합집합
    let area1: i64 = box_w(b1) * box_h(b1)
    let area2: i64 = box_w(b2) * box_h(b2)
    let union_area: i64 = area1 + area2 - inter

    if union_area == 0 { return 0 }
    // IoU * IOU_DEN (스케일드 반환)
    return inter * IOU_DEN / union_area
}

// ════════════════════════════════════════════════════════════════════
// 5) 신뢰도 필터링 — CONF_NUM/CONF_DEN 이상만 통과
// ════════════════════════════════════════════════════════════════════

fn passes_conf(r: i64, c: i64, b: i64) -> bool {
    // conf * CONF_DEN >= CONF_NUM * 10 (conf가 /10 스케일이므로)
    let conf: i64 = box_conf(r, c, b)
    return conf * CONF_DEN >= CONF_NUM * 10
}

fn count_conf_pass() -> i64 {
    let mut count: i64 = 0
    let mut r: i64 = 0
    while r < GRID_SIZE {
        let mut c: i64 = 0
        while c < GRID_SIZE {
            let mut b: i64 = 0
            while b < BOXES_PER_CELL {
                if passes_conf(r, c, b) { count = count + 1 }
                b = b + 1
            }
            c = c + 1
        }
        r = r + 1
    }
    return count
}

// ════════════════════════════════════════════════════════════════════
// 6) NMS 억제 계수 — 같은 셀 내 박스끼리 IoU 검사
//    IoU > IOU_NUM 이면 낮은 신뢰도 박스 억제
// ════════════════════════════════════════════════════════════════════

fn nms_suppressed_in_cell(r: i64, c: i64) -> i64 {
    let mut suppressed: i64 = 0
    let mut b1: i64 = 0
    while b1 < BOXES_PER_CELL {
        let mut b2: i64 = b1 + 1
        while b2 < BOXES_PER_CELL {
            let iou: i64 = iou_scaled(r, c, b1, r, c, b2)
            if iou > IOU_NUM {
                // 낮은 신뢰도 쪽 억제
                let c1: i64 = box_conf(r, c, b1)
                let c2: i64 = box_conf(r, c, b2)
                if c1 < c2 {
                    suppressed = suppressed + 1
                } else {
                    suppressed = suppressed + 1
                }
            }
            b2 = b2 + 1
        }
        b1 = b1 + 1
    }
    return suppressed
}

fn total_suppressed() -> i64 {
    let mut total: i64 = 0
    let mut r: i64 = 0
    while r < GRID_SIZE {
        let mut c: i64 = 0
        while c < GRID_SIZE {
            total = total + nms_suppressed_in_cell(r, c)
            c = c + 1
        }
        r = r + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 7) 총 예측 수
// ════════════════════════════════════════════════════════════════════

fn total_predictions() -> i64 {
    return GRID_SIZE * GRID_SIZE * BOXES_PER_CELL
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ YOLO NMS x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 그리드 = 6x6
    let g2: bool = GRID_SIZE == N_CORE
    println("G2 그리드=6x6               : " + g2)

    // G3: 박스/셀 = τ(6) = 4
    let g3: bool = BOXES_PER_CELL == t
    println("G3 박스/셀=τ=4              : " + g3)

    // G4: 총 예측 = σ(6)^2 = 144
    let tp: i64 = total_predictions()
    let g4: bool = tp == sig * sig
    println("G4 총예측=" + tp + "=σ²=144       : " + g4)

    // G5: IoU 임계값 = τ(6)/σ(6)
    let g5: bool = IOU_NUM == t && IOU_DEN == sig
    println("G5 IoU=τ/σ=4/12             : " + g5)

    // G6: 신뢰 임계값 = φ(6)/n
    let g6: bool = CONF_NUM == ph && CONF_DEN == N_CORE
    println("G6 신뢰=φ/n=2/6             : " + g6)

    // G7: 신뢰 통과 박스 수 < 전체
    let conf_pass: i64 = count_conf_pass()
    let g7: bool = conf_pass > 0 && conf_pass <= tp
    println("G7 신뢰통과=" + conf_pass + "/" + tp + "      : " + g7)

    // G8: NMS 억제 수 >= 0
    let supp: i64 = total_suppressed()
    let g8: bool = supp >= 0
    println("G8 NMS억제=" + supp + "             : " + g8)

    // 셀 (0,0) 상세 출력
    let mut b: i64 = 0
    while b < BOXES_PER_CELL {
        let cx: i64 = box_cx(0, 0, b)
        let cy: i64 = box_cy(0, 0, b)
        let w: i64 = box_w(b)
        let h: i64 = box_h(b)
        let conf: i64 = box_conf(0, 0, b)
        println("  셀(0,0) 박스" + b + ": cx=" + cx + " cy=" + cy + " " + w + "x" + h + " 신뢰=" + conf)
        b = b + 1
    }

    // G9: 클래스 = n = 6
    let g9: bool = N_CLASSES == N_CORE
    println("G9 클래스=n=6               : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("그리드: " + GRID_SIZE + "x" + GRID_SIZE)
    println("박스/셀: " + BOXES_PER_CELL)
    println("총 예측: " + tp)
    println("신뢰 통과: " + conf_pass)
    println("NMS 억제: " + supp)
    println("최종 탐지: ~" + (conf_pass - supp))

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("YOLO NMS OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("YOLO NMS FAIL: 게이트 위반")
    }
}
