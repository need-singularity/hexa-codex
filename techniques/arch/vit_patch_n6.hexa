// arch/vit_patch_n6.hexa — Vision Transformer 6x6 패치 x n=6 정식 본문
//
// 원본 경로: techniques/arch/vit_patch_n6.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 28: ViT Patch Design (BT-66, Dosovitskiy 외 2021)
//            6x6 패치, n=6 기반 ViT 아키텍처
// n=6 정렬:
//   - 패치 크기      = 6x6        -> n x n 패치
//   - 이미지 크기    = 36x36      -> 6^2 x 6^2
//   - 시퀀스 길이    = 36         -> (36/6)^2 = 36 패치
//   - 임베딩 차원    = σ(6) = 12  -> 패치 임베딩
//   - 트랜스포머 층  = τ(6) = 4   -> 4층 인코더
//   - 어텐션 헤드    = φ(6) = 2   -> 2헤드
//   - 클래스 수      = 6          -> n 분류
//
// 실행: hexa run techniques/arch/vit_patch_n6.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) ViT 스펙 (n=6 정렬)
//    이미지 = 36x36, 패치 = 6x6, 시퀀스 = 36+1(CLS)
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const PATCH_SIZE: i64 = 6     // n=6 패치
const IMG_SIZE:   i64 = 36    // 6^2 = 36
const EMBED_DIM:  i64 = 12    // σ(6) = 12
const N_LAYERS:   i64 = 4     // τ(6) = 4
const N_HEADS:    i64 = 2     // φ(6) = 2
const N_CLASSES:  i64 = 6     // n = 6 분류

// ════════════════════════════════════════════════════════════════════
// 3) 시퀀스 길이 — 패치 수 + CLS 토큰
// ════════════════════════════════════════════════════════════════════

fn n_patches() -> i64 {
    let patches_per_side: i64 = IMG_SIZE / PATCH_SIZE
    return patches_per_side * patches_per_side
}

fn seq_len() -> i64 {
    // 패치 수 + 1 (CLS 토큰)
    return n_patches() + 1
}

// ════════════════════════════════════════════════════════════════════
// 4) 패치 임베딩 — 선형 프로젝션
//    입력: PATCH_SIZE^2 * 채널(=1) = 36
//    출력: EMBED_DIM = 12
//    파라미터: 36 * 12 = 432
// ════════════════════════════════════════════════════════════════════

fn patch_embed_params() -> i64 {
    let patch_pixels: i64 = PATCH_SIZE * PATCH_SIZE
    return patch_pixels * EMBED_DIM
}

// 위치 임베딩 파라미터 (학습 가능)
fn pos_embed_params() -> i64 {
    return seq_len() * EMBED_DIM
}

// ════════════════════════════════════════════════════════════════════
// 5) 패치 임베딩 값 — 결정론적 시드
//    패치 p, 차원 d: (p * EMBED_DIM + d) % 13 - 6
// ════════════════════════════════════════════════════════════════════

fn patch_value(p: i64, d: i64) -> i64 {
    return (p * EMBED_DIM + d) % 13 - N_CORE
}

fn patch_norm_sq(p: i64) -> i64 {
    let mut norm: i64 = 0
    let mut d: i64 = 0
    while d < EMBED_DIM {
        let v: i64 = patch_value(p, d)
        norm = norm + v * v
        d = d + 1
    }
    return norm
}

// ════════════════════════════════════════════════════════════════════
// 6) 셀프 어텐션 — φ(6)=2 헤드
//    head_dim = EMBED_DIM / N_HEADS = 6
//    어텐션 파라미터/블록 = 4 * EMBED_DIM^2
// ════════════════════════════════════════════════════════════════════

fn head_dim() -> i64 {
    return EMBED_DIM / N_HEADS
}

fn attn_params_per_layer() -> i64 {
    // Q, K, V, O 각각 EMBED_DIM * EMBED_DIM
    return 4 * EMBED_DIM * EMBED_DIM
}

// ════════════════════════════════════════════════════════════════════
// 7) FFN 파라미터 — 4배 확장 (τ(6)=4)
//    FFN_DIM = EMBED_DIM * τ(6) = 48
// ════════════════════════════════════════════════════════════════════

fn ffn_dim() -> i64 {
    return EMBED_DIM * N_LAYERS  // 12 * 4 = 48
}

fn ffn_params_per_layer() -> i64 {
    let fd: i64 = ffn_dim()
    return EMBED_DIM * fd + fd * EMBED_DIM
}

// ════════════════════════════════════════════════════════════════════
// 8) 전체 파라미터 계산
// ════════════════════════════════════════════════════════════════════

fn layer_params() -> i64 {
    return attn_params_per_layer() + ffn_params_per_layer()
}

fn cls_head_params() -> i64 {
    return EMBED_DIM * N_CLASSES
}

fn total_params() -> i64 {
    let pe: i64 = patch_embed_params()
    let pos: i64 = pos_embed_params()
    let layers: i64 = N_LAYERS * layer_params()
    let cls: i64 = cls_head_params()
    return pe + pos + layers + cls
}

// ════════════════════════════════════════════════════════════════════
// 9) 어텐션 스코어 — CLS 토큰과 패치 간 내적
// ════════════════════════════════════════════════════════════════════

fn cls_patch_attn(p: i64) -> i64 {
    // CLS 토큰 = 패치 0 근사
    let mut dot: i64 = 0
    let mut d: i64 = 0
    while d < EMBED_DIM {
        dot = dot + patch_value(0, d) * patch_value(p, d)
        d = d + 1
    }
    return dot
}

// ════════════════════════════════════════════════════════════════════
// 10) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ ViT Patch n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 패치 = 6x6
    let g2: bool = PATCH_SIZE == N_CORE
    println("G2 패치=6x6                 : " + g2)

    // G3: 이미지 = 6^2 = 36
    let g3: bool = IMG_SIZE == N_CORE * N_CORE
    println("G3 이미지=36x36             : " + g3)

    // G4: 패치 수 = (36/6)^2 = 36
    let np: i64 = n_patches()
    let g4: bool = np == 36
    println("G4 패치수=" + np + "=36            : " + g4)

    // G5: 임베딩 = σ(6) = 12
    let g5: bool = EMBED_DIM == sig
    println("G5 임베딩=σ=12              : " + g5)

    // G6: 인코더 층 = τ(6) = 4
    let g6: bool = N_LAYERS == t
    println("G6 인코더=τ=4               : " + g6)

    // G7: 어텐션 헤드 = φ(6) = 2
    let g7: bool = N_HEADS == ph
    println("G7 헤드=φ=2                 : " + g7)

    // G8: head_dim 정수 나눗셈 성립
    let hd: i64 = head_dim()
    let g8: bool = hd * N_HEADS == EMBED_DIM
    println("G8 head_dim=" + hd + " (정수)       : " + g8)

    // 패치 노름 출력 (처음 6개)
    let mut p: i64 = 0
    while p < N_CORE {
        let ns: i64 = patch_norm_sq(p)
        let attn: i64 = cls_patch_attn(p)
        println("  패치 " + p + ": 노름²=" + ns + " CLS어텐션=" + attn)
        p = p + 1
    }

    // G9: 분류 클래스 = n = 6
    let g9: bool = N_CLASSES == N_CORE
    println("G9 클래스=n=6               : " + g9)

    // 벤치마크 지표
    let tp: i64 = total_params()
    println("--- 벤치마크 ---")
    println("이미지: " + IMG_SIZE + "x" + IMG_SIZE + " / 패치: " + PATCH_SIZE + "x" + PATCH_SIZE)
    println("시퀀스: " + seq_len() + " (패치 " + np + " + CLS)")
    println("head_dim: " + hd)
    println("FFN 차원: " + ffn_dim())
    println("패치임베딩 파라미터: " + patch_embed_params())
    println("총 파라미터: " + tp)

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("ViT Patch n=6 OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("ViT Patch n=6 FAIL: 게이트 위반")
    }
}
