// arch/whisper_ladder.hexa — Whisper 래더 디코딩 x n=6 정식 본문
//
// 원본 경로: techniques/arch/whisper_ladder.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 19: Whisper Model Hierarchy Ladder (Radford 외 2023)
//            6단 래더 디코딩, 멀티스케일 음성 인식
// n=6 정렬:
//   - 래더 단계     = 6           -> n단 디코딩 계층
//   - 멜 빈 수      = σ(6) = 12   -> 12 멜 주파수 빈
//   - 디코더 층     = τ(6) = 4    -> 4층 디코더
//   - 어텐션 헤드   = φ(6) = 2    -> 2헤드
//   - 프레임 길이   = 6           -> n 프레임
//   - 언어 토큰     = 6           -> n 언어 지원
//
// 실행: hexa run techniques/arch/whisper_ladder.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) 거듭제곱 유틸
// ════════════════════════════════════════════════════════════════════

fn pow_i64(base: i64, exp: i64) -> i64 {
    let mut result: i64 = 1
    let mut i: i64 = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// 3) Whisper 래더 스펙 (n=6 정렬)
//    6단 래더: 각 단계에서 시간 해상도/주파수 해상도 변경
//    래더 k: 시간해상도 = 6*2^k, 주파수빈 = 12/2^k (최소 1)
// ════════════════════════════════════════════════════════════════════

const N_CORE:      i64 = 6
const N_LADDER:    i64 = 6    // n=6 래더 단계
const MEL_BINS:    i64 = 12   // σ(6) = 12 멜 빈
const N_DEC_LAYER: i64 = 4    // τ(6) = 4 디코더 층
const N_HEADS:     i64 = 2    // φ(6) = 2 어텐션 헤드
const FRAME_LEN:   i64 = 6    // n=6 프레임
const N_LANGS:     i64 = 6    // n=6 언어

// ════════════════════════════════════════════════════════════════════
// 4) 래더 레벨 계산 — 시간/주파수 트레이드오프
//    레벨 k: 시간 해상도 = FRAME_LEN * 2^k
//           주파수 해상도 = max(1, MEL_BINS / 2^k)
// ════════════════════════════════════════════════════════════════════

fn time_resolution(k: i64) -> i64 {
    return FRAME_LEN * pow_i64(2, k)
}

fn freq_resolution(k: i64) -> i64 {
    let fr: i64 = MEL_BINS / pow_i64(2, k)
    if fr < 1 { return 1 }
    return fr
}

// 레벨별 특징 요소 수 = 시간 * 주파수
fn level_features(k: i64) -> i64 {
    return time_resolution(k) * freq_resolution(k)
}

// ════════════════════════════════════════════════════════════════════
// 5) 인코더 — 멜 스펙트로그램 → 임베딩
//    입력: MEL_BINS * FRAME_LEN = 72
//    출력: σ(6) = 12 차원 임베딩
// ════════════════════════════════════════════════════════════════════

fn encoder_input_size() -> i64 {
    return MEL_BINS * FRAME_LEN
}

fn encoder_params() -> i64 {
    // 1층 선형: 입력 * 은닉 + 은닉 * 은닉
    let hidden: i64 = MEL_BINS
    return encoder_input_size() * hidden + hidden * hidden
}

// ════════════════════════════════════════════════════════════════════
// 6) 디코더 파라미터 — τ(6)=4 층
//    각 층: 셀프어텐션 + 교차어텐션 + FFN
// ════════════════════════════════════════════════════════════════════

fn head_dim() -> i64 {
    return MEL_BINS / N_HEADS
}

fn dec_layer_params() -> i64 {
    // 셀프어텐션 + 교차어텐션 + FFN
    let attn_p: i64 = 4 * MEL_BINS * MEL_BINS  // Q,K,V,O
    let cross_p: i64 = 4 * MEL_BINS * MEL_BINS
    let ffn_dim: i64 = MEL_BINS * N_DEC_LAYER   // τ(6)배 확장
    let ffn_p: i64 = MEL_BINS * ffn_dim + ffn_dim * MEL_BINS
    return attn_p + cross_p + ffn_p
}

fn total_dec_params() -> i64 {
    return N_DEC_LAYER * dec_layer_params()
}

// ════════════════════════════════════════════════════════════════════
// 7) 멜 필터뱅크 — σ(6)=12 빈의 중심 주파수
//    빈 i: 중심 = (i+1) * 100 (Hz 근사, 정수)
//    래더 통합: 인접 빈 합산으로 해상도 조절
// ════════════════════════════════════════════════════════════════════

fn mel_center_freq(bin: i64) -> i64 {
    return (bin + 1) * 100
}

fn mel_bandwidth() -> i64 {
    // 전체 대역 = 마지막 - 처음
    return mel_center_freq(MEL_BINS - 1) - mel_center_freq(0)
}

// ════════════════════════════════════════════════════════════════════
// 8) 래더 융합 — 다중 해상도 결합
//    각 래더 레벨의 특징을 합산하여 최종 표현
// ════════════════════════════════════════════════════════════════════

fn total_ladder_features() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_LADDER {
        total = total + level_features(k)
        k = k + 1
    }
    return total
}

// 래더 효율: 최저 레벨 특징 / 전체
fn ladder_base_ratio_pct() -> i64 {
    return level_features(0) * 100 / total_ladder_features()
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Whisper Ladder x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 래더 단계 = n = 6
    let g2: bool = N_LADDER == N_CORE
    println("G2 래더=n=6                 : " + g2)

    // G3: 멜 빈 = σ(6) = 12
    let g3: bool = MEL_BINS == sig
    println("G3 멜빈=σ=12                : " + g3)

    // G4: 디코더 층 = τ(6) = 4
    let g4: bool = N_DEC_LAYER == t
    println("G4 디코더=τ=4               : " + g4)

    // G5: 어텐션 헤드 = φ(6) = 2
    let g5: bool = N_HEADS == ph
    println("G5 헤드=φ=2                 : " + g5)

    // 래더 레벨별 출력
    let mut k: i64 = 0
    while k < N_LADDER {
        let tr: i64 = time_resolution(k)
        let fr: i64 = freq_resolution(k)
        let feat: i64 = level_features(k)
        println("  래더 " + k + ": 시간=" + tr + " 주파수=" + fr + " 특징=" + feat)
        k = k + 1
    }

    // G6: 시간 해상도 단조 증가
    let mut g6: bool = true
    let mut lk: i64 = 0
    while lk < N_LADDER - 1 {
        if time_resolution(lk) >= time_resolution(lk + 1) { g6 = false }
        lk = lk + 1
    }
    println("G6 시간해상도 단조증가       : " + g6)

    // G7: 주파수 해상도 단조 감소
    let mut g7: bool = true
    let mut fk: i64 = 0
    while fk < N_LADDER - 1 {
        if freq_resolution(fk) < freq_resolution(fk + 1) { g7 = false }
        fk = fk + 1
    }
    println("G7 주파수해상도 단조감소     : " + g7)

    // G8: 인코더 입력 = σ(6) * n = 72
    let enc_in: i64 = encoder_input_size()
    let g8: bool = enc_in == MEL_BINS * FRAME_LEN
    println("G8 인코더입력=" + enc_in + "          : " + g8)

    // G9: 래더 전체 특징 양수
    let tlf: i64 = total_ladder_features()
    let g9: bool = tlf > 0
    println("G9 래더특징합=" + tlf + ">0       : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("래더: " + N_LADDER + " 단계")
    println("멜 빈: " + MEL_BINS + " / 프레임: " + FRAME_LEN)
    println("대역폭: " + mel_bandwidth() + " Hz")
    println("인코더 파라미터: " + encoder_params())
    println("디코더 파라미터: " + total_dec_params())
    println("래더 특징합: " + tlf)
    println("기저 비율: " + ladder_base_ratio_pct() + "%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Whisper Ladder OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("Whisper Ladder FAIL: 게이트 위반")
    }
}
