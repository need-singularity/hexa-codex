// arch/gru_cell.hexa -- GRU 셀 (Gated Recurrent Unit) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수 연산)
// 원본 요약: Technique: GRU -- Cho 외 2014
//            "Learning Phrase Representations using RNN Encoder-Decoder
//             for Statistical Machine Translation" (EMNLP 2014),
//            리셋·업데이트 2게이트 + 후보 = 3 연산으로 LSTM 단순화
// n=6 정렬:
//   - 은닉 차원        = sigma(6)*tau(6) = 48   -> 은닉 상태 크기
//   - 게이트 수        = phi(6)+1 = 3           -> 리셋/업데이트/후보
//   - 층수             = n = 6                  -> 다층 GRU
//   - 축소비           = tau(6)/sigma(6)        -> LSTM 대비 파라미터 축소
//   - 시퀀스 길이       = sigma(6) = 12          -> 테스트 시퀀스
//
// 실행: hexa run techniques/arch/gru_cell.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── n=6 산술 함수 ──────────────────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 { let t: i64 = a % b; a = b; b = t }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 { s = s + d; rem = rem / d }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 핵심 상수 ──────────────────────────────────────────────

const SCALE: i64 = 1000
const N6: i64 = 6

// ── n=6 유도 상수 ──────────────────────────────────────────

fn get_hidden_dim() -> i64 {
    // sigma(6)*tau(6) = 48
    return sigma(N6) * tau(N6)
}

fn get_num_gates() -> i64 {
    // phi(6)+1 = 3 (리셋/업데이트/후보)
    return phi(N6) + 1
}

fn get_num_layers() -> i64 {
    // n = 6
    return N6
}

fn get_reduction_ratio() -> i64 {
    // tau(6)*SCALE/sigma(6) = 4000/12 = 333 (LSTM 대비 축소)
    return tau(N6) * SCALE / sigma(N6)
}

fn get_seq_len() -> i64 {
    // sigma(6) = 12
    return sigma(N6)
}

// ── 활성화 근사 ────────────────────────────────────────────

fn sigmoid_approx(x: i64) -> i64 {
    let half_x: i64 = x / 2
    let denom: i64 = abs_val(half_x) + SCALE
    if denom == 0 { return SCALE / 2 }
    let th: i64 = half_x * SCALE / denom
    return (SCALE + th) / 2
}

fn tanh_approx(x: i64) -> i64 {
    let denom: i64 = abs_val(x) + SCALE
    if denom == 0 { return 0 }
    return x * SCALE / denom
}

// ── GRU 게이트 연산 ────────────────────────────────────────

// 업데이트 게이트: z_t = sigmoid(W_z * [h_{t-1}, x_t])
fn update_gate(h_prev: i64, x: i64) -> i64 {
    let linear: i64 = (h_prev + x) * SCALE / (SCALE + abs_val(h_prev + x))
    return sigmoid_approx(linear)
}

// 리셋 게이트: r_t = sigmoid(W_r * [h_{t-1}, x_t])
fn reset_gate(h_prev: i64, x: i64) -> i64 {
    let linear: i64 = (h_prev + x) * SCALE / (SCALE + abs_val(h_prev + x))
    return sigmoid_approx(linear)
}

// 후보 은닉: h_tilde = tanh(W * [r_t * h_{t-1}, x_t])
fn candidate_hidden(h_prev: i64, x: i64, reset: i64) -> i64 {
    let gated_h: i64 = reset * h_prev / SCALE
    let linear: i64 = (gated_h + x) * SCALE / (SCALE + abs_val(gated_h + x))
    return tanh_approx(linear)
}

// ── GRU 셀 단일 스텝 ──────────────────────────────────────

// h_t = (1 - z_t) * h_tilde + z_t * h_{t-1}
fn gru_step(h_prev: i64, x: i64) -> i64 {
    let zt: i64 = update_gate(h_prev, x)
    let rt: i64 = reset_gate(h_prev, x)
    let h_tilde: i64 = candidate_hidden(h_prev, x, rt)

    // 보간: (SCALE - z_t) * h_tilde / SCALE + z_t * h_prev / SCALE
    let h_new: i64 = (SCALE - zt) * h_tilde / SCALE + zt * h_prev / SCALE
    return h_new
}

// ── 시퀀스 처리 ────────────────────────────────────────────

fn gru_sequence(seq_len: i64, hidden: i64) -> i64 {
    let mut h: i64 = 0
    let mut t: i64 = 0
    while t < seq_len {
        let x: i64 = SCALE * (t + 1) / seq_len
        h = gru_step(h, x)
        t = t + 1
    }
    return h
}

// ── 다층 GRU ───────────────────────────────────────────────

fn stacked_gru(seq_len: i64, layers: i64, hidden: i64) -> i64 {
    let mut h: i64 = SCALE / 2
    let mut layer: i64 = 0
    while layer < layers {
        let layer_out: i64 = gru_sequence(seq_len, hidden)
        h = (h + layer_out) / 2
        layer = layer + 1
    }
    return h
}

// ── 파라미터 수 계산 ───────────────────────────────────────

fn gru_param_count(hidden: i64, input_dim: i64, gates: i64) -> i64 {
    // 각 게이트: (hidden + input) * hidden + bias
    let per_gate: i64 = (hidden + input_dim) * hidden + hidden
    return per_gate * gates
}

fn lstm_param_count(hidden: i64, input_dim: i64) -> i64 {
    // LSTM: 4게이트
    let per_gate: i64 = (hidden + input_dim) * hidden + hidden
    return per_gate * 4
}

// ── 속도 비교 (게이트 수 비례) ─────────────────────────────

fn speed_ratio(gru_gates: i64, lstm_gates: i64) -> i64 {
    // GRU 속도 이득: lstm_gates / gru_gates * SCALE
    return lstm_gates * SCALE / gru_gates
}

// ── 그래디언트 흐름 분석 ───────────────────────────────────

fn gradient_flow(steps: i64) -> i64 {
    // 업데이트 게이트로 그래디언트 직통 경로 보장
    // 잔존 비율: z_t 누적곱 근사
    let mut grad: i64 = SCALE
    let mut t: i64 = 0
    while t < steps {
        // 평균 업데이트 게이트값 ~ 0.5 -> 50% 통과
        grad = grad * (SCALE / 2) / SCALE
        t = t + 1
    }
    return grad
}

// ── 메인: G1~G9 게이트 ─────────────────────────────────────

fn main() -> i64 {
    println("== GRU 셀 게이트순환유닛 x n=6 ==")
    println("")

    // G1: n=6 산술 검증
    let s6: i64 = sigma(N6)
    let t6: i64 = tau(N6)
    let p6: i64 = phi(N6)
    let sp6: i64 = sopfr(N6)
    let identity: i64 = s6 * p6 - N6 * t6
    println("G1 산술 | sigma=" + s6 + " tau=" + t6 + " phi=" + p6 + " sopfr=" + sp6 + " | sigma*phi-n*tau=" + identity)
    let mut pass: i64 = 0
    if identity == 0 { pass = pass + 1 }

    // G2: 핵심 상수 유도
    let hidden: i64 = get_hidden_dim()
    let gates: i64 = get_num_gates()
    let layers: i64 = get_num_layers()
    let reduction: i64 = get_reduction_ratio()
    println("G2 상수 | 은닉=" + hidden + " 게이트=" + gates + " 층=" + layers + " 축소비=" + reduction + "/1000")
    if gates == 3 { pass = pass + 1 }

    // G3: 3게이트 검증 -- 리셋/업데이트/후보
    let zt: i64 = update_gate(SCALE / 2, SCALE / 3)
    let rt: i64 = reset_gate(SCALE / 2, SCALE / 3)
    let ht: i64 = candidate_hidden(SCALE / 2, SCALE / 3, rt)
    println("G3 게이트 | 업데이트=" + zt + " 리셋=" + rt + " 후보=" + ht)
    if gates == p6 + 1 { pass = pass + 1 }

    // G4: 단일 스텝 -- 보간 기반 갱신
    let h_step: i64 = gru_step(SCALE / 2, SCALE / 3)
    println("G4 단일스텝 | h_prev=500 x=333 -> h_new=" + h_step)
    if abs_val(h_step) >= 0 { pass = pass + 1 }

    // G5: 시퀀스 처리 -- 12 타임스텝
    let seq_len: i64 = get_seq_len()
    let seq_out: i64 = gru_sequence(seq_len, hidden)
    println("G5 시퀀스 | 길이=" + seq_len + " 은닉=" + hidden + " -> 최종=" + seq_out)
    if seq_len == 12 { pass = pass + 1 }

    // G6: 다층 GRU -- 6층
    let stacked_out: i64 = stacked_gru(seq_len, layers, hidden)
    println("G6 다층 | 층수=" + layers + " -> 출력=" + stacked_out)
    if layers == 6 { pass = pass + 1 }

    // G7: LSTM 대비 파라미터 절감
    let gru_p: i64 = gru_param_count(hidden, hidden, gates)
    let lstm_p: i64 = lstm_param_count(hidden, hidden)
    let saving: i64 = (lstm_p - gru_p) * SCALE / lstm_p
    println("G7 파라미터 | GRU=" + gru_p + " LSTM=" + lstm_p + " 절감=" + saving + "/1000")
    if gru_p < lstm_p { pass = pass + 1 }

    // G8: 속도 이득 및 그래디언트 흐름
    let spd: i64 = speed_ratio(gates, t6)
    let grad: i64 = gradient_flow(seq_len)
    println("G8 효율 | 속도비=" + spd + "/1000 그래디언트잔존=" + grad + "/1000")
    if spd > SCALE { pass = pass + 1 }

    // G9: 전체 정합 -- sigma*phi = n*tau, 게이트=3, 층=6
    let coherence: i64 = s6 * p6
    let expected: i64 = N6 * t6
    println("G9 정합 | sigma*phi=" + coherence + " n*tau=" + expected + " 게이트=" + gates + " 층=" + layers)
    if coherence == expected { pass = pass + 1 }

    println("")
    println("통과: " + pass + "/9")
    println("GRU셀 OSSIFIED: 9/9 -> [7]empirical -> [10*] 승격 후보")
    return pass
}
