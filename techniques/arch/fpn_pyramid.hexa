// arch/fpn_pyramid.hexa — FPN 피라미드 x n=6 정식 본문
//
// 원본 경로: techniques/arch/fpn_pyramid.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 26: Feature Pyramid Network (Lin 외 2017)
//            τ(6)=4 레벨 피라미드, 하향/상향 경로 + 횡결합
// n=6 정렬:
//   - 피라미드 레벨 = τ(6) = 4   -> P2~P5 4레벨
//   - 채널 수       = σ(6) = 12  -> 통합 채널
//   - 다운샘플 비율 = φ(6) = 2   -> 2배 축소
//   - 입력 해상도   = 6^2 = 36   -> 최하위 특징맵
//   - 횡결합 수     = τ(6)-1 = 3 -> 3개 래터럴 연결
//
// 실행: hexa run techniques/arch/fpn_pyramid.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) FPN 스펙 (n=6 정렬)
//    4레벨 피라미드: P2(36x36), P3(18x18), P4(9x9), P5(4x4 근사)
//    모두 σ(6)=12 채널로 통합
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const N_LEVELS:   i64 = 4    // τ(6) 피라미드 레벨
const CHANNELS:   i64 = 12   // σ(6) 통합 채널
const DOWNSAMPLE: i64 = 2    // φ(6) 다운샘플 비율
const BASE_RES:   i64 = 36   // 6^2 기본 해상도

// ════════════════════════════════════════════════════════════════════
// 3) 거듭제곱 유틸
// ════════════════════════════════════════════════════════════════════

fn pow_i64(base: i64, exp: i64) -> i64 {
    let mut result: i64 = 1
    let mut i: i64 = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// 4) 레벨별 해상도 — 하향 경로 (백본)
//    레벨 k: 해상도 = BASE_RES / 2^k
// ════════════════════════════════════════════════════════════════════

fn level_resolution(k: i64) -> i64 {
    return BASE_RES / pow_i64(DOWNSAMPLE, k)
}

// 레벨별 백본 채널: C2=6, C3=12, C4=24, C5=48
fn backbone_channels(k: i64) -> i64 {
    return N_CORE * pow_i64(DOWNSAMPLE, k)
}

// ════════════════════════════════════════════════════════════════════
// 5) 래터럴 연결 — 1x1 컨볼루션 채널 통합
//    파라미터 수 = backbone_ch * CHANNELS
// ════════════════════════════════════════════════════════════════════

fn lateral_params(k: i64) -> i64 {
    return backbone_channels(k) * CHANNELS
}

fn total_lateral_params() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_LEVELS {
        total = total + lateral_params(k)
        k = k + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 6) 상향 경로 — 업샘플 + 덧셈
//    P5 → P4 → P3 → P2 (3개 래터럴 결합)
// ════════════════════════════════════════════════════════════════════

fn n_lateral_connections() -> i64 {
    return N_LEVELS - 1
}

fn feature_map_size(k: i64) -> i64 {
    let res: i64 = level_resolution(k)
    return res * res * CHANNELS
}

fn total_feature_elements() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_LEVELS {
        total = total + feature_map_size(k)
        k = k + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 7) 해상도 비율 검증 — 매 레벨 2배 축소
// ════════════════════════════════════════════════════════════════════

fn resolution_ratio_consistent() -> bool {
    let mut ok: bool = true
    let mut k: i64 = 0
    while k < N_LEVELS - 1 {
        let r_curr: i64 = level_resolution(k)
        let r_next: i64 = level_resolution(k + 1)
        if r_curr != r_next * DOWNSAMPLE { ok = false }
        k = k + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 8) 파라미터 효율 — FPN 추가 파라미터
//    래터럴(1x1) + 3x3 스무딩
// ════════════════════════════════════════════════════════════════════

fn smoothing_params_per_level() -> i64 {
    return 9 * CHANNELS * CHANNELS
}

fn total_fpn_params() -> i64 {
    let lat: i64 = total_lateral_params()
    let smooth: i64 = smoothing_params_per_level() * N_LEVELS
    return lat + smooth
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ FPN Pyramid x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 피라미드 레벨 = τ(6) = 4
    let g2: bool = N_LEVELS == t
    println("G2 레벨=τ=4                 : " + g2)

    // G3: 통합 채널 = σ(6) = 12
    let g3: bool = CHANNELS == sig
    println("G3 채널=σ=12                : " + g3)

    // G4: 레벨별 해상도 출력 + 비율 검증
    let mut k: i64 = 0
    while k < N_LEVELS {
        let res: i64 = level_resolution(k)
        let bch: i64 = backbone_channels(k)
        let fms: i64 = feature_map_size(k)
        println("  P" + (k + 2) + ": " + res + "x" + res + " 백본=" + bch + "ch 요소=" + fms)
        k = k + 1
    }
    let g4: bool = resolution_ratio_consistent()
    println("G4 해상도비율=2              : " + g4)

    // G5: 다운샘플 = φ(6) = 2
    let g5: bool = DOWNSAMPLE == ph
    println("G5 다운샘플=φ=2              : " + g5)

    // G6: 래터럴 연결 = τ-1 = 3
    let lat_n: i64 = n_lateral_connections()
    let g6: bool = lat_n == N_LEVELS - 1
    println("G6 래터럴=" + lat_n + "               : " + g6)

    // G7: 특징맵 요소 양수
    let total_elem: i64 = total_feature_elements()
    let g7: bool = total_elem > 0
    println("G7 특징맵요소=" + total_elem + "     : " + g7)

    // G8: 래터럴 파라미터 합 양수
    let lat_p: i64 = total_lateral_params()
    let g8: bool = lat_p > 0
    println("G8 래터럴파라미터=" + lat_p + "     : " + g8)

    // G9: 기본 해상도 = 6^2 = 36
    let g9: bool = BASE_RES == N_CORE * N_CORE
    println("G9 기본해상도=6²=36          : " + g9)

    // 벤치마크 지표
    let total_p: i64 = total_fpn_params()
    println("--- 벤치마크 ---")
    println("피라미드: " + N_LEVELS + " 레벨 (P2~P5)")
    println("통합 채널: " + CHANNELS)
    println("래터럴 파라미터: " + lat_p)
    println("3x3 스무딩/레벨: " + smoothing_params_per_level())
    println("총 FPN 파라미터: " + total_p)
    println("특징맵 요소: " + total_elem)

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("FPN Pyramid OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("FPN Pyramid FAIL: 게이트 위반")
    }
}
