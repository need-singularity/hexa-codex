// arch/simclr_temperature.hexa — SimCLR 온도 스케줄링 x n=6 정식 본문
//
// 원본 경로: techniques/arch/simclr_temperature.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 29: SimCLR Temperature (Chen 외 2020)
//            τ(6)=4 기반 온도 스케줄링, 대조 학습
// n=6 정렬:
//   - 배치 크기     = 6           -> n 샘플 (양쌍 6 + 음쌍)
//   - 임베딩 차원   = σ(6) = 12   -> 프로젝션 공간
//   - 온도 파라미터 = τ(6) = 4    -> τ(6) 스케일 (정수 분모)
//   - 양성 쌍       = 6           -> 자기 증강 쌍
//   - 음성 쌍       = 6*(6-1)=30  -> n(n-1) 음성 쌍
//   - 프로젝션 헤드 = φ(6) = 2    -> 2층 MLP
//
// 실행: hexa run techniques/arch/simclr_temperature.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) SimCLR 스펙 (n=6 정렬)
//    NT-Xent 손실: -log(exp(sim(i,j)/τ) / Σ exp(sim(i,k)/τ))
//    τ(6)=4를 온도로 사용 (정수 나눗셈 분모)
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const BATCH_SIZE: i64 = 6    // n=6 샘플
const EMBED_DIM:  i64 = 12   // σ(6) 임베딩 차원
const TEMPERATURE:i64 = 4    // τ(6) 온도 파라미터
const N_PROJ:     i64 = 2    // φ(6) 프로젝션 레이어 수
const PROJ_DIM:   i64 = 12   // σ(6) 프로젝션 차원

// ════════════════════════════════════════════════════════════════════
// 3) 임베딩 초기화 — 결정론적 시드
//    원본 뷰: embed_a[i][d] = (i*EMBED_DIM + d) % 13 - 6
//    증강 뷰: embed_b[i][d] = (i*EMBED_DIM + d + 7) % 13 - 6
//    양쌍: (a_i, b_i), 음쌍: (a_i, b_j) j!=i
// ════════════════════════════════════════════════════════════════════

fn embed_a(i: i64, d: i64) -> i64 {
    return (i * EMBED_DIM + d) % 13 - N_CORE
}

fn embed_b(i: i64, d: i64) -> i64 {
    return (i * EMBED_DIM + d + 7) % 13 - N_CORE
}

// ════════════════════════════════════════════════════════════════════
// 4) 유사도 — 내적 (코사인 근사, 정수)
//    sim(a_i, b_j) = Σ embed_a(i,d) * embed_b(j,d)
// ════════════════════════════════════════════════════════════════════

fn similarity(i: i64, j: i64) -> i64 {
    let mut dot: i64 = 0
    let mut d: i64 = 0
    while d < EMBED_DIM {
        dot = dot + embed_a(i, d) * embed_b(j, d)
        d = d + 1
    }
    return dot
}

// ════════════════════════════════════════════════════════════════════
// 5) 온도 스케일 유사도 — sim / τ
//    정수 나눗셈으로 근사
// ════════════════════════════════════════════════════════════════════

fn scaled_sim(i: i64, j: i64) -> i64 {
    return similarity(i, j) / TEMPERATURE
}

// ════════════════════════════════════════════════════════════════════
// 6) 양쌍/음쌍 유사도 분석
//    양쌍 = 대각 (i==j), 음쌍 = 비대각 (i!=j)
// ════════════════════════════════════════════════════════════════════

fn positive_sim_sum() -> i64 {
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < BATCH_SIZE {
        total = total + similarity(i, i)
        i = i + 1
    }
    return total
}

fn negative_sim_sum() -> i64 {
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < BATCH_SIZE {
        let mut j: i64 = 0
        while j < BATCH_SIZE {
            if j != i {
                total = total + similarity(i, j)
            }
            j = j + 1
        }
        i = i + 1
    }
    return total
}

fn n_positive_pairs() -> i64 {
    return BATCH_SIZE
}

fn n_negative_pairs() -> i64 {
    return BATCH_SIZE * (BATCH_SIZE - 1)
}

// ════════════════════════════════════════════════════════════════════
// 7) 프로젝션 헤드 파라미터 — φ(6)=2 층 MLP
//    입력 → PROJ_DIM → PROJ_DIM (ReLU)
// ════════════════════════════════════════════════════════════════════

fn proj_params() -> i64 {
    // 2층: EMBED_DIM*PROJ_DIM + PROJ_DIM*PROJ_DIM
    return EMBED_DIM * PROJ_DIM + PROJ_DIM * PROJ_DIM
}

// ════════════════════════════════════════════════════════════════════
// 8) 노름 계산 — 임베딩 크기
// ════════════════════════════════════════════════════════════════════

fn embed_a_norm_sq(i: i64) -> i64 {
    let mut norm: i64 = 0
    let mut d: i64 = 0
    while d < EMBED_DIM {
        let v: i64 = embed_a(i, d)
        norm = norm + v * v
        d = d + 1
    }
    return norm
}

fn embed_b_norm_sq(i: i64) -> i64 {
    let mut norm: i64 = 0
    let mut d: i64 = 0
    while d < EMBED_DIM {
        let v: i64 = embed_b(i, d)
        norm = norm + v * v
        d = d + 1
    }
    return norm
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ SimCLR Temperature x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 배치 = n = 6
    let g2: bool = BATCH_SIZE == N_CORE
    println("G2 배치=n=6                 : " + g2)

    // G3: 임베딩 = σ(6) = 12
    let g3: bool = EMBED_DIM == sig
    println("G3 임베딩=σ=12              : " + g3)

    // G4: 온도 = τ(6) = 4
    let g4: bool = TEMPERATURE == t
    println("G4 온도=τ=4                 : " + g4)

    // G5: 양쌍 수 = 6, 음쌍 수 = 30
    let np: i64 = n_positive_pairs()
    let nn: i64 = n_negative_pairs()
    let g5: bool = np == N_CORE && nn == N_CORE * (N_CORE - 1)
    println("G5 양쌍=" + np + " 음쌍=" + nn + "       : " + g5)

    // G6: 양쌍 유사도 > 음쌍 평균 (대조 학습 핵심)
    let pos_sum: i64 = positive_sim_sum()
    let neg_sum: i64 = negative_sim_sum()
    let pos_avg: i64 = pos_sum / np
    let neg_avg: i64 = neg_sum / nn
    let g6: bool = pos_avg > neg_avg
    println("G6 양쌍평균=" + pos_avg + ">음쌍=" + neg_avg + " : " + g6)

    // 샘플별 유사도 출력
    let mut i: i64 = 0
    while i < BATCH_SIZE {
        let ps: i64 = similarity(i, i)
        let ss: i64 = scaled_sim(i, i)
        println("  샘플 " + i + ": sim=" + ps + " scaled=" + ss + " 노름a²=" + embed_a_norm_sq(i))
        i = i + 1
    }

    // G7: 프로젝션 = φ(6) = 2 층
    let g7: bool = N_PROJ == ph
    println("G7 프로젝션=φ=2              : " + g7)

    // G8: 온도 스케일링 후 유사도 감소 (abs)
    let mut g8: bool = true
    let mut si: i64 = 0
    while si < BATCH_SIZE {
        let raw: i64 = abs_val(similarity(si, si))
        let scl: i64 = abs_val(scaled_sim(si, si))
        if scl > raw { g8 = false }
        si = si + 1
    }
    println("G8 스케일링후감소            : " + g8)

    // G9: 전체 노름 양수
    let mut g9: bool = true
    let mut ni: i64 = 0
    while ni < BATCH_SIZE {
        if embed_a_norm_sq(ni) <= 0 { g9 = false }
        if embed_b_norm_sq(ni) <= 0 { g9 = false }
        ni = ni + 1
    }
    println("G9 노름양수                  : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("배치: " + BATCH_SIZE + " (n=6)")
    println("온도: " + TEMPERATURE + " (τ(6)=4)")
    println("양쌍합: " + pos_sum + " 음쌍합: " + neg_sum)
    println("프로젝션 파라미터: " + proj_params())

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("SimCLR Temperature OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("SimCLR Temperature FAIL: 게이트 위반")
    }
}
