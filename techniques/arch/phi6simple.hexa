// arch/phi6simple.hexa — Phi-6 경량 LLM x n=6 정식 본문
//
// 원본 경로: techniques/arch/phi6simple.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: H-EE-1: Cyclotomic Polynomial Activation (Phi-6 경량 아키텍처)
//            φ(6)=2 경량 파라미터 설계, 원환 다항식 Φ_6(x)=x²-x+1 활성화
// n=6 정렬:
//   - 블록 수       = φ(6) = 2   -> 2블록 경량 구조
//   - 은닉 차원     = σ(6) = 12  -> 최소 은닉층
//   - 어텐션 헤드   = τ(6) = 4   -> 4헤드 어텐션
//   - 활성화        = Φ_6(x) = x²-x+1 (원환 다항식)
//   - 임베딩 차원   = 6           -> n 차원
//   - FFN 확장비    = φ(6) = 2   -> 2배 확장
//
// 실행: hexa run techniques/arch/phi6simple.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Phi-6 아키텍처 스펙
//    초경량: φ(6)=2 블록만으로 구성
//    Φ_6(x) = x² - x + 1 (6차 원환 다항식)을 활성화로 사용
// ════════════════════════════════════════════════════════════════════

const N_CORE:    i64 = 6
const N_BLOCKS:  i64 = 2    // φ(6) = 2 블록
const HIDDEN:    i64 = 12   // σ(6) = 12 은닉 차원
const N_HEADS:   i64 = 4    // τ(6) = 4 어텐션 헤드
const EMBED_DIM: i64 = 6    // n = 6 임베딩
const FFN_MULT:  i64 = 2    // φ(6) = 2 FFN 확장비

// ════════════════════════════════════════════════════════════════════
// 3) Φ_6(x) 활성화 — 6차 원환 다항식
//    Φ_6(x) = x² - x + 1
//    특성: x=1일 때 Φ_6(1)=1, x=0일 때 Φ_6(0)=1
//    항상 양수 (판별식 = 1-4 = -3 < 0)
// ════════════════════════════════════════════════════════════════════

fn cyclotomic_6(x: i64) -> i64 {
    // Φ_6(x) = x² - x + 1
    return x * x - x + 1
}

// 원환 다항식의 근 판별 — 항상 양수 검증
fn cyclotomic_always_positive(lo: i64, hi: i64) -> bool {
    let mut ok: bool = true
    let mut x: i64 = lo
    while x <= hi {
        if cyclotomic_6(x) <= 0 { ok = false }
        x = x + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 4) 원환 다항식 항등식 검증
//    x^6 - 1 = Φ_1(x) * Φ_2(x) * Φ_3(x) * Φ_6(x)
//    = (x-1)(x+1)(x²+x+1)(x²-x+1)
//    x=2 검증: 63 = 1*3*7*3 = 63
// ════════════════════════════════════════════════════════════════════

fn cyclotomic_1(x: i64) -> i64 { return x - 1 }
fn cyclotomic_2(x: i64) -> i64 { return x + 1 }
fn cyclotomic_3(x: i64) -> i64 { return x * x + x + 1 }

fn factorization_check(x: i64) -> bool {
    let lhs: i64 = x * x * x * x * x * x - 1
    let rhs: i64 = cyclotomic_1(x) * cyclotomic_2(x) * cyclotomic_3(x) * cyclotomic_6(x)
    return lhs == rhs
}

// ════════════════════════════════════════════════════════════════════
// 5) 어텐션 파라미터 수 — τ(6)=4 멀티헤드
//    head_dim = HIDDEN / N_HEADS = 12 / 4 = 3
//    QKV 파라미터 = 3 * HIDDEN * HIDDEN = 3 * 144 = 432
//    출력 프로젝션 = HIDDEN * HIDDEN = 144
// ════════════════════════════════════════════════════════════════════

fn head_dim() -> i64 {
    return HIDDEN / N_HEADS
}

fn attn_params() -> i64 {
    // Q, K, V 각각 HIDDEN*HIDDEN + 출력 프로젝션 HIDDEN*HIDDEN
    return N_HEADS * head_dim() * HIDDEN + HIDDEN * HIDDEN
}

// ════════════════════════════════════════════════════════════════════
// 6) FFN 파라미터 수 — φ(6)=2 확장
//    FFN 차원 = HIDDEN * FFN_MULT = 24
//    상향 + 하향 = 2 * HIDDEN * FFN_DIM = 2 * 12 * 24 = 576
// ════════════════════════════════════════════════════════════════════

fn ffn_dim() -> i64 {
    return HIDDEN * FFN_MULT
}

fn ffn_params() -> i64 {
    // 상향 프로젝션 + 하향 프로젝션
    return HIDDEN * ffn_dim() + ffn_dim() * HIDDEN
}

// ════════════════════════════════════════════════════════════════════
// 7) 블록당/전체 파라미터
// ════════════════════════════════════════════════════════════════════

fn block_params() -> i64 {
    return attn_params() + ffn_params()
}

fn total_params() -> i64 {
    // 임베딩 + N_BLOCKS * 블록 + 출력
    let embed_p: i64 = EMBED_DIM * HIDDEN
    let blocks_p: i64 = N_BLOCKS * block_params()
    let out_p: i64 = HIDDEN * EMBED_DIM
    return embed_p + blocks_p + out_p
}

// ════════════════════════════════════════════════════════════════════
// 8) 활성화 적용 시뮬 — Φ_6 전파
//    입력 [-6..6] 에 Φ_6 적용, 합 계산
// ════════════════════════════════════════════════════════════════════

fn activation_sum() -> i64 {
    let mut total: i64 = 0
    let mut x: i64 = 0 - N_CORE
    while x <= N_CORE {
        total = total + cyclotomic_6(x)
        x = x + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Phi-6 Simple (경량 LLM) x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 블록 수 = φ(6) = 2
    let g2: bool = N_BLOCKS == ph
    println("G2 블록=φ=2                 : " + g2)

    // G3: 은닉 차원 = σ(6) = 12
    let g3: bool = HIDDEN == sig
    println("G3 은닉=σ=12                : " + g3)

    // G4: 어텐션 헤드 = τ(6) = 4
    let g4: bool = N_HEADS == t
    println("G4 헤드=τ=4                 : " + g4)

    // G5: Φ_6 항상 양수 [-6, 6]
    let g5: bool = cyclotomic_always_positive(0 - N_CORE, N_CORE)
    println("G5 Φ_6 양수 [-6,6]          : " + g5)

    // G6: x^6-1 인수분해 검증 (x=2,3)
    let g6a: bool = factorization_check(2)
    let g6b: bool = factorization_check(3)
    let g6: bool = g6a && g6b
    println("G6 인수분해 x=2,3           : " + g6)

    // Φ_6 값 출력
    let mut x: i64 = 0 - 3
    while x <= 3 {
        println("  Φ_6(" + x + ") = " + cyclotomic_6(x))
        x = x + 1
    }

    // G7: head_dim = 12/4 = 3 (정수 나눗셈)
    let hd: i64 = head_dim()
    let g7: bool = hd * N_HEADS == HIDDEN
    println("G7 head_dim=" + hd + " (정수)       : " + g7)

    // G8: FFN 확장비 = φ(6) = 2
    let g8: bool = FFN_MULT == ph
    println("G8 FFN확장=φ=2              : " + g8)

    // G9: 전체 파라미터 양수 + 경량 (< 10000)
    let tp: i64 = total_params()
    let g9: bool = tp > 0 && tp < 10000
    println("G9 총파라미터=" + tp + " (경량)  : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("블록: " + N_BLOCKS + " (φ(6)=2)")
    println("head_dim: " + hd)
    println("FFN 차원: " + ffn_dim())
    println("어텐션 파라미터/블록: " + attn_params())
    println("FFN 파라미터/블록: " + ffn_params())
    println("총 파라미터: " + tp)
    println("활성화 합 [-6,6]: " + activation_sum())

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Phi-6 Simple OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("Phi-6 Simple FAIL: 게이트 위반")
    }
}
