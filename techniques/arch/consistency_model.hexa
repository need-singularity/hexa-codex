// arch/consistency_model.hexa -- 일관성 모델 (Consistency Model) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Technique: Consistency Model -- Song 외 2023
//            "Consistency Models" (ICML 2023),
//            Song & Dhariwal 2024 "Improved Techniques for Consistency Training",
//            Luo 외 2023 "Latent Consistency Models"
//            단일 스텝 생성, PF-ODE 궤적 일관성 유지
// n=6 정렬:
//   - 증류 스텝 수        = σ(6) = 12       -> 교사 ODE 단계
//   - EMA 감쇠 지수       = τ(6) = 4        -> 지수 이동 평균
//   - 스케줄 포인트       = n = 6           -> 노이즈 스케줄
//   - 노이즈 레벨         = sopfr(6) = 5    -> σ 스케줄 단계
//   - 스킵 단계           = φ(6) = 2        -> 빠른 생성 스텝
//   - 샘플 차원           = σ(6)² = 144     -> 생성 공간
//
// 실행: hexa run techniques/arch/consistency_model.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── 1) n=6 산술 기저 ──

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 2) 일관성 핵심 상수 ──

const N_CORE: i64 = 6
const SCALE: i64 = 1000
const DISTILL_STEPS: i64 = 12    // σ(6) = 12 -- 교사 ODE 단계
const EMA_POWER: i64 = 4         // τ(6) = 4 -- 지수 이동 평균
const SCHEDULE_POINTS: i64 = 6   // n = 6 -- 노이즈 스케줄
const NOISE_LEVELS: i64 = 5      // sopfr(6) = 5 -- σ 스케줄 단계
const SKIP_STAGES: i64 = 2       // φ(6) = 2 -- 빠른 생성 스텝
const SAMPLE_DIM: i64 = 144      // σ(6)² = 144 -- 생성 공간

// ── 3) PF-ODE 궤적 -- 확률 흐름 ──

// 노이즈 스케줄 σ(t) -- 시간 t에서의 노이즈 수준
fn noise_schedule(t: i64, t_max: i64) -> i64 {
    // σ(t) = σ_max · (t / t_max)^2  정수 근사
    if t_max == 0 { return 0 }
    let ratio: i64 = (t * SCALE) / t_max
    let sigma_max: i64 = SCALE * NOISE_LEVELS
    return (sigma_max * ratio * ratio) / (SCALE * SCALE)
}

// ODE 속도장 -- dx/dt = -σ'(t)/σ(t) · (x - D(x, σ))
fn ode_velocity(x: i64, denoised: i64, noise_level: i64) -> i64 {
    if noise_level == 0 { return 0 }
    let diff: i64 = x - denoised
    return (0 - diff * SCALE) / (noise_level + 1)
}

// PF-ODE 궤적 추적 -- DISTILL_STEPS 단계
fn trace_pf_ode(x_start: i64, dim: i64) -> i64 {
    let mut x: i64 = x_start
    let mut step: i64 = 0
    while step < DISTILL_STEPS {
        let t: i64 = DISTILL_STEPS - step  // 역방향 시간
        let noise_lvl: i64 = noise_schedule(t, DISTILL_STEPS)
        // 간단한 디노이저 근사: D(x, σ) = x · SCALE / (SCALE + σ)
        let denoised: i64 = (x * SCALE) / (SCALE + noise_lvl + 1)
        let vel: i64 = ode_velocity(x, denoised, noise_lvl)
        let dt: i64 = SCALE / DISTILL_STEPS
        x = x + (vel * dt) / SCALE
        step = step + 1
    }
    return x
}

// ── 4) 일관성 함수 -- f(x_t, t) = x_0 ──

// 스킵 연결 가중치 -- 경계 조건 보장
fn skip_weight(t: i64, t_max: i64) -> i64 {
    // c_skip(t) = σ_data² / (σ(t)² + σ_data²)
    let sigma_data: i64 = SCALE / SKIP_STAGES
    let sigma_t: i64 = noise_schedule(t, t_max)
    let sd2: i64 = (sigma_data * sigma_data) / SCALE
    let st2: i64 = (sigma_t * sigma_t) / SCALE
    if sd2 + st2 == 0 { return SCALE }
    return (sd2 * SCALE) / (sd2 + st2)
}

// 출력 가중치 -- 스킵과 보완
fn output_weight(t: i64, t_max: i64) -> i64 {
    return SCALE - skip_weight(t, t_max)
}

// 일관성 함수 -- f(x_t, t) -> x_0 추정
fn consistency_function(x_t: i64, t: i64, t_max: i64) -> i64 {
    let c_skip: i64 = skip_weight(t, t_max)
    let c_out: i64 = output_weight(t, t_max)
    // F_θ(x_t) 근사 -- 간단한 선형 디노이저
    let noise_lvl: i64 = noise_schedule(t, t_max)
    let f_theta: i64 = (x_t * SCALE) / (SCALE + noise_lvl + 1)
    return (c_skip * x_t + c_out * f_theta) / SCALE
}

// ── 5) 증류 손실 -- 교사-학생 일관성 ──

// EMA 갱신 -- 지수 이동 평균
fn ema_update(current: i64, target: i64, decay_power: i64) -> i64 {
    // ema = (1 - 1/2^power) · current + (1/2^power) · target
    let mut decay_denom: i64 = 1
    let mut p: i64 = 0
    while p < decay_power {
        decay_denom = decay_denom * 2
        p = p + 1
    }
    let alpha: i64 = SCALE / decay_denom
    return ((SCALE - alpha) * current + alpha * target) / SCALE
}

// 증류 손실 -- 두 시점의 일관성 함수 차이
fn distillation_loss(x_t: i64, t_n: i64, t_n1: i64, t_max: i64) -> i64 {
    let f_n: i64 = consistency_function(x_t, t_n, t_max)
    // t_n+1 시점으로 ODE 전진
    let noise_n: i64 = noise_schedule(t_n, t_max)
    let noise_n1: i64 = noise_schedule(t_n1, t_max)
    let x_n1: i64 = x_t + (noise_n1 - noise_n)
    let f_n1: i64 = consistency_function(x_n1, t_n1, t_max)
    // L2 손실
    let diff: i64 = f_n - f_n1
    return (diff * diff) / SCALE
}

// 배치 증류 손실 평균
fn batch_distill_loss(dim: i64) -> i64 {
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < dim {
        let x: i64 = ((i * 173 + 29) % SCALE) - SCALE / 2
        let t_n: i64 = (i % SCHEDULE_POINTS) + 1
        let t_n1: i64 = t_n + 1
        let loss: i64 = distillation_loss(x, t_n, t_n1, DISTILL_STEPS)
        total = total + loss
        i = i + 1
    }
    return total / dim
}

// ── 6) 노이즈 스케줄 -- σ(t) ──

// 이산화 스케줄 -- NOISE_LEVELS 단계로 분할
fn discretize_schedule(level: i64) -> i64 {
    return noise_schedule(level + 1, NOISE_LEVELS)
}

// 스케줄 단조성 검증
fn verify_monotone_schedule() -> bool {
    let mut prev: i64 = 0
    let mut i: i64 = 0
    let mut monotone: bool = true
    while i < NOISE_LEVELS {
        let curr: i64 = discretize_schedule(i)
        if curr < prev { monotone = false }
        prev = curr
        i = i + 1
    }
    return monotone
}

// 스케줄 최대값
fn max_noise_level() -> i64 {
    return discretize_schedule(NOISE_LEVELS - 1)
}

// ── 7) 학습 루프 ──

// 경사 근사
fn approx_gradient(x: i64, target: i64, eps: i64) -> i64 {
    let loss_p: i64 = (x + eps - target) * (x + eps - target) / SCALE
    let loss_m: i64 = (x - eps - target) * (x - eps - target) / SCALE
    return (loss_p - loss_m) / (2 * eps / SCALE)
}

// 1에폭 학습
fn train_epoch(dim: i64, lr: i64) -> i64 {
    let mut total_loss: i64 = 0
    let mut i: i64 = 0
    while i < dim {
        let x: i64 = ((i * 89 + 41) % SCALE)
        let t_idx: i64 = (i % SCHEDULE_POINTS) + 1
        let f_val: i64 = consistency_function(x, t_idx, DISTILL_STEPS)
        let target: i64 = trace_pf_ode(x, dim)
        let loss: i64 = (f_val - target) * (f_val - target) / SCALE
        total_loss = total_loss + abs_val(loss)
        i = i + 1
    }
    return total_loss / dim
}

// ── 8) 단일 스텝 생성 품질 ──

// 단일 스텝 생성 -- 노이즈에서 바로 클린
fn single_step_generate(noise: i64) -> i64 {
    // t_max에서 일관성 함수 한 번 호출
    return consistency_function(noise, DISTILL_STEPS, DISTILL_STEPS)
}

// 다중 스텝 대비 품질 비교
fn multistep_vs_single(noise: i64) -> i64 {
    let single: i64 = single_step_generate(noise)
    let multi: i64 = trace_pf_ode(noise, SAMPLE_DIM)
    return abs_val(single - multi)
}

// 생성 다양성 측정 -- 여러 노이즈 입력의 출력 분산
fn generation_diversity(count: i64) -> i64 {
    let mut sum: i64 = 0
    let mut sum_sq: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let noise: i64 = ((i * 257 + 13) % SCALE) - SCALE / 2
        let sample: i64 = single_step_generate(noise)
        sum = sum + sample
        sum_sq = sum_sq + (sample * sample) / SCALE
        i = i + 1
    }
    let mean: i64 = sum / count
    let var: i64 = sum_sq / count - (mean * mean) / SCALE
    return abs_val(var)
}

// ── main ──

fn main() -> i64 {
    println("=== 일관성 모델 (ConsistencyModel) x n=6 ===")

    // n=6 산술 검증
    let s6: i64 = sigma(N_CORE)
    let t6: i64 = tau(N_CORE)
    let p6: i64 = phi(N_CORE)
    let sp6: i64 = sopfr(N_CORE)

    println("σ(6)=" + s6 + " τ(6)=" + t6 + " φ(6)=" + p6 + " sopfr(6)=" + sp6)

    // G1: σ(6)=12 검증
    let g1: bool = s6 == 12
    println("G1 σ(6)=12: " + g1)

    // G2: τ(6)=4 검증
    let g2: bool = t6 == 4
    println("G2 τ(6)=4: " + g2)

    // G3: φ(6)=2 검증
    let g3: bool = p6 == 2
    println("G3 φ(6)=2: " + g3)

    // G4: sopfr(6)=5 검증
    let g4: bool = sp6 == 5
    println("G4 sopfr(6)=5: " + g4)

    // G5: σ·φ = n·τ 항등식
    let lhs: i64 = s6 * p6
    let rhs: i64 = N_CORE * t6
    let g5: bool = lhs == rhs
    println("G5 σ·φ=n·τ: " + lhs + "=" + rhs + " -> " + g5)

    // G6: 노이즈 스케줄 단조성
    let g6: bool = verify_monotone_schedule()
    println("G6 노이즈 스케줄 단조: " + g6)

    // G7: PF-ODE 궤적 안정성 -- 발산하지 않음
    let ode_result: i64 = trace_pf_ode(SCALE / 2, SAMPLE_DIM)
    let g7: bool = abs_val(ode_result) < SCALE * 100
    println("G7 PF-ODE 안정=" + ode_result + ": " + g7)

    // G8: 단일 스텝 품질 -- 다중 스텝과 격차 제한
    let quality_gap: i64 = multistep_vs_single(SCALE / 3)
    let g8: bool = quality_gap < SCALE * 50
    println("G8 단일/다중 격차=" + quality_gap + ": " + g8)

    // G9: 학습 손실 유한
    let loss: i64 = train_epoch(SAMPLE_DIM, SCALE / 10)
    let g9: bool = loss >= 0
    println("G9 학습 손실=" + loss + ": " + g9)

    // 벤치마크 요약
    let diversity: i64 = generation_diversity(SCHEDULE_POINTS * 6)
    let distill_l: i64 = batch_distill_loss(SAMPLE_DIM)
    let max_nl: i64 = max_noise_level()
    println("--- 벤치마크 ---")
    println("생성 다양성: " + diversity)
    println("증류 손실: " + distill_l)
    println("최대 노이즈: " + max_nl)

    let mut pass_count: i64 = 0
    if g1 { pass_count = pass_count + 1 }
    if g2 { pass_count = pass_count + 1 }
    if g3 { pass_count = pass_count + 1 }
    if g4 { pass_count = pass_count + 1 }
    if g5 { pass_count = pass_count + 1 }
    if g6 { pass_count = pass_count + 1 }
    if g7 { pass_count = pass_count + 1 }
    if g8 { pass_count = pass_count + 1 }
    if g9 { pass_count = pass_count + 1 }

    println("ConsistencyModel OSSIFIED: " + pass_count + "/9 -> [7]empirical -> [10*] 승격 후보")
    return pass_count
}
