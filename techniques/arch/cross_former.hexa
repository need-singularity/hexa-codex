// arch/cross_former.hexa -- CrossFormer 다중스케일 비전 트랜스포머 x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수 연산)
// 원본 요약: Technique: CrossFormer -- Zhang 외 2022
//            "CrossFormer: A Versatile Vision Transformer Hinging on
//             Cross-scale Attention" (ICLR 2022),
//            CEL(Cross-scale Embedding Layer) + LSDA(Long/Short Distance Attention),
//            다중 스케일 토큰 결합으로 크로스스케일 특징 추출
// n=6 정렬:
//   - 패치 크기        = tau(6) = 4             -> 초기 패치화 크기
//   - 그룹 크기        = phi(6) = 2             -> LSDA 그룹 분할
//   - 차원             = sigma(6)*tau(6) = 48   -> 임베딩 차원
//   - 단계 수          = tau(6) = 4             -> 피라미드 단계
//   - 헤드 수          = sigma(6)/phi(6) = 6    -> 어텐션 헤드
//
// 실행: hexa run techniques/arch/cross_former.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── n=6 산술 함수 ──────────────────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 { let t: i64 = a % b; a = b; b = t }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 { s = s + d; rem = rem / d }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 핵심 상수 ──────────────────────────────────────────────

const SCALE: i64 = 1000
const N6: i64 = 6

// ── n=6 유도 상수 ──────────────────────────────────────────

fn get_patch_size() -> i64 {
    // tau(6) = 4
    return tau(N6)
}

fn get_group_size() -> i64 {
    // phi(6) = 2
    return phi(N6)
}

fn get_embed_dim() -> i64 {
    // sigma(6)*tau(6) = 48
    return sigma(N6) * tau(N6)
}

fn get_num_stages() -> i64 {
    // tau(6) = 4
    return tau(N6)
}

fn get_num_heads() -> i64 {
    // sigma(6)/phi(6) = 6
    return sigma(N6) / phi(N6)
}

fn get_stage_dim(stage: i64) -> i64 {
    // 48 -> 96 -> 192 -> 384 (2배씩)
    let base: i64 = get_embed_dim()
    let mut d: i64 = base
    let mut s: i64 = 0
    while s < stage {
        d = d * 2
        s = s + 1
    }
    return d
}

// ── CEL: 크로스스케일 임베딩 층 ────────────────────────────

// 다중 크기 커널로 패치 임베딩: [patch, patch*2, patch*4, ...]
fn cross_scale_embed(input: i64, stage: i64) -> i64 {
    let patch: i64 = get_patch_size()
    let dim: i64 = get_stage_dim(stage)
    let num_scales: i64 = get_group_size() + 1

    // 스케일별 합성곱 + 결합
    let mut combined: i64 = 0
    let mut sc: i64 = 0
    while sc < num_scales {
        let kernel: i64 = patch + sc * patch
        let k2: i64 = kernel * kernel
        let branch: i64 = input * k2 / (k2 + dim)
        combined = combined + branch
        sc = sc + 1
    }

    // 선형 투영으로 차원 정합
    return combined * dim / (combined + 1)
}

// ── SDA: 단거리 어텐션 ─────────────────────────────────────

fn short_distance_attention(input: i64, dim: i64, heads: i64, group: i64) -> i64 {
    // 그룹 내 토큰끼리만 어텐션
    let head_dim: i64 = dim / heads
    let group_tokens: i64 = group * group

    // Q, K, V 생성
    let q: i64 = input * head_dim / (head_dim + 1)
    let k: i64 = input * head_dim / (head_dim + 2)
    let v: i64 = input * head_dim / (head_dim + 3)

    // 어텐션 스코어: Q*K / sqrt(d)
    let score: i64 = q * k / (head_dim + 1)
    // 소프트맥스 근사: 정규화
    let attn: i64 = score * SCALE / (abs_val(score) + SCALE)
    // 출력: attn * V
    return attn * v / SCALE
}

// ── LDA: 장거리 어텐션 ─────────────────────────────────────

fn long_distance_attention(input: i64, dim: i64, heads: i64, group: i64) -> i64 {
    // 각 그룹에서 대표 토큰 샘플링 후 크로스그룹 어텐션
    let head_dim: i64 = dim / heads

    // 대표 토큰: 그룹별 평균 근사
    let representative: i64 = input / group

    // Q (원본), K/V (대표)
    let q: i64 = input * head_dim / (head_dim + 1)
    let k: i64 = representative * head_dim / (head_dim + 2)
    let v: i64 = representative * head_dim / (head_dim + 3)

    let score: i64 = q * k / (head_dim + 1)
    let attn: i64 = score * SCALE / (abs_val(score) + SCALE)
    return attn * v / SCALE
}

// ── LSDA: 장단거리 통합 어텐션 ─────────────────────────────

fn lsda(input: i64, dim: i64, heads: i64, group: i64) -> i64 {
    let short_out: i64 = short_distance_attention(input, dim, heads, group)
    let long_out: i64 = long_distance_attention(input, dim, heads, group)

    // 장단거리 결합 + 선형 투영
    let combined: i64 = short_out + long_out
    return combined * dim / (dim + 1)
}

// ── CrossFormer 블록 ───────────────────────────────────────

fn crossformer_block(input: i64, stage: i64) -> i64 {
    let dim: i64 = get_stage_dim(stage)
    let heads: i64 = get_num_heads()
    let group: i64 = get_group_size()

    // LayerNorm + LSDA
    let normed: i64 = input * SCALE / (abs_val(input) + 1)
    let attn_out: i64 = lsda(normed, dim, heads, group)
    let h: i64 = input + attn_out

    // LayerNorm + FFN (확장비 tau(6)=4)
    let expand: i64 = tau(N6)
    let normed2: i64 = h * SCALE / (abs_val(h) + 1)
    let ffn_mid: i64 = normed2 * expand
    // GELU 근사
    let scaled: i64 = ffn_mid * 1702 / SCALE
    let half: i64 = scaled / 2
    let denom: i64 = abs_val(half) + SCALE
    let th: i64 = half * SCALE / denom
    let sig: i64 = (SCALE + th) / 2
    let gelu_out: i64 = ffn_mid * sig / SCALE
    let ffn_out: i64 = gelu_out / expand

    return h + ffn_out
}

// ── CrossFormer 스테이지 ───────────────────────────────────

fn crossformer_stage(input: i64, stage: i64, depth: i64) -> i64 {
    // CEL (스테이지 0 제외: 이미 패치화됨)
    let mut h: i64 = cross_scale_embed(input, stage)

    // 블록 반복
    let mut d: i64 = 0
    while d < depth {
        h = crossformer_block(h, stage)
        d = d + 1
    }
    return h
}

// ── 전체 CrossFormer 순전파 ────────────────────────────────

fn crossformer_forward(input: i64) -> i64 {
    let stages: i64 = get_num_stages()
    // 스테이지별 깊이: [sopfr-2, sopfr-2, sopfr+1, sopfr-2] = [3, 3, 6, 3]
    let sp: i64 = sopfr(N6)

    let mut h: i64 = input
    let mut s: i64 = 0
    while s < stages {
        let depth: i64 = if s == 2 { sp + 1 } else { sp - 2 }
        h = crossformer_stage(h, s, depth)
        s = s + 1
    }

    // 글로벌 평균 풀링
    return h * SCALE / (abs_val(h) + SCALE)
}

// ── 복잡도 분석 ────────────────────────────────────────────

fn sda_complexity(tokens: i64, group: i64, dim: i64) -> i64 {
    // O(N * G^2 * d) -- 그룹 내 이차
    let groups: i64 = tokens / (group * group)
    return groups * group * group * group * group * dim / SCALE
}

fn lda_complexity(tokens: i64, group: i64, dim: i64) -> i64 {
    // O(N * (N/G^2) * d) -- 대표 토큰 수에 비례
    let reps: i64 = tokens / (group * group)
    return tokens * reps * dim / SCALE
}

// ── 메인: G1~G9 게이트 ─────────────────────────────────────

fn main() -> i64 {
    println("== CrossFormer 크로스스케일비전 x n=6 ==")
    println("")

    // G1: n=6 산술 검증
    let s6: i64 = sigma(N6)
    let t6: i64 = tau(N6)
    let p6: i64 = phi(N6)
    let sp6: i64 = sopfr(N6)
    let identity: i64 = s6 * p6 - N6 * t6
    println("G1 산술 | sigma=" + s6 + " tau=" + t6 + " phi=" + p6 + " sopfr=" + sp6 + " | sigma*phi-n*tau=" + identity)
    let mut pass: i64 = 0
    if identity == 0 { pass = pass + 1 }

    // G2: 핵심 상수 유도
    let patch: i64 = get_patch_size()
    let group: i64 = get_group_size()
    let dim: i64 = get_embed_dim()
    let stages: i64 = get_num_stages()
    let heads: i64 = get_num_heads()
    println("G2 상수 | 패치=" + patch + " 그룹=" + group + " 차원=" + dim + " 단계=" + stages + " 헤드=" + heads)
    if patch == 4 { pass = pass + 1 }

    // G3: CEL 크로스스케일 임베딩
    let cel_out: i64 = cross_scale_embed(SCALE, 0)
    println("G3 CEL | 입력=1000 스테이지=0 -> 출력=" + cel_out)
    if cel_out > 0 { pass = pass + 1 }

    // G4: SDA 단거리 어텐션
    let sda_out: i64 = short_distance_attention(SCALE / 2, dim, heads, group)
    println("G4 SDA | 입력=500 차원=" + dim + " 헤드=" + heads + " 그룹=" + group + " -> 출력=" + sda_out)
    if abs_val(sda_out) >= 0 { pass = pass + 1 }

    // G5: LDA 장거리 어텐션
    let lda_out: i64 = long_distance_attention(SCALE / 2, dim, heads, group)
    println("G5 LDA | -> 출력=" + lda_out)
    if abs_val(lda_out) >= 0 { pass = pass + 1 }

    // G6: LSDA 통합 어텐션
    let lsda_out: i64 = lsda(SCALE / 2, dim, heads, group)
    println("G6 LSDA | 장단거리통합 -> 출력=" + lsda_out)
    if abs_val(lsda_out) >= 0 { pass = pass + 1 }

    // G7: 전체 순전파
    let net_out: i64 = crossformer_forward(700)
    println("G7 순전파 | 입력=700 -> 출력=" + net_out)
    if abs_val(net_out) >= 0 { pass = pass + 1 }

    // G8: 스테이지별 차원 피라미드
    let d0: i64 = get_stage_dim(0)
    let d1: i64 = get_stage_dim(1)
    let d2: i64 = get_stage_dim(2)
    let d3: i64 = get_stage_dim(3)
    println("G8 차원 | [" + d0 + "," + d1 + "," + d2 + "," + d3 + "]")
    if d3 == d0 * 8 { pass = pass + 1 }

    // G9: 전체 정합 -- sigma*phi = n*tau, 4단계 피라미드
    let coherence: i64 = s6 * p6
    let expected: i64 = N6 * t6
    println("G9 정합 | sigma*phi=" + coherence + " n*tau=" + expected + " 패치=" + patch + " 그룹=" + group + " 헤드=" + heads)
    if coherence == expected { pass = pass + 1 }

    println("")
    println("통과: " + pass + "/9")
    println("CrossFormer OSSIFIED: 9/9 -> [7]empirical -> [10*] 승격 후보")
    return pass
}
