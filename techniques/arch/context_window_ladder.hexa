// arch/context_window_ladder.hexa — 컨텍스트 윈도우 래더 x n=6 정식 본문
//
// 원본 경로: techniques/arch/context_window_ladder.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 19: Context Window Ladder (BT-44)
//            n=6 단계로 컨텍스트 윈도우를 지수적 확장
//            각 단계 = base * 2^k 토큰, 총 6단계
// n=6 정렬:
//   - 래더 단계     = 6           -> n
//   - 기본 윈도우   = σ(6) = 12   -> 최소 컨텍스트
//   - 확장 계수     = φ(6) = 2    -> 2배 확장
//   - 압축 레벨     = τ(6) = 4    -> 4단계 압축
//   - 최대 윈도우   = 12*2^5=384  -> 최종 컨텍스트
//
// 실행: hexa run techniques/arch/context_window_ladder.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) 래더 스펙 (n=6 정렬)
//    6단계 래더: 각 단계 k (0..5)에서 윈도우 = base * expand^k
//    base = σ(6) = 12, expand = φ(6) = 2
//    [12, 24, 48, 96, 192, 384] 토큰
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const BASE_WIN:   i64 = 12   // σ(6) 기본 윈도우
const EXPAND:     i64 = 2    // φ(6) 확장 계수
const N_COMPRESS: i64 = 4    // τ(6) 압축 레벨
const N_STEPS:    i64 = 6    // n=6 래더 단계

// ════════════════════════════════════════════════════════════════════
// 3) 거듭제곱 유틸 — 정수 지수
// ════════════════════════════════════════════════════════════════════

fn pow_i64(base: i64, exp: i64) -> i64 {
    let mut result: i64 = 1
    let mut i: i64 = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// 4) 래더 윈도우 크기 — 단계 k에서의 윈도우
// ════════════════════════════════════════════════════════════════════

fn window_at_step(k: i64) -> i64 {
    // 윈도우 = base * expand^k = 12 * 2^k
    return BASE_WIN * pow_i64(EXPAND, k)
}

// ════════════════════════════════════════════════════════════════════
// 5) 압축률 계산 — 래더 단계별 효율
//    매 단계 정보를 τ(6)=4 레벨로 압축 후 확장
//    오버헤드 = τ(6) * k (단계가 올라갈수록 압축 오버헤드 증가)
// ════════════════════════════════════════════════════════════════════

fn compress_ratio(k: i64) -> i64 {
    if k == 0 { return 1 }
    return window_at_step(k) / window_at_step(k - 1)
}

fn effective_tokens(k: i64) -> i64 {
    let win: i64 = window_at_step(k)
    let overhead: i64 = N_COMPRESS * k
    if win > overhead {
        return win - overhead
    }
    return 0
}

// ════════════════════════════════════════════════════════════════════
// 6) 전체 래더 용량 — 6단계 총 유효 토큰
// ════════════════════════════════════════════════════════════════════

fn total_capacity() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_STEPS {
        total = total + effective_tokens(k)
        k = k + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 7) 래더 전체 윈도우 합 + 등비급수 검증
//    합 = base*(expand^N-1)/(expand-1) = 12*(64-1)/1 = 756
// ════════════════════════════════════════════════════════════════════

fn total_raw_windows() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_STEPS {
        total = total + window_at_step(k)
        k = k + 1
    }
    return total
}

fn geometric_sum_check() -> bool {
    let raw: i64 = total_raw_windows()
    let expected: i64 = BASE_WIN * (pow_i64(EXPAND, N_STEPS) - 1) / (EXPAND - 1)
    return raw == expected
}

// ════════════════════════════════════════════════════════════════════
// 8) 래더 효율 — 유효/원시 비율
//    총 오버헤드 = τ(6) * (0+1+2+3+4+5) = 4 * 15 = 60
// ════════════════════════════════════════════════════════════════════

fn total_overhead() -> i64 {
    let mut total: i64 = 0
    let mut k: i64 = 0
    while k < N_STEPS {
        total = total + N_COMPRESS * k
        k = k + 1
    }
    return total
}

fn ladder_efficiency_pct() -> i64 {
    let raw: i64 = total_raw_windows()
    let eff: i64 = total_capacity()
    return eff * 100 / raw
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Context Window Ladder x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 기본 윈도우 = σ(6) = 12
    let g2: bool = BASE_WIN == sig
    println("G2 기본윈도우=σ=12           : " + g2)

    // G3: 확장 계수 = φ(6) = 2
    let g3: bool = EXPAND == ph
    println("G3 확장계수=φ=2              : " + g3)

    // G4: 래더 단계별 윈도우 출력
    let mut k: i64 = 0
    while k < N_STEPS {
        let w: i64 = window_at_step(k)
        let e: i64 = effective_tokens(k)
        println("  단계 " + k + ": 윈도우=" + w + " 유효=" + e)
        k = k + 1
    }
    let final_win: i64 = window_at_step(N_STEPS - 1)
    let g4: bool = final_win == BASE_WIN * pow_i64(EXPAND, N_STEPS - 1)
    println("G4 최종윈도우=" + final_win + "         : " + g4)

    // G5: 등비급수 검증
    let g5: bool = geometric_sum_check()
    let raw: i64 = total_raw_windows()
    println("G5 등비급수합=" + raw + "           : " + g5)

    // G6: 유효 토큰 > 원시의 90%
    let eff_pct: i64 = ladder_efficiency_pct()
    let g6: bool = eff_pct > 90
    println("G6 효율=" + eff_pct + "%>90%          : " + g6)

    // G7: 압축 레벨 = τ(6) = 4
    let g7: bool = N_COMPRESS == t
    println("G7 압축레벨=τ(6)=4           : " + g7)

    // G8: 총 오버헤드 = τ * 15 = 60
    let ovh: i64 = total_overhead()
    let g8: bool = ovh == N_COMPRESS * 15
    println("G8 총오버헤드=" + ovh + "             : " + g8)

    // G9: 확장비 일관성 (매 단계 2배)
    let mut g9: bool = true
    let mut s: i64 = 1
    while s < N_STEPS {
        if compress_ratio(s) != EXPAND { g9 = false }
        s = s + 1
    }
    println("G9 확장비일관=2              : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("래더 단계: " + N_STEPS + " (n=6)")
    println("윈도우 범위: " + BASE_WIN + " ~ " + final_win)
    println("총 용량: " + total_capacity() + " 유효 토큰")
    println("효율: " + eff_pct + "%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Context Window Ladder OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("Context Window Ladder FAIL: 게이트 위반")
    }
}
