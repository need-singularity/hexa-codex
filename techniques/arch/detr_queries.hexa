// arch/detr_queries.hexa — DETR 오브젝트 쿼리 x n=6 정식 본문
//
// 원본 경로: techniques/arch/detr_queries.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 27: DETR Object Queries (Carion 외 2020)
//            n=6 오브젝트 쿼리로 디코더 집합 예측
// n=6 정렬:
//   - 쿼리 수       = 6           -> n 오브젝트 슬롯
//   - 쿼리 차원     = σ(6) = 12   -> 쿼리 임베딩 크기
//   - 디코더 레이어 = τ(6) = 4    -> 4층 디코더
//   - 클래스 수     = φ(6) = 2    -> 이진 탐지 (존재/부재)
//   - 바운딩 박스   = τ(6) = 4    -> (cx, cy, w, h)
//
// 실행: hexa run techniques/arch/detr_queries.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) DETR 스펙 (n=6 정렬)
//    n=6 쿼리가 각각 d=12 차원, τ(6)=4 레이어 디코더
//    헝가리안 매칭 비용: L1 + 분류 비용
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const N_QUERIES:  i64 = 6    // n=6 오브젝트 쿼리
const QUERY_DIM:  i64 = 12   // σ(6) 쿼리 임베딩 차원
const N_LAYERS:   i64 = 4    // τ(6) 디코더 레이어
const N_CLASSES:  i64 = 2    // φ(6) 클래스 (존재/부재)
const BBOX_DIM:   i64 = 4    // τ(6) 바운딩 박스 (cx,cy,w,h)

// ════════════════════════════════════════════════════════════════════
// 3) 쿼리 임베딩 초기화 — 결정론적 시드
//    쿼리 q의 차원 d 값 = (q * QUERY_DIM + d) % (σ(6)+1) - 6
//    범위: [-6, 6] 정수 임베딩
// ════════════════════════════════════════════════════════════════════

fn query_embed(q: i64, d: i64) -> i64 {
    return (q * QUERY_DIM + d) % (QUERY_DIM + 1) - N_CORE
}

// ════════════════════════════════════════════════════════════════════
// 4) 쿼리 간 직교성 — 내적 계산
//    쿼리 i, j 내적 = Σ embed(i,d)*embed(j,d)
// ════════════════════════════════════════════════════════════════════

fn query_dot(qi: i64, qj: i64) -> i64 {
    let mut dot: i64 = 0
    let mut d: i64 = 0
    while d < QUERY_DIM {
        dot = dot + query_embed(qi, d) * query_embed(qj, d)
        d = d + 1
    }
    return dot
}

fn query_norm_sq(q: i64) -> i64 {
    return query_dot(q, q)
}

// ════════════════════════════════════════════════════════════════════
// 5) 헝가리안 매칭 비용 — 쿼리-GT 간 L1 거리
//    GT 바운딩 박스: (idx*2, idx*2+1, 3, 3)
//    예측 박스: 쿼리 임베딩의 처음 4차원
// ════════════════════════════════════════════════════════════════════

fn gt_bbox(idx: i64, dim: i64) -> i64 {
    if dim == 0 { return idx * 2 }
    if dim == 1 { return idx * 2 + 1 }
    return 3
}

fn pred_bbox(q: i64, dim: i64) -> i64 {
    return query_embed(q, dim)
}

fn l1_cost(q: i64, gt_idx: i64) -> i64 {
    let mut cost: i64 = 0
    let mut d: i64 = 0
    while d < BBOX_DIM {
        cost = cost + abs_val(pred_bbox(q, d) - gt_bbox(gt_idx, d))
        d = d + 1
    }
    return cost
}

// ════════════════════════════════════════════════════════════════════
// 6) 매칭 비용 행렬 — N x N (쿼리 x GT)
// ════════════════════════════════════════════════════════════════════

fn cost_matrix_sum() -> i64 {
    let mut total: i64 = 0
    let mut q: i64 = 0
    while q < N_QUERIES {
        let mut g: i64 = 0
        while g < N_QUERIES {
            total = total + l1_cost(q, g)
            g = g + 1
        }
        q = q + 1
    }
    return total
}

fn diagonal_cost_sum() -> i64 {
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < N_QUERIES {
        total = total + l1_cost(i, i)
        i = i + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 7) 디코더 레이어 시뮬 — τ(6)=4 층 반복 정제
//    각 레이어에서 잔차 = 원본 + layer (정수 시뮬)
// ════════════════════════════════════════════════════════════════════

fn decoder_refine(q: i64, d: i64, layer: i64) -> i64 {
    return query_embed(q, d) + layer
}

fn decoder_output_norm_sq(q: i64, layer: i64) -> i64 {
    let mut norm: i64 = 0
    let mut d: i64 = 0
    while d < QUERY_DIM {
        let v: i64 = decoder_refine(q, d, layer)
        norm = norm + v * v
        d = d + 1
    }
    return norm
}

// ════════════════════════════════════════════════════════════════════
// 8) 분류 점수 — φ(6)=2 클래스 (존재/부재)
//    노름 > σ(6) 이면 존재(1), 아니면 부재(0)
// ════════════════════════════════════════════════════════════════════

fn classify_query(q: i64) -> i64 {
    let norm: i64 = query_norm_sq(q)
    if norm > QUERY_DIM {
        return 1
    }
    return 0
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ DETR Object Queries x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 쿼리 수 = n = 6
    let g2: bool = N_QUERIES == N_CORE
    println("G2 쿼리수=n=6               : " + g2)

    // G3: 쿼리 차원 = σ(6) = 12
    let g3: bool = QUERY_DIM == sig
    println("G3 쿼리차원=σ=12             : " + g3)

    // G4: 디코더 레이어 = τ(6) = 4
    let g4: bool = N_LAYERS == t
    println("G4 디코더층=τ=4              : " + g4)

    // G5: 쿼리 노름 양수 (모든 쿼리)
    let mut g5: bool = true
    let mut q: i64 = 0
    while q < N_QUERIES {
        let ns: i64 = query_norm_sq(q)
        if ns <= 0 { g5 = false }
        println("  쿼리 " + q + ": 노름²=" + ns + " 클래스=" + classify_query(q))
        q = q + 1
    }
    println("G5 쿼리노름>0               : " + g5)

    // G6: 비용 행렬 양수
    let cm_sum: i64 = cost_matrix_sum()
    let g6: bool = cm_sum > 0
    println("G6 비용행렬합=" + cm_sum + ">0     : " + g6)

    // G7: 대각 비용 < 전체 비용 (대각 매칭이 효율적)
    let diag_sum: i64 = diagonal_cost_sum()
    let g7: bool = diag_sum * N_QUERIES < cm_sum
    println("G7 대각비용<평균 (" + diag_sum + ")  : " + g7)

    // G8: 디코더 정제 후 노름 증가 (레이어 0 vs 마지막)
    let mut g8: bool = true
    let mut qi: i64 = 0
    while qi < N_QUERIES {
        let n0: i64 = decoder_output_norm_sq(qi, 0)
        let n3: i64 = decoder_output_norm_sq(qi, N_LAYERS - 1)
        if n3 <= n0 { g8 = false }
        qi = qi + 1
    }
    println("G8 디코더정제 노름증가       : " + g8)

    // G9: 바운딩 박스 = τ(6) = 4 차원
    let g9: bool = BBOX_DIM == t
    println("G9 bbox차원=τ=4              : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("쿼리: " + N_QUERIES + " x " + QUERY_DIM + "d")
    println("디코더: " + N_LAYERS + " 레이어")
    println("클래스: " + N_CLASSES + " (존재/부재)")
    println("비용행렬합: " + cm_sum)
    println("대각비용합: " + diag_sum)

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("DETR Queries OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("DETR Queries FAIL: 게이트 위반")
    }
}
