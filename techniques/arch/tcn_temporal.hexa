// arch/tcn_temporal.hexa -- 시간 합성곱 네트워크 (TCN) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수 연산)
// 원본 요약: Technique: TCN -- Bai 외 2018
//            "An Empirical Evaluation of Generic Convolutional and
//             Recurrent Networks for Sequence Modeling" (arXiv 2018),
//            인과 확장 합성곱 + 잔차 연결로 RNN 대비 병렬화 가능,
//            수용야 지수적 성장, 시퀀스 모델링 범용 대안
// n=6 정렬:
//   - 커널 크기        = sopfr(6) = 5           -> 합성곱 커널
//   - 확장 비율        = phi(6) = 2             -> 확장(dilation) 배수
//   - 층수             = sigma(6) = 12          -> 전체 합성곱 층
//   - 수용야           = 커널·Sigma(확장^i)      -> 지수적 확장
//   - 잔차 블록 수     = tau(6) = 4             -> 잔차 연결 블록
//
// 실행: hexa run techniques/arch/tcn_temporal.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── n=6 산술 함수 ──────────────────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 { let t: i64 = a % b; a = b; b = t }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 { s = s + d; rem = rem / d }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 핵심 상수 ──────────────────────────────────────────────

const SCALE: i64 = 1000
const N6: i64 = 6

// ── n=6 유도 상수 ──────────────────────────────────────────

fn get_kernel_size() -> i64 {
    // sopfr(6) = 5
    return sopfr(N6)
}

fn get_dilation_base() -> i64 {
    // phi(6) = 2
    return phi(N6)
}

fn get_num_layers() -> i64 {
    // sigma(6) = 12
    return sigma(N6)
}

fn get_num_residual_blocks() -> i64 {
    // tau(6) = 4
    return tau(N6)
}

fn get_layers_per_block() -> i64 {
    // sigma(6) / tau(6) = 12 / 4 = 3
    return sigma(N6) / tau(N6)
}

// ── 거듭제곱 ───────────────────────────────────────────────

fn power(base: i64, exp: i64) -> i64 {
    let mut result: i64 = 1
    let mut i: i64 = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

// ── 활성화 함수 ────────────────────────────────────────────

fn relu(x: i64) -> i64 {
    if x < 0 { return 0 }
    return x
}

// 가중합 드롭아웃 근사: 입력의 (1-rate) 비율 통과
fn dropout_approx(x: i64, keep_rate: i64) -> i64 {
    return x * keep_rate / SCALE
}

// ── 인과 확장 합성곱 ───────────────────────────────────────

fn causal_dilated_conv(input: i64, kernel: i64, dilation: i64) -> i64 {
    // 수용야: (kernel - 1) * dilation + 1
    let rf: i64 = (kernel - 1) * dilation + 1
    // 가중합 근사
    let output: i64 = input * rf / (rf + 1)
    return output
}

// ── 가중 정규화 (Weight Normalization) ─────────────────────

fn weight_norm(x: i64, channels: i64) -> i64 {
    // 가중치 크기 정규화 근사
    let norm: i64 = abs_val(x) + 1
    return x * channels / norm
}

// ── 잔차 블록 ──────────────────────────────────────────────

// TCN 잔차 블록: Conv1d -> WeightNorm -> ReLU -> Dropout -> Conv1d -> WeightNorm -> ReLU -> Dropout + 잔차
fn tcn_residual_block(input: i64, block_idx: i64, kernel: i64, base: i64, lpb: i64) -> i64 {
    let mut h: i64 = input
    let mut l: i64 = 0
    while l < lpb {
        let layer_idx: i64 = block_idx * lpb + l
        let dilation: i64 = power(base, layer_idx)

        // 확장 인과 합성곱
        h = causal_dilated_conv(h, kernel, dilation)
        // 가중 정규화
        h = weight_norm(h, sigma(N6))
        // ReLU
        h = relu(h)
        // 드롭아웃 (유지율 90%)
        h = dropout_approx(h, 900)

        l = l + 1
    }

    // 1x1 합성곱 (채널 정합)
    let residual: i64 = input * sigma(N6) / (sigma(N6) + 1)
    return h + residual
}

// ── 수용야 계산 ────────────────────────────────────────────

fn receptive_field(num_layers: i64, kernel: i64, base: i64) -> i64 {
    // RF = 1 + (kernel-1) * sum(dilation^i for i in 0..layers)
    let mut dilation_sum: i64 = 0
    let mut l: i64 = 0
    while l < num_layers {
        dilation_sum = dilation_sum + power(base, l)
        l = l + 1
    }
    return 1 + (kernel - 1) * dilation_sum
}

// ── 전체 TCN 순전파 ────────────────────────────────────────

fn tcn_forward(input: i64) -> i64 {
    let kernel: i64 = get_kernel_size()
    let base: i64 = get_dilation_base()
    let blocks: i64 = get_num_residual_blocks()
    let lpb: i64 = get_layers_per_block()

    let mut h: i64 = input
    let mut b: i64 = 0
    while b < blocks {
        h = tcn_residual_block(h, b, kernel, base, lpb)
        b = b + 1
    }

    // 최종 출력: 마지막 시점의 은닉
    return h
}

// ── RNN 대비 복잡도 비교 ───────────────────────────────────

fn rnn_sequential_cost(seq_len: i64) -> i64 {
    // RNN: O(T) 순차 연산
    return seq_len
}

fn tcn_parallel_cost(seq_len: i64, num_layers: i64) -> i64 {
    // TCN: O(log T) 병렬 -- 층 수에 비례
    return num_layers
}

fn parallelism_gain(seq_len: i64, num_layers: i64) -> i64 {
    // 병렬화 이득: seq_len / num_layers * SCALE
    return seq_len * SCALE / num_layers
}

// ── 확장 비율 시퀀스 ───────────────────────────────────────

fn print_dilation_sequence(layers: i64, base: i64) -> i64 {
    let mut l: i64 = 0
    let mut total: i64 = 0
    while l < layers {
        let d: i64 = power(base, l)
        total = total + d
        l = l + 1
    }
    return total
}

// ── 메인: G1~G9 게이트 ─────────────────────────────────────

fn main() -> i64 {
    println("== TCN 시간합성곱네트워크 x n=6 ==")
    println("")

    // G1: n=6 산술 검증
    let s6: i64 = sigma(N6)
    let t6: i64 = tau(N6)
    let p6: i64 = phi(N6)
    let sp6: i64 = sopfr(N6)
    let identity: i64 = s6 * p6 - N6 * t6
    println("G1 산술 | sigma=" + s6 + " tau=" + t6 + " phi=" + p6 + " sopfr=" + sp6 + " | sigma*phi-n*tau=" + identity)
    let mut pass: i64 = 0
    if identity == 0 { pass = pass + 1 }

    // G2: 핵심 상수 유도
    let kernel: i64 = get_kernel_size()
    let base: i64 = get_dilation_base()
    let layers: i64 = get_num_layers()
    let blocks: i64 = get_num_residual_blocks()
    let lpb: i64 = get_layers_per_block()
    println("G2 상수 | 커널=" + kernel + " 확장기저=" + base + " 층=" + layers + " 블록=" + blocks + " 층/블록=" + lpb)
    if kernel == 5 { pass = pass + 1 }

    // G3: 확장 비율 -- 지수적 증가
    let d0: i64 = power(base, 0)
    let d3: i64 = power(base, 3)
    let d6: i64 = power(base, 6)
    let d11: i64 = power(base, 11)
    println("G3 확장 | 층0=" + d0 + " 층3=" + d3 + " 층6=" + d6 + " 층11=" + d11)
    if d11 == 2048 { pass = pass + 1 }

    // G4: 인과 확장 합성곱
    let conv_out: i64 = causal_dilated_conv(SCALE, kernel, power(base, 3))
    println("G4 합성곱 | 입력=1000 커널=" + kernel + " 확장=8 -> 출력=" + conv_out)
    if conv_out > 0 { pass = pass + 1 }

    // G5: 잔차 블록
    let block_out: i64 = tcn_residual_block(SCALE / 2, 0, kernel, base, lpb)
    println("G5 잔차블록 | 입력=500 블록=0 -> 출력=" + block_out)
    if block_out > 0 { pass = pass + 1 }

    // G6: 전체 순전파
    let net_out: i64 = tcn_forward(700)
    println("G6 순전파 | 입력=700 -> 출력=" + net_out)
    if net_out > 0 { pass = pass + 1 }

    // G7: 수용야 -- 지수적 확장
    let rf: i64 = receptive_field(layers, kernel, base)
    println("G7 수용야 | 층=" + layers + " 커널=" + kernel + " 확장기저=" + base + " -> 수용야=" + rf)
    if rf > 1000 { pass = pass + 1 }

    // G8: RNN 대비 병렬화 이득
    let seq: i64 = sigma(N6) * sigma(N6)
    let rnn_cost: i64 = rnn_sequential_cost(seq)
    let tcn_cost: i64 = tcn_parallel_cost(seq, layers)
    let gain: i64 = parallelism_gain(seq, layers)
    println("G8 병렬화 | 시퀀스=" + seq + " RNN=" + rnn_cost + " TCN=" + tcn_cost + " 이득=" + gain + "/1000")
    if gain > SCALE { pass = pass + 1 }

    // G9: 전체 정합 -- sigma*phi = n*tau, 수용야 지수급
    let coherence: i64 = s6 * p6
    let expected: i64 = N6 * t6
    let dilation_sum: i64 = print_dilation_sequence(layers, base)
    println("G9 정합 | sigma*phi=" + coherence + " n*tau=" + expected + " 확장합=" + dilation_sum + " 수용야=" + rf)
    if coherence == expected { pass = pass + 1 }

    println("")
    println("통과: " + pass + "/9")
    println("TCN시간합성곱 OSSIFIED: 9/9 -> [7]empirical -> [10*] 승격 후보")
    return pass
}
