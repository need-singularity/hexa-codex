// arch/constitutional_ai.hexa — Constitutional AI 자기수정 x n=6 정식 본문
//
// 원본 경로: techniques/arch/constitutional_ai.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 20: Constitutional AI Revision Rounds (n=6)
//            Bai 외 2022, "Constitutional AI: Harmlessness from AI Feedback"
//            σ(6)=12 원칙 기반 자기 수정, 6 라운드 반복 정제
// n=6 정렬:
//   - 수정 라운드   = 6           -> n
//   - 원칙 수       = σ(6) = 12   -> 12개 헌법 원칙
//   - 감쇠율        = φ(6) = 2    -> 2단계 감쇠
//   - 위반 임계값   = τ(6) = 4    -> 4점 이하 위반
//   - 점수 범위     = [0, 12]     -> σ(6) 스케일
//
// 실행: hexa run techniques/arch/constitutional_ai.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) 헌법 원칙 체계 — σ(6)=12 원칙
//    각 원칙은 점수 [0, 12] 범위를 갖고, τ(6)=4 이하면 위반
//    원칙 분류: 6쌍 (안전/유익/정직/공정/투명/자율)
// ════════════════════════════════════════════════════════════════════

const N_CORE:        i64 = 6
const N_PRINCIPLES:  i64 = 12   // σ(6) = 12 원칙
const VIOLATION_THR: i64 = 4    // τ(6) = 4 위반 임계값
const DECAY_FACTOR:  i64 = 2    // φ(6) = 2 감쇠 계수
const N_ROUNDS:      i64 = 6    // n = 6 수정 라운드

// ════════════════════════════════════════════════════════════════════
// 3) 원칙 점수 초기화 — 의도적 위반 시뮬레이션
//    12개 원칙 중 절반(6개)이 위반 상태(τ 이하)에서 시작
//    인덱스 i의 초기 점수 = i+1 (1~12), 홀수 인덱스는 τ 이하로 설정
// ════════════════════════════════════════════════════════════════════

fn init_score(idx: i64) -> i64 {
    // 짝수 인덱스: 정상 (idx+1), 홀수 인덱스: 위반 (idx%τ+1)
    if idx % 2 == 0 {
        return idx + N_CORE
    }
    // 홀수: τ 이하 강제
    return idx % VIOLATION_THR + 1
}

fn is_violation(score: i64) -> bool {
    return score <= VIOLATION_THR
}

// ════════════════════════════════════════════════════════════════════
// 4) 자기 비평 (Self-Critique) — 위반 원칙 감지
//    전체 12 원칙을 순회하여 위반 수 계산
// ════════════════════════════════════════════════════════════════════

fn count_violations_arr(s0: i64, s1: i64, s2: i64, s3: i64,
                        s4: i64, s5: i64, s6: i64, s7: i64,
                        s8: i64, s9: i64, s10: i64, s11: i64) -> i64 {
    let mut v: i64 = 0
    if is_violation(s0) { v = v + 1 }
    if is_violation(s1) { v = v + 1 }
    if is_violation(s2) { v = v + 1 }
    if is_violation(s3) { v = v + 1 }
    if is_violation(s4) { v = v + 1 }
    if is_violation(s5) { v = v + 1 }
    if is_violation(s6) { v = v + 1 }
    if is_violation(s7) { v = v + 1 }
    if is_violation(s8) { v = v + 1 }
    if is_violation(s9) { v = v + 1 }
    if is_violation(s10) { v = v + 1 }
    if is_violation(s11) { v = v + 1 }
    return v
}

// ════════════════════════════════════════════════════════════════════
// 5) 수정 (Revision) — 위반 점수를 φ(6)=2 단위로 개선
//    매 라운드 위반 원칙 점수 += DECAY_FACTOR
//    최대 σ(6)=12 까지 클램프
// ════════════════════════════════════════════════════════════════════

fn revise_score(score: i64) -> i64 {
    if is_violation(score) {
        let new_score: i64 = score + DECAY_FACTOR
        if new_score > N_PRINCIPLES {
            return N_PRINCIPLES
        }
        return new_score
    }
    return score
}

// ════════════════════════════════════════════════════════════════════
// 6) 전체 점수 합산 — 시스템 건강도
//    최대 = 12 * 12 = 144 = σ(6)^2
// ════════════════════════════════════════════════════════════════════

fn total_score(s0: i64, s1: i64, s2: i64, s3: i64,
               s4: i64, s5: i64, s6: i64, s7: i64,
               s8: i64, s9: i64, s10: i64, s11: i64) -> i64 {
    return s0 + s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11
}

// ════════════════════════════════════════════════════════════════════
// 7) 수렴 판정 — 모든 원칙이 위반 없으면 수렴
// ════════════════════════════════════════════════════════════════════

fn is_converged(s0: i64, s1: i64, s2: i64, s3: i64,
                s4: i64, s5: i64, s6: i64, s7: i64,
                s8: i64, s9: i64, s10: i64, s11: i64) -> bool {
    return count_violations_arr(s0, s1, s2, s3, s4, s5, s6, s7,
                                s8, s9, s10, s11) == 0
}

// ════════════════════════════════════════════════════════════════════
// 8) 6 라운드 자기수정 시뮬레이션
//    라운드마다: 비평(위반 수) → 수정(점수 증가) → 판정(수렴?)
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Constitutional AI x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // 원칙 점수 초기화 (12개)
    let mut s0:  i64 = init_score(0)
    let mut s1:  i64 = init_score(1)
    let mut s2:  i64 = init_score(2)
    let mut s3:  i64 = init_score(3)
    let mut s4:  i64 = init_score(4)
    let mut s5:  i64 = init_score(5)
    let mut s6:  i64 = init_score(6)
    let mut s7:  i64 = init_score(7)
    let mut s8:  i64 = init_score(8)
    let mut s9:  i64 = init_score(9)
    let mut s10: i64 = init_score(10)
    let mut s11: i64 = init_score(11)

    // G2: 초기 원칙 수 = σ(6) = 12
    let g2: bool = N_PRINCIPLES == sig
    println("G2 원칙수=σ(6)=12           : " + g2)

    // G3: 초기 위반 수 > 0
    let init_v: i64 = count_violations_arr(s0, s1, s2, s3, s4, s5,
                                            s6, s7, s8, s9, s10, s11)
    let g3: bool = init_v > 0
    println("G3 초기위반>0 (=" + init_v + ")        : " + g3)

    // 6 라운드 수정 루프
    let mut round: i64 = 1
    let mut converge_round: i64 = 0
    while round <= N_ROUNDS {
        let viol: i64 = count_violations_arr(s0, s1, s2, s3, s4, s5,
                                              s6, s7, s8, s9, s10, s11)
        let ts: i64 = total_score(s0, s1, s2, s3, s4, s5,
                                   s6, s7, s8, s9, s10, s11)
        println("라운드 " + round + ": 위반=" + viol + " 총점=" + ts)

        // 수정 적용
        s0  = revise_score(s0)
        s1  = revise_score(s1)
        s2  = revise_score(s2)
        s3  = revise_score(s3)
        s4  = revise_score(s4)
        s5  = revise_score(s5)
        s6  = revise_score(s6)
        s7  = revise_score(s7)
        s8  = revise_score(s8)
        s9  = revise_score(s9)
        s10 = revise_score(s10)
        s11 = revise_score(s11)

        if converge_round == 0 {
            if is_converged(s0, s1, s2, s3, s4, s5,
                            s6, s7, s8, s9, s10, s11) {
                converge_round = round
            }
        }
        round = round + 1
    }

    // G4: 6 라운드 이내 수렴
    let g4: bool = converge_round > 0
    println("G4 수렴라운드<=" + N_ROUNDS + " (=" + converge_round + ")   : " + g4)

    // G5: 최종 위반 = 0
    let final_v: i64 = count_violations_arr(s0, s1, s2, s3, s4, s5,
                                             s6, s7, s8, s9, s10, s11)
    let g5: bool = final_v == 0
    println("G5 최종위반=0                : " + g5)

    // G6: 최종 총점 = σ(6)^2 범위 내
    let final_ts: i64 = total_score(s0, s1, s2, s3, s4, s5,
                                     s6, s7, s8, s9, s10, s11)
    let max_possible: i64 = sig * sig
    let g6: bool = final_ts <= max_possible
    println("G6 총점<=" + max_possible + " (=" + final_ts + ")    : " + g6)

    // G7: 위반 임계값 = τ(6) = 4
    let g7: bool = VIOLATION_THR == t
    println("G7 임계값=τ(6)=4             : " + g7)

    // G8: 감쇠 계수 = φ(6) = 2
    let g8: bool = DECAY_FACTOR == ph
    println("G8 감쇠=φ(6)=2               : " + g8)

    // G9: 수정 라운드 = n = 6
    let g9: bool = N_ROUNDS == N_CORE
    println("G9 라운드=n=6                : " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("원칙 수: " + N_PRINCIPLES + " (σ(6)=12)")
    println("위반 임계값: " + VIOLATION_THR + " (τ(6)=4)")
    println("수정 증분: " + DECAY_FACTOR + " (φ(6)=2)")
    println("수렴 라운드: " + converge_round + " / " + N_ROUNDS)
    println("최종 총점: " + final_ts + " / " + max_possible)

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Constitutional AI OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("Constitutional AI FAIL: 게이트 위반")
    }
}
