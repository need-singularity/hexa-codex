// sparse/rfilter_phase.hexa — R-filter Phase Detection x n=6 정식 본문
//
// 원본 경로: techniques/sparse/rfilter_phase.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: H-SEDI-6 — R-filter detects training phase transitions
//            학습 과정에서 loss 시계열의 위상 전이를 감지
//            R(t) = Σ_{k=1}^{w} μ(k)·loss(t-k) / Σ_{k=1}^{w} |μ(k)|
//            뫼비우스 가중 이동평균 → 진동 성분 증폭 → 전이점 탐지
// n=6 정렬:
//   - 윈도우 크기  = n = 6         → R-filter 창
//   - 위상 수      = τ(6) = 4      → 학습 4단계 (초기/학습/안정/수렴)
//   - 전이 임계    = σ(6)-τ(6) = 8 → R 값 변화 경계
//   - 감쇠율       = φ(6)/n = 1/3  → 지수 감쇠 정수 근사
//   - 검출 주기    = sopfr(6) = 5  → 매 5 스텝 검사
//
// 실행: hexa run techniques/sparse/rfilter_phase.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut sum: i64 = 0
    let mut m: i64 = n
    let mut p: i64 = 2
    while p <= m {
        while m % p == 0 {
            sum = sum + p
            m = m / p
        }
        p = p + 1
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 2) 뫼비우스 함수 μ(n) — R-filter 가중치 핵심
// ════════════════════════════════════════════════════════════════════

fn mobius(n: i64) -> i64 {
    if n == 1 { return 1 }
    let mut m: i64 = n
    let mut factors: i64 = 0
    let mut p: i64 = 2
    while p * p <= m {
        if m % p == 0 {
            m = m / p
            if m % p == 0 { return 0 }
            factors = factors + 1
        }
        p = p + 1
    }
    if m > 1 { factors = factors + 1 }
    if factors % 2 == 0 { return 1 }
    return 0 - 1
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 3) R-filter 스펙 — 뫼비우스 가중 필터
//    R(t) = Σ_{k=1}^{w} μ(k)·x(t-k) / Σ_{k=1}^{w} |μ(k)|
//    분모 = |μ(1)|+|μ(2)|+|μ(3)|+|μ(4)|+|μ(5)|+|μ(6)|
//         = 1+1+1+0+1+1 = 5 (μ(4)=0 제외)
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const WINDOW:       i64 = 6     // n = 필터 윈도우
const N_PHASES:     i64 = 4     // τ(6) = 학습 위상 수
const TRANSITION_TH: i64 = 8   // σ-τ = 전이 임계값
const CHECK_PERIOD: i64 = 5    // sopfr(6) = 검사 주기

// ════════════════════════════════════════════════════════════════════
// 4) R-filter 분모 — 뫼비우스 절댓값 합
//    Σ|μ(k)| for k=1..6 = 5 (μ(4)=0 이므로)
// ════════════════════════════════════════════════════════════════════

fn rfilter_denom(w: i64) -> i64 {
    let mut sum: i64 = 0
    let mut k: i64 = 1
    while k <= w {
        sum = sum + abs_val(mobius(k))
        k = k + 1
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 5) Loss 시뮬레이션 — 4단계 학습 커브
//    단계 0 (초기):    loss = 1000 - 50·t
//    단계 1 (급강하):  loss = 700 - 100·(t-6)
//    단계 2 (안정):    loss = 100 - 2·(t-12)
//    단계 3 (수렴):    loss = 76 - (t-24)/2
//    총 36 스텝 (= 6^2)
// ════════════════════════════════════════════════════════════════════

fn sim_loss(t: i64) -> i64 {
    if t < N_CORE {
        // 초기: 높은 loss, 완만 감소
        return 1000 - 50 * t
    }
    if t < N_CORE * 2 {
        // 급강하: 빠른 학습
        return 700 - 100 * (t - N_CORE)
    }
    if t < N_CORE * 4 {
        // 안정: 느린 감소
        return 100 - 2 * (t - N_CORE * 2)
    }
    // 수렴: 거의 평탄
    return 76 - (t - N_CORE * 4) / 2
}

// ════════════════════════════════════════════════════════════════════
// 6) R-filter 값 계산 — 특정 시점 t
//    R(t) = Σ_{k=1}^{w} μ(k)·loss(t-k+1) × 1000 / denom
//    × 1000: 밀리 단위 정수 출력
// ════════════════════════════════════════════════════════════════════

fn rfilter_value(t: i64) -> i64 {
    let denom: i64 = rfilter_denom(WINDOW)
    if denom == 0 { return 0 }
    let mut numer: i64 = 0
    let mut k: i64 = 1
    while k <= WINDOW {
        let idx: i64 = t - k + 1
        if idx >= 0 {
            let mu_k: i64 = mobius(k)
            let loss_k: i64 = sim_loss(idx)
            numer = numer + mu_k * loss_k
        }
        k = k + 1
    }
    return (numer * 1000) / denom
}

// ════════════════════════════════════════════════════════════════════
// 7) 위상 전이 감지 — R 값의 절대 변화가 임계 초과
//    |R(t) - R(t-1)| > TRANSITION_TH × 1000
//    전이점 = 학습 위상 경계
// ════════════════════════════════════════════════════════════════════

fn is_transition(t: i64) -> bool {
    if t < WINDOW + 1 { return false }   // 윈도우 확보 필요
    let r_curr: i64 = rfilter_value(t)
    let r_prev: i64 = rfilter_value(t - 1)
    let delta: i64 = abs_val(r_curr - r_prev)
    return delta > TRANSITION_TH * 1000
}

// 전이점 카운트
fn count_transitions(total_steps: i64) -> i64 {
    let mut cnt: i64 = 0
    let mut t: i64 = WINDOW + 1
    while t < total_steps {
        if is_transition(t) { cnt = cnt + 1 }
        t = t + 1
    }
    return cnt
}

// ════════════════════════════════════════════════════════════════════
// 8) 위상 분류 — R 값 부호/크기로 현재 위상 판별
//    R >> 0: 급감소 중 (학습 위상)
//    R ≈ 0: 안정/수렴
//    R << 0: 진동/불안정
// ════════════════════════════════════════════════════════════════════

fn classify_phase(r_val: i64) -> i64 {
    // 밀리 단위 r_val
    if r_val > 50000 { return 0 }          // 초기 (큰 양수)
    if r_val > 10000 { return 1 }          // 급강하 (중간 양수)
    if abs_val(r_val) <= 10000 { return 2 } // 안정 (작은 값)
    return 3                                // 수렴/진동
}

// ════════════════════════════════════════════════════════════════════
// 9) 지수 감쇠 가중 — 최근 값에 더 큰 가중
//    w_k = (WINDOW - k + 1) / WINDOW 선형 감쇠 (정수 근사)
//    또는 1/3^k 지수 감쇠 (φ/n = 1/3)
// ════════════════════════════════════════════════════════════════════

fn weighted_rfilter(t: i64) -> i64 {
    let denom: i64 = rfilter_denom(WINDOW)
    if denom == 0 { return 0 }
    let mut numer: i64 = 0
    let mut weight_sum: i64 = 0
    let mut k: i64 = 1
    while k <= WINDOW {
        let idx: i64 = t - k + 1
        if idx >= 0 {
            let mu_k: i64 = mobius(k)
            let loss_k: i64 = sim_loss(idx)
            // 선형 감쇠 가중: (WINDOW - k + 1)
            let w: i64 = WINDOW - k + 1
            numer = numer + mu_k * loss_k * w
            weight_sum = weight_sum + abs_val(mu_k) * w
        }
        k = k + 1
    }
    if weight_sum == 0 { return 0 }
    return (numer * 1000) / weight_sum
}

// ════════════════════════════════════════════════════════════════════
// 10) R-filter 부호 안정성 — 연속 같은 부호 유지 스텝 수
//     안정성 = max 연속 동일 부호 구간 / 전체 스텝
// ════════════════════════════════════════════════════════════════════

fn sign_stability(total_steps: i64) -> i64 {
    let mut max_run: i64 = 0
    let mut cur_run: i64 = 1
    let mut prev_sign: i64 = 0
    let mut t: i64 = WINDOW
    while t < total_steps {
        let r: i64 = rfilter_value(t)
        let cur_sign: i64 = 0
        if r > 0 {
            if prev_sign == 1 {
                cur_run = cur_run + 1
            } else {
                if cur_run > max_run { max_run = cur_run }
                cur_run = 1
            }
            prev_sign = 1
        } else {
            if prev_sign == 0 - 1 {
                cur_run = cur_run + 1
            } else {
                if cur_run > max_run { max_run = cur_run }
                cur_run = 1
            }
            prev_sign = 0 - 1
        }
        t = t + 1
    }
    if cur_run > max_run { max_run = cur_run }
    return max_run
}

// ════════════════════════════════════════════════════════════════════
// 11) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ R-filter Phase Detection × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 윈도우 = n = 6
    let g2: bool = WINDOW == N_CORE
    println("G2 윈도우=n=6               : " + g2)

    // G3: 위상 수 = τ(6) = 4
    let g3: bool = N_PHASES == t
    println("G3 위상수=τ=4               : " + g3)

    // G4: 전이 임계 = σ-τ = 8
    let g4: bool = TRANSITION_TH == sig - t
    println("G4 전이임계=σ-τ=8           : " + g4)

    // G5: R-filter 분모 = 5 (μ(4)=0 제외)
    let denom: i64 = rfilter_denom(WINDOW)
    let g5: bool = denom == 5
    println("G5 R분모=5 (sopfr(6))       : " + g5)

    // G6: sopfr(6) = 5 = 검사 주기
    let sf: i64 = sopfr(N_CORE)
    let g6: bool = sf == CHECK_PERIOD
    println("G6 sopfr(6)=5=검사주기      : " + g6)

    // G7: 초기 R 값 > 0 (loss 감소 중)
    let r_init: i64 = rfilter_value(WINDOW)
    let g7: bool = r_init != 0   // 필터 출력 존재
    println("G7 R(" + WINDOW + ")=" + r_init + " 비제로     : " + g7)

    // G8: 전이점 감지 — 최소 1회 이상 감지
    let total_steps: i64 = N_CORE * N_CORE   // 36 스텝
    let transitions: i64 = count_transitions(total_steps)
    let g8: bool = transitions >= 1
    println("G8 전이점=" + transitions + "개              : " + g8)

    // G9: 부호 안정성 — 최대 연속 구간 > 2
    let stability: i64 = sign_stability(total_steps)
    let g9: bool = stability >= 2
    println("G9 부호안정성=" + stability + "스텝          : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("시뮬 스텝: " + total_steps + " (n^2)")
    println("윈도우: " + WINDOW)
    println("전이점: " + transitions + "개")
    println("R-filter 분모: " + denom)
    let r_mid: i64 = rfilter_value(N_CORE * 2)
    let r_end: i64 = rfilter_value(total_steps - 1)
    println("R(초기)=" + r_init + " R(중간)=" + r_mid + " R(후반)=" + r_end)
    println("MISS: 실수 지수감쇠 → 선형 정수 근사")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("RFILTER OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("RFILTER PARTIAL: 게이트 일부 위반")
    }
}
