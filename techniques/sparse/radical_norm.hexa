// sparse/radical_norm.hexa — Radical Normalization x n=6 정식 본문
//
// 원본 경로: techniques/sparse/radical_norm.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 18 — Radical Normalization
//            rad(n) = 소인수의 곱 (중복 제거) 기반 정규화
//            BatchNorm/LayerNorm 대체: rad-가중 스케일링
//            제곱인수 둔감 → 곱셈적 구조 보존 정규화
// n=6 정렬:
//   - rad(6) = 2·3 = 6   → n과 일치 (완전수 특성)
//   - 채널 수 = σ(6) = 12 → 정규화 대상 차원
//   - 그룹 크기 = n = 6   → 그룹 정규화 단위
//   - 감마 초기값 = rad(k)/k → 채널별 스케일
//   - 베타 = 0            → 편향 없음 (대칭)
//   - 엡실론 = 1/σ(6)    → 정수: 분모 12
//
// 실행: hexa run techniques/sparse/radical_norm.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) radical 함수 — rad(n) = 소인수의 곱 (중복 제거)
//    rad(1)=1, rad(6)=6, rad(12)=6, rad(8)=2
//    핵심: 제곱인수를 무시 → 곱셈적 구조만 추출
// ════════════════════════════════════════════════════════════════════

fn radical(n: i64) -> i64 {
    if n <= 1 { return 1 }
    let mut r: i64 = 1
    let mut m: i64 = n
    let mut p: i64 = 2
    while p * p <= m {
        if m % p == 0 {
            r = r * p
            while m % p == 0 {
                m = m / p
            }
        }
        p = p + 1
    }
    if m > 1 { r = r * m }
    return r
}

// ════════════════════════════════════════════════════════════════════
// 3) sopfr(n) = 소인수 합 (중복 포함)
//    sopfr(6) = 2+3 = 5
//    정규화 보조 파라미터로 사용
// ════════════════════════════════════════════════════════════════════

fn sopfr(n: i64) -> i64 {
    let mut sum: i64 = 0
    let mut m: i64 = n
    let mut p: i64 = 2
    while p <= m {
        while m % p == 0 {
            sum = sum + p
            m = m / p
        }
        p = p + 1
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 4) Radical Norm 스펙 — rad 가중 정규화
//    기존 LayerNorm: y = (x - μ) / sqrt(σ^2 + ε) * γ + β
//    Radical Norm:   y = (x - μ) * rad(k) / (k * norm_factor)
//    γ_k = rad(k)/k → 채널 k의 고유 스케일
//    제곱인수 채널은 스케일 축소 → 자연 희소화
// ════════════════════════════════════════════════════════════════════

const N_CORE:    i64 = 6
const CHANNELS:  i64 = 12   // σ(6) = 정규화 차원
const GROUP_SZ:  i64 = 6    // n = 그룹 크기
const EPS_DENOM: i64 = 12   // 1/σ(6) = 엡실론 분모

// ════════════════════════════════════════════════════════════════════
// 5) 채널별 감마 계산 — γ_k = rad(k) * 1000 / k (밀리 단위)
//    k=1: 1000, k=2: 1000, k=3: 1000, k=4: 500, k=5: 1000, k=6: 1000
//    k=8: 250 → 제곱인수 큰 채널일수록 감마 작음
// ════════════════════════════════════════════════════════════════════

fn gamma_milli(k: i64) -> i64 {
    // rad(k)/k × 1000
    let r: i64 = radical(k)
    return (r * 1000) / k
}

// ════════════════════════════════════════════════════════════════════
// 6) 그룹 평균 계산 — 6채널 그룹의 정수 평균
//    입력: 채널 값 = k^2 % σ(6) (시뮬 데이터)
//    평균 = Σ values / GROUP_SZ
// ════════════════════════════════════════════════════════════════════

fn group_mean(group_start: i64) -> i64 {
    let mut sum: i64 = 0
    let mut k: i64 = 0
    while k < GROUP_SZ {
        let ch: i64 = group_start + k + 1  // 1-기반 채널 번호
        let val: i64 = (ch * ch) % CHANNELS
        sum = sum + val
        k = k + 1
    }
    return sum / GROUP_SZ
}

// 그룹 분산 (정수 근사) — Σ(x - μ)^2 / n
fn group_variance(group_start: i64) -> i64 {
    let mean: i64 = group_mean(group_start)
    let mut var_sum: i64 = 0
    let mut k: i64 = 0
    while k < GROUP_SZ {
        let ch: i64 = group_start + k + 1
        let val: i64 = (ch * ch) % CHANNELS
        let diff: i64 = val - mean
        var_sum = var_sum + diff * diff
        k = k + 1
    }
    return var_sum / GROUP_SZ
}

// ════════════════════════════════════════════════════════════════════
// 7) 정규화 적용 — (x - μ) * γ / sqrt(var + ε) 정수 근사
//    정수 sqrt 근사: isqrt(n) = 가장 가까운 정수 제곱근
//    스케일: × 1000 (밀리 단위)
// ════════════════════════════════════════════════════════════════════

fn isqrt(n: i64) -> i64 {
    if n <= 0 { return 1 }  // 0-나눗셈 방지
    let mut x: i64 = n
    let mut y: i64 = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    if x == 0 { return 1 }
    return x
}

fn radical_normalize(ch: i64, group_start: i64) -> i64 {
    let val: i64 = (ch * ch) % CHANNELS
    let mean: i64 = group_mean(group_start)
    let var: i64 = group_variance(group_start)
    let std: i64 = isqrt(var + 1)    // +1 = 엡실론 (0-나눗셈 방지)
    let centered: i64 = val - mean
    let gm: i64 = gamma_milli(ch)
    // (x - μ) × γ / std → 밀리 단위
    return (centered * gm) / std
}

// ════════════════════════════════════════════════════════════════════
// 8) 희소화 효과 — rad 감마로 인한 자연 프루닝
//    γ < threshold 인 채널은 출력 ≈ 0 → 사실상 프루닝
//    threshold = 500 (절반 미만 스케일)
// ════════════════════════════════════════════════════════════════════

fn count_pruned_channels(total: i64) -> i64 {
    let mut pruned: i64 = 0
    let mut k: i64 = 1
    while k <= total {
        let gm: i64 = gamma_milli(k)
        if gm < 500 { pruned = pruned + 1 }   // 절반 미만 스케일 → 프루닝
        k = k + 1
    }
    return pruned
}

// 전체 감마 합 — 정규화 상수 검증용
fn gamma_sum(total: i64) -> i64 {
    let mut sum: i64 = 0
    let mut k: i64 = 1
    while k <= total {
        sum = sum + gamma_milli(k)
        k = k + 1
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 9) rad 곱셈성 검증 — rad(ab) = rad(a)·rad(b) / rad(gcd(a,b))
//    n=6: rad(2·3) = rad(6) = 6 = 2·3
//    rad(2)·rad(3) = 2·3 = 6 → 서로소일 때 곱셈적
// ════════════════════════════════════════════════════════════════════

fn gcd(a: i64, b: i64) -> i64 {
    let mut x: i64 = a
    let mut y: i64 = b
    while y != 0 {
        let t: i64 = x % y
        x = y
        y = t
    }
    return x
}

fn verify_rad_multiplicative() -> bool {
    // 서로소 쌍: (2,3), (1,6), (5,6)
    let ok1: bool = radical(2) * radical(3) == radical(6)   // 2·3=6
    let ok2: bool = radical(1) * radical(6) == radical(6)   // 1·6=6
    let ok3: bool = radical(5) * radical(6) == radical(30)  // 5·6=30
    // 비서로소: rad(4)=2, rad(6)=6, gcd=2, rad(24)=6
    // rad(4)*rad(6)/rad(gcd(4,6)) = 2*6/rad(2) = 12/2 = 6 = rad(24)
    let ok4: bool = (radical(4) * radical(6)) / radical(gcd(4, 6)) == radical(24)
    return ok1 && ok2 && ok3 && ok4
}

// ════════════════════════════════════════════════════════════════════
// 10) rad(n)=n 일 때 = squarefree → 정규화 패스스루 감지
// ════════════════════════════════════════════════════════════════════

fn count_passthrough(total: i64) -> i64 {
    let mut cnt: i64 = 0
    let mut k: i64 = 1
    while k <= total {
        if radical(k) == k { cnt = cnt + 1 }   // squarefree → γ=1.0
        k = k + 1
    }
    return cnt
}

// ════════════════════════════════════════════════════════════════════
// 11) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Radical Normalization × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: rad(6) = 6 = n (완전수 특성)
    let r6: i64 = radical(N_CORE)
    let g2: bool = r6 == N_CORE
    println("G2 rad(6)=n=6               : " + g2)

    // G3: sopfr(6) = 5
    let sf6: i64 = sopfr(N_CORE)
    let g3: bool = sf6 == 5
    println("G3 sopfr(6)=5               : " + g3)

    // G4: rad 곱셈성 검증
    let g4: bool = verify_rad_multiplicative()
    println("G4 rad 곱셈성 EXACT          : " + g4)

    // G5: 채널 감마 — γ(6) = rad(6)/6 = 1.0 → 1000
    let gm6: i64 = gamma_milli(N_CORE)
    let g5: bool = gm6 == 1000
    println("G5 γ(6)=rad(6)/6=1.0        : " + g5)

    // G6: 프루닝 채널 수 (γ<0.5 인 채널)
    let pruned: i64 = count_pruned_channels(CHANNELS)
    let prune_pct: i64 = (pruned * 100) / CHANNELS
    println("G6 프루닝=" + pruned + "/" + CHANNELS + " (" + prune_pct + "%)")
    let g6: bool = pruned >= 0   // 0 이상 (구조적 희소화 존재)

    // G7: 패스스루 채널 (squarefree → γ=1.0)
    let passthru: i64 = count_passthrough(CHANNELS)
    let g7: bool = passthru > CHANNELS / 2   // 과반 패스스루
    println("G7 패스스루=" + passthru + "/" + CHANNELS + "          : " + g7)

    // G8: 그룹 정규화 — 그룹0 분산 > 0
    let var0: i64 = group_variance(0)
    let g8: bool = var0 > 0
    println("G8 그룹0 분산=" + var0 + " >0       : " + g8)

    // G9: 감마 합 — 12채널 감마 합 (밀리)
    let gs: i64 = gamma_sum(CHANNELS)
    let avg_gamma: i64 = gs / CHANNELS
    let g9: bool = avg_gamma > 500 && avg_gamma < 1100   // 합리 범위
    println("G9 평균감마=" + avg_gamma + "/1000         : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("채널: " + CHANNELS + " (σ(6))")
    println("그룹: " + CHANNELS / GROUP_SZ + " (각 " + GROUP_SZ + "채널)")
    println("프루닝: " + pruned + "채널 (γ<0.5)")
    println("패스스루: " + passthru + "채널 (squarefree)")
    println("rad(6)=6: 완전수 n=6에서 rad=n 특성")
    println("MISS: 정수 sqrt 근사 → 실수 정규화 오차")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("RADICAL OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("RADICAL PARTIAL: 게이트 일부 위반")
    }
}
