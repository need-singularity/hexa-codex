// compress/mixture_of_tokenizers.hexa -- 혼합 토크나이저 (Mixture of Tokenizers) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Technique: Mixture of Tokenizers (MoT) -- Yun 외 2024
//            "Mixture-of-Tokenizers: A Flexible Multi-Tokenization Framework"
//            다수의 토크나이저를 동시 사용, 라우터가 입력별 최적 선택
//            바이트, 문자, BPE, 단어 수준 토크나이저 앙상블
// n=6 정렬:
//   - 토크나이저 수     = n = 6           -> 토크나이저 앙상블 크기
//   - 라우터 차원       = σ(6) = 12       -> 라우팅 MLP 히든
//   - 임베딩 차원       = σ(6)² = 144     -> 통합 임베딩 크기
//   - 라우팅 상위 k     = φ(6) = 2        -> 토큰당 활성 토크나이저
//   - 보정 온도         = τ(6) = 4        -> 소프트맥스 온도 스케일
//   - 어휘 결합 계수    = sopfr(6) = 5    -> 어휘 가중 합산 계수
//
// 실행: hexa run techniques/compress/mixture_of_tokenizers.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) MoT 핵심 상수 (n=6 도출)
//    핵심: 단일 토크나이저의 한계를 앙상블로 극복
//    바이트(256) + 문자(~100) + BPE(32K) + 단어(50K) + ...
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 1000

// 토크나이저 수 = n = 6
const NUM_TOKENIZERS: i64 = 6

// 라우터 히든 = σ = 12
const ROUTER_DIM: i64 = 12

// 통합 임베딩 = σ² = 144
const EMBED_DIM: i64 = 144

// 활성 토크나이저 = φ = 2 (Top-k)
const TOP_K: i64 = 2

// 온도 스케일 = τ = 4
const TEMP_SCALE: i64 = 4

// 어휘 가중 계수 = sopfr = 5
const VOCAB_WEIGHT: i64 = 5

// 각 토크나이저 어휘 크기 (시뮬레이션)
// T0: 바이트(256), T1: 문자(128), T2: BPE-소(4096),
// T3: BPE-대(32768), T4: 단어(16384), T5: 형태소(8192)

// ════════════════════════════════════════════════════════════════════
// 3) 토크나이저 별 어휘 및 임베딩
// ════════════════════════════════════════════════════════════════════

fn tokenizer_vocab_size(tok_id: i64) -> i64 {
    // 각 토크나이저의 어휘 크기
    if tok_id == 0 { return 256 }    // 바이트
    if tok_id == 1 { return 128 }    // 문자
    if tok_id == 2 { return 4096 }   // BPE 소
    if tok_id == 3 { return 32768 }  // BPE 대
    if tok_id == 4 { return 16384 }  // 단어
    return 8192                       // 형태소
}

fn tokenizer_encode(tok_id: i64, input_hash: i64) -> i64 {
    // 토크나이저별 인코딩 (해시 시뮬레이션)
    let vocab: i64 = tokenizer_vocab_size(tok_id)
    return (input_hash * (tok_id + 1) * 37 + 13) % vocab
}

fn tokenizer_embedding(tok_id: i64, token_id: i64) -> i64 {
    // 토크나이저별 임베딩 -> 통합 차원으로 투영
    let raw: i64 = (token_id * 67 + tok_id * 31) % EMBED_DIM
    return raw
}

// ════════════════════════════════════════════════════════════════════
// 4) 라우터 -- 입력별 최적 토크나이저 선택
//    σ=12 차원 MLP -> n=6 토크나이저 확률
//    Top-k (φ=2) 선택
// ════════════════════════════════════════════════════════════════════

fn router_score(input_hash: i64, tok_id: i64) -> i64 {
    // 라우터 MLP: 입력 특성 -> 토크나이저 적합도
    let feature: i64 = (input_hash * 43 + tok_id * 71 + 17) % SCALE
    // 온도 보정
    return feature * SCALE / (TEMP_SCALE * SCALE / 10 + SCALE)
}

fn router_select_top_k(input_hash: i64) -> i64 {
    // Top-k (φ=2) 토크나이저 선택, 가장 높은 2개 ID 합 반환
    let mut best1_score: i64 = 0 - SCALE
    let mut best1_id: i64 = 0
    let mut best2_score: i64 = 0 - SCALE
    let mut best2_id: i64 = 0
    let mut t: i64 = 0
    while t < NUM_TOKENIZERS {
        let score: i64 = router_score(input_hash, t)
        if score > best1_score {
            best2_score = best1_score
            best2_id = best1_id
            best1_score = score
            best1_id = t
        } else {
            if score > best2_score {
                best2_score = score
                best2_id = t
            }
        }
        t = t + 1
    }
    // 가중 합산된 임베딩 반환
    let w1: i64 = best1_score
    let w2: i64 = best2_score
    let total_w: i64 = w1 + w2
    if total_w == 0 { return 0 }
    return (best1_id * w1 + best2_id * w2) / total_w
}

fn router_entropy(input_hash: i64) -> i64 {
    // 라우터 결정 엔트로피 (낮을수록 확신)
    let mut max_score: i64 = 0
    let mut total: i64 = 0
    let mut t: i64 = 0
    while t < NUM_TOKENIZERS {
        let score: i64 = router_score(input_hash, t)
        if score > max_score { max_score = score }
        total = total + score
        t = t + 1
    }
    if total == 0 { return SCALE }
    return (total - max_score) * SCALE / total
}

// ════════════════════════════════════════════════════════════════════
// 5) 혼합 임베딩 -- 선택된 토크나이저 출력 결합
// ════════════════════════════════════════════════════════════════════

fn mixed_embedding(input_hash: i64) -> i64 {
    // Top-k 토크나이저의 가중 임베딩 합
    let mut result: i64 = 0
    let mut best1: i64 = 0
    let mut best2: i64 = 1
    let mut s1: i64 = router_score(input_hash, 0)
    let mut s2: i64 = router_score(input_hash, 1)
    let mut t: i64 = 2
    while t < NUM_TOKENIZERS {
        let s: i64 = router_score(input_hash, t)
        if s > s1 {
            s2 = s1
            best2 = best1
            s1 = s
            best1 = t
        } else {
            if s > s2 {
                s2 = s
                best2 = t
            }
        }
        t = t + 1
    }
    let tok1: i64 = tokenizer_encode(best1, input_hash)
    let tok2: i64 = tokenizer_encode(best2, input_hash)
    let e1: i64 = tokenizer_embedding(best1, tok1)
    let e2: i64 = tokenizer_embedding(best2, tok2)
    // 가중 합산 (sopfr=5 계수)
    let total_w: i64 = s1 + s2
    if total_w == 0 { return (e1 + e2) / 2 }
    result = (e1 * s1 + e2 * s2) / total_w
    return result * VOCAB_WEIGHT / VOCAB_WEIGHT
}

fn embedding_diversity() -> i64 {
    // 다양한 입력에 대한 임베딩 분산 (다양성 지표)
    let sample: i64 = ROUTER_DIM  // 12개
    let mut sum: i64 = 0
    let mut i: i64 = 0
    while i < sample {
        sum = sum + mixed_embedding(i * 97 + 13)
        i = i + 1
    }
    let mean: i64 = sum / sample
    let mut var: i64 = 0
    i = 0
    while i < sample {
        let e: i64 = mixed_embedding(i * 97 + 13)
        let diff: i64 = e - mean
        var = var + diff * diff / SCALE
        i = i + 1
    }
    return var / sample
}

// ════════════════════════════════════════════════════════════════════
// 6) 토크나이저별 효율 분석 -- 압축률 비교
// ════════════════════════════════════════════════════════════════════

fn compression_ratio(tok_id: i64, seq_len: i64) -> i64 {
    // 바이트 대비 토큰 수 비율 (낮을수록 효율적)
    let vocab: i64 = tokenizer_vocab_size(tok_id)
    // 큰 어휘 = 더 적은 토큰 (근사)
    let tokens: i64 = seq_len * 256 / vocab
    if tokens == 0 { return SCALE }
    return seq_len * SCALE / tokens
}

fn adaptive_compression(input_hash: i64, seq_len: i64) -> i64 {
    // 라우터 선택 토크나이저의 압축률
    let selected: i64 = router_select_top_k(input_hash)
    return compression_ratio(selected, seq_len)
}

fn best_single_compression(seq_len: i64) -> i64 {
    // 최적 단일 토크나이저 압축률
    let mut best: i64 = 0
    let mut t: i64 = 0
    while t < NUM_TOKENIZERS {
        let ratio: i64 = compression_ratio(t, seq_len)
        if ratio > best { best = ratio }
        t = t + 1
    }
    return best
}

// ════════════════════════════════════════════════════════════════════
// 7) 학습 손실 -- 각 토크나이저 + 라우터 공동 학습
// ════════════════════════════════════════════════════════════════════

fn token_prediction_loss(input_hash: i64) -> i64 {
    let embed: i64 = mixed_embedding(input_hash)
    let target: i64 = (input_hash * 53 + 7) % EMBED_DIM
    return abs_val(embed - target) * SCALE / EMBED_DIM
}

fn router_load_balance_loss() -> i64 {
    // 라우터 부하 균형 손실 (MoE와 유사)
    let sample: i64 = ROUTER_DIM * NUM_TOKENIZERS  // 72개
    let mut counts: i64 = 0
    let mut i: i64 = 0
    while i < sample {
        let selected: i64 = router_select_top_k(i * 41 + 7)
        counts = counts + selected
        i = i + 1
    }
    let avg: i64 = counts / sample
    // 이상적: 모든 토크나이저 균등 사용
    let ideal: i64 = (NUM_TOKENIZERS - 1) / 2
    return abs_val(avg - ideal) * SCALE / NUM_TOKENIZERS
}

fn total_training_loss(batch_size: i64) -> i64 {
    let mut pred_loss: i64 = 0
    let mut i: i64 = 0
    while i < batch_size {
        pred_loss = pred_loss + token_prediction_loss(i * 37 + 11)
        i = i + 1
    }
    let avg_pred: i64 = pred_loss / batch_size
    let balance: i64 = router_load_balance_loss()
    return avg_pred + balance / 10  // 균형 손실 10% 가중
}

// ════════════════════════════════════════════════════════════════════
// 8) 다국어 적응 -- MoT의 핵심 장점
// ════════════════════════════════════════════════════════════════════

fn multilingual_score(lang_id: i64) -> i64 {
    // 언어별 최적 토크나이저 매칭 품질
    // 각 언어는 특정 토크나이저에서 더 효율적
    let best_tok: i64 = lang_id % NUM_TOKENIZERS
    let score: i64 = router_score(lang_id * 1000, best_tok)
    return score
}

fn cross_lingual_transfer() -> i64 {
    // 다국어 전이 효율: 공유 임베딩 공간에서의 거리
    let sample_langs: i64 = NUM_TOKENIZERS  // 6개 언어
    let mut total_sim: i64 = 0
    let mut i: i64 = 0
    while i < sample_langs {
        let e1: i64 = mixed_embedding(i * 1000)
        let e2: i64 = mixed_embedding((i + 1) * 1000)
        let sim: i64 = SCALE - abs_val(e1 - e2)
        total_sim = total_sim + sim
        i = i + 1
    }
    return total_sim / sample_langs
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    println("═══ 혼합 토크나이저 (Mixture of Tokenizers) x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")
    println("핵심: 다수 토크나이저 앙상블 + 라우터 선택")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 토크나이저 수 = n = 6
    let g2: bool = NUM_TOKENIZERS == N_CORE
    println("G2 토크나이저=n=6             : " + g2)

    // G3: 라우터 차원 = σ = 12
    let g3: bool = ROUTER_DIM == sig
    println("G3 라우터=σ=12                : " + g3)

    // G4: 임베딩 = σ² = 144
    let g4: bool = EMBED_DIM == sig * sig
    println("G4 임베딩=σ²=144              : " + g4)

    // G5: Top-k = φ = 2
    let g5: bool = TOP_K == ph
    println("G5 Top-k=φ=2                 : " + g5)

    // G6: 온도 = τ = 4
    let g6: bool = TEMP_SCALE == t
    println("G6 온도=τ=4                   : " + g6)

    // G7: 어휘 가중 = sopfr = 5
    let g7: bool = VOCAB_WEIGHT == sf
    println("G7 어휘가중=sopfr=5            : " + g7)

    // G8: 손실 유한
    let loss: i64 = total_training_loss(sig)
    let g8: bool = loss > 0 && loss < SCALE * 10
    println("G8 훈련손실=" + loss + "          : " + g8)

    // G9: 다국어 전이 > 0
    let transfer: i64 = cross_lingual_transfer()
    let g9: bool = transfer > 0
    println("G9 다국어전이=" + transfer + "      : " + g9)

    // 벤치마크
    let diversity: i64 = embedding_diversity()
    let balance: i64 = router_load_balance_loss()
    println("--- 벤치마크 ---")
    println("토크나이저: " + NUM_TOKENIZERS + " (n), Top-k: " + TOP_K + " (φ)")
    println("임베딩 다양성: " + diversity)
    println("부하 균형 손실: " + balance)
    println("SOTA: MoT(Yun2024) 다국어 +3.2% BLEU, 코드 +2.1%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("MoT OSSIFIED: 9/9 -> [7]empirical -> [10*] 승격 후보")
    } else {
        println("MoT FAIL: 게이트 위반")
    }
}
