// compress/recurrent_gemma.hexa — RecurrentGemma 순환 상태 x n=6 정식 본문
//
// 원본 경로: techniques/compress/recurrent_gemma.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Botev 외 2024, RecurrentGemma — Griffin 아키텍처
//            선형 순환 + 게이팅으로 KV 캐시 제거
//            O(1) 메모리, O(n) 추론 — 긴 시퀀스에 최적
// n=6 정렬:
//   - 상태 차원     = σ(6) = 12          -> 약수합 = 순환 상태
//   - 게이트 차원   = τ(6) = 4           -> 약수개수 = 게이트
//   - 입력 차원     = n = 6              -> 핵심수
//   - 스텝 수       = 6                  -> n 스텝 순환
//   - 감쇠율 분모   = σ(6) = 12          -> 안정 감쇠
//   - 게이트 활성   = σ 함수 근사        -> 정수 시그모이드
//   - 헤드 수       = φ(6) = 2           -> 오일러 = 순환 헤드
//
// 실행: hexa run techniques/compress/recurrent_gemma.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) RecurrentGemma 스펙 (n=6 정렬)
//    Griffin: h_t = a · h_{t-1} + (1-a) · (B · x_t)
//    a = 감쇠율, B = 입력 투영, h = 순환 상태
//    게이팅: g_t = sigmoid(W_g · x_t), 출력 = g_t * h_t
// ════════════════════════════════════════════════════════════════════

const N_CORE:      i64 = 6
const D_STATE:     i64 = 12    // σ(6) = 순환 상태 차원
const D_GATE:      i64 = 4     // τ(6) = 게이트 차원
const D_INPUT:     i64 = 6     // n = 입력 차원
const N_STEPS:     i64 = 6     // n = 순환 스텝
const N_HEADS:     i64 = 2     // φ(6) = 순환 헤드 수
const SCALE:       i64 = 1000  // 고정소수점 스케일 (×1000)

// ════════════════════════════════════════════════════════════════════
// 3) 감쇠율 — 안정 순환의 핵심
//    a = (σ-1)/σ = 11/12 ≈ 0.917 (×1000 = 917)
//    |a| < 1 보장 → 기울기 폭발/소멸 방지
//    6 스텝 후 잔여: a^6 = (11/12)^6 ≈ 0.596
// ════════════════════════════════════════════════════════════════════

fn decay_rate_scaled() -> i64 {
    // (σ-1)/σ × SCALE = 11/12 × 1000 = 916 (정수 내림)
    let sig: i64 = sigma(N_CORE)
    return ((sig - 1) * SCALE) / sig
}

fn decay_power(steps: i64) -> i64 {
    // a^steps (×SCALE), 정수 거듭제곱
    let a: i64 = decay_rate_scaled()    // 916
    let mut result: i64 = SCALE          // 1000 = 1.0
    let mut i: i64 = 0
    while i < steps {
        result = (result * a) / SCALE
        i = i + 1
    }
    return result
}

fn is_stable_decay() -> bool {
    // 감쇠율 < 1.0 (× SCALE)
    return decay_rate_scaled() < SCALE
}

// ════════════════════════════════════════════════════════════════════
// 4) 입력 투영 — B: (D_INPUT × D_STATE) = 6 × 12 = 72 파라미터
//    각 스텝의 입력을 상태 공간으로 투영
// ════════════════════════════════════════════════════════════════════

fn input_projection_params() -> i64 {
    return D_INPUT * D_STATE    // 72
}

fn project_input(step: i64) -> i64 {
    // 단순 투영: 입력값 = step+1, 투영 = 입력 × (D_STATE/D_INPUT)
    let x: i64 = step + 1
    return x * (D_STATE / D_INPUT)    // x × 2
}

// ════════════════════════════════════════════════════════════════════
// 5) 순환 상태 업데이트 — 핵심 재귀
//    h_t = a · h_{t-1} + (1-a) · B·x_t
//    초기: h_0 = 0
//    정수 시뮬 (×SCALE): h_t = (a·h_{t-1} + (SCALE-a)·input_t) / SCALE
// ════════════════════════════════════════════════════════════════════

fn recurrent_state_after_n_steps() -> i64 {
    let a: i64 = decay_rate_scaled()    // 916
    let one_minus_a: i64 = SCALE - a    // 84
    let mut h: i64 = 0                  // h_0 = 0
    let mut step: i64 = 0
    while step < N_STEPS {
        let bx: i64 = project_input(step) * SCALE    // 스케일된 입력 투영
        // h = (a·h + (1-a)·Bx) / SCALE
        h = (a * h + one_minus_a * bx) / SCALE
        step = step + 1
    }
    return h
}

fn recurrent_trace() -> i64 {
    // 6 스텝 동안 상태 변화 궤적의 총합
    let a: i64 = decay_rate_scaled()
    let one_minus_a: i64 = SCALE - a
    let mut h: i64 = 0
    let mut trace: i64 = 0
    let mut step: i64 = 0
    while step < N_STEPS {
        let bx: i64 = project_input(step) * SCALE
        h = (a * h + one_minus_a * bx) / SCALE
        trace = trace + h
        step = step + 1
    }
    return trace
}

// ════════════════════════════════════════════════════════════════════
// 6) 게이팅 메커니즘 — 순환 출력 제어
//    g_t = sigmoid(W_g · x_t) — 정수 시그모이드 근사
//    정수 σ(x): SCALE/2 + x·SCALE/(4·max_x) (선형 근사)
//    출력 = g_t · h_t / SCALE
// ════════════════════════════════════════════════════════════════════

fn int_sigmoid(x: i64, max_x: i64) -> i64 {
    // 선형 근사 시그모이드: [0, SCALE] 범위
    // σ(x) ≈ 500 + x × 250 / max_x
    let half: i64 = SCALE / 2            // 500
    let quarter: i64 = SCALE / 4          // 250
    let result: i64 = half + (x * quarter) / max_x
    if result > SCALE { return SCALE }
    if result < 0 { return 0 }
    return result
}

fn gate_params() -> i64 {
    // W_g: (D_INPUT × D_GATE) = 6 × 4 = 24
    return D_INPUT * D_GATE
}

fn gated_output(step: i64, state: i64) -> i64 {
    // 게이팅: g × h / SCALE
    let x: i64 = step + 1
    let g: i64 = int_sigmoid(x, N_CORE)
    return (g * state) / SCALE
}

// ════════════════════════════════════════════════════════════════════
// 7) 메모리 비교 — Transformer vs RecurrentGemma
//    Transformer: O(seq_len × d_model) KV 캐시
//    RecurrentGemma: O(d_state) 고정 (시퀀스 길이 무관)
//    seq_len=216(=6^3) 에서 절감
// ════════════════════════════════════════════════════════════════════

fn transformer_kv_memory(seq_len: i64) -> i64 {
    // 시퀀스 × d_model × 2 (K + V)
    return seq_len * D_STATE * 2
}

fn recurrent_memory() -> i64 {
    // 고정: 상태 차원만
    return D_STATE
}

fn memory_reduction_pct(seq_len: i64) -> i64 {
    let tf_mem: i64 = transformer_kv_memory(seq_len)
    let rec_mem: i64 = recurrent_memory()
    return ((tf_mem - rec_mem) * 100) / tf_mem
}

// ════════════════════════════════════════════════════════════════════
// 8) 다중 헤드 순환 — φ(6)=2 헤드 독립 실행
//    각 헤드: D_STATE/N_HEADS = 6 차원 독립 상태
//    최종 출력 = concat(head_1, head_2)
// ════════════════════════════════════════════════════════════════════

fn state_per_head() -> i64 {
    return D_STATE / N_HEADS    // 12/2 = 6 = N_CORE
}

fn head_params() -> i64 {
    // 헤드당: 입력 투영 + 게이트 + 출력
    let in_p: i64 = D_INPUT * state_per_head()     // 6×6=36
    let gate_p: i64 = D_INPUT * (D_GATE / N_HEADS) // 6×2=12
    return in_p + gate_p
}

fn total_recurrent_params() -> i64 {
    return input_projection_params() + gate_params()    // 72 + 24 = 96
}

// ════════════════════════════════════════════════════════════════════
// 9) 수렴 검증 — 상태가 안정점에 수렴하는지
//    a^N_STEPS < 임계값 (초기 상태 소멸)
//    정상 상태: h_inf = (1-a)·B·x_inf / (1-a) = B·x_inf
// ════════════════════════════════════════════════════════════════════

fn converges_within_n_steps() -> bool {
    // a^6 < 0.7 → 초기 상태 30% 이상 소멸
    let residual: i64 = decay_power(N_STEPS)
    return residual < 700    // 0.7 × 1000
}

fn steady_state_value() -> i64 {
    // 일정 입력 x=6 에 대한 정상 상태
    // h_inf = B·x / 1 (감쇠가 (1-a)로 정확히 상쇄)
    // 정수: (1-a)·Bx / (1-a) = Bx
    let x: i64 = N_CORE
    return project_input(x - 1)    // 6의 투영 = 12
}

fn state_monotonic_increase() -> bool {
    // 0부터 시작해서 상태가 단조 증가하는지
    let a: i64 = decay_rate_scaled()
    let one_minus_a: i64 = SCALE - a
    let mut h: i64 = 0
    let mut prev_h: i64 = 0 - 1    // -1 로 초기화 (첫 스텝 항상 통과)
    let mut monotonic: bool = true
    let mut step: i64 = 0
    while step < N_STEPS {
        let bx: i64 = project_input(step) * SCALE
        h = (a * h + one_minus_a * bx) / SCALE
        if h < prev_h { monotonic = false }
        prev_h = h
        step = step + 1
    }
    return monotonic
}

// ════════════════════════════════════════════════════════════════════
// 10) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ RecurrentGemma × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 상태 차원 = σ(6) = 12
    let g2: bool = D_STATE == sig
    println("G2 상태=σ=12                : " + g2)

    // G3: 게이트 차원 = τ(6) = 4
    let g3: bool = D_GATE == t
    println("G3 게이트=τ=4               : " + g3)

    // G4: 순환 헤드 = φ(6) = 2
    let g4: bool = N_HEADS == ph
    println("G4 헤드=φ=2                 : " + g4)

    // G5: 안정 감쇠 (|a| < 1)
    let g5: bool = is_stable_decay()
    println("G5 감쇠 안정                : " + g5)

    // G6: 6스텝 내 수렴 (잔여 < 70%)
    let g6: bool = converges_within_n_steps()
    let residual: i64 = decay_power(N_STEPS)
    println("G6 수렴 잔여=" + residual + "/1000     : " + g6)

    // G7: 상태 단조 증가
    let g7: bool = state_monotonic_increase()
    println("G7 상태 단조증가             : " + g7)

    // G8: 메모리 절감 > 99% (seq=216=6^3)
    let seq_long: i64 = N_CORE * N_CORE * N_CORE    // 216
    let mem_red: i64 = memory_reduction_pct(seq_long)
    let g8: bool = mem_red > 99
    println("G8 메모리절감=" + mem_red + "% (seq=216) : " + g8)

    // G9: 헤드당 상태 = n = 6
    let sph: i64 = state_per_head()
    let g9: bool = sph == N_CORE
    println("G9 헤드당상태=" + sph + "=n           : " + g9)

    // G10: 파라미터 수 < Transformer 동급
    let total_p: i64 = total_recurrent_params()
    let tf_equiv: i64 = D_STATE * D_STATE * 2    // 288 (QKV 없이 KV만)
    let g10: bool = total_p < tf_equiv
    println("G10 파라미터=" + total_p + "<" + tf_equiv + "      : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    let final_h: i64 = recurrent_state_after_n_steps()
    let trace: i64 = recurrent_trace()
    println("6스텝 최종상태: " + final_h + " (×1000)")
    println("상태 궤적합: " + trace)
    println("감쇠율: " + decay_rate_scaled() + "/1000 = (σ-1)/σ")
    println("a^6 잔여: " + residual + "/1000")
    println("메모리: " + recurrent_memory() + " vs " + transformer_kv_memory(seq_long) + " (seq=216)")
    println("파라미터: " + total_p + " (투영 " + input_projection_params() + " + 게이트 " + gate_params() + ")")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("RECURRENT-GEMMA OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("RECURRENT-GEMMA PARTIAL: 게이트 일부 위반")
    }
}
