// compress/mae_masking.hexa — MAE Masking x n=6 정식 본문
//
// 원본 경로: techniques/compress/mae_masking.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: He 외 2022, Masked Autoencoders Are Scalable Vision Learners
//            입력 패치의 75% 무작위 마스킹 → 인코더는 25%만 처리
//            디코더가 마스크된 패치 복원 → 자기지도 사전학습
// n=6 정렬:
//   - 패치 그리드   = 6 × 6 = 36 패치       -> n^2
//   - 마스킹 비율   = 3/4 = 75%             -> (σ-τ+1)/σ 근사
//   - 가시 패치     = 36/4 = 9              -> 36 × 25%
//   - 마스크 패치   = 27                     -> 36 × 75%
//   - 인코더 차원   = σ(6) = 12             -> 약수합
//   - 디코더 차원   = τ(6) = 4              -> 경량 디코더
//   - 패치 크기     = φ(6) = 2 × 2          -> 오일러 기반
//
// 실행: hexa run techniques/compress/mae_masking.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) MAE 스펙 (n=6 정렬)
//    패치 분할: 이미지 → 6×6 그리드 → 36 패치
//    마스킹: 75% 무작위 마스크, 25% 가시
//    인코더: 가시 패치만 처리 (9개)
//    디코더: 전체 패치 복원 (36개)
// ════════════════════════════════════════════════════════════════════

const N_CORE:        i64 = 6
const GRID_SIZE:     i64 = 6     // n = 그리드 한 변
const TOTAL_PATCHES: i64 = 36    // n^2 = 전체 패치
const MASK_RATIO_NUM:   i64 = 3  // 마스킹 비율 분자
const MASK_RATIO_DEN:   i64 = 4  // 마스킹 비율 분모 (3/4=75%)
const D_ENCODER:     i64 = 12    // σ(6) = 인코더 차원
const D_DECODER:     i64 = 4     // τ(6) = 디코더 차원
const PATCH_SIDE:    i64 = 2     // φ(6) = 패치 한 변

// ════════════════════════════════════════════════════════════════════
// 3) 패치 분할 계산
//    이미지 해상도 = 6 × PATCH_SIDE = 12 = σ(6) 픽셀
//    총 패치 = (12/2)^2 = 6^2 = 36
// ════════════════════════════════════════════════════════════════════

fn image_resolution() -> i64 {
    return GRID_SIZE * PATCH_SIDE    // 6 × 2 = 12 = σ(6)
}

fn total_patch_count() -> i64 {
    return GRID_SIZE * GRID_SIZE    // 36
}

fn patch_pixels() -> i64 {
    return PATCH_SIDE * PATCH_SIDE    // 4 = τ(6)
}

// ════════════════════════════════════════════════════════════════════
// 4) 마스킹 패턴 — 75% 마스크 / 25% 가시
//    가시 패치 수 = 36 × 1/4 = 9
//    마스크 패치 수 = 36 × 3/4 = 27
//    연산 절감 = 1 - 9/36 = 75% (인코더)
// ════════════════════════════════════════════════════════════════════

fn visible_patches() -> i64 {
    return (TOTAL_PATCHES * (MASK_RATIO_DEN - MASK_RATIO_NUM)) / MASK_RATIO_DEN
}

fn masked_patches() -> i64 {
    return (TOTAL_PATCHES * MASK_RATIO_NUM) / MASK_RATIO_DEN
}

fn encoder_flop_reduction_pct() -> i64 {
    // 인코더는 가시 패치만 처리: 절감 = 75%
    let vis: i64 = visible_patches()
    return ((TOTAL_PATCHES - vis) * 100) / TOTAL_PATCHES
}

// ════════════════════════════════════════════════════════════════════
// 5) 마스크 생성기 — 결정적 패턴 (n=6 기반)
//    6의 약수 {1,2,3,6} 기반 주기적 마스크
//    위치 i: i%4 < 3 이면 마스크 (75% 비율 보장)
// ════════════════════════════════════════════════════════════════════

fn is_masked(patch_idx: i64) -> bool {
    // 4주기 패턴: 0,1,2 마스크 / 3 가시 → 75% 마스킹
    return (patch_idx % MASK_RATIO_DEN) < MASK_RATIO_NUM
}

fn count_masked_in_row(row: i64) -> i64 {
    // 한 행(6패치)에서 마스크된 수
    let mut count: i64 = 0
    let mut col: i64 = 0
    while col < GRID_SIZE {
        let idx: i64 = row * GRID_SIZE + col
        if is_masked(idx) { count = count + 1 }
        col = col + 1
    }
    return count
}

fn verify_mask_ratio() -> bool {
    // 전체 마스크 비율 검증: 정확히 27/36
    let mut total_masked: i64 = 0
    let mut i: i64 = 0
    while i < TOTAL_PATCHES {
        if is_masked(i) { total_masked = total_masked + 1 }
        i = i + 1
    }
    return total_masked == masked_patches()
}

// ════════════════════════════════════════════════════════════════════
// 6) 인코더 연산량 — 가시 패치만 처리
//    표준 ViT: 36 패치 × O(d^2) = 36 × 144
//    MAE 인코더: 9 패치 × O(d^2) = 9 × 144
//    셀프어텐션: O(vis^2 × d) vs O(total^2 × d)
// ════════════════════════════════════════════════════════════════════

fn encoder_linear_flops() -> i64 {
    let vis: i64 = visible_patches()    // 9
    return vis * D_ENCODER * D_ENCODER    // 9 × 144 = 1296
}

fn standard_linear_flops() -> i64 {
    return TOTAL_PATCHES * D_ENCODER * D_ENCODER    // 36 × 144 = 5184
}

fn encoder_attn_flops() -> i64 {
    let vis: i64 = visible_patches()
    return vis * vis * D_ENCODER    // 9 × 9 × 12 = 972
}

fn standard_attn_flops() -> i64 {
    return TOTAL_PATCHES * TOTAL_PATCHES * D_ENCODER    // 36 × 36 × 12 = 15552
}

// ════════════════════════════════════════════════════════════════════
// 7) 디코더 — 전체 토큰 복원 (경량)
//    디코더 입력: 9 가시 토큰 + 27 마스크 토큰 = 36
//    디코더 차원: τ(6)=4 (인코더의 1/3)
//    복원 대상: 마스크된 27 패치의 픽셀값
// ════════════════════════════════════════════════════════════════════

fn decoder_flops() -> i64 {
    // 전체 36 토큰 × 디코더 차원^2
    return TOTAL_PATCHES * D_DECODER * D_DECODER    // 36 × 16 = 576
}

fn decoder_ratio_pct() -> i64 {
    // 디코더/인코더 연산량 비율
    let enc: i64 = encoder_linear_flops()
    let dec: i64 = decoder_flops()
    return (dec * 100) / enc
}

// ════════════════════════════════════════════════════════════════════
// 8) 복원 품질 — 패치별 MSE 시뮬 (정수)
//    원본: 패치값 = patch_idx + 1
//    복원: 평균값 근사 (인접 가시 패치 평균)
//    MSE = Σ(원본-복원)^2 / N_masked
// ════════════════════════════════════════════════════════════════════

fn patch_value(idx: i64) -> i64 {
    return idx + 1
}

fn nearest_visible_value(idx: i64) -> i64 {
    // 가장 가까운 가시 패치의 값으로 복원
    // 가시 패치: idx%4 == 3 → 값 = idx - (idx%4) + 3 + 1
    let base: i64 = idx - (idx % MASK_RATIO_DEN) + MASK_RATIO_NUM
    return base + 1
}

fn reconstruction_mse_sum() -> i64 {
    // 마스크 패치들의 복원 오차 제곱합
    let mut mse_sum: i64 = 0
    let mut i: i64 = 0
    while i < TOTAL_PATCHES {
        if is_masked(i) {
            let orig: i64 = patch_value(i)
            let recon: i64 = nearest_visible_value(i)
            let diff: i64 = orig - recon
            mse_sum = mse_sum + diff * diff
        }
        i = i + 1
    }
    return mse_sum
}

// ════════════════════════════════════════════════════════════════════
// 9) 위치 임베딩 — 6×6 그리드 좌표
//    2D 위치: (row, col) = (i/6, i%6)
//    위치 차원 = φ(6) = 2 (행, 열)
//    마스크 토큰도 위치 임베딩 보유 (디코더 입력)
// ════════════════════════════════════════════════════════════════════

fn patch_row(idx: i64) -> i64 {
    return idx / GRID_SIZE
}

fn patch_col(idx: i64) -> i64 {
    return idx % GRID_SIZE
}

fn position_dim() -> i64 {
    // 2D 위치: 행 + 열 = φ(6) 차원
    return phi(N_CORE)
}

fn grid_center_distance(idx: i64) -> i64 {
    // 그리드 중심(2.5,2.5)으로부터 맨해튼 거리 (정수×2 스케일)
    let r: i64 = patch_row(idx) * 2 + 1    // 0→1, 1→3, ..., 5→11
    let c: i64 = patch_col(idx) * 2 + 1
    let cr: i64 = 5    // 중심 = 2.5 → ×2 = 5
    let dr: i64 = r - cr
    let dc: i64 = c - cr
    let abs_dr: i64 = dr
    let abs_dc: i64 = dc
    if dr < 0 { return (0 - dr) + (0 - dc) }
    if dc < 0 { return dr + (0 - dc) }
    return dr + dc
}

// ════════════════════════════════════════════════════════════════════
// 10) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ MAE Masking × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 그리드 = 6×6 = 36 패치
    let g2: bool = total_patch_count() == N_CORE * N_CORE
    println("G2 그리드=6×6=36             : " + g2)

    // G3: 해상도 = σ(6) = 12 픽셀
    let res: i64 = image_resolution()
    let g3: bool = res == sig
    println("G3 해상도=σ=12               : " + g3)

    // G4: 패치 픽셀 = τ(6) = 4
    let pp: i64 = patch_pixels()
    let g4: bool = pp == t
    println("G4 패치픽셀=τ=4              : " + g4)

    // G5: 마스킹 비율 = 75%
    let reduction: i64 = encoder_flop_reduction_pct()
    let g5: bool = reduction == 75
    println("G5 마스킹=75%                : " + g5)

    // G6: 가시 패치 = 9
    let vis: i64 = visible_patches()
    let g6: bool = vis == 9
    println("G6 가시패치=9                : " + g6)

    // G7: 마스크 비율 검증 (정확히 27/36)
    let g7: bool = verify_mask_ratio()
    println("G7 마스크비율 정합           : " + g7)

    // G8: 인코더 연산 절감 > 70%
    let enc_f: i64 = encoder_linear_flops()
    let std_f: i64 = standard_linear_flops()
    let flop_save: i64 = ((std_f - enc_f) * 100) / std_f
    let g8: bool = flop_save == 75
    println("G8 인코더절감=" + flop_save + "%          : " + g8)

    // G9: 디코더 경량 — 인코더 대비 < 50%
    let dec_r: i64 = decoder_ratio_pct()
    let g9: bool = dec_r < 50
    println("G9 디코더비율=" + dec_r + "% (<50%)   : " + g9)

    // G10: 위치 차원 = φ(6) = 2
    let pd: i64 = position_dim()
    let g10: bool = pd == ph
    println("G10 위치차원=φ=2             : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("패치: " + TOTAL_PATCHES + "개 (" + GRID_SIZE + "×" + GRID_SIZE + "), 패치크기=" + PATCH_SIDE + "×" + PATCH_SIDE)
    println("마스크: " + masked_patches() + "/" + TOTAL_PATCHES + " (75%)")
    println("인코더 FLOP: " + enc_f + " vs " + std_f + " (" + flop_save + "%절감)")
    println("어텐션: " + encoder_attn_flops() + " vs " + standard_attn_flops())
    println("디코더: " + decoder_flops() + " FLOP (인코더의 " + dec_r + "%)")
    println("MSE 합: " + reconstruction_mse_sum())

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("MAE OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("MAE PARTIAL: 게이트 일부 위반")
    }
}
