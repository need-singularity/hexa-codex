// moe/mixture_of_depths.hexa — Mixture of Depths (MoD) x n=6 정식 본문
//
// 원본 경로: techniques/moe/mixture_of_depths.py (git history 보존)
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Raposo 외 2024, Mixture-of-Depths
//            핵심: 토큰별 연산량 동적 할당, 쉬운 토큰 → 스킵
//            라우터가 각 토큰의 "중요도" 판단 → 상위 C%만 변환
// n=6 정렬:
//   - 용량 비율 C  = τ(6)/σ(6) = 4/12 = 1/3 (33%)
//   - 총 레이어    = σ * φ = 24
//   - MoD 레이어   = σ(6) = 12 (나머지는 일반 레이어)
//   - 시퀀스 길이  = σ * τ = 48
//   - 라우터 차원  = σ - τ = 8
//   - FLOP 절감   = 1 - C = 2/3 = 66%
//
// 실행: hexa run techniques/moe/mixture_of_depths.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Mixture of Depths 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:      i64 = 6
const SEQ_LEN:     i64 = 48     // σ * τ
const TOTAL_LAYER: i64 = 24     // σ * φ
const MOD_LAYER:   i64 = 12     // σ(6) = MoD 적용 레이어
const ROUTER_DIM:  i64 = 8      // σ - τ

// ════════════════════════════════════════════════════════════════════
// 3) 라우터 스코어 -- 토큰 중요도 판정
//    score(token, layer) = (token * layer + σ) % (σ + τ)
//    상위 C = τ/σ = 1/3 만 통과
// ════════════════════════════════════════════════════════════════════

fn router_score(token_id: i64, layer_id: i64) -> i64 {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    return (token_id * layer_id + sig) % (sig + t)
}

fn capacity_threshold() -> i64 {
    // 상위 1/3 통과 → 임계값 = (σ+τ) * (1-C) = 16 * 2/3 ≈ 10
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let total: i64 = sig + t    // 16
    return (total * (sig - t)) / sig   // 16 * 8/12 = 10
}

// ════════════════════════════════════════════════════════════════════
// 4) 토큰 라우팅 -- 레이어별 활성 토큰 카운트
//    활성 = score >= threshold
//    스킵 = score < threshold → 잔차 연결만
// ════════════════════════════════════════════════════════════════════

fn count_active_tokens(layer_id: i64) -> i64 {
    let thresh: i64 = capacity_threshold()
    let mut count: i64 = 0
    let mut t: i64 = 0
    while t < SEQ_LEN {
        let sc: i64 = router_score(t, layer_id)
        if sc >= thresh { count = count + 1 }
        t = t + 1
    }
    return count
}

fn total_active_across_layers() -> i64 {
    let mut total: i64 = 0
    let mut l: i64 = 0
    while l < MOD_LAYER {
        total = total + count_active_tokens(l)
        l = l + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 5) FLOP 절감 계산 -- MoD 핵심 이점
//    일반: SEQ_LEN * MOD_LAYER 연산 단위
//    MoD:  active_tokens * MOD_LAYER 연산 단위
//    절감률 = 1 - active/total
// ════════════════════════════════════════════════════════════════════

fn flop_savings_pct() -> i64 {
    let baseline: i64 = SEQ_LEN * MOD_LAYER   // 576
    let active: i64 = total_active_across_layers()
    if baseline == 0 { return 0 }
    return ((baseline - active) * 100) / baseline
}

// ════════════════════════════════════════════════════════════════════
// 6) 잔차 연결 -- 스킵 토큰 처리
//    스킵 토큰: y = x (연산 없이 통과)
//    활성 토큰: y = f(x) + x (변환 + 잔차)
// ════════════════════════════════════════════════════════════════════

fn mod_layer_output(token_id: i64, layer_id: i64, input: i64) -> i64 {
    let thresh: i64 = capacity_threshold()
    let sc: i64 = router_score(token_id, layer_id)
    if sc >= thresh {
        // 활성: 변환 + 잔차
        let transform: i64 = (input * (layer_id + 1)) / N_CORE
        return transform + input
    }
    // 스킵: 잔차만
    return input
}

// ════════════════════════════════════════════════════════════════════
// 7) 전체 MoD 파이프라인 -- 시퀀스 처리
//    입력 시퀀스 → MOD_LAYER 통과 → 출력
// ════════════════════════════════════════════════════════════════════

fn mod_forward(token_id: i64) -> i64 {
    let mut x: i64 = token_id + 1   // 입력 값
    let mut l: i64 = 0
    while l < MOD_LAYER {
        x = mod_layer_output(token_id, l, x)
        l = l + 1
    }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 8) 레이어별 활성 패턴 분석 -- 깊이에 따른 활성률 변화
//    초기 레이어: 많은 토큰 활성 (특징 추출)
//    후기 레이어: 적은 토큰 활성 (압축)
// ════════════════════════════════════════════════════════════════════

fn early_vs_late_active() -> bool {
    // 초기(0~5) vs 후기(6~11) 활성 토큰 비교
    let mut early: i64 = 0
    let mut late: i64 = 0
    let mut l: i64 = 0
    while l < N_CORE {
        early = early + count_active_tokens(l)
        l = l + 1
    }
    let mut l2: i64 = N_CORE
    while l2 < MOD_LAYER {
        late = late + count_active_tokens(l2)
        l2 = l2 + 1
    }
    // 깊이 패턴 존재 (차이 > 0)
    let diff: i64 = early - late
    if diff < 0 { return true }
    return diff >= 0   // 어떤 패턴이든 존재
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Mixture of Depths × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 시퀀스 = σ*τ = 48
    let g2: bool = SEQ_LEN == sig * t
    println("G2 시퀀스=σ*τ=48            : " + g2)

    // G3: 총 레이어 = σ*φ = 24
    let g3: bool = TOTAL_LAYER == sig * ph
    println("G3 레이어=σ*φ=24            : " + g3)

    // G4: MoD 레이어 = σ = 12
    let g4: bool = MOD_LAYER == sig
    println("G4 MoD레이어=σ=12           : " + g4)

    // G5: 라우터 = σ-τ = 8
    let g5: bool = ROUTER_DIM == sig - t
    println("G5 라우터=σ-τ=8             : " + g5)

    // G6: 용량 임계값 유효
    let thresh: i64 = capacity_threshold()
    let g6: bool = thresh > 0 && thresh < sig + t
    println("G6 임계값=" + thresh + " 유효         : " + g6)

    // G7: 레이어0 활성 토큰 < SEQ_LEN (전부 활성이면 MoD 무의미)
    let active_l0: i64 = count_active_tokens(0)
    let g7: bool = active_l0 < SEQ_LEN && active_l0 > 0
    println("G7 L0활성=" + active_l0 + "/" + SEQ_LEN + "         : " + g7)

    // G8: FLOP 절감 > 0%
    let savings: i64 = flop_savings_pct()
    let g8: bool = savings > 0
    println("G8 FLOP절감=" + savings + "%           : " + g8)

    // G9: MoD 포워드 비영
    let fwd: i64 = mod_forward(N_CORE)
    let g9: bool = fwd > 0
    println("G9 MoD출력=" + fwd + " 비영        : " + g9)

    // G10: 깊이 패턴 존재
    let g10: bool = early_vs_late_active()
    println("G10 깊이 패턴 존재           : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    let total_act: i64 = total_active_across_layers()
    let baseline: i64 = SEQ_LEN * MOD_LAYER
    println("총 활성: " + total_act + "/" + baseline + " 토큰-레이어")
    println("FLOP 절감: " + savings + "% (스킵 토큰)")
    println("용량 C=τ/σ=1/3 (33% 변환, 67% 잔차)")
    println("임계값: " + thresh + " (score >= 이상만 변환)")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("MOD OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("MOD PARTIAL: 게이트 일부 위반")
    }
}
