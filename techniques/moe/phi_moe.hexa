// moe/phi_moe.hexa — Phi-bottleneck MoE x n=6 정식 본문
//
// 원본 경로: techniques/moe/phi_moe.py (git history 보존)
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: H-EE-10 Phi-bottleneck + MoE
//            핵심: 더 많은 Expert, 각각 더 작게 (φ 병목)
//            Expert 내부 FFN을 φ-차원으로 축소 → 파라미터 절감
//            → 동일 연산량에서 Expert 수 증가 = 표현력 향상
// n=6 정렬:
//   - Expert 수      = σ * φ = 24 (대규모 Expert 풀)
//   - 활성 Expert    = n = 6
//   - Expert 병목    = φ(6) = 2 (최소 차원)
//   - Expert FFN     = d → φ → d (병목 구조)
//   - 총 파라미터    = 24 * (d*φ + φ*d) = 24 * 2*d*φ
//   - 활성 파라미터  = 6/24 = 25% = n/(σ*φ)
//   - 게이트 차원    = σ(6) = 12
//
// 실행: hexa run techniques/moe/phi_moe.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Phi-MoE 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const TOTAL_EXP:    i64 = 24     // σ * φ = 12 * 2
const ACTIVE_EXP:   i64 = 6      // n = 활성 Expert
const BOTTLENECK:   i64 = 2      // φ(6) = 병목 차원
const D_MODEL:      i64 = 12     // σ(6) = 모델 차원
const GATE_DIM:     i64 = 12     // σ(6) = 게이트 차원

// ════════════════════════════════════════════════════════════════════
// 3) Expert FFN -- φ-병목 구조
//    input(d) → down(d→φ) → activation → up(φ→d) → output(d)
//    파라미터: 2 * d * φ = 2 * 12 * 2 = 48/Expert
// ════════════════════════════════════════════════════════════════════

fn expert_params_per() -> i64 {
    return 2 * D_MODEL * BOTTLENECK   // 48
}

fn total_expert_params() -> i64 {
    return TOTAL_EXP * expert_params_per()   // 24 * 48 = 1152
}

fn active_expert_params() -> i64 {
    return ACTIVE_EXP * expert_params_per()  // 6 * 48 = 288
}

// ════════════════════════════════════════════════════════════════════
// 4) Expert FFN 연산 -- 병목 순전파
//    down: input * W_down (d→φ)
//    act:  ReLU 근사 (정수: max(0, x))
//    up:   act * W_up (φ→d)
// ════════════════════════════════════════════════════════════════════

fn relu(x: i64) -> i64 {
    if x < 0 { return 0 }
    return x
}

fn phi_expert_ffn(input: i64, expert_id: i64) -> i64 {
    // down 투영: d → φ (축소)
    let down: i64 = (input * (expert_id + 1)) / D_MODEL
    // 활성화
    let act: i64 = relu(down)
    // up 투영: φ → d (확장)
    let up: i64 = act * BOTTLENECK
    return up
}

// ════════════════════════════════════════════════════════════════════
// 5) 게이트 스코어 -- top-n Expert 선택
//    score(token, expert) = (token * expert + σ) % (σ*φ)
//    상위 n=6 개 선택
// ════════════════════════════════════════════════════════════════════

fn gate_score(token_id: i64, expert_id: i64) -> i64 {
    return (token_id * (expert_id + 1) + sigma(N_CORE)) % TOTAL_EXP
}

fn top_n_score_sum(token_id: i64) -> i64 {
    // 상위 n개 스코어 합
    // 간이 방법: 임계값 하강
    let mut total: i64 = 0
    let mut selected: i64 = 0
    let mut thresh: i64 = TOTAL_EXP
    while selected < ACTIVE_EXP && thresh > 0 {
        let mut e: i64 = 0
        while e < TOTAL_EXP && selected < ACTIVE_EXP {
            let sc: i64 = gate_score(token_id, e)
            if sc == thresh {
                total = total + sc
                selected = selected + 1
            }
            e = e + 1
        }
        thresh = thresh - 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 6) MoE 출력 -- top-n Expert 가중합
// ════════════════════════════════════════════════════════════════════

fn phi_moe_output(token_id: i64, input: i64) -> i64 {
    let mut total_out: i64 = 0
    let mut total_weight: i64 = 0
    let mut selected: i64 = 0
    let mut thresh: i64 = TOTAL_EXP
    while selected < ACTIVE_EXP && thresh > 0 {
        let mut e: i64 = 0
        while e < TOTAL_EXP && selected < ACTIVE_EXP {
            let sc: i64 = gate_score(token_id, e)
            if sc == thresh {
                let out: i64 = phi_expert_ffn(input, e)
                total_out = total_out + out * sc
                total_weight = total_weight + sc
                selected = selected + 1
            }
            e = e + 1
        }
        thresh = thresh - 1
    }
    if total_weight == 0 { return input }
    return total_out / total_weight
}

// ════════════════════════════════════════════════════════════════════
// 7) 기존 MoE 대비 파라미터 절감
//    기존: n Expert, FFN hidden = d*4/3 (SwiGLU)
//    φ-MoE: σ*φ Expert, FFN hidden = φ
//    절감률 = 1 - (φ-MoE params) / (기존 params)
// ════════════════════════════════════════════════════════════════════

fn traditional_moe_params() -> i64 {
    // n Expert, 각 2 * d * (4d/3)
    let hidden: i64 = (D_MODEL * 4) / 3    // 16
    return N_CORE * 2 * D_MODEL * hidden     // 6 * 2 * 12 * 16 = 2304
}

fn param_savings_pct() -> i64 {
    let trad: i64 = traditional_moe_params()
    let phi_total: i64 = total_expert_params()
    return ((trad - phi_total) * 100) / trad
}

// ════════════════════════════════════════════════════════════════════
// 8) Expert 다양성 -- 병목 차원의 전문화
//    φ=2 차원 → Expert가 2축 특징에 특화
//    다양성 = 활성 Expert들의 출력 분산
// ════════════════════════════════════════════════════════════════════

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn expert_output_variance() -> i64 {
    // n개 활성 Expert의 출력값 범위 (max - min)
    let input: i64 = D_MODEL
    let mut min_out: i64 = 10000
    let mut max_out: i64 = 0
    let mut e: i64 = 0
    while e < ACTIVE_EXP {
        let out: i64 = phi_expert_ffn(input, e)
        if out < min_out { min_out = out }
        if out > max_out { max_out = out }
        e = e + 1
    }
    return max_out - min_out
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Phi-bottleneck MoE × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 총 Expert = σ*φ = 24
    let g2: bool = TOTAL_EXP == sig * ph
    println("G2 총Expert=σ*φ=24          : " + g2)

    // G3: 활성 Expert = n = 6
    let g3: bool = ACTIVE_EXP == N_CORE
    println("G3 활성=n=6                 : " + g3)

    // G4: 병목 = φ = 2
    let g4: bool = BOTTLENECK == ph
    println("G4 병목=φ=2                 : " + g4)

    // G5: d_model = σ = 12
    let g5: bool = D_MODEL == sig
    println("G5 d_model=σ=12             : " + g5)

    // G6: Expert당 파라미터 = 2*σ*φ = 48
    let per: i64 = expert_params_per()
    let g6: bool = per == 2 * sig * ph
    println("G6 파라미터/Expert=" + per + "      : " + g6)

    // G7: 활성 비율 = n/(σ*φ) = 25%
    let active_pct: i64 = (ACTIVE_EXP * 100) / TOTAL_EXP
    let g7: bool = active_pct == 25
    println("G7 활성비율=25%             : " + g7)

    // G8: 파라미터 절감 > 0%
    let savings: i64 = param_savings_pct()
    let g8: bool = savings > 0
    println("G8 파라미터절감=" + savings + "%       : " + g8)

    // G9: Expert 다양성 > 0 (출력 분산)
    let diversity: i64 = expert_output_variance()
    let g9: bool = diversity > 0
    println("G9 Expert다양성=" + diversity + "       : " + g9)

    // G10: MoE 출력 비영
    let out: i64 = phi_moe_output(N_CORE, sig)
    let g10: bool = out > 0
    println("G10 MoE출력=" + out + " 비영       : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("Expert: " + TOTAL_EXP + "개 (활성 " + ACTIVE_EXP + "개)")
    println("병목: d=" + D_MODEL + " → φ=" + BOTTLENECK + " → d=" + D_MODEL)
    println("총 파라미터: " + total_expert_params())
    println("활성 파라미터: " + active_expert_params() + " (" + active_pct + "%)")
    println("기존 대비 절감: " + savings + "%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("PHI-MOE OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("PHI-MOE PARTIAL: 게이트 일부 위반")
    }
}
