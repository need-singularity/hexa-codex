// moe/moco_queue.hexa — MoCo Memory Queue x n=6 정식 본문
//
// 원본 경로: techniques/moe/moco_queue.py (git history 보존)
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: He 외 2020, Momentum Contrast (MoCo)
//            핵심: 큐 기반 대조 학습, 모멘텀 인코더 업데이트
//            query/key 쌍 → 큐에 저장 → 대조 손실 계산
// n=6 정렬:
//   - 큐 크기       = σ(6)^2 = 144  (축소 시뮬; 원본 65536)
//   - 배치 크기     = σ * τ = 48
//   - 임베딩 차원   = σ(6) = 12
//   - 모멘텀 m      = (σ-1)/σ = 11/12 ≈ 0.916
//   - 온도 τ_temp   = τ(6)/100 = 0.04 → 정수: 40/1000
//   - 양성 쌍       = φ(6) = 2 (증강 뷰 쌍)
//
// 실행: hexa run techniques/moe/moco_queue.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) MoCo 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:     i64 = 6
const QUEUE_SIZE: i64 = 144    // σ^2
const BATCH_SIZE: i64 = 48     // σ * τ
const EMBED_DIM:  i64 = 12     // σ(6)
const MOMENTUM:   i64 = 916    // (σ-1)/σ * 1000
const TEMP:       i64 = 40     // τ/100 * 1000

// ════════════════════════════════════════════════════════════════════
// 3) 모멘텀 인코더 업데이트 -- EMA
//    key_encoder = m * key_encoder + (1-m) * query_encoder
//    정수화: 밀리 단위 (1000 기준)
// ════════════════════════════════════════════════════════════════════

fn momentum_update(key_param: i64, query_param: i64) -> i64 {
    // new = m * key + (1-m) * query
    let new_val: i64 = (MOMENTUM * key_param + (1000 - MOMENTUM) * query_param) / 1000
    return new_val
}

fn momentum_update_n_steps(key_init: i64, query_val: i64, steps: i64) -> i64 {
    let mut k: i64 = key_init
    let mut s: i64 = 0
    while s < steps {
        k = momentum_update(k, query_val)
        s = s + 1
    }
    return k
}

// ════════════════════════════════════════════════════════════════════
// 4) 큐 관리 -- FIFO 원형 버퍼
//    새 키 삽입 → 가장 오래된 키 제거
//    큐 포화 = σ^2 = 144 항목
// ════════════════════════════════════════════════════════════════════

fn queue_enqueue_dequeue(queue_len: i64, new_batch: i64) -> i64 {
    // 큐에 새 배치 추가 후 크기 조정
    let new_len: i64 = queue_len + new_batch
    if new_len > QUEUE_SIZE { return QUEUE_SIZE }
    return new_len
}

fn queue_fill_steps() -> i64 {
    // 큐 완전 포화까지 필요한 배치 수
    // 144 / 48 = 3 배치
    return QUEUE_SIZE / BATCH_SIZE
}

// ════════════════════════════════════════════════════════════════════
// 5) 대조 손실 -- InfoNCE
//    L = -log(exp(q·k+/τ) / Σ exp(q·ki/τ))
//    정수화: 유사도 스코어 직접 계산
// ════════════════════════════════════════════════════════════════════

fn dot_product(q_id: i64, k_id: i64) -> i64 {
    // 간이 유사도: (q * k + σ) % (σ * τ)
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    return (q_id * k_id + sig) % (sig * t)
}

fn positive_score(q_id: i64) -> i64 {
    // 양성 쌍: 같은 이미지의 다른 증강 → k+ = q
    let raw: i64 = dot_product(q_id, q_id)
    return (raw * 1000) / TEMP   // 온도 스케일
}

fn contrastive_loss_approx(q_id: i64) -> i64 {
    // InfoNCE 근사: positive - mean(negatives)
    let pos: i64 = positive_score(q_id)
    // 음성 키: 큐의 일부 (σ개 샘플링)
    let mut neg_sum: i64 = 0
    let mut k: i64 = 0
    while k < sigma(N_CORE) {
        let neg: i64 = dot_product(q_id, k + BATCH_SIZE)
        neg_sum = neg_sum + (neg * 1000) / TEMP
        k = k + 1
    }
    let neg_mean: i64 = neg_sum / sigma(N_CORE)
    return pos - neg_mean   // 양수일수록 좋음
}

// ════════════════════════════════════════════════════════════════════
// 6) 큐 다양성 검증 -- 큐 내 고유 패턴 수
//    이상적: QUEUE_SIZE 개 전부 고유
//    해시 충돌률 = 1 - unique/total
// ════════════════════════════════════════════════════════════════════

fn queue_diversity(sample_size: i64) -> i64 {
    // 해시 분포 시뮬: σ 버킷에 sample_size 항목 분배
    // 버킷별 카운트 (간이: 6버킷)
    let mut b0: i64 = 0
    let mut b1: i64 = 0
    let mut b2: i64 = 0
    let mut b3: i64 = 0
    let mut b4: i64 = 0
    let mut b5: i64 = 0
    let mut i: i64 = 0
    while i < sample_size {
        let bucket: i64 = (i * 7 + 3) % N_CORE
        if bucket == 0 { b0 = b0 + 1 }
        if bucket == 1 { b1 = b1 + 1 }
        if bucket == 2 { b2 = b2 + 1 }
        if bucket == 3 { b3 = b3 + 1 }
        if bucket == 4 { b4 = b4 + 1 }
        if bucket == 5 { b5 = b5 + 1 }
        i = i + 1
    }
    // 비어있지 않은 버킷 수
    let mut filled: i64 = 0
    if b0 > 0 { filled = filled + 1 }
    if b1 > 0 { filled = filled + 1 }
    if b2 > 0 { filled = filled + 1 }
    if b3 > 0 { filled = filled + 1 }
    if b4 > 0 { filled = filled + 1 }
    if b5 > 0 { filled = filled + 1 }
    return (filled * 100) / N_CORE
}

// ════════════════════════════════════════════════════════════════════
// 7) 모멘텀 수렴 검증 -- EMA 안정성
//    충분한 스텝 후 key ≈ query
//    수렴 기준: |key - query| < σ
// ════════════════════════════════════════════════════════════════════

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn momentum_converges(query_val: i64, steps: i64) -> bool {
    let key_init: i64 = 0
    let final_key: i64 = momentum_update_n_steps(key_init, query_val, steps)
    let diff: i64 = abs_val(final_key - query_val)
    return diff < sigma(N_CORE)
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ MoCo Memory Queue × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 큐 = σ^2 = 144
    let g2: bool = QUEUE_SIZE == sig * sig
    println("G2 큐=σ²=144               : " + g2)

    // G3: 배치 = σ*τ = 48
    let g3: bool = BATCH_SIZE == sig * t
    println("G3 배치=σ*τ=48              : " + g3)

    // G4: 임베딩 = σ = 12
    let g4: bool = EMBED_DIM == sig
    println("G4 임베딩=σ=12              : " + g4)

    // G5: 모멘텀 = 916/1000 = (σ-1)/σ
    let expected_m: i64 = ((sig - 1) * 1000) / sig
    let g5: bool = MOMENTUM == expected_m
    println("G5 모멘텀=(σ-1)/σ=916‰      : " + g5)

    // G6: 온도 = τ * 10 = 40/1000
    let g6: bool = TEMP == t * 10
    println("G6 온도=τ*10=40‰            : " + g6)

    // G7: 큐 포화 = 3배치 = σ/τ 배치
    let fill: i64 = queue_fill_steps()
    let g7: bool = fill == sig / t
    println("G7 포화=" + fill + "배치=σ/τ        : " + g7)

    // G8: 대조 손실 양수 (양성 > 음성 평균)
    let loss: i64 = contrastive_loss_approx(N_CORE)
    let g8: bool = loss > 0
    println("G8 대조손실=" + loss + " 양수     : " + g8)

    // G9: 모멘텀 수렴 (σ 스텝 후)
    let g9: bool = momentum_converges(100, sig * sig)
    println("G9 모멘텀수렴(144스텝)       : " + g9)

    // G10: 큐 다양성 100% (전 버킷 활성)
    let div: i64 = queue_diversity(QUEUE_SIZE)
    let g10: bool = div == 100
    println("G10 큐다양성=" + div + "%          : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("큐: " + QUEUE_SIZE + " 키 (FIFO)")
    println("배치당 갱신: " + BATCH_SIZE + " 키 enqueue")
    println("모멘텀: " + MOMENTUM + "‰ (느린 업데이트)")
    println("온도: " + TEMP + "‰ (날카로운 분포)")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("MOCO OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("MOCO PARTIAL: 게이트 일부 위반")
    }
}
