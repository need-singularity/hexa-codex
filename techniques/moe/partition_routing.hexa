// moe/partition_routing.hexa — Partition Routing MoE x n=6 정식 본문
//
// 원본 경로: techniques/moe/partition_routing.py (git history 보존)
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Partition Routing -- 입력 공간을 분할하여 Expert에 할당
//            핵심: 해시 기반 파티션 → Expert 맵핑 (학습 불필요)
//            Voronoi 분할의 이산화 → 결정적 라우팅
// n=6 정렬:
//   - 파티션 수     = σ(6) = 12 (입력 공간 분할)
//   - Expert 수     = n = 6 (파티션 2:1 매핑)
//   - 파티션/Expert = σ/n = 2 = φ(6)
//   - 해시 차원     = τ(6) = 4
//   - 배치 크기     = σ * τ = 48
//   - 충돌 허용     = σ - τ = 8 (버퍼)
//
// 실행: hexa run techniques/moe/partition_routing.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Partition Routing 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const N_PARTITIONS: i64 = 12    // σ(6) = 파티션 수
const N_EXPERTS:    i64 = 6     // n = Expert 수
const HASH_DIM:     i64 = 4     // τ(6) = 해시 차원
const BATCH_SIZE:   i64 = 48    // σ * τ
const BUFFER:       i64 = 8     // σ - τ = 충돌 버퍼

// ════════════════════════════════════════════════════════════════════
// 3) 해시 함수 -- 입력 → 파티션 매핑
//    다차원 해시: τ개 독립 해시 조합
//    partition = (h1 * h2 * h3 * h4) % σ
// ════════════════════════════════════════════════════════════════════

fn hash_dim(token_id: i64, dim: i64) -> i64 {
    // 차원별 해시: (token * prime[dim] + salt) % σ
    let mut prime: i64 = 7
    if dim == 1 { prime = 11 }
    if dim == 2 { prime = 13 }
    if dim == 3 { prime = 17 }
    return (token_id * prime + N_CORE) % (sigma(N_CORE) + 1)
}

fn partition_hash(token_id: i64) -> i64 {
    // τ-차원 해시 결합 → 파티션 인덱스
    let mut combined: i64 = 0
    let mut d: i64 = 0
    while d < HASH_DIM {
        combined = combined + hash_dim(token_id, d)
        d = d + 1
    }
    return combined % N_PARTITIONS
}

// ════════════════════════════════════════════════════════════════════
// 4) 파티션 → Expert 매핑
//    σ 파티션 → n Expert (2:1 매핑)
//    expert = partition / φ (φ=2 파티션/Expert)
// ════════════════════════════════════════════════════════════════════

fn partition_to_expert(partition_id: i64) -> i64 {
    let parts_per_expert: i64 = phi(N_CORE)   // 2
    return partition_id / parts_per_expert
}

fn route_token(token_id: i64) -> i64 {
    let part: i64 = partition_hash(token_id)
    return partition_to_expert(part)
}

// ════════════════════════════════════════════════════════════════════
// 5) 로드밸런스 -- Expert별 토큰 분포
//    이상적: 각 Expert = BATCH_SIZE / N_EXPERTS = 8
// ════════════════════════════════════════════════════════════════════

fn expert_load(expert_id: i64) -> i64 {
    let mut count: i64 = 0
    let mut t: i64 = 0
    while t < BATCH_SIZE {
        if route_token(t) == expert_id { count = count + 1 }
        t = t + 1
    }
    return count
}

fn max_load_deviation() -> i64 {
    let ideal: i64 = BATCH_SIZE / N_EXPERTS   // 8
    let mut max_dev: i64 = 0
    let mut e: i64 = 0
    while e < N_EXPERTS {
        let load: i64 = expert_load(e)
        let dev: i64 = load - ideal
        let abs_dev: i64 = dev
        if abs_dev < 0 {
            if (0 - abs_dev) > max_dev { max_dev = 0 - abs_dev }
        } else {
            if abs_dev > max_dev { max_dev = abs_dev }
        }
        e = e + 1
    }
    return max_dev
}

// ════════════════════════════════════════════════════════════════════
// 6) 파티션 충돌 분석 -- 해시 충돌률
//    충돌: 다른 토큰이 같은 파티션에 할당
//    σ 파티션에 48 토큰 → 평균 4/파티션
// ════════════════════════════════════════════════════════════════════

fn partition_occupancy(part_id: i64) -> i64 {
    let mut count: i64 = 0
    let mut t: i64 = 0
    while t < BATCH_SIZE {
        if partition_hash(t) == part_id { count = count + 1 }
        t = t + 1
    }
    return count
}

fn max_partition_occupancy() -> i64 {
    let mut max_occ: i64 = 0
    let mut p: i64 = 0
    while p < N_PARTITIONS {
        let occ: i64 = partition_occupancy(p)
        if occ > max_occ { max_occ = occ }
        p = p + 1
    }
    return max_occ
}

fn empty_partitions() -> i64 {
    let mut count: i64 = 0
    let mut p: i64 = 0
    while p < N_PARTITIONS {
        if partition_occupancy(p) == 0 { count = count + 1 }
        p = p + 1
    }
    return count
}

// ════════════════════════════════════════════════════════════════════
// 7) Voronoi 거리 -- 파티션 중심까지 거리
//    각 파티션의 "중심" = 파티션 인덱스 * (σ/n)
//    토큰-중심 거리가 작을수록 라우팅 정확
// ════════════════════════════════════════════════════════════════════

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn avg_distance_to_center() -> i64 {
    // 배치 내 모든 토큰의 파티션 중심 거리 평균
    let mut total_dist: i64 = 0
    let mut t: i64 = 0
    while t < BATCH_SIZE {
        let part: i64 = partition_hash(t)
        let center: i64 = part * (sigma(N_CORE) / N_CORE)  // 파티션 중심
        let dist: i64 = abs_val(t - center)
        total_dist = total_dist + dist
        t = t + 1
    }
    return total_dist / BATCH_SIZE
}

// ════════════════════════════════════════════════════════════════════
// 8) 결정적 라우팅 검증 -- 동일 입력 → 동일 Expert
//    해시 기반이므로 100% 결정적
// ════════════════════════════════════════════════════════════════════

fn deterministic_check() -> bool {
    let mut ok: bool = true
    let mut t: i64 = 0
    while t < BATCH_SIZE {
        let r1: i64 = route_token(t)
        let r2: i64 = route_token(t)
        if r1 != r2 { ok = false }
        t = t + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Partition Routing MoE × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 파티션 = σ = 12
    let g2: bool = N_PARTITIONS == sig
    println("G2 파티션=σ=12              : " + g2)

    // G3: Expert = n = 6
    let g3: bool = N_EXPERTS == N_CORE
    println("G3 Expert=n=6               : " + g3)

    // G4: 파티션/Expert = φ = 2
    let parts_per: i64 = N_PARTITIONS / N_EXPERTS
    let g4: bool = parts_per == ph
    println("G4 파티션/Expert=φ=2        : " + g4)

    // G5: 해시 차원 = τ = 4
    let g5: bool = HASH_DIM == t
    println("G5 해시차원=τ=4             : " + g5)

    // G6: 결정적 라우팅 100%
    let g6: bool = deterministic_check()
    println("G6 결정적=100%              : " + g6)

    // G7: 최대 로드 편차 < 버퍼
    let dev: i64 = max_load_deviation()
    let g7: bool = dev <= BUFFER
    println("G7 편차=" + dev + "≤버퍼=" + BUFFER + "       : " + g7)

    // G8: 빈 파티션 < σ/2
    let empty: i64 = empty_partitions()
    let g8: bool = empty < sig / 2
    println("G8 빈파티션=" + empty + "<" + (sig / 2) + "       : " + g8)

    // G9: 최대 파티션 점유 < σ
    let max_occ: i64 = max_partition_occupancy()
    let g9: bool = max_occ < sig
    println("G9 최대점유=" + max_occ + "<σ         : " + g9)

    // G10: 평균 거리 유한
    let avg_d: i64 = avg_distance_to_center()
    let g10: bool = avg_d > 0
    println("G10 평균거리=" + avg_d + " 양수      : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("파티션: " + N_PARTITIONS + " → Expert " + N_EXPERTS + " (2:1)")
    println("해시: " + HASH_DIM + "차원 결합 (결정적)")
    println("로드편차: " + dev + " (이상=0)")
    println("게이트 파라미터: 0 (해시 기반)")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("PARTITION OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("PARTITION PARTIAL: 게이트 일부 위반")
    }
}
