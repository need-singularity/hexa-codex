// moe/gshard_switch.hexa — GShard / Switch Transformer x n=6 정식 본문
//
// 원본 경로: techniques/moe/gshard_switch.py (git history 보존)
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Fedus 외 2022, Switch Transformer + Lepikhin 외 2021, GShard
//            핵심: top-1 라우팅, 용량 인수, 보조 손실 밸런싱
//            Switch = top-1 단순화, GShard = top-2 원조
// n=6 정렬:
//   - Expert 수       = σ(6) = 12
//   - Switch top-k    = 1 (단순)
//   - GShard top-k    = φ(6) = 2
//   - 용량 인수       = τ(6)/φ(6) = 2.0
//   - 버퍼 크기       = tokens/experts * capacity_factor
//   - 보조 손실 α     = 1/σ = 1/12
//   - 드롭 임계       = σ/n = 2 (오버플로 허용 배수)
//
// 실행: hexa run techniques/moe/gshard_switch.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) GShard/Switch 스펙 (n=6 정렬)
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const N_EXPERTS:    i64 = 12     // σ(6)
const SWITCH_TOPK:  i64 = 1      // Switch: top-1
const GSHARD_TOPK:  i64 = 2      // GShard: top-2 = φ(6)
const CAP_FACTOR:   i64 = 2      // τ/φ = 4/2 = 용량 인수 (정수)
const BATCH_TOKENS: i64 = 48     // σ * τ = 배치 토큰 수
const AUX_ALPHA:    i64 = 83     // 1000/σ ≈ 83 (밀리 단위)

// ════════════════════════════════════════════════════════════════════
// 3) 라우팅 스코어 -- 게이트 함수
//    Switch: argmax(score) → top-1
//    GShard: top-2(score) → 두 Expert
// ════════════════════════════════════════════════════════════════════

fn gate_score(token_id: i64, expert_id: i64) -> i64 {
    return (token_id * (expert_id + 3) + N_CORE) % (sigma(N_CORE) + 1)
}

fn switch_route(token_id: i64) -> i64 {
    // top-1: 최고 스코어 Expert 인덱스 반환
    let mut best_sc: i64 = 0
    let mut best_id: i64 = 0
    let mut e: i64 = 0
    while e < N_EXPERTS {
        let sc: i64 = gate_score(token_id, e)
        if sc > best_sc {
            best_sc = sc
            best_id = e
        }
        e = e + 1
    }
    return best_id
}

fn gshard_route_pair(token_id: i64) -> i64 {
    // top-2: 상위 두 Expert 인덱스 합 반환
    let mut b1_sc: i64 = 0
    let mut b1_id: i64 = 0
    let mut b2_sc: i64 = 0
    let mut b2_id: i64 = 0
    let mut e: i64 = 0
    while e < N_EXPERTS {
        let sc: i64 = gate_score(token_id, e)
        if sc > b1_sc {
            b2_sc = b1_sc
            b2_id = b1_id
            b1_sc = sc
            b1_id = e
        } else {
            if sc > b2_sc {
                b2_sc = sc
                b2_id = e
            }
        }
        e = e + 1
    }
    return b1_id + b2_id
}

// ════════════════════════════════════════════════════════════════════
// 4) 용량 버퍼 -- Expert당 처리 가능 토큰 수
//    capacity = (tokens / experts) * capacity_factor
//    = (48/12) * 2 = 8 = σ - τ
// ════════════════════════════════════════════════════════════════════

fn expert_capacity() -> i64 {
    return (BATCH_TOKENS / N_EXPERTS) * CAP_FACTOR
}

// ════════════════════════════════════════════════════════════════════
// 5) Switch 라우팅 시뮬 -- 배치 전체 처리
//    Expert별 토큰 카운트 + 오버플로 드롭 검사
// ════════════════════════════════════════════════════════════════════

fn switch_simulate() -> i64 {
    // 총 처리 토큰 수 (드롭 제외)
    let cap: i64 = expert_capacity()
    let mut processed: i64 = 0
    let mut dropped: i64 = 0
    // Expert별 카운터 (간이: Expert 0~5만 추적)
    let mut c0: i64 = 0
    let mut c1: i64 = 0
    let mut c2: i64 = 0
    let mut c3: i64 = 0
    let mut c4: i64 = 0
    let mut c5: i64 = 0
    let mut t: i64 = 0
    while t < BATCH_TOKENS {
        let eid: i64 = switch_route(t)
        let mut cur: i64 = 0
        if eid == 0 { cur = c0 }
        if eid == 1 { cur = c1 }
        if eid == 2 { cur = c2 }
        if eid == 3 { cur = c3 }
        if eid == 4 { cur = c4 }
        if eid == 5 { cur = c5 }
        if cur < cap {
            processed = processed + 1
            if eid == 0 { c0 = c0 + 1 }
            if eid == 1 { c1 = c1 + 1 }
            if eid == 2 { c2 = c2 + 1 }
            if eid == 3 { c3 = c3 + 1 }
            if eid == 4 { c4 = c4 + 1 }
            if eid == 5 { c5 = c5 + 1 }
        } else {
            dropped = dropped + 1
        }
        t = t + 1
    }
    return processed
}

// ════════════════════════════════════════════════════════════════════
// 6) 보조 손실 -- 로드밸런스 유도
//    L_aux = α * N * Σ(f_i * P_i)
//    f_i = Expert i에 배분된 토큰 비율
//    P_i = Expert i의 평균 라우팅 확률
//    정수화: 밀리 단위 계산
// ════════════════════════════════════════════════════════════════════

fn aux_loss_component(expert_id: i64) -> i64 {
    // f_i: 배치 내 해당 Expert로 라우팅된 토큰 비율 (밀리 단위)
    let mut count: i64 = 0
    let mut t: i64 = 0
    while t < BATCH_TOKENS {
        if switch_route(t) == expert_id { count = count + 1 }
        t = t + 1
    }
    let f_i: i64 = (count * 1000) / BATCH_TOKENS
    // P_i: 평균 게이트 스코어 (밀리 단위)
    let mut score_sum: i64 = 0
    let mut t2: i64 = 0
    while t2 < BATCH_TOKENS {
        score_sum = score_sum + gate_score(t2, expert_id)
        t2 = t2 + 1
    }
    let p_i: i64 = score_sum / BATCH_TOKENS
    return f_i * p_i
}

fn total_aux_loss() -> i64 {
    let mut total: i64 = 0
    let mut e: i64 = 0
    while e < N_CORE {
        total = total + aux_loss_component(e)
        e = e + 1
    }
    return (AUX_ALPHA * N_EXPERTS * total) / 1000
}

// ════════════════════════════════════════════════════════════════════
// 7) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ GShard/Switch MoE × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: Expert = σ = 12
    let g2: bool = N_EXPERTS == sig
    println("G2 Expert=σ=12              : " + g2)

    // G3: Switch top-1, GShard top-2=φ
    let g3: bool = SWITCH_TOPK == 1 && GSHARD_TOPK == ph
    println("G3 Switch=1/GShard=φ=2      : " + g3)

    // G4: 용량 인수 = τ/φ = 2
    let g4: bool = CAP_FACTOR == t / ph
    println("G4 용량인수=τ/φ=2           : " + g4)

    // G5: Expert 용량 = (σ-τ) = 8
    let cap: i64 = expert_capacity()
    let g5: bool = cap == sig - t
    println("G5 Expert용량=σ-τ=8         : " + g5)

    // G6: 배치 = σ*τ = 48
    let g6: bool = BATCH_TOKENS == sig * t
    println("G6 배치=σ*τ=48              : " + g6)

    // G7: Switch 시뮬 -- 처리량 > 0
    let processed: i64 = switch_simulate()
    let g7: bool = processed > 0
    println("G7 Switch처리=" + processed + "/" + BATCH_TOKENS + "   : " + g7)

    // G8: GShard 라우팅 쌍 유효
    let pair: i64 = gshard_route_pair(N_CORE)
    let g8: bool = pair >= 0 && pair < N_EXPERTS * 2
    println("G8 GShard쌍합=" + pair + " 유효      : " + g8)

    // G9: 보조 손실 α = 83 (밀리 단위)
    let g9: bool = AUX_ALPHA == 1000 / sig
    println("G9 α=1/σ≈83/1000           : " + g9)

    // G10: 보조 손실 양수
    let aux: i64 = total_aux_loss()
    let g10: bool = aux > 0
    println("G10 보조손실=" + aux + " 양수      : " + g10)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("Switch: top-1 (최소 연산, 최대 처리량)")
    println("GShard: top-2 (용량 분산, 정밀도 향상)")
    println("드롭율: " + (BATCH_TOKENS - processed) + "/" + BATCH_TOKENS + " 토큰")
    println("용량 버퍼: " + cap + " 토큰/Expert")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9 && g10
    if all_pass {
        println("GSHARD-SWITCH OSSIFIED: 10/10  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("GSHARD-SWITCH PARTIAL: 게이트 일부 위반")
    }
}
