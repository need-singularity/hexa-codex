// optim/entropy_early_stop.hexa — 엔트로피 수렴 조기 종료 x n=6
//
// 원본 경로: techniques/optim/entropy_early_stop.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: H-SEDI-EE-1: SEDI Entropy Test as Early Stopping Criterion
//            엔트로피 변화율이 임계치 이하로 수렴하면 학습 중단
//            과적합 방지 + 계산 절약
// n=6 정렬:
//   - 인내심(patience) = τ(6) = 4     -> 4에폭 대기
//   - 윈도우 크기 = φ(6) = 2          -> 2에폭 이동평균
//   - 임계치 = sopfr(6)/SCALE = 0.005 -> 수렴 판별
//   - 최대 에폭 = σ(6)^2 = 144       -> 상한
//   - 클래스 수 = n = 6               -> 분류 문제
//
// 실행: hexa run techniques/optim/entropy_early_stop.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) 엔트로피 상수 (n=6 도출)
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 10000    // 정수 정밀도 (소수 4자리)
const MAX_EPOCHS: i64 = 144 // σ(6)^2

// ════════════════════════════════════════════════════════════════════
// 3) 엔트로피 계산 — 정수 근사
//    H = -Σ p_i * log(p_i)
//    정수화: p_i = count_i * SCALE / total
//    log 근사: log(x/SCALE) ~ (x - SCALE) * 2 / (x + SCALE)
// ════════════════════════════════════════════════════════════════════

// 정수 로그 근사: ln(x/SCALE) * SCALE
fn log_approx(x: i64) -> i64 {
    if x <= 0 { return 0 - SCALE * 10 }
    // Pade 근사: ln(x) ~ 2*(x-1)/(x+1)
    // 여기서 x 는 이미 SCALE 배
    return 2 * SCALE * (x - SCALE) / (x + SCALE)
}

// n=6 클래스 분류 문제 엔트로피 시뮬레이션
// 에폭에 따라 분포가 균등 → 집중으로 변화
fn entropy_at_epoch(epoch: i64) -> i64 {
    // 확률 분포 시뮬: 학습 진행 시 클래스 0에 집중
    // p_0 = SCALE/N + epoch * SCALE / (N * MAX_EPOCHS)
    // p_i (i>0) = 나머지 균등 분배
    let base_p: i64 = SCALE / N_CORE  // 1666
    let shift: i64 = epoch * SCALE / (N_CORE * 3)
    let p0: i64 = base_p + shift
    let remaining: i64 = SCALE - p0
    let p_other: i64 = remaining / (N_CORE - 1)

    // H = -p0*log(p0) - (N-1)*p_other*log(p_other)
    let h0: i64 = 0 - p0 * log_approx(p0) / SCALE
    let h_rest: i64 = 0 - (N_CORE - 1) * p_other * log_approx(p_other) / SCALE
    return h0 + h_rest
}

// ════════════════════════════════════════════════════════════════════
// 4) 엔트로피 변화율 — 이동 윈도우
//    delta_H = |H(t) - H(t-window)| / window
// ════════════════════════════════════════════════════════════════════

fn entropy_delta(epoch: i64, window: i64) -> i64 {
    if epoch < window { return SCALE }  // 초기: 큰 변화율
    let h_now: i64 = entropy_at_epoch(epoch)
    let h_prev: i64 = entropy_at_epoch(epoch - window)
    return abs_val(h_now - h_prev) / window
}

// ════════════════════════════════════════════════════════════════════
// 5) 조기 종료 판별
//    patience = τ(6) = 4: 연속 4회 임계치 미만이면 종료
//    threshold = sopfr(6) = 5 (SCALE 대비)
// ════════════════════════════════════════════════════════════════════

fn early_stop_epoch() -> i64 {
    let patience: i64 = tau(N_CORE)     // 4
    let window: i64 = phi(N_CORE)       // 2
    let threshold: i64 = sopfr(N_CORE)  // 5

    let mut consecutive: i64 = 0
    let mut epoch: i64 = window
    while epoch < MAX_EPOCHS {
        let delta: i64 = entropy_delta(epoch, window)
        if delta <= threshold {
            consecutive = consecutive + 1
            if consecutive >= patience {
                return epoch
            }
        } else {
            consecutive = 0
        }
        epoch = epoch + 1
    }
    return MAX_EPOCHS
}

// ════════════════════════════════════════════════════════════════════
// 6) 절감율 계산
// ════════════════════════════════════════════════════════════════════

fn savings_pct(stop_epoch: i64) -> i64 {
    return (MAX_EPOCHS - stop_epoch) * 100 / MAX_EPOCHS
}

// ════════════════════════════════════════════════════════════════════
// 7) 엔트로피 단조 감소 검증
//    학습 진행 시 엔트로피는 단조 감소해야 함
// ════════════════════════════════════════════════════════════════════

fn entropy_monotone_decreasing(until: i64) -> bool {
    let mut prev: i64 = entropy_at_epoch(0)
    let mut ok: bool = true
    let mut e: i64 = 1
    while e < until {
        let h: i64 = entropy_at_epoch(e)
        if h > prev { ok = false }
        prev = h
        e = e + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 8) 최대 엔트로피 검증: H_max = log(N) 에서 시작
// ════════════════════════════════════════════════════════════════════

fn max_entropy_check() -> bool {
    let h0: i64 = entropy_at_epoch(0)
    // 균등 분포 엔트로피 ~ log(6) * SCALE ~ 17917
    // 근사값이 양수이면 통과
    return h0 > 0
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    println("═══ Entropy Early Stop x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: patience = τ(6) = 4
    let g2: bool = t == 4
    println("G2 patience=τ=4             : " + g2)

    // G3: window = φ(6) = 2
    let g3: bool = ph == 2
    println("G3 window=φ=2               : " + g3)

    // G4: threshold = sopfr(6) = 5
    let g4: bool = sf == 5
    println("G4 threshold=sopfr=5        : " + g4)

    // G5: max_epochs = σ(6)^2 = 144
    let g5: bool = MAX_EPOCHS == sig * sig
    println("G5 max_epochs=σ^2=144       : " + g5)

    // G6: 조기 종료 발동 (MAX_EPOCHS 미만)
    let stop: i64 = early_stop_epoch()
    let g6: bool = stop < MAX_EPOCHS
    println("G6 조기종료 epoch=" + stop + "    : " + g6)

    // G7: 절감율 > 0%
    let saved: i64 = savings_pct(stop)
    let g7: bool = saved > 0
    println("G7 절감율=" + saved + "%          : " + g7)

    // G8: 엔트로피 단조 감소
    let g8: bool = entropy_monotone_decreasing(stop)
    println("G8 엔트로피 단조감소        : " + g8)

    // G9: 초기 엔트로피 양수
    let g9: bool = max_entropy_check()
    println("G9 초기엔트로피>0           : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("조기 종료: epoch " + stop + " / " + MAX_EPOCHS)
    println("절감: " + saved + "%")
    println("patience: " + t + " 에폭")
    println("window: " + ph + " 에폭")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Entropy EarlyStop OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("Entropy EarlyStop FAIL: 게이트 위반")
    }
}
