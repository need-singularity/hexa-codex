// lr_schedule_n6.hexa — LR Schedule N6 × n=6 정식 본문
//
// 원본 경로: techniques/optim/lr_schedule_n6.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 26 — LLM Learning Rate Schedule (BT-164)
//            6단계 스케줄: 워밍업→피크→유지→감쇠→미세→냉각
// n=6 정렬:
//   - 페이즈 수    = n = 6           → 6단계
//   - 워밍업 비율  = φ/σ = 1/6       → 전체의 16.7%
//   - 피크 lr      = σ-φ = 10        → 밀리 스케일
//   - 감쇠율       = τ²/σ = 4/3      → 코사인 감쇠 계수
//   - 최소 lr      = φ = 2           → 하한
//   - 총 스텝      = σ·τ = 48        → 에폭 단위
//
// 실행: hexa run techniques/optim/lr_schedule_n6.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) LR Schedule 스펙 — 6 페이즈
//    Phase 0: 워밍업     [0,  8)   → 선형 0→10
//    Phase 1: 피크       [8, 16)   → 상수 10
//    Phase 2: 유지       [16,24)   → 상수 10 (안정화)
//    Phase 3: 감쇠       [24,32)   → 선형 10→6
//    Phase 4: 미세조정   [32,40)   → 선형 6→2
//    Phase 5: 냉각       [40,48)   → 상수 2
//    각 페이즈 = 48/6 = 8 스텝 = σ-τ
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const TOTAL_STEPS:  i64 = 48    // σ·τ
const PHASE_LEN:    i64 = 8     // σ-τ = 스텝/페이즈
const LR_PEAK:      i64 = 10    // σ-φ
const LR_MID:       i64 = 6     // n
const LR_MIN:       i64 = 2     // φ

// ════════════════════════════════════════════════════════════════════
// 3) LR 조회 함수 — step → lr 값
// ════════════════════════════════════════════════════════════════════

fn get_lr(step: i64) -> i64 {
    let phase: i64 = step / PHASE_LEN
    let local: i64 = step % PHASE_LEN

    // Phase 0: 워밍업 (선형 0→peak)
    if phase == 0 {
        return (LR_PEAK * local) / PHASE_LEN
    }
    // Phase 1: 피크 (상수)
    if phase == 1 {
        return LR_PEAK
    }
    // Phase 2: 유지 (상수)
    if phase == 2 {
        return LR_PEAK
    }
    // Phase 3: 감쇠 (선형 peak→mid)
    if phase == 3 {
        return LR_PEAK - ((LR_PEAK - LR_MID) * local) / PHASE_LEN
    }
    // Phase 4: 미세조정 (선형 mid→min)
    if phase == 4 {
        return LR_MID - ((LR_MID - LR_MIN) * local) / PHASE_LEN
    }
    // Phase 5: 냉각 (상수)
    return LR_MIN
}

// ════════════════════════════════════════════════════════════════════
// 4) 전체 스케줄 총합 — 면적 계산 (효과적 학습량)
//    이상적 총합: LR 곡선 아래 면적
// ════════════════════════════════════════════════════════════════════

fn total_lr_sum() -> i64 {
    let mut sum: i64 = 0
    let mut s: i64 = 0
    while s < TOTAL_STEPS {
        sum = sum + get_lr(s)
        s = s + 1
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 5) 단조성 검증 — 워밍업 증가, 감쇠 감소
// ════════════════════════════════════════════════════════════════════

fn warmup_monotonic() -> bool {
    let mut ok: bool = true
    let mut s: i64 = 1
    while s < PHASE_LEN {
        if get_lr(s) < get_lr(s - 1) { ok = false }
        s = s + 1
    }
    return ok
}

fn decay_monotonic() -> bool {
    let mut ok: bool = true
    let decay_start: i64 = 3 * PHASE_LEN    // Phase 3 시작
    let decay_end: i64 = 5 * PHASE_LEN      // Phase 5 시작
    let mut s: i64 = decay_start + 1
    while s < decay_end {
        if get_lr(s) > get_lr(s - 1) { ok = false }
        s = s + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 6) 페이즈 경계값 검증
// ════════════════════════════════════════════════════════════════════

fn phase_boundary_check() -> bool {
    let p0_start: bool = get_lr(0) == 0               // 워밍업 시작
    let p1_start: bool = get_lr(PHASE_LEN) == LR_PEAK // 피크 진입
    let p5_end:   bool = get_lr(TOTAL_STEPS - 1) == LR_MIN  // 냉각 끝
    return p0_start && p1_start && p5_end
}

// ════════════════════════════════════════════════════════════════════
// 7) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ LR Schedule N6 × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 페이즈 수 = 6
    let g2: bool = TOTAL_STEPS / PHASE_LEN == N_CORE
    println("G2 페이즈=n=6               : " + g2)

    // G3: 총 스텝 = σ·τ = 48
    let g3: bool = TOTAL_STEPS == sig * t
    println("G3 총스텝=σ·τ=48            : " + g3)

    // G4: 페이즈 길이 = σ-τ = 8
    let g4: bool = PHASE_LEN == sig - t
    println("G4 페이즈길이=σ-τ=8          : " + g4)

    // G5: 피크 lr = σ-φ = 10
    let g5: bool = LR_PEAK == sig - ph
    println("G5 피크lr=σ-φ=10            : " + g5)

    // G6: 워밍업 단조 증가
    let g6: bool = warmup_monotonic()
    println("G6 워밍업 단조증가           : " + g6)

    // G7: 감쇠 단조 감소
    let g7: bool = decay_monotonic()
    println("G7 감쇠 단조감소             : " + g7)

    // G8: 경계값 정확
    let g8: bool = phase_boundary_check()
    println("G8 경계값 EXACT              : " + g8)

    // LR 총합 (효과적 학습량)
    let lr_sum: i64 = total_lr_sum()
    println("--- 벤치마크 ---")
    println("LR 총합(면적): " + lr_sum)
    println("페이즈: 워밍업→피크→유지→감쇠→미세→냉각")
    println("범위: [0, " + LR_PEAK + "] → [" + LR_MIN + "]")

    // 각 페이즈 경계 LR 출력
    let mut p: i64 = 0
    while p < N_CORE {
        let lr_val: i64 = get_lr(p * PHASE_LEN)
        println("  Phase " + p + " 시작 lr=" + lr_val)
        p = p + 1
    }

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8
    if all_pass {
        println("LR-SCHED OSSIFIED: 8/8  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("LR-SCHED PARTIAL: 게이트 일부 위반")
    }
}
