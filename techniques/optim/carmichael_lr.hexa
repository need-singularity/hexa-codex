// optim/carmichael_lr.hexa — 카마이클 함수 기반 학습률 스케줄러 x n=6
//
// 원본 경로: techniques/optim/carmichael_lr.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 14: Carmichael LR Cycle
//            카마이클 함수 λ(n) = lcm 주기 기반 학습률 순환
//            정수론 주기성을 학습률 스케줄에 매핑
// n=6 정렬:
//   - λ(6) = 2               -> 기본 순환 주기
//   - σ(6) = 12              -> 전체 에폭 수
//   - τ(6) = 4               -> 워밍업 스텝
//   - φ(6) = 2               -> 최소 학습률 배수
//   - sopfr(6) = 5           -> 감쇠 계수
//   - 순환 길이 = lcm(1..6)=60 -> 완전 주기
//
// 실행: hexa run techniques/optim/carmichael_lr.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 2) GCD / LCM — 카마이클 함수 핵심
// ════════════════════════════════════════════════════════════════════

fn gcd(a: i64, b: i64) -> i64 {
    let mut x: i64 = a
    let mut y: i64 = b
    while y != 0 {
        let t: i64 = x % y
        x = y
        y = t
    }
    return x
}

fn lcm(a: i64, b: i64) -> i64 {
    if a == 0 { return b }
    if b == 0 { return a }
    return (a / gcd(a, b)) * b
}

// ════════════════════════════════════════════════════════════════════
// 3) 카마이클 함수 λ(n) — 오일러 함수의 최소 지수 버전
//    λ(n) = lcm(λ(p1^e1), λ(p2^e2), ...)
//    간이 구현: 1..n 중 a^k ≡ 1 (mod n) 인 최소 k
// ════════════════════════════════════════════════════════════════════

fn carmichael_lambda(n: i64) -> i64 {
    // λ(n) = lcm(ord_n(a)) for all a coprime to n
    // 간이: 1..n-1 중 gcd(a,n)=1 인 a에 대해 ord 계산, lcm 취합
    if n <= 1 { return 1 }
    let mut result: i64 = 1
    let mut a: i64 = 1
    while a < n {
        if gcd(a, n) == 1 {
            // a의 위수 계산 (최소 k: a^k ≡ 1 mod n)
            let mut power: i64 = a % n
            let mut ord: i64 = 1
            while power != 1 {
                power = (power * a) % n
                ord = ord + 1
            }
            result = lcm(result, ord)
        }
        a = a + 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// 4) LCM(1..n) — 전체 순환 주기
//    lcm(1,2,3,4,5,6) = 60
// ════════════════════════════════════════════════════════════════════

fn lcm_range(n: i64) -> i64 {
    let mut result: i64 = 1
    let mut i: i64 = 1
    while i <= n {
        result = lcm(result, i)
        i = i + 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// 5) 학습률 스케줄러 — 카마이클 주기 코사인 근사
//    lr(t) = lr_min + (lr_max - lr_min) * cycle_factor(t)
//    cycle_factor: λ(6)=2 주기로 반복, sopfr(6)=5 감쇠
//    정수 스케일: lr 을 1000배 스케일링
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const LR_SCALE: i64 = 10000   // 정수 정밀도 스케일
const LR_MAX: i64 = 10000     // 1.0 스케일드
const LR_MIN: i64 = 100       // 0.01 스케일드

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// 삼각파 근사 — 주기 p 에서 t 위치의 값 (0~SCALE)
fn triangle_wave(t: i64, period: i64) -> i64 {
    let pos: i64 = t % period
    let half: i64 = period / 2
    if half == 0 { return LR_SCALE }
    if pos <= half {
        return LR_SCALE - (LR_SCALE * pos / half)
    }
    return LR_SCALE * (pos - half) / half
}

// 감쇠 계수 — 에폭 진행에 따라 sopfr(6)=5 기반 감소
fn decay_factor(epoch: i64, total_epochs: i64) -> i64 {
    // 감쇠 = SCALE * (total - epoch) / total
    let sf: i64 = sopfr(N_CORE)  // 5
    let decayed: i64 = LR_SCALE * (total_epochs * sf - epoch * sf) / (total_epochs * sf)
    return decayed
}

// 최종 학습률 계산 (정수 스케일)
fn carmichael_lr(step: i64, total_steps: i64) -> i64 {
    let lambda: i64 = carmichael_lambda(N_CORE)  // λ(6) = 2
    let warmup: i64 = tau(N_CORE)                // τ(6) = 4 워밍업 스텝

    // 워밍업 단계: 선형 증가
    if step < warmup {
        return LR_MIN + (LR_MAX - LR_MIN) * step / warmup
    }

    // 주기적 코사인 근사 (삼각파 사용)
    let period: i64 = lambda * N_CORE  // 2 * 6 = 12 스텝 주기
    let wave: i64 = triangle_wave(step - warmup, period)
    let decay: i64 = decay_factor(step, total_steps)

    // lr = lr_min + (lr_max - lr_min) * wave * decay / SCALE^2
    let range: i64 = LR_MAX - LR_MIN
    let lr: i64 = LR_MIN + range * wave / LR_SCALE * decay / LR_SCALE
    return lr
}

// ════════════════════════════════════════════════════════════════════
// 6) 학습률 궤적 검증
// ════════════════════════════════════════════════════════════════════

fn lr_trajectory_valid(total_steps: i64) -> bool {
    let mut prev: i64 = 0
    let mut monotone_warmup: bool = true
    let warmup: i64 = tau(N_CORE)

    // 워밍업 단조 증가 검증
    let mut t: i64 = 0
    while t < warmup {
        let lr: i64 = carmichael_lr(t, total_steps)
        if t > 0 {
            if lr < prev { monotone_warmup = false }
        }
        prev = lr
        t = t + 1
    }

    // 전체 범위: lr_min <= lr <= lr_max
    let mut in_range: bool = true
    t = 0
    while t < total_steps {
        let lr: i64 = carmichael_lr(t, total_steps)
        if lr < LR_MIN { in_range = false }
        if lr > LR_MAX { in_range = false }
        t = t + 1
    }

    return monotone_warmup && in_range
}

// ════════════════════════════════════════════════════════════════════
// 7) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)
    let lam: i64 = carmichael_lambda(N_CORE)

    println("═══ Carmichael LR 스케줄러 x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5 / λ=2")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: λ(6) = 2 (카마이클 함수값)
    let g2: bool = lam == 2
    println("G2 λ(6)=2                   : " + g2)

    // G3: λ(6) = φ(6) = 2 (n=6 에서 일치)
    let g3: bool = lam == ph
    println("G3 λ(6)=φ(6) 일치           : " + g3)

    // G4: lcm(1..6) = 60 (전체 순환 주기)
    let full_period: i64 = lcm_range(N_CORE)
    let g4: bool = full_period == 60
    println("G4 lcm(1..6)=60             : " + g4)

    // G5: 워밍업 스텝 = τ(6) = 4
    let g5: bool = t == 4
    println("G5 워밍업=τ(6)=4            : " + g5)

    // G6: 감쇠 계수 = sopfr(6) = 5
    let g6: bool = sf == 5
    println("G6 감쇠계수=sopfr=5         : " + g6)

    // G7: 학습률 궤적 유효 (60스텝)
    let total: i64 = full_period  // 60
    let g7: bool = lr_trajectory_valid(total)
    println("G7 궤적 유효(60스텝)        : " + g7)

    // G8: 초기 lr = LR_MIN (스텝 0)
    let lr0: i64 = carmichael_lr(0, total)
    let g8: bool = lr0 == LR_MIN
    println("G8 초기 lr=LR_MIN           : " + g8)

    // G9: 워밍업 끝 lr = LR_MAX 부근
    let lr_w: i64 = carmichael_lr(t - 1, total)
    let g9: bool = lr_w > LR_MAX / 2
    println("G9 워밍업 끝 lr>max/2       : " + g9)

    // 벤치마크 출력
    println("--- 벤치마크 ---")
    println("주기: λ(6)*6=" + lam * N_CORE + " 스텝")
    println("전체순환: lcm(1..6)=" + full_period)
    println("워밍업: " + t + " 스텝")
    println("감쇠: sopfr(6)=" + sf + " 배속")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Carmichael LR OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("Carmichael LR FAIL: 게이트 위반")
    }
}
