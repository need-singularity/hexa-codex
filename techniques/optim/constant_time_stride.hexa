// optim/constant_time_stride.hexa — 등간격 스트라이드 어텐션 x n=6
//
// 원본 경로: techniques/optim/constant_time_stride.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 23: Constant-Time Stride Attention (CTSA)
//            고정 간격 스트라이드로 어텐션/학습 단계 건너뛰기
//            계산량 절감 + 정밀도 유지 균형
// n=6 정렬:
//   - 스트라이드 간격 = φ(6) = 2     -> 매 2스텝마다 실행
//   - 전체 시퀀스 = σ(6) = 12        -> 한 에폭 12토큰
//   - 실행 스텝 = σ(6)/φ(6) = 6     -> 실제 계산 6회
//   - 체크포인트 = τ(6) = 4          -> 4개 체크포인트
//   - 누적 배치 = sopfr(6) = 5      -> 5배치 누적
//
// 실행: hexa run techniques/optim/constant_time_stride.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 2) 스트라이드 스케줄러 핵심
//    stride = φ(6) = 2: 짝수 위치만 어텐션 계산
//    total = σ(6) = 12 토큰 시퀀스
//    effective = total / stride = 6 = n
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6

// 위치가 활성 어텐션 대상인지 판별
fn is_active_pos(pos: i64, stride: i64) -> bool {
    return pos % stride == 0
}

// 실제 어텐션 계산 위치 수
fn count_active(total: i64, stride: i64) -> i64 {
    let mut count: i64 = 0
    let mut s: i64 = 0
    while s < total {
        if is_active_pos(s, stride) { count = count + 1 }
        s = s + 1
    }
    return count
}

// ════════════════════════════════════════════════════════════════════
// 3) 어텐션 스코어 누적 — 스트라이드 구간 내 집계
//    비활성 위치의 정보를 활성 위치가 흡수
// ════════════════════════════════════════════════════════════════════

// 토큰 값 시뮬레이션: 위치+1
fn token_value(pos: i64) -> i64 {
    return pos + 1
}

// 스트라이드 구간 어텐션 합산: [start, start+stride) 범위 합
fn stride_attention_sum(start: i64, stride: i64) -> i64 {
    let mut total: i64 = 0
    let mut p: i64 = start
    while p < start + stride {
        total = total + token_value(p)
        p = p + 1
    }
    return total
}

// 전체 누적 어텐션
fn total_strided_attention(seq_len: i64, stride: i64) -> i64 {
    let mut sum: i64 = 0
    let mut p: i64 = 0
    while p < seq_len {
        if is_active_pos(p, stride) {
            sum = sum + stride_attention_sum(p, stride)
        }
        p = p + stride
    }
    return sum
}

// ════════════════════════════════════════════════════════════════════
// 4) 체크포인트 스케줄 — τ(6)=4 등간격
// ════════════════════════════════════════════════════════════════════

fn checkpoint_interval(total: i64, num_ckpt: i64) -> i64 {
    return total / num_ckpt
}

fn is_checkpoint(pos: i64, total: i64, num_ckpt: i64) -> bool {
    let interval: i64 = checkpoint_interval(total, num_ckpt)
    if interval == 0 { return false }
    return pos % interval == 0
}

fn count_checkpoints(total: i64, num_ckpt: i64) -> i64 {
    let mut count: i64 = 0
    let mut s: i64 = 0
    while s < total {
        if is_checkpoint(s, total, num_ckpt) { count = count + 1 }
        s = s + 1
    }
    return count
}

// ════════════════════════════════════════════════════════════════════
// 5) 계산 절감 비율
//    어텐션 복잡도: O(n^2) -> O(n^2/stride^2)
//    위치 절감: active/total = n/σ(n) = 6/12 = 50%
//    어텐션 절감: 1 - (active/total)^2 = 75%
// ════════════════════════════════════════════════════════════════════

fn position_savings_pct(total: i64, stride: i64) -> i64 {
    let active: i64 = count_active(total, stride)
    return (total - active) * 100 / total
}

fn attention_savings_pct(total: i64, stride: i64) -> i64 {
    let active: i64 = count_active(total, stride)
    // 어텐션 쌍 절감 = 1 - (active/total)^2
    // = (total^2 - active^2) * 100 / total^2
    let full: i64 = total * total
    let reduced: i64 = active * active
    return (full - reduced) * 100 / full
}

// ════════════════════════════════════════════════════════════════════
// 6) 정밀도 보존 검증 — 누적합 동치
// ════════════════════════════════════════════════════════════════════

fn precision_preserved(total: i64, stride: i64) -> bool {
    // 단순 합: 모든 위치 토큰값 합
    let mut simple_sum: i64 = 0
    let mut p: i64 = 0
    while p < total {
        simple_sum = simple_sum + token_value(p)
        p = p + 1
    }
    // 스트라이드 누적 합
    let strided_sum: i64 = total_strided_attention(total, stride)
    return simple_sum == strided_sum
}

// ════════════════════════════════════════════════════════════════════
// 7) 2단계 스트라이드 — φ(6)=2 + τ(6)=4
//    세밀: stride=2, 거칠: stride=4
//    세밀 스텝에서 상세 계산, 거친 스텝에서 빠른 근사
// ════════════════════════════════════════════════════════════════════

fn two_level_stride_count(total: i64) -> i64 {
    let fine_stride: i64 = phi(N_CORE)   // 2
    let coarse_stride: i64 = tau(N_CORE) // 4
    let mut count: i64 = 0
    let mut p: i64 = 0
    while p < total {
        if is_active_pos(p, fine_stride) { count = count + 1 }
        if is_active_pos(p, coarse_stride) { count = count + 1 }
        p = p + 1
    }
    return count
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    let stride: i64 = ph
    let total: i64 = sig

    println("═══ Constant-Time Stride Attention x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 스트라이드 = φ(6) = 2
    let g2: bool = stride == 2
    println("G2 스트라이드=φ=2            : " + g2)

    // G3: 활성 위치 = n = 6
    let active: i64 = count_active(total, stride)
    let g3: bool = active == N_CORE
    println("G3 활성위치=n=6             : " + g3)

    // G4: 체크포인트 = τ(6) = 4
    let ckpts: i64 = count_checkpoints(total, t)
    let g4: bool = ckpts == t
    println("G4 체크포인트=τ=4           : " + g4)

    // G5: 위치 절감 50%
    let pos_save: i64 = position_savings_pct(total, stride)
    let g5: bool = pos_save == 50
    println("G5 위치절감=50%             : " + g5)

    // G6: 어텐션 절감 75%
    let attn_save: i64 = attention_savings_pct(total, stride)
    let g6: bool = attn_save == 75
    println("G6 어텐션절감=75%           : " + g6)

    // G7: 정밀도 보존
    let g7: bool = precision_preserved(total, stride)
    println("G7 정밀도 보존              : " + g7)

    // G8: 비율 σ/n = φ
    let ratio: i64 = total / active
    let g8: bool = ratio == ph
    println("G8 비율=σ/n=φ=2            : " + g8)

    // G9: 체크 간격 = σ/τ = 3
    let interval: i64 = checkpoint_interval(total, t)
    let g9: bool = interval == 3
    println("G9 체크간격=σ/τ=3           : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("전체 시퀀스: " + total + " 토큰")
    println("활성 위치: " + active + " (절감 " + pos_save + "%)")
    println("어텐션 절감: " + attn_save + "%")
    println("체크포인트: " + ckpts + "개 (간격 " + interval + ")")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("CTSA OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("CTSA FAIL: 게이트 위반")
    }
}
