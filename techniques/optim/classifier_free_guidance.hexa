// optim/classifier_free_guidance.hexa -- 분류기 없는 안내 (Classifier-Free Guidance) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Technique: Classifier-Free Guidance -- Ho & Salimans 2022
//            "Classifier-Free Diffusion Guidance",
//            Nichol 외 2021 "GLIDE",
//            Brooks 외 2023 "InstructPix2Pix"
//            조건부/비조건부 출력 보간으로 생성 품질 향상
// n=6 정렬:
//   - 안내 스케일          = n + 1 = 7→n = 6 -> CFG 스케일 w
//   - 비조건부 비율        = sopfr(6) = 5    -> 드롭아웃 50% 근사
//   - 스케줄 스텝          = σ(6) = 12       -> 확산 스텝
//   - CFG 채널            = σ(6)² = 144     -> 조건부 차원
//   - 보간 포인트          = τ(6) = 4        -> 안내 보간 지점
//   - 널 토큰 차원         = φ(6) = 2        -> 무조건 임베딩 축
//
// 실행: hexa run techniques/optim/classifier_free_guidance.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── 1) n=6 산술 함수 ──────────────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 2) CFG 핵심 상수 ──────────────────────────────────────

const N_CORE: i64 = 6
const SCALE: i64 = 1000

// n=6 유도 상수
const GUIDANCE_SCALE: i64 = 6     // n = 6 -- CFG 안내 스케일 w
const UNCOND_RATIO: i64 = 5       // sopfr(6) = 5 -- 비조건부 드롭 비율 (50% 근사)
const SCHEDULE_STEPS: i64 = 12    // σ(6) = 12 -- 확산 역과정 스텝
const CFG_DIM: i64 = 144          // σ(6)² = 144 -- 조건부 특징 차원
const INTERP_POINTS: i64 = 4      // τ(6) = 4 -- 보간 포인트 수
const NULL_DIM: i64 = 2           // φ(6) = 2 -- 널 토큰 임베딩 축

// 학습 파라미터
const TRAIN_EPOCHS: i64 = 36      // 6 × 6 -- 학습 에포크
const DROPOUT_PROB: i64 = 500     // 0.5 × SCALE -- 조건 드롭아웃 확률
const NOISE_SCALE: i64 = 100      // 초기 노이즈 크기

// ── 3) 조건부 예측 -- ε_θ(x_t, c) ────────────────────────

// 조건부 노이즈 예측 -- 텍스트 조건 c 가 주어졌을 때
fn predict_conditional(x_t: i64, condition: i64, t_step: i64) -> i64 {
    // 조건부 특징 추출
    let cond_feat: i64 = (condition * CFG_DIM) / SCALE
    // 시간 스텝 임베딩
    let time_emb: i64 = (SCALE - (t_step * SCALE) / SCHEDULE_STEPS)
    // 노이즈 예측: x_t 와 조건의 상호작용
    let noise_pred: i64 = (x_t * time_emb) / SCALE - (cond_feat * time_emb) / SCALE
    return noise_pred
}

// 조건부 특징 인코딩 -- 텍스트→벡터
fn encode_condition(text_id: i64) -> i64 {
    // 텍스트 토큰을 CFG_DIM 차원 벡터로 투영
    let base: i64 = (text_id * 127 + 31) % CFG_DIM
    return (base + 1) * SCALE / CFG_DIM
}

// ── 4) 비조건부 예측 -- ε_θ(x_t, ∅) ─────────────────────

// 비조건부 노이즈 예측 -- 널 토큰 ∅
fn predict_unconditional(x_t: i64, t_step: i64) -> i64 {
    // 널 임베딩: NULL_DIM 차원 영벡터 근사
    let null_feat: i64 = NULL_DIM  // 최소 편향
    let time_emb: i64 = (SCALE - (t_step * SCALE) / SCHEDULE_STEPS)
    // 무조건 예측: 조건 정보 없이 순수 노이즈 추정
    let noise_pred: i64 = (x_t * time_emb) / SCALE - null_feat
    return noise_pred
}

// 널 토큰 생성 -- 학습용 빈 조건
fn create_null_token() -> i64 {
    return NULL_DIM * SCALE / CFG_DIM
}

// ── 5) 안내 보간 -- ε = (1+w)·ε_c - w·ε_∅ ───────────────

// CFG 보간 -- 핵심 수식
fn guided_prediction(x_t: i64, condition: i64, t_step: i64, w: i64) -> i64 {
    let eps_c: i64 = predict_conditional(x_t, condition, t_step)
    let eps_u: i64 = predict_unconditional(x_t, t_step)
    // ε = ε_u + w · (ε_c - ε_u) = (1+w)·ε_c - w·ε_u 와 동치
    let guided: i64 = eps_u + (w * (eps_c - eps_u)) / SCALE
    return guided
}

// 단일 역과정 스텝 -- x_{t-1} 계산
fn reverse_step(x_t: i64, condition: i64, t_step: i64, w: i64) -> i64 {
    let eps: i64 = guided_prediction(x_t, condition, t_step, w)
    // α_bar 근사: 선형 스케줄
    let alpha_bar: i64 = (SCALE * (SCHEDULE_STEPS - t_step)) / SCHEDULE_STEPS
    if alpha_bar == 0 { return x_t - eps }
    // x_{t-1} = (x_t - sqrt(1-α_bar)·ε) / sqrt(α_bar)
    let x_prev: i64 = (x_t * SCALE - eps * (SCALE - alpha_bar)) / (alpha_bar + 1)
    return x_prev / SCALE
}

// 전체 역과정 -- T→0 생성
fn full_reverse_process(x_T: i64, condition: i64, w: i64) -> i64 {
    let mut x: i64 = x_T
    let mut t: i64 = SCHEDULE_STEPS
    while t > 0 {
        x = reverse_step(x, condition, t, w)
        t = t - 1
    }
    return x
}

// ── 6) 동적 안내 -- 스텝별 스케일 조절 ───────────────────

// 동적 CFG 스케일 -- 초기엔 낮게, 후반엔 높게
fn dynamic_guidance_scale(t_step: i64, base_w: i64) -> i64 {
    // 코사인 근사: w(t) = base_w × (1 - t/T)
    let progress: i64 = (SCALE * (SCHEDULE_STEPS - t_step)) / SCHEDULE_STEPS
    let dynamic_w: i64 = (base_w * progress) / SCALE
    // 최소 스케일 보장
    if dynamic_w < SCALE / N_CORE { return SCALE / N_CORE }
    return dynamic_w
}

// 동적 스케일 역과정
fn dynamic_reverse_process(x_T: i64, condition: i64) -> i64 {
    let mut x: i64 = x_T
    let base_w: i64 = GUIDANCE_SCALE * SCALE / N_CORE
    let mut t: i64 = SCHEDULE_STEPS
    while t > 0 {
        let w: i64 = dynamic_guidance_scale(t, base_w)
        x = reverse_step(x, condition, t, w)
        t = t - 1
    }
    return x
}

// 보간 스펙트럼 -- 여러 w 값으로 비교
fn interpolation_spectrum(x_T: i64, condition: i64) -> i64 {
    let mut best_score: i64 = 0
    let mut p: i64 = 0
    while p < INTERP_POINTS {
        let w: i64 = (p + 1) * SCALE / INTERP_POINTS
        let sample: i64 = full_reverse_process(x_T, condition, w)
        let score: i64 = abs_val(sample)
        if score > best_score { best_score = score }
        p = p + 1
    }
    return best_score
}

// ── 7) 학습 루프 (드롭아웃 학습) ──────────────────────────

// 드롭아웃 학습 -- 조건을 확률적으로 제거
fn train_step(theta: i64, x_0: i64, condition: i64, step: i64) -> i64 {
    // 드롭아웃 판정: step 기반 의사난수
    let drop: bool = ((step * 7 + 13) % 10) < (UNCOND_RATIO)
    // 노이즈 추가
    let t: i64 = (step % SCHEDULE_STEPS) + 1
    let noise: i64 = ((step * 31 + 17) % NOISE_SCALE) - NOISE_SCALE / 2
    let x_t: i64 = x_0 + noise
    // 조건부 또는 비조건부 예측
    let mut pred: i64 = 0
    if drop {
        pred = predict_unconditional(x_t, t)
    }
    if drop == false {
        pred = predict_conditional(x_t, condition, t)
    }
    // MSE 손실 -- |pred - noise|²
    let diff: i64 = pred - noise
    let loss: i64 = (diff * diff) / SCALE
    // 파라미터 갱신
    return theta - loss / SCALE
}

// 전체 학습 루프
fn train_cfg() -> i64 {
    let mut theta: i64 = SCALE
    let mut total_loss: i64 = 0
    let mut epoch: i64 = 0
    while epoch < TRAIN_EPOCHS {
        let mut step: i64 = 0
        while step < SCHEDULE_STEPS {
            let x_0: i64 = SCALE + (step * 50)
            let cond: i64 = encode_condition(step)
            theta = train_step(theta, x_0, cond, epoch * SCHEDULE_STEPS + step)
            step = step + 1
        }
        if epoch % N_CORE == 0 {
            println("  에포크 " + epoch + " | θ=" + theta)
        }
        epoch = epoch + 1
    }
    return theta
}

// ── 8) 생성 품질 측정 ─────────────────────────────────────

// FID 근사 -- 생성 분포와 실제 분포 거리
fn fid_approximate(theta: i64) -> i64 {
    let mut fid_sum: i64 = 0
    let mut s: i64 = 0
    while s < N_CORE {
        let x_T: i64 = NOISE_SCALE * (s + 1)
        let cond: i64 = encode_condition(s)
        let w: i64 = GUIDANCE_SCALE * SCALE / N_CORE
        let sample: i64 = full_reverse_process(x_T, cond, w)
        let target: i64 = SCALE + s * 50
        let diff: i64 = abs_val(sample - target)
        fid_sum = fid_sum + diff
        s = s + 1
    }
    return fid_sum / N_CORE
}

// 다양성 점수 -- 생성물 간 분산
fn diversity_score(theta: i64) -> i64 {
    let mut samples: i64 = 0
    let mut sum_sq: i64 = 0
    let mut s: i64 = 0
    while s < N_CORE {
        let x_T: i64 = NOISE_SCALE * (s + 1)
        let cond: i64 = encode_condition(0)  // 같은 조건
        let w: i64 = GUIDANCE_SCALE * SCALE / N_CORE
        let sample: i64 = full_reverse_process(x_T, cond, w)
        samples = samples + sample
        sum_sq = sum_sq + (sample * sample) / SCALE
        s = s + 1
    }
    let mean: i64 = samples / N_CORE
    let variance: i64 = sum_sq / N_CORE - (mean * mean) / SCALE
    return abs_val(variance)
}

// ── main ──────────────────────────────────────────────────

fn main() {
    println("=== 분류기 없는 안내 (CFG) x n=6 ===")
    println("")

    // G1: σ(6)=12 검증
    let g1: bool = sigma(N_CORE) == 12
    println("G1 σ(6)=12       : " + g1)

    // G2: τ(6)=4 검증
    let g2: bool = tau(N_CORE) == 4
    println("G2 τ(6)=4        : " + g2)

    // G3: φ(6)=2 검증
    let g3: bool = phi(N_CORE) == 2
    println("G3 φ(6)=2        : " + g3)

    // G4: sopfr(6)=5 검증
    let g4: bool = sopfr(N_CORE) == 5
    println("G4 sopfr(6)=5    : " + g4)

    // G5: σ·φ = n·τ 유일성
    let lhs: i64 = sigma(N_CORE) * phi(N_CORE)
    let rhs: i64 = N_CORE * tau(N_CORE)
    let g5: bool = lhs == rhs
    println("G5 σφ=nτ         : " + g5 + " (" + lhs + "=" + rhs + ")")

    // G6: 조건부/비조건부 예측 분기 확인
    let x_t: i64 = SCALE
    let cond: i64 = encode_condition(3)
    let eps_c: i64 = predict_conditional(x_t, cond, 6)
    let eps_u: i64 = predict_unconditional(x_t, 6)
    let g6: bool = eps_c != eps_u
    println("G6 조건분기확인   : " + g6 + " (ε_c=" + eps_c + " ε_u=" + eps_u + ")")

    // G7: CFG 보간 공식 검증 -- w=0 이면 비조건부와 동일
    let guided_0: i64 = guided_prediction(x_t, cond, 6, 0)
    let g7: bool = guided_0 == eps_u
    println("G7 w=0→비조건부  : " + g7)

    // G8: 동적 스케일 단조증가 확인
    let w_early: i64 = dynamic_guidance_scale(SCHEDULE_STEPS, GUIDANCE_SCALE * SCALE / N_CORE)
    let w_late: i64 = dynamic_guidance_scale(1, GUIDANCE_SCALE * SCALE / N_CORE)
    let g8: bool = w_late >= w_early
    println("G8 동적스케일단조 : " + g8 + " (초기=" + w_early + " 후기=" + w_late + ")")

    // G9: 전체 학습 + 생성 품질
    println("")
    println("-- CFG 학습 루프 --")
    let theta: i64 = train_cfg()
    let fid: i64 = fid_approximate(theta)
    let diversity: i64 = diversity_score(theta)
    let g9: bool = fid >= 0
    println("")
    println("G9 학습완료       : " + g9 + " (FID근사=" + fid + ", 다양성=" + diversity + ")")

    // 최종 집계
    let mut pass: i64 = 0
    if g1 { pass = pass + 1 }
    if g2 { pass = pass + 1 }
    if g3 { pass = pass + 1 }
    if g4 { pass = pass + 1 }
    if g5 { pass = pass + 1 }
    if g6 { pass = pass + 1 }
    if g7 { pass = pass + 1 }
    if g8 { pass = pass + 1 }
    if g9 { pass = pass + 1 }
    println("")
    println("CFG OSSIFIED: " + pass + "/9 -> [7]empirical -> [10*] 승격 후보")
}
