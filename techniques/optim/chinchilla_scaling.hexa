// optim/chinchilla_scaling.hexa — Chinchilla 스케일링 법칙 x n=6
//
// 원본 경로: techniques/optim/chinchilla_scaling.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 25: Chinchilla Scaling Law (BT-26)
//            Hoffmann 외 2022, 최적 토큰/파라미터 비율 T ~ N
//            "Compute-Optimal": 동일 FLOPs 예산에서 모델+데이터 균형
// n=6 정렬:
//   - 기본 파라미터 = 6M           -> n
//   - 최적 비율 = σ(6)/φ(6) = 6   -> 토큰 = 6 * 파라미터
//   - FLOPs 계수 = 6              -> 6*N*T (Kaplan 법칙)
//   - 모델 크기 단계 = sopfr(6)=5 -> 5단계 스케일링 곡선
//   - 스케일링 지수 = τ(6) = 4    -> 정수 근사 0.4
//
// 실행: hexa run techniques/optim/chinchilla_scaling.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 2) Chinchilla 스케일링 상수 (n=6 도출)
//    핵심 법칙: L(N,D) = E + A/N^a + B/D^b
//    최적 조건: N_opt ~ C^a, D_opt ~ C^b (a+b=1)
//    n=6 정렬: 토큰/파라미터 비율 = σ(6)/φ(6) = 6
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 1000

// 모델 크기 단계 (sopfr(6)=5 단계, 단위: 백만 파라미터)
// 6M -> 36M -> 216M -> 1296M -> 7776M (6^k 스케일링)
fn model_size(stage: i64) -> i64 {
    let mut size: i64 = N_CORE
    let mut i: i64 = 0
    while i < stage {
        size = size * N_CORE
        i = i + 1
    }
    return size
}

// 최적 토큰 수 = 모델크기 * 비율
// 비율 = σ(6)/φ(6) = 12/2 = 6
fn optimal_tokens(params_m: i64) -> i64 {
    let ratio: i64 = sigma(N_CORE) / phi(N_CORE)  // 6
    return params_m * ratio
}

// FLOPs 추정: C ~ 6 * N * D (Kaplan 근사)
fn compute_flops(params_m: i64, tokens_m: i64) -> i64 {
    return N_CORE * params_m * tokens_m
}

// ════════════════════════════════════════════════════════════════════
// 3) 손실 함수 근사
//    정수 제곱근 (뉴턴법)
// ════════════════════════════════════════════════════════════════════

fn isqrt(n: i64) -> i64 {
    if n <= 0 { return 0 }
    let mut x: i64 = n
    let mut y: i64 = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

// N^0.4 근사 — sqrt(N) 기반 정수 근사
fn power_04(n: i64) -> i64 {
    if n <= 1 { return n }
    return isqrt(n)
}

const LOSS_E: i64 = 1700     // 잔차 손실 (1.7 * SCALE)
const LOSS_A: i64 = 4060     // 모델 크기 계수
const LOSS_B: i64 = 4100     // 데이터 크기 계수

// 손실 추정 (정수 스케일)
fn loss_estimate(params_m: i64, tokens_m: i64) -> i64 {
    let n_factor: i64 = power_04(params_m)
    let d_factor: i64 = isqrt(isqrt(tokens_m))
    if n_factor == 0 { return LOSS_E + LOSS_A + LOSS_B }
    if d_factor == 0 { return LOSS_E + LOSS_A + LOSS_B }
    let loss: i64 = LOSS_E + LOSS_A / n_factor + LOSS_B / d_factor
    return loss
}

// ════════════════════════════════════════════════════════════════════
// 4) 스케일링 효율성 검증
//    동일 FLOPs 에서 Chinchilla vs 대안 비교
// ════════════════════════════════════════════════════════════════════

fn chinchilla_wins(params_m: i64) -> bool {
    let opt_tokens: i64 = optimal_tokens(params_m)
    let chinchilla_loss: i64 = loss_estimate(params_m, opt_tokens)
    // 대안 1: 모델 2배, 데이터 절반
    let big_model_loss: i64 = loss_estimate(params_m * 2, opt_tokens / 2)
    // 대안 2: 모델 절반, 데이터 2배
    let big_data_loss: i64 = loss_estimate(params_m / 2, opt_tokens * 2)
    return chinchilla_loss <= big_model_loss && chinchilla_loss <= big_data_loss
}

// ════════════════════════════════════════════════════════════════════
// 5) 토큰/파라미터 비율 일관성 검증
// ════════════════════════════════════════════════════════════════════

fn ratio_consistency() -> bool {
    let expected_ratio: i64 = sigma(N_CORE) / phi(N_CORE)
    let stages: i64 = sopfr(N_CORE)
    let mut consistent: bool = true
    let mut s: i64 = 0
    while s < stages {
        let params: i64 = model_size(s)
        let tokens: i64 = optimal_tokens(params)
        if tokens / params != expected_ratio { consistent = false }
        s = s + 1
    }
    return consistent
}

// ════════════════════════════════════════════════════════════════════
// 6) FLOPs 스케일링 곡선 — 6^k 단계별
// ════════════════════════════════════════════════════════════════════

fn flops_scaling_monotone() -> bool {
    let stages: i64 = sopfr(N_CORE)
    let mut prev_flops: i64 = 0
    let mut prev_loss: i64 = 999999
    let mut ok: bool = true
    let mut s: i64 = 0
    while s < stages {
        let params: i64 = model_size(s)
        let tokens: i64 = optimal_tokens(params)
        let flops: i64 = compute_flops(params, tokens)
        let loss: i64 = loss_estimate(params, tokens)
        if s > 0 {
            if flops <= prev_flops { ok = false }
        }
        if loss > prev_loss { ok = false }
        prev_flops = flops
        prev_loss = loss
        s = s + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 7) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)
    let ratio: i64 = sig / ph

    println("═══ Chinchilla 스케일링 법칙 x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 토큰/파라미터 비율 = σ/φ = 6
    let g2: bool = ratio == N_CORE
    println("G2 비율=σ/φ=6               : " + g2)

    // G3: 스케일링 단계 = sopfr(6) = 5
    let g3: bool = sf == 5
    println("G3 단계=sopfr=5             : " + g3)

    // G4: 비율 일관성 (모든 단계)
    let g4: bool = ratio_consistency()
    println("G4 비율 일관성              : " + g4)

    // G5: Chinchilla 최적성 (6M 기준)
    let g5: bool = chinchilla_wins(N_CORE)
    println("G5 Chinchilla 최적성        : " + g5)

    // G6: FLOPs/손실 스케일링 단조성
    let g6: bool = flops_scaling_monotone()
    println("G6 스케일링 단조성          : " + g6)

    // G7: 기본 모델 = 6M
    let base: i64 = model_size(0)
    let g7: bool = base == N_CORE
    println("G7 기본모델=6M              : " + g7)

    // G8: 최대 모델 = 6^5 = 7776M
    let max_model: i64 = model_size(sf - 1)
    let g8: bool = max_model == 7776
    println("G8 최대모델=7776M           : " + g8)

    // G9: FLOPs 계수 = 6
    let flops_base: i64 = compute_flops(1, 1)
    let g9: bool = flops_base == N_CORE
    println("G9 FLOPs계수=6              : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    let mut s: i64 = 0
    while s < sf {
        let p: i64 = model_size(s)
        let tok: i64 = optimal_tokens(p)
        let fl: i64 = compute_flops(p, tok)
        println("단계" + s + ": " + p + "M 파라미터 / " + tok + "M 토큰 / " + fl + "M FLOPs")
        s = s + 1
    }

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Chinchilla OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("Chinchilla FAIL: 게이트 위반")
    }
}
