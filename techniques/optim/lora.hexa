// optim/lora.hexa -- 저랭크 적응 (Low-Rank Adaptation) x n=6 정식 본문
//
// 포팅 상태: BODY (의존 없음 -- 순수 정수/실수 연산)
// 원본 요약: Technique: LoRA -- Hu 외 2021
//            "LoRA: Low-Rank Adaptation of Large Language Models" (ICLR 2022),
//            Dettmers 외 2023 "QLoRA",
//            Liu 외 2024 "DoRA: Weight-Decomposed Low-Rank Adaptation"
//            사전학습 가중치 동결, 저랭크 분해 DeltaW=BA만 학습
// n=6 정렬:
//   - 랭크               = n = 6            -> LoRA 랭크 r
//   - 알파 스케일          = sigma(6) = 12       -> alpha/r 스케일링
//   - 타겟 모듈 수         = tau(6) = 4        -> Q,K,V,O 적용
//   - 드롭아웃 팩터        = sopfr(6) = 5   -> 드롭아웃 비율 기저
//   - 병합 가중치          = phi(6) = 2        -> 머지 스텝
//   - 은닉 차원            = sigma(6)^2 = 144    -> 원본 차원 d
//
// 실행: hexa run techniques/optim/lora.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ── 1) n=6 산술 함수 (EXACT) ──────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ── 2) LoRA 핵심 상수 ─────────────────────────────────────

const N_CORE: i64 = 6
const SCALE: i64 = 1000

// n=6 유도 상수
const RANK: i64 = 6              // n = 6 -- LoRA 랭크 r
const ALPHA_SCALE: i64 = 12      // sigma(6) = 12 -- alpha 스케일링
const TARGET_MODULES: i64 = 4    // tau(6) = 4 -- Q,K,V,O 모듈
const DROPOUT_FACTOR: i64 = 5    // sopfr(6) = 5 -- 드롭아웃 기저
const MERGE_STEPS: i64 = 2       // phi(6) = 2 -- 머지 스텝
const HIDDEN_DIM: i64 = 144      // sigma(6)^2 = 144 -- 원본 차원 d

// 학습 파라미터
const LR: i64 = 10               // 0.01 * SCALE
const EPOCHS: i64 = 12           // sigma(6) = 12
const BATCH_SIZE: i64 = 6        // n = 6

// ── 3) 저랭크 분해 -- B(d x r) dot A(r x d) 초기화 ──────────

// A 행렬 초기화: 가우시안 근사 (작은 값)
fn init_A(row: i64, col: i64) -> i64 {
    // A: r x d 행렬, 가우시안 초기화
    let val: i64 = ((row * 41 + col * 67 + 13) % 201) - 100
    return val * SCALE / 1000
}

// B 행렬 초기화: 영행렬 (표준 LoRA)
fn init_B(row: i64, col: i64) -> i64 {
    // B: d x r 행렬, 영행렬 초기화 -> DeltaW 초기값 = 0
    return 0
}

// 동결 가중치: 사전학습된 W_frozen (변경 불가)
fn frozen_weight(row: i64, col: i64) -> i64 {
    // 결정적 의사난수 사전학습 가중치
    let val: i64 = ((row * 37 + col * 53 + 7) % 301) - 150
    return val * SCALE / 150
}

// B*A 행렬곱의 (row, col) 원소 계산
fn compute_BA(row: i64, col: i64, b_scale: i64) -> i64 {
    // BA[row][col] = sum_k B[row][k] * A[k][col]
    let mut dot: i64 = 0
    let mut k: i64 = 0
    while k < RANK {
        let b_val: i64 = init_B(row, k) + b_scale * ((row + k * 3) % 10 - 5)
        let a_val: i64 = init_A(k, col)
        dot = dot + (b_val * a_val) / SCALE
        k = k + 1
    }
    return dot
}

// ── 4) 순전파 -- W_frozen + (alpha/r) dot BA ────────────────

// 스케일링 팩터: alpha / r = 12 / 6 = 2
fn lora_scaling() -> i64 {
    return (ALPHA_SCALE * SCALE) / RANK
}

// 단일 원소 순전파: W + (alpha/r)*BA
fn forward_element(row: i64, col: i64, b_scale: i64) -> i64 {
    let w: i64 = frozen_weight(row, col)
    let ba: i64 = compute_BA(row, col, b_scale)
    let scale_factor: i64 = lora_scaling()
    let delta: i64 = (ba * scale_factor) / SCALE
    return w + delta
}

// 벡터 순전파: 입력 벡터와 LoRA 적용된 가중치 곱
fn forward_pass(input_idx: i64, b_scale: i64) -> i64 {
    let mut output: i64 = 0
    let mut col: i64 = 0
    while col < N_CORE {
        let input_val: i64 = (input_idx * 10 + col * 7 + 50) % 200
        let w_lora: i64 = forward_element(0, col, b_scale)
        output = output + (input_val * w_lora) / SCALE
        col = col + 1
    }
    return output
}

// 드롭아웃 적용 (결정적 시뮬레이션)
fn apply_dropout(val: i64, idx: i64) -> i64 {
    // 드롭아웃 비율 = DROPOUT_FACTOR / 100 = 5%
    let drop_check: i64 = (idx * 31 + 11) % 100
    if drop_check < DROPOUT_FACTOR {
        return 0  // 드롭
    }
    // 스케일 보상: val / (1 - dropout_rate)
    let compensated: i64 = (val * 100) / (100 - DROPOUT_FACTOR)
    return compensated
}

// ── 5) 그래디언트 -- A,B만 갱신 ─────────────────────────────

// 손실 계산: L2
fn compute_loss(pred: i64, target: i64) -> i64 {
    let diff: i64 = pred - target
    return (diff * diff) / SCALE
}

// A 그래디언트 근사
fn grad_A(row: i64, col: i64, loss: i64) -> i64 {
    // dL/dA ~= B^T * dL/dY * x^T (단순화)
    let grad: i64 = (loss * (row + 1)) / (SCALE * RANK)
    return grad
}

// B 그래디언트 근사
fn grad_B(row: i64, col: i64, loss: i64) -> i64 {
    // dL/dB ~= dL/dY * x^T * A^T (단순화)
    let grad: i64 = (loss * (col + 1)) / (SCALE * RANK)
    return grad
}

// A 업데이트
fn update_A(old_val: i64, grad: i64) -> i64 {
    let updated: i64 = old_val - (LR * grad) / SCALE
    return updated
}

// B 업데이트
fn update_B(old_val: i64, grad: i64) -> i64 {
    let updated: i64 = old_val - (LR * grad) / SCALE
    return updated
}

// ── 6) 모듈별 적용 -- Q,K,V,O 4개 모듈 ─────────────────────

// 모듈 ID: 0=Q, 1=K, 2=V, 3=O
fn module_name_id(mod_id: i64) -> i64 {
    // Q=0, K=1, V=2, O=3
    return mod_id % TARGET_MODULES
}

// 모듈별 LoRA 순전파
fn module_forward(mod_id: i64, input_idx: i64, b_scale: i64) -> i64 {
    // 모듈마다 다른 가중치 오프셋
    let offset: i64 = mod_id * HIDDEN_DIM / TARGET_MODULES
    let shifted_input: i64 = input_idx + offset
    let output: i64 = forward_pass(shifted_input, b_scale + mod_id)
    return output
}

// 전체 어텐션 모듈 LoRA 적용
fn attention_lora(input_idx: i64, b_scale: i64) -> i64 {
    let mut total: i64 = 0
    let mut mod_id: i64 = 0
    while mod_id < TARGET_MODULES {
        let out: i64 = module_forward(mod_id, input_idx, b_scale)
        let dropped: i64 = apply_dropout(out, mod_id + input_idx)
        total = total + dropped
        mod_id = mod_id + 1
    }
    // 모듈 평균
    return total / TARGET_MODULES
}

// LoRA 가중치 병합: W_merged = W_frozen + (alpha/r)*BA
fn merge_weights(row: i64, col: i64, b_scale: i64) -> i64 {
    let merged: i64 = forward_element(row, col, b_scale)
    return merged
}

// 병합 실행: MERGE_STEPS=2 단계로 점진적 병합
fn gradual_merge(b_scale: i64) -> i64 {
    let mut merge_sum: i64 = 0
    let mut step: i64 = 0
    while step < MERGE_STEPS {
        let partial_scale: i64 = (b_scale * (step + 1)) / MERGE_STEPS
        let mut r: i64 = 0
        while r < N_CORE {
            let merged: i64 = merge_weights(r, 0, partial_scale)
            merge_sum = merge_sum + abs_val(merged)
            r = r + 1
        }
        step = step + 1
    }
    return merge_sum / (MERGE_STEPS * N_CORE)
}

// ── 7) 학습 루프 ─────────────────────────────────────────

// 전체 학습 루프
fn training_loop() -> i64 {
    let mut total_loss: i64 = 0
    let mut epoch: i64 = 0
    let mut b_scale: i64 = 1  // B 학습 진행도

    while epoch < EPOCHS {
        let mut epoch_loss: i64 = 0
        let mut batch: i64 = 0
        while batch < BATCH_SIZE {
            let input_idx: i64 = (batch * 47 + epoch * 13 + 100) % 500
            let target: i64 = (input_idx * 3 + 50) % 500
            // 전체 어텐션 LoRA 순전파
            let pred: i64 = attention_lora(input_idx, b_scale)
            let loss: i64 = compute_loss(pred, target)
            epoch_loss = epoch_loss + loss
            batch = batch + 1
        }
        // B 스케일 점진 증가 (학습 진행)
        b_scale = b_scale + 1
        total_loss = total_loss + epoch_loss / BATCH_SIZE
        epoch = epoch + 1
    }
    return total_loss / EPOCHS
}

// ── 8) 파라미터 효율 측정 ────────────────────────────────

// 전체 파라미터 수: d*d (동결)
fn total_frozen_params() -> i64 {
    return HIDDEN_DIM * HIDDEN_DIM
}

// LoRA 학습 파라미터 수: (d*r + r*d) * 모듈수
fn lora_trainable_params() -> i64 {
    // A: r x d = 6 x 144 = 864
    // B: d x r = 144 x 6 = 864
    // 모듈당 = 1728, 4 모듈 = 6912
    let per_module: i64 = RANK * HIDDEN_DIM * 2
    return per_module * TARGET_MODULES
}

// 파라미터 효율비: 학습 파라미터 / 전체 파라미터
fn param_efficiency() -> i64 {
    let total: i64 = total_frozen_params()
    let trainable: i64 = lora_trainable_params()
    if total == 0 { return 0 }
    // 비율 (SCALE 기반)
    let ratio: i64 = (trainable * SCALE) / total
    return ratio
}

// 메모리 절감률: 1 - (학습 파라미터 / 전체)
fn memory_savings() -> i64 {
    let efficiency: i64 = param_efficiency()
    return SCALE - efficiency
}

// 랭크 대비 성능: 랭크별 기여도
fn rank_contribution(r: i64) -> i64 {
    // 각 랭크의 특이값 근사: 감소하는 기여도
    let singular: i64 = SCALE / (r + 1)
    return singular
}

// 누적 분산 설명률
fn cumulative_variance() -> i64 {
    let mut total_var: i64 = 0
    let mut captured_var: i64 = 0
    let mut r: i64 = 0
    while r < HIDDEN_DIM {
        let contrib: i64 = rank_contribution(r)
        total_var = total_var + contrib
        if r < RANK {
            captured_var = captured_var + contrib
        }
        r = r + 1
    }
    if total_var == 0 { return 0 }
    return (captured_var * SCALE) / total_var
}

// ── main ─────────────────────────────────────────────────

fn main() {
    println("=== 저랭크 적응 (LoRA) x n=6 ===")
    println("")

    // G1: sigma(6) = 12
    let s6: i64 = sigma(N_CORE)
    let g1: bool = s6 == 12
    println("G1 sigma(6)=12: " + g1)

    // G2: tau(6) = 4
    let t6: i64 = tau(N_CORE)
    let g2: bool = t6 == 4
    println("G2 tau(6)=4: " + g2)

    // G3: phi(6) = 2
    let p6: i64 = phi(N_CORE)
    let g3: bool = p6 == 2
    println("G3 phi(6)=2: " + g3)

    // G4: sigma*phi = n*tau -> 12*2 = 6*4 = 24
    let lhs: i64 = s6 * p6
    let rhs: i64 = N_CORE * t6
    let g4: bool = lhs == rhs
    println("G4 sigma*phi=n*tau (24=24): " + g4)

    // G5: 랭크=6=n 검증
    let g5: bool = RANK == N_CORE
    println("G5 RANK=n=6: " + g5)

    // G6: LoRA 순전파 동작 검증
    let fwd_out: i64 = attention_lora(100, 5)
    let g6: bool = fwd_out != 0
    println("G6 LoRA 순전파 비영: " + g6)
    println("   순전파 출력 = " + fwd_out)

    // G7: 점진적 병합 동작
    let merged: i64 = gradual_merge(5)
    let g7: bool = merged > 0
    println("G7 점진적 병합 동작: " + g7)
    println("   병합 평균 크기 = " + merged)

    // G8: 학습 루프 손실 유한
    let avg_loss: i64 = training_loop()
    let g8: bool = avg_loss >= 0
    println("G8 학습 평균손실 유한: " + g8)
    println("   평균 손실 = " + avg_loss)

    // G9: 파라미터 효율 + 메모리 절감
    let total: i64 = total_frozen_params()
    let trainable: i64 = lora_trainable_params()
    let efficiency: i64 = param_efficiency()
    let savings: i64 = memory_savings()
    let variance: i64 = cumulative_variance()
    let g9: bool = savings > 0
    println("G9 메모리 절감 양수: " + g9)
    println("   전체 파라미터 = " + total)
    println("   학습 파라미터 = " + trainable)
    println("   효율비 = " + efficiency + "/1000")
    println("   메모리 절감 = " + savings + "/1000")
    println("   분산 설명률 = " + variance + "/1000")

    // 최종 집계
    let mut pass: i64 = 0
    if g1 { pass = pass + 1 }
    if g2 { pass = pass + 1 }
    if g3 { pass = pass + 1 }
    if g4 { pass = pass + 1 }
    if g5 { pass = pass + 1 }
    if g6 { pass = pass + 1 }
    if g7 { pass = pass + 1 }
    if g8 { pass = pass + 1 }
    if g9 { pass = pass + 1 }
    println("")
    println("LoRA OSSIFIED: " + pass + "/9 -> [7]empirical -> [10*] 승격 후보")
}
