// optim/streaming_llm.hexa — StreamingLLM 어텐션 싱크 x n=6
//
// 원본 경로: techniques/optim/streaming_llm.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: StreamingLLM — n=6 Constant Verification
//            Xiao 외 2023, 무한 시퀀스 스트리밍 추론
//            어텐션 싱크: 초기 토큰 고정 + 슬라이딩 윈도우
//            KV 캐시 고정 크기 유지 → 무한 길이 추론
// n=6 정렬:
//   - 싱크 토큰 수 = φ(6) = 2      -> 2개 초기 토큰 고정
//   - 슬라이딩 윈도우 = σ(6) = 12   -> 12토큰 최근 윈도우
//   - 전체 KV 캐시 = σ(6)+φ(6) = 14 -> 14토큰 캐시
//   - 어텐션 헤드 = n = 6           -> 6헤드
//   - 스트림 단위 = τ(6) = 4        -> 4토큰씩 입력
//
// 실행: hexa run techniques/optim/streaming_llm.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) StreamingLLM 상수
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 1000
const SINK_TOKENS: i64 = 2     // φ(6) = 2 어텐션 싱크
const WINDOW_SIZE: i64 = 12    // σ(6) = 12 슬라이딩 윈도우
const CACHE_SIZE: i64 = 14     // SINK + WINDOW = 14
const NUM_HEADS: i64 = 6       // n = 6 헤드
const CHUNK_SIZE: i64 = 4      // τ(6) = 4 스트림 단위

// ════════════════════════════════════════════════════════════════════
// 3) KV 캐시 시뮬레이션
//    구조: [싱크0, 싱크1 | 최근_w0, ..., 최근_w11]
//    새 토큰 입력 시: 최근 윈도우 FIFO 갱신, 싱크 고정
// ════════════════════════════════════════════════════════════════════

// 스트림 위치 t에서 캐시에 있는 토큰 인덱스 집합 크기
fn cache_occupancy(stream_pos: i64) -> i64 {
    if stream_pos < CACHE_SIZE {
        return stream_pos + 1
    }
    return CACHE_SIZE  // 항상 14 유지
}

// 싱크 토큰 위치: 항상 0, 1
fn is_sink_token(token_idx: i64) -> bool {
    return token_idx < SINK_TOKENS
}

// 윈도우 토큰: 최근 WINDOW_SIZE 개
fn is_in_window(token_idx: i64, stream_pos: i64) -> bool {
    if stream_pos < CACHE_SIZE { return true }  // 아직 캐시 미충전
    let oldest: i64 = stream_pos - WINDOW_SIZE + 1
    return token_idx >= oldest
}

// 캐시에 있는지 (싱크 OR 윈도우)
fn is_cached(token_idx: i64, stream_pos: i64) -> bool {
    if is_sink_token(token_idx) { return true }
    return is_in_window(token_idx, stream_pos)
}

// ════════════════════════════════════════════════════════════════════
// 4) 어텐션 스코어 시뮬레이션
//    싱크 토큰: 높은 고정 스코어 (어텐션 앵커 역할)
//    윈도우 토큰: 거리 기반 감쇠
// ════════════════════════════════════════════════════════════════════

fn attention_score(query_pos: i64, key_pos: i64) -> i64 {
    if is_sink_token(key_pos) {
        // 싱크 토큰: 고정 높은 스코어
        return SCALE * 8 / 10  // 0.8
    }
    // 최근 토큰: 거리에 따라 감쇠
    let dist: i64 = abs_val(query_pos - key_pos)
    if dist == 0 { return SCALE }
    return SCALE / (1 + dist)
}

// 쿼리의 전체 어텐션 합 (캐시 내)
fn total_attention(query_pos: i64, stream_pos: i64) -> i64 {
    let mut total: i64 = 0
    // 싱크 토큰 어텐션
    let mut s: i64 = 0
    while s < SINK_TOKENS {
        total = total + attention_score(query_pos, s)
        s = s + 1
    }
    // 윈도우 토큰 어텐션
    let window_start: i64 = stream_pos - WINDOW_SIZE + 1
    let mut w: i64 = window_start
    if w < SINK_TOKENS { w = SINK_TOKENS }
    while w <= stream_pos {
        total = total + attention_score(query_pos, w)
        w = w + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 5) 싱크 비율 검증 — 싱크 어텐션이 전체의 유의미한 비중
// ════════════════════════════════════════════════════════════════════

fn sink_attention_pct(stream_pos: i64) -> i64 {
    let query: i64 = stream_pos
    let total: i64 = total_attention(query, stream_pos)
    if total == 0 { return 0 }
    // 싱크 어텐션 합
    let mut sink_total: i64 = 0
    let mut s: i64 = 0
    while s < SINK_TOKENS {
        sink_total = sink_total + attention_score(query, s)
        s = s + 1
    }
    return sink_total * 100 / total
}

// ════════════════════════════════════════════════════════════════════
// 6) 메모리 절감 — 고정 캐시 vs 전체 시퀀스
// ════════════════════════════════════════════════════════════════════

fn memory_savings_pct(stream_len: i64) -> i64 {
    if stream_len <= CACHE_SIZE { return 0 }
    return (stream_len - CACHE_SIZE) * 100 / stream_len
}

// ════════════════════════════════════════════════════════════════════
// 7) 청크 처리 — τ(6)=4 토큰씩 스트림 입력
//    각 청크 처리 후 캐시 갱신
// ════════════════════════════════════════════════════════════════════

fn chunks_processed(stream_len: i64) -> i64 {
    return stream_len / CHUNK_SIZE
}

fn cache_stable_after_fill() -> bool {
    // 캐시 충전 후 크기 불변 검증
    let start: i64 = CACHE_SIZE
    let end: i64 = CACHE_SIZE + CHUNK_SIZE * 10  // 40토큰 더
    let mut stable: bool = true
    let mut pos: i64 = start
    while pos < end {
        if cache_occupancy(pos) != CACHE_SIZE { stable = false }
        pos = pos + 1
    }
    return stable
}

// ════════════════════════════════════════════════════════════════════
// 8) PPL (혼란도) 안정성 — 긴 시퀀스에서 품질 유지
//    attn 합이 일정 범위 유지 = PPL 안정
// ════════════════════════════════════════════════════════════════════

fn ppl_stable(stream_len: i64) -> bool {
    let check_start: i64 = CACHE_SIZE * 2
    let check_end: i64 = stream_len
    if check_end <= check_start { return true }

    let ref_attn: i64 = total_attention(check_start, check_start)
    let mut stable: bool = true
    let mut pos: i64 = check_start
    while pos < check_end {
        let attn: i64 = total_attention(pos, pos)
        // 참조 대비 50% 이상 변동이면 불안정
        let diff: i64 = abs_val(attn - ref_attn)
        if diff * 2 > ref_attn { stable = false }
        pos = pos + CHUNK_SIZE
    }
    return stable
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    let stream_len: i64 = sig * sig * sig  // 12^3 = 1728 긴 시퀀스

    println("═══ StreamingLLM x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 싱크 토큰 = φ(6) = 2
    let g2: bool = SINK_TOKENS == ph
    println("G2 싱크=φ=2                 : " + g2)

    // G3: 윈도우 = σ(6) = 12
    let g3: bool = WINDOW_SIZE == sig
    println("G3 윈도우=σ=12              : " + g3)

    // G4: 캐시 = σ+φ = 14
    let g4: bool = CACHE_SIZE == sig + ph
    println("G4 캐시=σ+φ=14             : " + g4)

    // G5: 청크 = τ(6) = 4
    let g5: bool = CHUNK_SIZE == t
    println("G5 청크=τ=4                : " + g5)

    // G6: 캐시 안정성 (충전 후 크기 불변)
    let g6: bool = cache_stable_after_fill()
    println("G6 캐시안정                 : " + g6)

    // G7: 메모리 절감 > 90%
    let mem_save: i64 = memory_savings_pct(stream_len)
    let g7: bool = mem_save > 90
    println("G7 메모리절감=" + mem_save + "%     : " + g7)

    // G8: PPL 안정 (긴 시퀀스)
    let test_len: i64 = CACHE_SIZE * 10  // 140
    let g8: bool = ppl_stable(test_len)
    println("G8 PPL안정                  : " + g8)

    // G9: 싱크 어텐션 비중 > 0%
    let sink_pct: i64 = sink_attention_pct(stream_len)
    let g9: bool = sink_pct > 0
    println("G9 싱크비중=" + sink_pct + "%       : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("스트림: " + stream_len + " 토큰")
    println("캐시: " + CACHE_SIZE + " (싱크 " + SINK_TOKENS + " + 윈도우 " + WINDOW_SIZE + ")")
    println("청크: " + CHUNK_SIZE + " 토큰 / 처리횟수: " + chunks_processed(stream_len))
    println("메모리 절감: " + mem_save + "%")
    println("싱크 어텐션: " + sink_pct + "%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("StreamingLLM OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("StreamingLLM FAIL: 게이트 위반")
    }
}
