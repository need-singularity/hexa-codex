// speculative_decoding.hexa — Speculative Decoding × n=6 정식 본문
//
// 원본 경로: techniques/optim/speculative_decoding.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Speculative Decoding — n=6 상수 검증
//            Draft 모델이 n=6 토큰 예측 → Target 모델이 일괄 검증
//            수용률 α에 따라 1+α·n 배 가속
// n=6 정렬:
//   - 추측 길이     = n = 6           → draft 토큰 수
//   - Draft 크기    = 1/σ 스케일      → Target 의 1/12 파라미터
//   - 수용 임계     = φ/τ = 1/2       → 확률 비율 임계
//   - 평균 수용     = τ(6) = 4        → 6중 4 수용 (이상적)
//   - 가속 배수     = 1 + 4/6 = 5/3   → 이론적 가속
//   - 배치 크기     = σ·τ = 48        → 동시 검증 단위
//
// 실행: hexa run techniques/optim/speculative_decoding.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Speculative Decoding 스펙
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const SPEC_LEN:     i64 = 6     // n = 추측 길이
const ACCEPT_THRESH: i64 = 500  // φ/τ × 1000 = 1/2 × 1000
const BATCH:        i64 = 48    // σ·τ

// ════════════════════════════════════════════════════════════════════
// 3) Draft 모델 시뮬 — 토큰 예측
//    Draft 확률 p_d[i], Target 확률 p_t[i]
//    수용 조건: p_t[i] / p_d[i] >= threshold
//    정수 시뮬: 확률 = 밀리 단위 (0~1000)
// ════════════════════════════════════════════════════════════════════

fn draft_prob(token_pos: i64) -> i64 {
    // Draft 확률: 초기 위치일수록 높음 (자신감 감소)
    // p_d = 1000 - token_pos × (1000/n) × (1/3)
    // 위치 0: 944, 위치 5: 722
    return 1000 - (token_pos * 1000) / (N_CORE * 3)
}

fn target_prob(token_pos: i64) -> i64 {
    // Target 확률: Draft보다 약간 높거나 비슷
    // p_t = 800 - token_pos × 50
    return 800 - token_pos * 50
}

fn accept_token(pos: i64) -> bool {
    let pd: i64 = draft_prob(pos)
    let pt: i64 = target_prob(pos)
    // 수용: pt/pd >= threshold (0.5)
    // 정수: pt × 1000 >= pd × ACCEPT_THRESH
    return pt * 1000 >= pd * ACCEPT_THRESH
}

// ════════════════════════════════════════════════════════════════════
// 4) 수용 시퀀스 — 첫 거부까지 연속 수용 수
// ════════════════════════════════════════════════════════════════════

fn accepted_length() -> i64 {
    let mut acc: i64 = 0
    let mut pos: i64 = 0
    while pos < SPEC_LEN {
        if accept_token(pos) {
            acc = acc + 1
        } else {
            return acc
        }
        pos = pos + 1
    }
    return acc
}

// ════════════════════════════════════════════════════════════════════
// 5) 가속 배수 계산 — (1 + accepted/spec_len)
//    이상적: 4/6 수용 → 1 + 4/6 = 5/3 ≈ 1.67x
//    정수: (spec_len + accepted) × 100 / spec_len
// ════════════════════════════════════════════════════════════════════

fn speedup_pct(accepted: i64) -> i64 {
    return ((SPEC_LEN + accepted) * 100) / SPEC_LEN
}

// ════════════════════════════════════════════════════════════════════
// 6) Draft/Target 크기 비율
//    Draft = Target / σ(6) → 12배 작음
//    Draft 연산 비용 ≈ 1/σ² = 1/144
// ════════════════════════════════════════════════════════════════════

fn draft_cost_ratio() -> i64 {
    let sig: i64 = sigma(N_CORE)
    return (1000) / (sig * sig)   // 1/144 × 1000 ≈ 6
}

// ════════════════════════════════════════════════════════════════════
// 7) 다중 추측 라운드 시뮬 — 총 생성 토큰/라운드
// ════════════════════════════════════════════════════════════════════

fn tokens_per_round(n_rounds: i64) -> i64 {
    // 각 라운드: accepted + 1 (target에서 1토큰 추가)
    let acc: i64 = accepted_length()
    return n_rounds * (acc + 1)
}

fn rounds_for_target(target_tokens: i64) -> i64 {
    let per_round: i64 = accepted_length() + 1
    let rounds: i64 = target_tokens / per_round
    if rounds * per_round < target_tokens {
        return rounds + 1
    }
    return rounds
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Speculative Decoding × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 추측 길이 = n = 6
    let g2: bool = SPEC_LEN == N_CORE
    println("G2 추측길이=n=6             : " + g2)

    // G3: 수용 임계 = φ/τ = 1/2 (500/1000)
    let g3: bool = ACCEPT_THRESH == (ph * 1000) / t
    println("G3 임계=φ/τ=0.5             : " + g3)

    // G4: 배치 = σ·τ = 48
    let g4: bool = BATCH == sig * t
    println("G4 배치=σ·τ=48              : " + g4)

    // G5: 수용 길이 > 0 (최소 1토큰 수용)
    let acc: i64 = accepted_length()
    let g5: bool = acc > 0
    println("G5 수용=" + acc + "/" + SPEC_LEN + "              : " + g5)

    // G6: 가속 > 100% (순수 autoregressive 대비)
    let speed: i64 = speedup_pct(acc)
    let g6: bool = speed > 100
    println("G6 가속=" + speed + "%                : " + g6)

    // G7: Draft 비용 < Target 의 1%
    let cost: i64 = draft_cost_ratio()
    let g7: bool = cost < 10   // 1/144 = 0.69%
    println("G7 Draft비용=" + cost + "/1000        : " + g7)

    // G8: 48토큰 생성에 필요한 라운드 수
    let rounds: i64 = rounds_for_target(BATCH)
    let g8: bool = rounds > 0 && rounds < BATCH
    println("G8 " + BATCH + "토큰→" + rounds + "라운드          : " + g8)

    // 벤치마크
    let tpr: i64 = tokens_per_round(1)
    println("--- 벤치마크 ---")
    println("추측: " + SPEC_LEN + " 토큰/라운드")
    println("수용: " + acc + "/" + SPEC_LEN + " (수용률 " + ((acc * 100) / SPEC_LEN) + "%)")
    println("가속: " + speed + "% (vs autoregressive)")
    println("토큰/라운드: " + tpr)
    println("48토큰 생성: " + rounds + " 라운드")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8
    if all_pass {
        println("SPEC-DEC OSSIFIED: 8/8  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("SPEC-DEC PARTIAL: 게이트 일부 위반")
    }
}
