// optim/predictive_early_stop.hexa — 예측 기반 조기 종료 x n=6
//
// 원본 경로: techniques/optim/predictive_early_stop.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique #22: Predictive EarlyStop (PES)
//            학습 곡선 외삽으로 최적 종료점 예측
//            과적합 직전 정밀 종료 — 검증 손실 기반
// n=6 정렬:
//   - 관측 윈도우 = σ(6) = 12     -> 12에폭 관측
//   - 예측 지평 = n = 6            -> 6에폭 앞 예측
//   - 다항식 차수 = τ(6) = 4       -> 4차 피팅
//   - 인내심 = sopfr(6) = 5        -> 5에폭 대기
//   - 최소 관측 = φ(6) = 2         -> 2에폭 최소 데이터
//
// 실행: hexa run techniques/optim/predictive_early_stop.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) 예측 조기 종료 상수
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 10000
const OBSERVE_W: i64 = 12     // σ(6) 관측 윈도우
const PREDICT_H: i64 = 6      // n 예측 지평
const POLY_DEG: i64 = 4       // τ(6) 다항식 차수
const PATIENCE: i64 = 5       // sopfr(6) 인내심
const MAX_EPOCHS: i64 = 72    // σ(6) * n

// ════════════════════════════════════════════════════════════════════
// 3) 학습 곡선 시뮬레이션
//    검증 손실: 초기 감소 → 최저점 → 과적합 증가
//    loss(e) = base / (1 + e/decay) + overfit * e^2 / total^2
// ════════════════════════════════════════════════════════════════════

fn validation_loss(epoch: i64) -> i64 {
    // 감소 항: SCALE * 6 / (6 + epoch)
    let decrease: i64 = SCALE * N_CORE / (N_CORE + epoch)
    // 과적합 항: epoch^2 / (MAX_EPOCHS * 2)
    let overfit: i64 = epoch * epoch / (MAX_EPOCHS * 2)
    return decrease + overfit
}

fn training_loss(epoch: i64) -> i64 {
    // 학습 손실: 단조 감소 (과적합 반영 안됨)
    return SCALE * N_CORE / (N_CORE + epoch + epoch / 3)
}

// ════════════════════════════════════════════════════════════════════
// 4) 학습 곡선 외삽 — 선형 추세 기반 예측
//    최근 OBSERVE_W 에폭의 추세로 PREDICT_H 앞 손실 예측
// ════════════════════════════════════════════════════════════════════

fn predicted_loss(current_epoch: i64) -> i64 {
    if current_epoch < phi(N_CORE) { return SCALE * 10 }  // 데이터 부족

    // 선형 추세: (loss[current] - loss[current-window]) / window
    let window: i64 = phi(N_CORE)  // 2
    let loss_now: i64 = validation_loss(current_epoch)
    let loss_prev: i64 = validation_loss(current_epoch - window)
    let trend: i64 = (loss_now - loss_prev)  // 양수면 악화

    // 예측: loss_now + trend * PREDICT_H / window
    return loss_now + trend * PREDICT_H / window
}

// ════════════════════════════════════════════════════════════════════
// 5) 최적 종료점 탐색
//    예측 손실이 현재보다 악화되면 카운트 증가
//    PATIENCE 연속 악화 시 종료
// ════════════════════════════════════════════════════════════════════

fn find_optimal_stop() -> i64 {
    let mut best_loss: i64 = SCALE * 100
    let mut patience_count: i64 = 0

    let mut epoch: i64 = OBSERVE_W
    while epoch < MAX_EPOCHS {
        let current_loss: i64 = validation_loss(epoch)
        let future_loss: i64 = predicted_loss(epoch)

        if current_loss < best_loss {
            best_loss = current_loss
            patience_count = 0
        }

        // 미래 손실이 현재보다 악화되면 과적합 예측
        if future_loss > current_loss {
            patience_count = patience_count + 1
        } else {
            patience_count = 0
        }

        if patience_count >= PATIENCE {
            return epoch
        }
        epoch = epoch + 1
    }
    return MAX_EPOCHS
}

// ════════════════════════════════════════════════════════════════════
// 6) 절감율 + 품질 검증
// ════════════════════════════════════════════════════════════════════

fn savings_pct(stop: i64) -> i64 {
    return (MAX_EPOCHS - stop) * 100 / MAX_EPOCHS
}

// 실제 최적점 (검증 손실 최솟값)
fn true_optimal_epoch() -> i64 {
    let mut best: i64 = SCALE * 100
    let mut best_epoch: i64 = 0
    let mut e: i64 = 0
    while e < MAX_EPOCHS {
        let loss: i64 = validation_loss(e)
        if loss < best {
            best = loss
            best_epoch = e
        }
        e = e + 1
    }
    return best_epoch
}

// 예측 종료점과 실제 최적점의 차이
fn prediction_error(pred_stop: i64) -> i64 {
    let true_opt: i64 = true_optimal_epoch()
    return abs_val(pred_stop - true_opt)
}

// ════════════════════════════════════════════════════════════════════
// 7) 과적합 갭 검증
//    train_loss << val_loss 이면 과적합
// ════════════════════════════════════════════════════════════════════

fn overfit_gap(epoch: i64) -> i64 {
    let train: i64 = training_loss(epoch)
    let val: i64 = validation_loss(epoch)
    if val > train {
        return (val - train) * 100 / val
    }
    return 0
}

fn overfit_detected_at_stop(stop: i64) -> bool {
    // 종료점에서 과적합 갭 > 0
    return overfit_gap(stop) > 0
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    println("═══ Predictive EarlyStop x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 관측 윈도우 = σ(6) = 12
    let g2: bool = OBSERVE_W == sig
    println("G2 관측윈도우=σ=12          : " + g2)

    // G3: 예측 지평 = n = 6
    let g3: bool = PREDICT_H == N_CORE
    println("G3 예측지평=n=6             : " + g3)

    // G4: 다항식 차수 = τ(6) = 4
    let g4: bool = POLY_DEG == t
    println("G4 다항식차수=τ=4           : " + g4)

    // G5: 인내심 = sopfr(6) = 5
    let g5: bool = PATIENCE == sf
    println("G5 인내심=sopfr=5           : " + g5)

    // G6: 조기 종료 발동
    let stop: i64 = find_optimal_stop()
    let g6: bool = stop < MAX_EPOCHS
    println("G6 종료epoch=" + stop + "<" + MAX_EPOCHS + "   : " + g6)

    // G7: 절감율 > 0%
    let saved: i64 = savings_pct(stop)
    let g7: bool = saved > 0
    println("G7 절감율=" + saved + "%          : " + g7)

    // G8: 예측 오차 < OBSERVE_W
    let err: i64 = prediction_error(stop)
    let g8: bool = err < OBSERVE_W
    println("G8 예측오차=" + err + "<" + OBSERVE_W + "     : " + g8)

    // G9: 종료점에서 과적합 감지
    let g9: bool = overfit_detected_at_stop(stop)
    println("G9 과적합감지              : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    let true_opt: i64 = true_optimal_epoch()
    println("예측 종료: epoch " + stop + " / 실제 최적: epoch " + true_opt)
    println("오차: " + err + " 에폭")
    println("절감: " + saved + "% (" + MAX_EPOCHS + " → " + stop + ")")
    println("과적합 갭: " + overfit_gap(stop) + "%")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("PES OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("PES FAIL: 게이트 위반")
    }
}
