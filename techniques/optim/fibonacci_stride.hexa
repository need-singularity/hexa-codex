// optim/fibonacci_stride.hexa — 피보나치 스트라이드 어텐션 x n=6
//
// 원본 경로: techniques/optim/fibonacci_stride.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 20: Fibonacci-Strided Attention
//            피보나치 수열 간격으로 어텐션 위치 선택
//            가까운 토큰은 촘촘, 먼 토큰은 듬성 — 자연 감쇠
// n=6 정렬:
//   - 시퀀스 길이 = σ(6)^2 = 144   -> 피보나치 F(12)=144 일치!
//   - 어텐션 헤드 = n = 6           -> 6헤드 병렬
//   - 윈도우 스텝 = τ(6) = 4        -> 초기 밀집 구간
//   - 최소 스트라이드 = φ(6) = 2    -> 첫 간격
//   - 피보나치 항 수 = σ(6) = 12    -> F(1)~F(12) 사용
//
// 실행: hexa run techniques/optim/fibonacci_stride.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 2) 피보나치 수열
//    F(1)=1, F(2)=1, F(3)=2, ..., F(12)=144
// ════════════════════════════════════════════════════════════════════

fn fib(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    if n == 2 { return 1 }
    let mut a: i64 = 1
    let mut b: i64 = 1
    let mut i: i64 = 3
    while i <= n {
        let c: i64 = a + b
        a = b
        b = c
        i = i + 1
    }
    return b
}

// 피보나치 합: F(1) + F(2) + ... + F(n) = F(n+2) - 1
fn fib_sum(n: i64) -> i64 {
    let mut total: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        total = total + fib(i)
        i = i + 1
    }
    return total
}

const N_CORE: i64 = 6
const SEQ_LEN: i64 = 144    // σ(6)^2 = F(12)

// ════════════════════════════════════════════════════════════════════
// 3) 피보나치 스트라이드 위치 선택
//    현재 위치에서 F(1), F(2), F(3)... 거리의 토큰에 어텐션
//    -> 가까운 곳 촘촘, 먼 곳 성긴 자연 패턴
// ════════════════════════════════════════════════════════════════════

// 쿼리 위치 q 에서 어텐션 대상 위치 수 (시퀀스 범위 내)
fn attended_positions(q: i64, num_fibs: i64) -> i64 {
    let mut count: i64 = 0
    let mut k: i64 = 1
    while k <= num_fibs {
        let offset: i64 = fib(k)
        // 뒤쪽 어텐션: q - offset >= 0
        if q - offset >= 0 { count = count + 1 }
        // 앞쪽 어텐션: q + offset < SEQ_LEN
        if q + offset < SEQ_LEN { count = count + 1 }
        k = k + 1
    }
    return count
}

// 전체 어텐션 밀도: 모든 쿼리의 어텐션 위치 합 / (SEQ_LEN^2)
fn total_attention_count(num_fibs: i64) -> i64 {
    let mut total: i64 = 0
    let mut q: i64 = 0
    while q < SEQ_LEN {
        total = total + attended_positions(q, num_fibs)
        q = q + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 4) 밀도 vs 전체 어텐션 비율
//    절감율 = 1 - fib_attention / full_attention
// ════════════════════════════════════════════════════════════════════

fn density_pct(num_fibs: i64) -> i64 {
    let fib_attn: i64 = total_attention_count(num_fibs)
    let full_attn: i64 = SEQ_LEN * SEQ_LEN
    return fib_attn * 100 / full_attn
}

fn savings_pct(num_fibs: i64) -> i64 {
    return 100 - density_pct(num_fibs)
}

// ════════════════════════════════════════════════════════════════════
// 5) 피보나치 - n=6 공명 검증
//    F(12) = 144 = σ(6)^2  (핵심 공명!)
//    F(6)  = 8   (피보나치 6번째)
//    Σ F(1..12) = F(14) - 1 = 376
// ════════════════════════════════════════════════════════════════════

fn fib_n6_resonance() -> bool {
    let sig: i64 = sigma(N_CORE)
    // F(σ(6)) = F(12) = 144 = σ(6)^2
    let f12: i64 = fib(sig)
    return f12 == sig * sig
}

// ════════════════════════════════════════════════════════════════════
// 6) 밀집 구간 검증 — 처음 τ(6)=4 토큰은 거의 전체 어텐션
// ════════════════════════════════════════════════════════════════════

fn dense_region_check() -> bool {
    let dense_window: i64 = tau(N_CORE)  // 4
    let num_fibs: i64 = sigma(N_CORE)    // 12
    // 중앙 위치의 밀집구간 어텐션: F(1)=1,F(2)=1 거리는 항상 접근 가능
    let mid: i64 = SEQ_LEN / 2
    let near_count: i64 = attended_positions(mid, dense_window)
    // 최소 dense_window 개 이상 접근
    return near_count >= dense_window
}

// ════════════════════════════════════════════════════════════════════
// 7) 어텐션 스코어 시뮬 — 거리 기반 감쇠
//    score(q,k) = SCALE / (1 + distance)
// ════════════════════════════════════════════════════════════════════

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn fib_attention_score(q: i64, num_fibs: i64) -> i64 {
    let mut total_score: i64 = 0
    let mut k: i64 = 1
    while k <= num_fibs {
        let offset: i64 = fib(k)
        if q - offset >= 0 {
            total_score = total_score + 1000 / (1 + offset)
        }
        if q + offset < SEQ_LEN {
            total_score = total_score + 1000 / (1 + offset)
        }
        k = k + 1
    }
    return total_score
}

// 스코어 단조 감소 검증: 중앙에서 가장 높고 가장자리 낮음
fn score_center_dominant() -> bool {
    let num_fibs: i64 = sigma(N_CORE)
    let center: i64 = SEQ_LEN / 2
    let edge: i64 = 0
    let center_score: i64 = fib_attention_score(center, num_fibs)
    let edge_score: i64 = fib_attention_score(edge, num_fibs)
    return center_score >= edge_score
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 검증
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)
    let num_fibs: i64 = sig  // σ(6) = 12 피보나치 항

    println("═══ Fibonacci Stride Attention x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: F(12) = 144 = σ(6)^2 공명
    let g2: bool = fib_n6_resonance()
    println("G2 F(12)=σ^2=144 공명       : " + g2)

    // G3: 시퀀스 길이 = σ^2 = 144
    let g3: bool = SEQ_LEN == sig * sig
    println("G3 seq_len=σ^2=144          : " + g3)

    // G4: 피보나치 항 수 = σ(6) = 12
    let g4: bool = num_fibs == 12
    println("G4 fib항수=σ=12             : " + g4)

    // G5: 어텐션 절감 > 50%
    let saved: i64 = savings_pct(num_fibs)
    let g5: bool = saved > 50
    println("G5 절감율=" + saved + "%          : " + g5)

    // G6: 밀집구간 검증
    let g6: bool = dense_region_check()
    println("G6 밀집구간(τ=4) 유효       : " + g6)

    // G7: 스코어 중앙 우세
    let g7: bool = score_center_dominant()
    println("G7 스코어 중앙우세          : " + g7)

    // G8: F(6) = 8
    let f6: i64 = fib(N_CORE)
    let g8: bool = f6 == 8
    println("G8 F(6)=8                   : " + g8)

    // G9: Σ F(1..12) = F(14)-1 = 376
    let fsum: i64 = fib_sum(sig)
    let f14m1: i64 = fib(sig + 2) - 1
    let g9: bool = fsum == f14m1
    println("G9 ΣF(1..12)=F(14)-1=" + fsum + " : " + g9)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("시퀀스: " + SEQ_LEN + " 토큰")
    println("피보나치 항: " + num_fibs + "개")
    println("밀도: " + density_pct(num_fibs) + "% / 절감: " + saved + "%")
    println("F(1..6): 1,1,2,3,5,8")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("Fibonacci Stride OSSIFIED: 9/9 → [10*] 승격 후보")
    } else {
        println("Fibonacci Stride FAIL: 게이트 위반")
    }
}
