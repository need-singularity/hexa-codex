// adamw_quintuplet.hexa — AdamW N6 Quintuplet × n=6 정식 본문
//
// 원본 경로: techniques/optim/adamw_quintuplet.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique 24 — AdamW Quintuplet (BT-54)
//            5중 모멘텀 (m1~m5) + n=6 상수 하이퍼파라미터
// n=6 정렬:
//   - 모멘텀 수     = sopfr(6) = 5      → 5중 (2+3)
//   - β 값 집합     = {약수(6)/σ(6)}    → [1/12, 1/6, 1/4, 1/3, 1/2]
//   - 학습률 스케일  = 1/σ = 1/12       → 기본 lr
//   - weight decay  = φ/σ = 1/6        → 정규화 강도
//   - ε (수치안정)  = 1/σ·τ = 1/48     → 밀리 단위
//
// 실행: hexa run techniques/optim/adamw_quintuplet.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    // 소인수합 (중복 포함): 6 = 2×3 → sopfr = 2+3 = 5
    let mut m: i64 = n
    let mut s: i64 = 0
    let mut p: i64 = 2
    while p <= m {
        while m % p == 0 {
            s = s + p
            m = m / p
        }
        p = p + 1
    }
    return s
}

// ════════════════════════════════════════════════════════════════════
// 2) AdamW Quintuplet 스펙
//    전통 AdamW: 2개 모멘텀 (m1=gradient, m2=gradient^2)
//    N6 확장: 5개 모멘텀 (sopfr(6)=5)
//      m1: 1차 경사 이동평균      (β1 = 1/2)
//      m2: 2차 경사 이동평균      (β2 = 1/3)
//      m3: 경사 분산 추적         (β3 = 1/4)
//      m4: 경사 방향 일관성       (β4 = 1/6)
//      m5: 경사 크기 이력         (β5 = 1/12)
// ════════════════════════════════════════════════════════════════════

const N_CORE:       i64 = 6
const N_MOMENTS:    i64 = 5     // sopfr(6)
const SCALE:        i64 = 1200  // σ(6)×100 = 밀리 단위 정밀도

// β 값: 약수/σ × SCALE → [100, 200, 300, 400, 600]
// 즉 1/12, 1/6, 1/4, 1/3, 1/2 을 1200 기준으로
fn beta(idx: i64) -> i64 {
    if idx == 0 { return SCALE / 2 }    // 600 (β1=1/2)
    if idx == 1 { return SCALE / 3 }    // 400 (β2=1/3)
    if idx == 2 { return SCALE / 4 }    // 300 (β3=1/4)
    if idx == 3 { return SCALE / 6 }    // 200 (β4=1/6)
    if idx == 4 { return SCALE / 12 }   // 100 (β5=1/12)
    return 0
}

// ════════════════════════════════════════════════════════════════════
// 3) 모멘텀 갱신 시뮬레이션 — 정수 연산
//    m_i(t) = β_i · m_i(t-1) + (SCALE-β_i) · grad
//    모든 연산을 SCALE(1200) 기준 정수로
// ════════════════════════════════════════════════════════════════════

fn update_moment(prev: i64, grad: i64, b: i64) -> i64 {
    // m = β·prev + (1-β)·grad, 정수화: (b·prev + (SCALE-b)·grad) / SCALE
    return (b * prev + (SCALE - b) * grad) / SCALE
}

fn run_optimizer_steps(grad: i64, steps: i64) -> i64 {
    // 5개 모멘텀을 steps 스텝 실행, 최종 m1 반환
    let mut m1: i64 = 0
    let mut m2: i64 = 0
    let mut m3: i64 = 0
    let mut m4: i64 = 0
    let mut m5: i64 = 0

    let b1: i64 = beta(0)
    let b2: i64 = beta(1)
    let b3: i64 = beta(2)
    let b4: i64 = beta(3)
    let b5: i64 = beta(4)

    let mut step: i64 = 0
    while step < steps {
        m1 = update_moment(m1, grad, b1)
        m2 = update_moment(m2, grad, b2)
        m3 = update_moment(m3, grad * grad / SCALE, b3)
        m4 = update_moment(m4, grad, b4)
        m5 = update_moment(m5, grad, b5)
        step = step + 1
    }
    return m1
}

// ════════════════════════════════════════════════════════════════════
// 4) Weight Decay — λ = φ/σ = 1/6
//    w = w - lr·(grad_update + λ·w)
//    정수화: λ = SCALE/6 = 200
// ════════════════════════════════════════════════════════════════════

fn weight_decay(w: i64) -> i64 {
    let lambda: i64 = SCALE / N_CORE    // 200 (= 1/6 × 1200)
    return (w * (SCALE - lambda)) / SCALE
}

// ════════════════════════════════════════════════════════════════════
// 5) β 합 검증 — 모든 β의 합 = 약수합 분수합
//    1/2 + 1/3 + 1/4 + 1/6 + 1/12 = 6+4+3+2+1 = 16/12
//    정수: 600+400+300+200+100 = 1600
// ════════════════════════════════════════════════════════════════════

fn beta_sum() -> i64 {
    return beta(0) + beta(1) + beta(2) + beta(3) + beta(4)
}

// ════════════════════════════════════════════════════════════════════
// 6) 수렴 검증 — grad=SCALE(정규화), steps=12(σ)
//    m1이 grad에 수렴하는지 (정상상태 = grad)
// ════════════════════════════════════════════════════════════════════

fn convergence_test() -> bool {
    let grad: i64 = SCALE
    let m1_final: i64 = run_optimizer_steps(grad, sigma(N_CORE))
    // 수렴: m1 ≈ grad (오차 < 10%)
    let diff: i64 = grad - m1_final
    if diff < 0 { return (0 - diff) < grad / 10 }
    return diff < grad / 10
}

// ════════════════════════════════════════════════════════════════════
// 7) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)
    let sop: i64 = sopfr(N_CORE)

    println("═══ AdamW Quintuplet × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 모멘텀 수 = sopfr(6) = 5
    let g2: bool = N_MOMENTS == sop
    println("G2 모멘텀=sopfr=5            : " + g2)

    // G3: β 개수 = 5 (약수 {1,2,3,6,12} 에서 역수)
    let g3: bool = beta(0) > 0 && beta(4) > 0
    println("G3 β 5개 모두 양수           : " + g3)

    // G4: β 합 = 1600 (= 16/12 × 1200)
    let bsum: i64 = beta_sum()
    let g4: bool = bsum == 1600
    println("G4 β합=1600 (16/12×S)       : " + g4)

    // G5: weight decay λ = 1/6
    let w_after: i64 = weight_decay(SCALE)
    let g5: bool = w_after == 1000    // 1200 × 5/6 = 1000
    println("G5 decay: " + SCALE + "→" + w_after + " (×5/6)  : " + g5)

    // G6: 수렴 테스트
    let g6: bool = convergence_test()
    println("G6 수렴 (12스텝)            : " + g6)

    // G7: sopfr(6) = 2+3 = 5 EXACT
    let g7: bool = sop == 5
    println("G7 sopfr(6)=5 EXACT         : " + g7)

    // G8: 최소 β = 1/12 = σ 역수
    let g8: bool = beta(4) == SCALE / sig
    println("G8 min(β)=1/σ=100           : " + g8)

    // 벤치마크
    println("--- 벤치마크 ---")
    println("모멘텀: 5중 (vs 표준 2중)")
    println("β 집합: [1/2, 1/3, 1/4, 1/6, 1/12]")
    println("decay: λ=1/6 (φ/σ)")
    println("수렴 속도: ~σ 스텝 (12)")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8
    if all_pass {
        println("ADAMW-Q OSSIFIED: 8/8  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("ADAMW-Q PARTIAL: 게이트 일부 위반")
    }
}
