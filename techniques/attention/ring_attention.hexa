// attention/ring_attention.hexa — Ring Attention x n=6 정식 본문
//
// 원본 경로: techniques/attention/ring_attention.py (git history 보존)
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique #23 — Liu 외 2023, "Ring Attention with Blockwise Transformers"
//            시퀀스를 노드 수만큼 분할, 링 토폴로지로 KV 블록 순환
//            시퀀스 길이 ∝ 노드 수 → 무한 컨텍스트 이론상 가능
// n=6 정렬:
//   - 노드 수       = n = 6       -> 링 크기
//   - 블록 크기     = σ(6) = 12   -> 노드당 토큰 수
//   - 전체 시퀀스   = 6·12 = 72   -> n·σ
//   - 통신 라운드   = n-1 = 5     -> 링 완전 순환
//   - KV 버퍼      = τ(6) = 4    -> 이중 버퍼 + 계산/통신 오버랩
//
// 실행: hexa run techniques/attention/ring_attention.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수 (정의에서 도출)
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

// ════════════════════════════════════════════════════════════════════
// 2) Ring Attention 스펙 (n=6 정렬)
//    6개 노드가 링 토폴로지: 0→1→2→3→4→5→0
//    각 노드는 자기 Q 블록 보유, KV 블록을 왼쪽 이웃에서 수신
//    5라운드 후 모든 노드가 전체 KV 열람 완료
// ════════════════════════════════════════════════════════════════════

const N_CORE:      i64 = 6
const N_NODES:     i64 = 6      // 링 노드 수 = n
const BLOCK_SIZE:  i64 = 12     // σ(6) = 노드당 토큰 수
const TOTAL_SEQ:   i64 = 72     // n · σ = 전체 시퀀스
const COMM_ROUNDS: i64 = 5      // n - 1 = 링 완전 순환
const KV_BUFFERS:  i64 = 4      // τ(6) = 이중 버퍼 쌍 수

// ════════════════════════════════════════════════════════════════════
// 3) 링 토폴로지 — 다음/이전 노드 계산
// ════════════════════════════════════════════════════════════════════

fn next_node(node: i64) -> i64 {
    return (node + 1) % N_NODES
}

fn prev_node(node: i64) -> i64 {
    return (node + N_NODES - 1) % N_NODES
}

// 링 거리: 노드 a → 노드 b 까지 최소 홉 수
fn ring_distance(a: i64, b: i64) -> i64 {
    let fwd: i64 = (b - a + N_NODES) % N_NODES
    let bwd: i64 = (a - b + N_NODES) % N_NODES
    if fwd < bwd { return fwd }
    return bwd
}

// ════════════════════════════════════════════════════════════════════
// 4) KV 블록 순환 시뮬레이션
//    각 라운드에서 노드 i 가 보유한 KV 블록 출처 추적
//    라운드 r 후: 노드 i 는 블록 i, (i-1)%6, ..., (i-r)%6 열람 완료
// ════════════════════════════════════════════════════════════════════

fn blocks_seen_after_round(r: i64) -> i64 {
    // 라운드 0 = 자기 블록 (1개), 라운드 r = r+1 개
    return r + 1
}

fn kv_source_at_round(node: i64, r: i64) -> i64 {
    // 라운드 r 에서 수신하는 KV 블록의 원래 소유자
    return (node - r + N_NODES * N_NODES) % N_NODES
}

// 전체 순환 완료 검증: 5라운드 후 모든 노드가 6블록 열람
fn full_circulation_check() -> bool {
    let mut ok: bool = true
    let mut node: i64 = 0
    while node < N_NODES {
        let seen: i64 = blocks_seen_after_round(COMM_ROUNDS)
        if seen != N_NODES { ok = false }
        node = node + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 5) 블록별 어텐션 스코어 — 노드 로컬 계산
//    노드 i 의 Q 블록: Q[t] = i·BLOCK + t (t=0..BLOCK-1)
//    KV 블록 j: K[t] = j·BLOCK + t
//    스코어 = sum(Q[s]·K[t]) (s,t 블록 내)
// ════════════════════════════════════════════════════════════════════

fn block_attn_score(q_node: i64, kv_node: i64) -> i64 {
    // 간이: Q 대표값 = q_node+1, K 대표값 = kv_node+1
    // 블록 내 상호작용 = BLOCK_SIZE^2 번 → 대표 스코어 * BLOCK^2
    let q_rep: i64 = q_node + 1
    let k_rep: i64 = kv_node + 1
    return q_rep * k_rep * BLOCK_SIZE
}

// 노드 0 이 전체 KV 순환 후 받는 총 스코어
fn total_score_node_0() -> i64 {
    let mut total: i64 = 0
    let mut kv: i64 = 0
    while kv < N_NODES {
        total = total + block_attn_score(0, kv)
        kv = kv + 1
    }
    return total
}

// ════════════════════════════════════════════════════════════════════
// 6) 통신/계산 오버랩 효율
//    이상: 통신 완전히 은닉 → 오버헤드 0%
//    실제: τ=4 버퍼로 파이프라인 → 오버헤드 ~ 1/(τ-1) = 33%
//    n=6 에서 유효 처리량 = (n-1)/n = 83%
// ════════════════════════════════════════════════════════════════════

fn overlap_efficiency_pct() -> i64 {
    // (N_NODES - 1) / N_NODES * 100
    return (N_NODES - 1) * 100 / N_NODES
}

fn pipeline_overhead_pct() -> i64 {
    // 1 / (τ-1) * 100 ≈ 33%
    let t: i64 = tau(N_CORE)
    return 100 / (t - 1)
}

// ════════════════════════════════════════════════════════════════════
// 7) 메모리 분석 — 분산 vs 단일
//    단일 노드: TOTAL_SEQ^2 · d = 72^2 · d
//    링 분산:   BLOCK_SIZE^2 · d = 12^2 · d (노드당)
//    메모리 절감 비율 = 1 - 1/N_NODES = 83%
// ════════════════════════════════════════════════════════════════════

fn memory_per_node() -> i64 {
    return BLOCK_SIZE * BLOCK_SIZE
}

fn memory_single() -> i64 {
    return TOTAL_SEQ * TOTAL_SEQ
}

fn memory_saving_pct() -> i64 {
    return (memory_single() - memory_per_node()) * 100 / memory_single()
}

// ════════════════════════════════════════════════════════════════════
// 8) 게이트 실행 + 벤치마크 출력
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t:   i64 = tau(N_CORE)
    let ph:  i64 = phi(N_CORE)

    println("═══ Ring Attention × n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2  (정의 도출)")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 노드 수 = n = 6
    let g2: bool = N_NODES == N_CORE
    println("G2 노드=n=6                 : " + g2)

    // G3: 블록 크기 = σ = 12
    let g3: bool = BLOCK_SIZE == sig
    println("G3 블록=σ=12                : " + g3)

    // G4: 전체 시퀀스 = n·σ = 72
    let g4: bool = TOTAL_SEQ == N_CORE * sig
    println("G4 시퀀스=n*σ=72            : " + g4)

    // G5: 통신 라운드 = n-1 = 5
    let g5: bool = COMM_ROUNDS == N_CORE - 1
    println("G5 라운드=n-1=5             : " + g5)

    // G6: 전체 순환 완료 검증
    let g6: bool = full_circulation_check()
    println("G6 전체순환 완료             : " + g6)

    // G7: 링 거리 대칭 (dist(0,3) = dist(3,0) = 3)
    let d03: i64 = ring_distance(0, 3)
    let d30: i64 = ring_distance(3, 0)
    let g7: bool = d03 == d30 && d03 == 3
    println("G7 링거리 대칭 d(0,3)=3     : " + g7)

    // G8: 오버랩 효율 > 80%
    let eff: i64 = overlap_efficiency_pct()
    let g8: bool = eff > 80
    println("G8 오버랩효율=" + eff + "% (>80%) : " + g8)

    // G9: 메모리 절감 > 90% (분산 대비 단일)
    let msave: i64 = memory_saving_pct()
    let g9: bool = msave > 90
    println("G9 메모리절감=" + msave + "% (>90%): " + g9)

    // 벤치마크 지표
    println("--- 벤치마크 ---")
    println("노드당 메모리: " + memory_per_node() + " (단일: " + memory_single() + ")")
    println("파이프라인 오버헤드: ~" + pipeline_overhead_pct() + "%")
    println("최대 시퀀스 길이: 노드 수에 비례 (무한 확장)")
    println("노드0 총스코어: " + total_score_node_0())

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("RING OSSIFIED: 9/9  →  [7]empirical → [10*] 승격 후보")
    } else {
        println("RING FAIL: 게이트 위반")
    }
}
