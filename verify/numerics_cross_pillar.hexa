#!hexa strict
// hexa-codex/verify/numerics_cross_pillar.hexa — recipe §7.4 priority 7 cross-cutter.
//
// All four F-CODEX falsifiers depend on the SAME n=6 lattice
//
//     σ = 12,  φ = 2,  τ = 4,  n = 6,  J₂ = σ·φ = n·τ = 24,
//     σ − φ = 10,  N6_EXP = J₂ / (J₂ + 1) = 24/25 = 0.96.
//
// Each pillar takes one structural constant and feeds it through a
// distinct closed form:
//
//     F-CODEX-1: train_cost_ratio(N·D)  = (N·D / 1e22)^N6_EXP
//     F-CODEX-2: infer_cost_ratio(ctx)  = (ctx / 8192)^τ
//     F-CODEX-3: alignment_score(prof)  = (1/σ) · Σ_{i=1..σ} prof_i
//     F-CODEX-4: motif_count            = σ − φ  (predicted), drift ≤ 3 vs OBS
//
// This script does NOT re-derive any single pillar — that is what
// `verify/numerics_<pillar>.hexa` already does. Instead it verifies
// CROSS-PILLAR consistency identities that would have to break
// simultaneously for the lattice itself to fall:
//
//   1. lattice closure: σ·φ = n·τ = J₂ = 24 (all four pillars rest on it)
//   2. N6_EXP · (J₂+1) = J₂  — recovers J₂ from F-CODEX-1 exponent
//   3. τ recovered from J₂ ÷ n; σ recovered from J₂ ÷ φ
//   4. ratio tower: σ/φ=6=n, σ/τ=3, J₂/σ=2=φ, J₂/τ=6=n — multi-pillar
//   5. composite anchor: train+infer simultaneously well-defined at the
//      "Llama-2 70B / 128k ctx" frontier point (cross F1×F2)
//   6. alignment × motif coupling: high-mean profile (1.0) × motif=10
//      gives the lattice-canonical product 10.0 (cross F3×F4)
//   7. 4-point frontier grid (Chinchilla / GPT-3 / Llama-2 / PaLM × 8k
//      ctx): all 4 produce finite positive (train_cost, infer_cost)
//      pairs (cross F1×F2 monotonicity)
//   8. coupled ODE system: { dx/dt = M − x  (F-CODEX-4 gradient flow),
//      dy/du = N6_EXP · y  (F-CODEX-1 cost growth) } solved jointly and
//      both reach their analytic asymptote (cross F1×F4)
//   9. lattice positivity: log σ, log φ, log τ, log(σ−φ), log J₂ all > 0
//      (every pillar uses a log somewhere; floor invariant)
//  10. exponent partition: N6_EXP < 1 (F1 sub-linear) AND τ > 1 (F2
//      super-linear) AND τ ≠ N6_EXP+1 — distinct pillars, distinct
//      growth modes
//
// PASS criterion (T2 cross-cutter floor): 10 checks pass. With all 4
// pillars at T2 ×3 (post iter 18) plus this cross-cutter, recipe §7.4
// priority 7 is closed; only priority 8 (lattice_arithmetic) remains
// before sat-1 saturation.
//
// Run:
//   hexa run verify/numerics_cross_pillar.hexa
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local verifier; integer + float arithmetic only.")

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()

// ── n=6 lattice (float copies) ────────────────────────────────────────────
let SIGMA  = 12.0
let PHI    = 2.0
let TAU    = 4.0
let N      = 6.0
let J2     = 24.0
let SIGMA_PHI_DIFF = 10.0                  // σ − φ
let N6_EXP = 24.0 / 25.0                   // 0.96 EXACT

let ND_REF  = 1.0e10 * 1.0e12              // F-CODEX-1 anchor (1e22)
let CTX_REF = 8192.0                       // F-CODEX-2 anchor (8k)

// 4 frontier anchors (Chinchilla / GPT-3 / Llama-2 / PaLM)
let MODELS = ["Chinchilla 70B", "GPT-3 175B", "Llama-2 70B", "PaLM 540B"]
let N_VALS = [70.0e9,             175.0e9,     70.0e9,        540.0e9]
let D_VALS = [1.4e12,             300.0e9,     2.0e12,        780.0e9]

// Frontier ctx anchors (paired with models 0..3 in the same order, hypothetical)
//   Llama-2 typically 4k, GPT-3 2k, Chinchilla 2k, PaLM 8k. Use 8k for all
//   to keep cross-pillar tests pillar-2-anchored.
let CTX_FOR_MODELS = [CTX_REF, CTX_REF, CTX_REF, CTX_REF]

// FALSIFIERS list (recipe §4 invariant 3) — references all four.
let FALSIFIERS = [
    "F-CODEX-1 (train_cost ∝ N·D^N6_EXP, cross-pillar)",
    "F-CODEX-2 (infer_cost ∝ ctx^τ, cross-pillar)",
    "F-CODEX-3 (alignment = mean over σ axes, cross-pillar)",
    "F-CODEX-4 (motif_count = σ − φ, cross-pillar)",
]

// ── helpers ──────────────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0
let mut FAILURES = []

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    } else {
        FAIL = FAIL + 1
        FAILURES.push(label + " :: " + detail)
        println("  [FAIL] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    }
}

fn _abs(x: float) -> float {
    return abs_pure(x)
}

// pillar 1 closed form
fn train_cost_ratio(nd: float) -> float {
    return pow_pure(nd / ND_REF, N6_EXP)
}

// pillar 2 closed form
fn infer_cost_ratio(ctx: float) -> float {
    return pow_pure(ctx / CTX_REF, TAU)
}

// pillar 3 closed form (uniform-axis approximation; for cross-pillar we
// use the analytic mean of 12 copies of a scalar score)
fn alignment_score_uniform(score: float) -> float {
    return score                       // mean of σ identical values is the value itself
}

// pillar 4 prediction (constant)
fn motif_count_predicted() -> float {
    return SIGMA_PHI_DIFF
}

// ── checks ───────────────────────────────────────────────────────────────

// Check 1: lattice closure σ·φ = n·τ = J₂ = 24 (the bedrock identity).
fn check_lattice_closure() {
    let lhs1 = SIGMA * PHI
    let lhs2 = N * TAU
    let drift = _abs(lhs1 - J2) + _abs(lhs2 - J2) + _abs(lhs1 - lhs2)
    _check(drift < 1.0e-12,
           "lattice closure σ·φ = n·τ = J₂ = 24 (all 4 pillars depend on it)",
           "σ·φ=" + to_string(lhs1) + " n·τ=" + to_string(lhs2) +
           " J₂=" + to_string(J2) + " drift=" + to_string(drift))
}

// Check 2: N6_EXP · (J₂ + 1) = J₂ — recovers F-CODEX-1 exponent from J₂.
fn check_n6_exp_recovers_j2() {
    let lhs = N6_EXP * (J2 + 1.0)
    let drift = _abs(lhs - J2)
    _check(drift < 1.0e-12,
           "F-CODEX-1: N6_EXP · (J₂+1) = J₂  (24/25 · 25 = 24)",
           "lhs=" + to_string(lhs) + " J₂=" + to_string(J2) +
           " drift=" + to_string(drift))
}

// Check 3: τ = J₂ / n  AND  σ = J₂ / φ — recovers F-CODEX-2 and F-CODEX-3
//   structural constants from J₂ alone.
fn check_tau_sigma_from_j2() {
    let tau_rec = J2 / N
    let sig_rec = J2 / PHI
    let drift = _abs(tau_rec - TAU) + _abs(sig_rec - SIGMA)
    _check(drift < 1.0e-12,
           "F-CODEX-2 τ = J₂/n = 4 ; F-CODEX-3 σ = J₂/φ = 12 (recovered from J₂)",
           "τ_rec=" + to_string(tau_rec) + " σ_rec=" + to_string(sig_rec) +
           " drift=" + to_string(drift))
}

// Check 4: ratio tower σ/φ=n=6, σ/τ=3, J₂/σ=φ=2, J₂/τ=n=6.
fn check_ratio_tower() {
    let r1 = SIGMA / PHI                 // 6
    let r2 = SIGMA / TAU                 // 3
    let r3 = J2 / SIGMA                  // 2 = φ
    let r4 = J2 / TAU                    // 6 = n
    let drift = _abs(r1 - N) + _abs(r2 - 3.0) + _abs(r3 - PHI) + _abs(r4 - N)
    _check(drift < 1.0e-12,
           "ratio tower: σ/φ=n, σ/τ=3, J₂/σ=φ, J₂/τ=n",
           "r=[" + to_string(r1) + "," + to_string(r2) + "," + to_string(r3) +
           "," + to_string(r4) + "] drift=" + to_string(drift))
}

// Check 5: composite anchor — train_cost + infer_cost simultaneously
//   well-defined and > 0 at "Llama-2 70B + 8k ctx" frontier (cross F1×F2).
fn check_composite_anchor() {
    let nd = N_VALS[2] * D_VALS[2]      // Llama-2 70B · 2T = 1.4e23
    let train_r = train_cost_ratio(nd)
    let infer_r = infer_cost_ratio(CTX_REF)         // = 1 by anchor definition
    let ok_train = (train_r > 0.0) && (train_r == train_r)
    let ok_infer = (infer_r > 0.0) && (infer_r == infer_r)
    let drift_infer = _abs(infer_r - 1.0)
    _check(ok_train && ok_infer && drift_infer < 1.0e-12,
           "composite F1×F2 anchor: Llama-2 70B + 8k ctx → both ratios finite, infer_r=1",
           "train=" + to_string(train_r) + " infer=" + to_string(infer_r))
}

// Check 6: alignment × motif coupling — score=1.0 (perfect) × motif=10
//   = 10 = σ−φ exactly (cross F3×F4 product index).
fn check_alignment_motif_coupling() {
    let score = alignment_score_uniform(1.0)        // 1.0
    let motifs = motif_count_predicted()            // 10.0
    let product = score * motifs
    let drift = _abs(product - SIGMA_PHI_DIFF)
    _check(drift < 1.0e-12,
           "F3×F4 product: alignment(1.0) · motif(10) = σ−φ = 10",
           "product=" + to_string(product) + " σ−φ=" + to_string(SIGMA_PHI_DIFF) +
           " drift=" + to_string(drift))
}

// Check 7: 4-point frontier × 8k-ctx grid produces finite positive (train,
//   infer) pairs for all 4 anchors (Chinchilla, GPT-3, Llama-2, PaLM).
fn check_grid_positivity() {
    let mut all_ok = true
    let mut min_train = 1.0e30
    let mut min_infer = 1.0e30
    let mut i = 0
    while i < len(MODELS) {
        let nd = N_VALS[i] * D_VALS[i]
        let t = train_cost_ratio(nd)
        let f = infer_cost_ratio(CTX_FOR_MODELS[i])
        if t <= 0.0 || (t == t) == false { all_ok = false }
        if f <= 0.0 || (f == f) == false { all_ok = false }
        if t < min_train { min_train = t }
        if f < min_infer { min_infer = f }
        i = i + 1
    }
    _check(all_ok,
           "4 frontier × 8k-ctx grid: all (train, infer) pairs > 0 + finite",
           "min_train=" + to_string(min_train) + " min_infer=" + to_string(min_infer))
}

// Check 8: coupled ODE system — solve simultaneously
//     dx/dt = M − x          (F-CODEX-4 gradient flow, M = σ − φ = 10)
//     dy/du = N6_EXP · y     (F-CODEX-1 cost growth from y(0)=1)
//   for t = u = 5 with RK4 and verify both reach their analytic asymptote
//   within tolerance.
fn check_coupled_ode_system() {
    let m  = SIGMA_PHI_DIFF             // 10
    let t_end = 5.0
    let n_steps = 256
    let h = t_end / to_float(n_steps)
    let mut x = 0.0
    let mut y = 1.0
    let mut i = 0
    while i < n_steps {
        // F-CODEX-4 gradient-flow RK4 step
        let kx1 = m - x
        let kx2 = m - (x + 0.5 * h * kx1)
        let kx3 = m - (x + 0.5 * h * kx2)
        let kx4 = m - (x + h * kx3)
        x = x + (h / 6.0) * (kx1 + 2.0 * kx2 + 2.0 * kx3 + kx4)
        // F-CODEX-1 cost-growth RK4 step
        let ky1 = N6_EXP * y
        let ky2 = N6_EXP * (y + 0.5 * h * ky1)
        let ky3 = N6_EXP * (y + 0.5 * h * ky2)
        let ky4 = N6_EXP * (y + h * ky3)
        y = y + (h / 6.0) * (ky1 + 2.0 * ky2 + 2.0 * ky3 + ky4)
        i = i + 1
    }
    let x_ref = m + (0.0 - m) * exp_pure(-t_end)        // ≈ 9.933
    let y_ref = exp_pure(N6_EXP * t_end)                 // ≈ 109.95
    let dx = _abs(x - x_ref) / x_ref
    let dy = _abs(y - y_ref) / y_ref
    _check((dx < 1.0e-8) && (dy < 1.0e-8),
           "F1×F4 coupled RK4: gradient flow + cost growth both ≤ 1e-8 (n=256)",
           "x=" + to_string(x) + " x_ref=" + to_string(x_ref) +
           " (rel " + to_string(dx) + ")  y=" + to_string(y) +
           " y_ref=" + to_string(y_ref) + " (rel " + to_string(dy) + ")")
}

// Check 9: lattice positivity — log of every primary lattice constant > 0.
fn check_lattice_log_positivity() {
    let l1 = log_pure(SIGMA)             // log 12 ≈ 2.485
    let l2 = log_pure(PHI)               // log 2  ≈ 0.693
    let l3 = log_pure(TAU)               // log 4  ≈ 1.386
    let l4 = log_pure(SIGMA_PHI_DIFF)    // log 10 ≈ 2.303
    let l5 = log_pure(J2)                // log 24 ≈ 3.178
    let all_pos = (l1 > 0.0) && (l2 > 0.0) && (l3 > 0.0) && (l4 > 0.0) && (l5 > 0.0)
    _check(all_pos,
           "log σ, log φ, log τ, log(σ−φ), log J₂ all > 0 (lattice positivity)",
           "logs=[" + to_string(l1) + "," + to_string(l2) + "," + to_string(l3) +
           "," + to_string(l4) + "," + to_string(l5) + "]")
}

// Check 10: exponent partition — F1 sub-linear (N6_EXP < 1) AND F2
//   super-linear (τ > 1) AND τ ≠ N6_EXP + 1 (pillars distinct, not
//   degenerate). Establishes that the four pillars probe different
//   growth modes.
fn check_exponent_partition() {
    let f1_sub   = N6_EXP < 1.0
    let f2_super = TAU > 1.0
    let distinct = _abs(TAU - (N6_EXP + 1.0)) > 1.0e-3
    _check(f1_sub && f2_super && distinct,
           "exponent partition: N6_EXP<1 (F1 sub-lin) ∧ τ>1 (F2 super-lin) ∧ τ ≠ N6_EXP+1",
           "N6_EXP=" + to_string(N6_EXP) + " τ=" + to_string(TAU) +
           " τ−(N6_EXP+1)=" + to_string(TAU - (N6_EXP + 1.0)))
}

// ── main ─────────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  hexa-codex cross-pillar (recipe §7.4 priority 7, math_pure)")
    println("  All 4 F-CODEX falsifiers tied to one n=6 lattice — verify cross-cutters")
    println("========================================================================")
    println("  σ=" + to_string(SIGMA) + " φ=" + to_string(PHI) + " τ=" + to_string(TAU) +
            " n=" + to_string(N) + " J₂=" + to_string(J2) + " σ−φ=" + to_string(SIGMA_PHI_DIFF))
    println("  N6_EXP=" + to_string(N6_EXP) + " ND_REF=" + to_string(ND_REF) +
            " CTX_REF=" + to_string(CTX_REF))
    println("")

    check_lattice_closure()
    check_n6_exp_recovers_j2()
    check_tau_sigma_from_j2()
    check_ratio_tower()
    check_composite_anchor()
    println("")
    check_alignment_motif_coupling()
    check_grid_positivity()
    check_coupled_ode_system()
    check_lattice_log_positivity()
    check_exponent_partition()

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  FAILURES:")
        for f in FAILURES { println("    ✗ " + f) }
        println("__HEXA_CODEX_NUMERICS_CROSS_PILLAR__ FAIL")
        exit(1)
    }
    println("  Cross-pillar T2 cross-cutter: closed.")
    println("  Recipe §7.4 priority 7: COMPLETE.")
    println("__HEXA_CODEX_NUMERICS_CROSS_PILLAR__ PASS")
    exit(0)
}
