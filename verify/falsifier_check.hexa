#!hexa strict
// hexa-codex/verify/falsifier_check.hexa вЂ” recipe В§7.4 priority 9 closure tracker (meta).
//
// Single source of truth for "where each F-CODEX falsifier sits on the
// closure ladder". Walks the verify/ directory and tallies, per pillar,
// using the recipe В§3 taxonomy:
//
//     T1   calc_<pillar>.hexa                                (1 file)
//     T2   numerics_<pillar>.hexa AND numerics_<pillar>_solver.hexa
//          (pure-math closed-form re-derivation вЂ” closed-form internal
//           consistency)                                      (2 files)
//     T3   numerics_<pillar>_parity.hexa
//          (archival empirical contact via published-ref comparison)
//                                                             (1 file)
//     T4   <pillar>_t4_*.hexa (live hardware / Stage-1+; recipe В§9 вЂ” out
//          of loop scope; informational only)                 (0 files)
//
// Plus the cross-cutter row:
//
//     X1   lattice_check.hexa, cross_doc_audit.hexa,
//          numerics_cross_pillar.hexa, numerics_lattice_arithmetic.hexa
//
// PASS criterion: every F-CODEX falsifier reaches recipe В§3
// closure_pct = 100% = 3/3 tiers (T1 + T2 + T3 all present), AND all 4
// cross-cutter slots are present.
//
// Sentinel: __HEXA_CODEX_FALSIFIER_CHECK__ PASS at recipe В§7.2 sat-1
// (= every falsifier 100% closure).
//
// Recipe В§3 closure_pct formula:
//
//     n = sum(t1_ok, t2_ok, t3_ok)     # 0..3
//     pct = 0 | 33 | 67 | 100          # ladder
//     sat-1 = AND_k (pct(k) == 100)
//
// Run:
//   hexa run verify/falsifier_check.hexa
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local verifier; integer + float arithmetic only.")

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()
let VERIFY_DIR = ROOT + "/verify"

// 4 F-CODEX pillars
let PILLARS = ["train_cost", "infer_cost", "alignment", "interpret"]

// FALSIFIERS list (recipe В§4 invariant 3).
let FALSIFIERS = [
    "F-CODEX-1 closure tracker",
    "F-CODEX-2 closure tracker",
    "F-CODEX-3 closure tracker",
    "F-CODEX-4 closure tracker",
]

// в”Ђв”Ђ helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

let mut RUN = 0
let mut FAIL = 0
let mut FAILURES = []

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
        if detail.len() > 0 { println("         В· " + detail) }
    } else {
        FAIL = FAIL + 1
        FAILURES.push(label + " :: " + detail)
        println("  [FAIL] " + label)
        if detail.len() > 0 { println("         В· " + detail) }
    }
}

// File-existence test via shell (`test -f path` returns exit 0 iff present).
fn _exists(path: str) -> bool {
    let r = exec_with_status("test -f '" + path + "' && echo OK")
    let out = to_string(r[0])
    return out.find("OK") >= 0
}

// Layer file path for (pillar, layer-tag).
//   layer в€€ {"calc", "numerics", "numerics_parity", "numerics_solver"}.
fn _layer_path(pillar: str, layer: str) -> str {
    if layer == "calc" {
        return VERIFY_DIR + "/calc_" + pillar + ".hexa"
    }
    if layer == "numerics" {
        return VERIFY_DIR + "/numerics_" + pillar + ".hexa"
    }
    if layer == "numerics_parity" {
        return VERIFY_DIR + "/numerics_" + pillar + "_parity.hexa"
    }
    if layer == "numerics_solver" {
        return VERIFY_DIR + "/numerics_" + pillar + "_solver.hexa"
    }
    return ""
}

// в”Ђв”Ђ checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// Check 1..4: per-falsifier closure under recipe В§3 taxonomy (T1/T2/T3).
//   T1 = calc_<pillar>.hexa
//   T2 = numerics_<pillar>.hexa AND numerics_<pillar>_solver.hexa  (pure-math
//                                                                   re-derivation)
//   T3 = numerics_<pillar>_parity.hexa (archival empirical contact via
//                                       published-ref comparison)
//   closure_pct: 33 (1/3) | 67 (2/3) | 100 (3/3) вЂ” recipe В§3 ladder.
fn check_pillar_closure(idx: int) {
    let pillar = PILLARS[idx]
    let p_calc   = _exists(_layer_path(pillar, "calc"))
    let p_num    = _exists(_layer_path(pillar, "numerics"))
    let p_solver = _exists(_layer_path(pillar, "numerics_solver"))
    let p_parity = _exists(_layer_path(pillar, "numerics_parity"))
    let t1_ok = p_calc
    let t2_ok = p_num && p_solver       // both pure-math floors required for T2 вњ“
    let t3_ok = p_parity
    let tier_count = (if t1_ok { 1 } else { 0 }) +
                     (if t2_ok { 1 } else { 0 }) +
                     (if t3_ok { 1 } else { 0 })
    let pct = if tier_count == 3 { 100 }
              else { if tier_count == 2 { 67 }
                     else { if tier_count == 1 { 33 } else { 0 } } }
    let label = "F-CODEX-" + str(idx + 1) + " (" + pillar + "): T1+T2+T3 closure"
    _check(tier_count == 3,
           label,
           "T1=" + str(t1_ok) + " T2=" + str(t2_ok) + " T3=" + str(t3_ok) +
           " вЂ” closure_pct=" + str(pct) + "% (3/3 = 100%)")
}

// Check 5: cross-cutter row presence.
fn check_cross_cutter_row() {
    let f1 = _exists(VERIFY_DIR + "/lattice_check.hexa")
    let f2 = _exists(VERIFY_DIR + "/cross_doc_audit.hexa")
    let f3 = _exists(VERIFY_DIR + "/numerics_cross_pillar.hexa")
    let f4 = _exists(VERIFY_DIR + "/numerics_lattice_arithmetic.hexa")
    let cnt = (if f1 { 1 } else { 0 }) + (if f2 { 1 } else { 0 }) +
              (if f3 { 1 } else { 0 }) + (if f4 { 1 } else { 0 })
    _check(cnt == 4,
           "cross-cutter row (X1): lattice/cross_doc/cross_pillar/lattice_arithmetic",
           "lattice=" + str(f1) + " cross_doc=" + str(f2) +
           " cross_pillar=" + str(f3) + " lattice_arith=" + str(f4) +
           " вЂ” closed=" + str(cnt) + "/4")
}

// Check 6: total runnable file count (4 pillars Г— 4 layers + 4 cross = 20).
fn check_total_runnable_count() {
    let mut total = 0
    let layers = ["calc", "numerics", "numerics_parity", "numerics_solver"]
    let mut p = 0
    while p < len(PILLARS) {
        let mut l = 0
        while l < len(layers) {
            if _exists(_layer_path(PILLARS[p], layers[l])) { total = total + 1 }
            l = l + 1
        }
        p = p + 1
    }
    let cross_paths = [
        VERIFY_DIR + "/lattice_check.hexa",
        VERIFY_DIR + "/cross_doc_audit.hexa",
        VERIFY_DIR + "/numerics_cross_pillar.hexa",
        VERIFY_DIR + "/numerics_lattice_arithmetic.hexa",
    ]
    let mut i = 0
    while i < len(cross_paths) {
        if _exists(cross_paths[i]) { total = total + 1 }
        i = i + 1
    }
    _check(total >= 20,
           "total runnable .hexa scripts = 20 (4 pillars Г— 4 layers + 4 cross-cutters)",
           "counted=" + str(total))
}

// Check 7: every falsifier reaches recipe В§3 closure_pct = 100% = 3/3 tiers.
//   T1 вњ“ + T2 вњ“ + T3 вњ“ for every pillar (parity = T3 archival empirical contact).
fn check_closure_pct_100() {
    let mut all_100 = true
    let mut min_pct = 100
    let mut p = 0
    while p < len(PILLARS) {
        let pillar = PILLARS[p]
        let t1 = _exists(_layer_path(pillar, "calc"))
        let t2 = _exists(_layer_path(pillar, "numerics")) &&
                 _exists(_layer_path(pillar, "numerics_solver"))
        let t3 = _exists(_layer_path(pillar, "numerics_parity"))
        let n = (if t1 { 1 } else { 0 }) + (if t2 { 1 } else { 0 }) + (if t3 { 1 } else { 0 })
        let pct = if n == 3 { 100 } else { if n == 2 { 67 } else { if n == 1 { 33 } else { 0 } } }
        if pct < 100 { all_100 = false }
        if pct < min_pct { min_pct = pct }
        p = p + 1
    }
    _check(all_100,
           "recipe В§3 closure_pct = 100% for every F-CODEX falsifier (T1+T2+T3 вњ“)",
           "min_pct=" + str(min_pct) + "%")
}

// Check 8: T4 (live hardware / Stage-1+) row вЂ” informational gap report.
//   T4 is recipe В§9 territory (loop-лІ”мњ„ л°–); does NOT block 100% closure.
fn check_t4_gap_report() {
    let mut t4_count = 0
    let mut p = 0
    while p < len(PILLARS) {
        let pillar = PILLARS[p]
        let candidate = VERIFY_DIR + "/" + pillar + "_t4_live.hexa"
        if _exists(candidate) { t4_count = t4_count + 1 }
        p = p + 1
    }
    let gap = 4 - t4_count
    _check(gap >= 0,
           "T4 (live hardware) row gap report: " + str(gap) + "/4 awaiting Stage-1+",
           "t4_count=" + str(t4_count) + " (informational; recipe В§9 вЂ” out of loop scope)")
}

// Check 9: papers/lean anchor presence (closure substrate).
fn check_substrate_anchors() {
    let p1 = _exists(ROOT + "/papers/n6-ai-17-techniques-experimental-paper.md")
    let p2 = _exists(ROOT + "/papers/n6-ai-techniques-68-integrated-paper.md")
    let p3 = _exists(ROOT + "/formal/lean4/N6/InvariantLattice/Sigma.lean")
    let cnt = (if p1 { 1 } else { 0 }) + (if p2 { 1 } else { 0 }) +
              (if p3 { 1 } else { 0 })
    _check(cnt >= 2,
           "substrate anchors: в‰Ґ 2 of {paper P1, paper P2, Sigma.lean} present",
           "P1=" + str(p1) + " P2=" + str(p2) + " Sigma.lean=" + str(p3) +
           " вЂ” present=" + str(cnt) + "/3")
}

// Check 10: recipe В§7.2 sat-1 gate вЂ” every falsifier 100% closure (T1+T2+T3 вњ“)
//   AND cross-cutter row 4/4. Recipe В§7.2 wording:
//   "sat-1 saturation = лЄЁл“  falsifier к°Ђ 100% closure лЏ„л‹¬
//    (T1 вњ“ + T2 в‰Ґ1 вњ“ + T3 в‰Ґ1 вњ“)".
fn check_overall_sat1() {
    let mut all_100 = true
    let mut p = 0
    while p < len(PILLARS) {
        let pillar = PILLARS[p]
        let t1 = _exists(_layer_path(pillar, "calc"))
        let t2 = _exists(_layer_path(pillar, "numerics")) &&
                 _exists(_layer_path(pillar, "numerics_solver"))
        let t3 = _exists(_layer_path(pillar, "numerics_parity"))
        if (t1 && t2 && t3) == false { all_100 = false }
        p = p + 1
    }
    let cross_ok = _exists(VERIFY_DIR + "/lattice_check.hexa") &&
                   _exists(VERIFY_DIR + "/cross_doc_audit.hexa") &&
                   _exists(VERIFY_DIR + "/numerics_cross_pillar.hexa") &&
                   _exists(VERIFY_DIR + "/numerics_lattice_arithmetic.hexa")
    _check(all_100 && cross_ok,
           "RECIPE В§7.2 sat-1 gate: all 4 pillars at 100% (T1+T2+T3) AND cross-cutter 4/4",
           "pillars_100pct=" + str(all_100) + " cross_ok=" + str(cross_ok))
}

// в”Ђв”Ђ main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn main() {
    println("========================================================================")
    println("  hexa-codex falsifier closure tracker (recipe В§7.4 priority 9)")
    println("  4 F-CODEX pillars Г— {T1, T2#1, T2#2, T2#3} + 4 cross-cutters")
    println("========================================================================")
    println("  ROOT = " + ROOT)
    println("")

    let mut i = 0
    while i < len(PILLARS) {
        check_pillar_closure(i)
        i = i + 1
    }
    println("")
    check_cross_cutter_row()
    check_total_runnable_count()
    check_closure_pct_100()
    check_t4_gap_report()
    check_substrate_anchors()
    check_overall_sat1()

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  FAILURES:")
        for f in FAILURES { println("    вњ— " + f) }
        println("__HEXA_CODEX_FALSIFIER_CHECK__ FAIL")
        exit(1)
    }
    println("  Falsifier closure tracker: sat-1 reached.")
    println("  Recipe В§7.4 priority 9: COMPLETE.")
    println("__HEXA_CODEX_FALSIFIER_CHECK__ PASS")
    exit(0)
}
