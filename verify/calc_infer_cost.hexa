#!hexa strict
// hexa-codex/verify/calc_infer_cost.hexa — F-CODEX-2 inference-cost calculator (T1).
//
// Closed form per .roadmap.hexa_codex §A.4:
//
//     inference_cost ∝ context^τ   where  τ = τ(6) = 4
//
// where τ(6) = 4 is the lattice quartet (pretrain / SFT / RLHF / deploy
// — lifecycle "depth" carried into serving cost).
//
// Falsifier comparison:
//   · naïve Transformer attention → O(context²)
//   · approximate / linear attention → ~O(context^1.5) in practice
//   · n=6 prediction → O(context^4) — strict UPPER bound
//
// F-CODEX-2 is **expected to falsify** for production long-context engines:
// Claude 4.7 1M ctx will likely fall below O(n^1.5). The recipe T1 floor
// here only verifies the arithmetic of τ=4 and consistency of the closed
// form; T2 (numerical fit) and T3 (live latency at 1M ctx) follow.
//
// Run:
//   hexa run verify/calc_infer_cost.hexa
//
// Cost: $0 (integer arithmetic + spec scan).
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local verifier; reads project docs only.")

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()
let DOC_SPEC = ROOT + "/infer_cost/ai-inference-cost.md"

// ── n=6 lattice ──────────────────────────────────────────────────────────
let N       = 6
let SIGMA_6 = 12
let TAU_6   = 4
let PHI_6   = 2
let J2      = 24

// ── attention exponent ladder ────────────────────────────────────────────
let EXP_LINEAR_X10  = 10    // 1.0  × 10
let EXP_APPROX_X10  = 15    // 1.5  × 10  (approximate / linear-attention practice)
let EXP_NAIVE_X10   = 20    // 2.0  × 10  (naïve Transformer O(n²))
let EXP_N6_X10      = 40    // 4.0  × 10  (n=6 closed form, τ exponent)

// FALSIFIERS list (recipe lint requires this).
let FALSIFIERS = ["F-CODEX-2 (inference_cost ∝ context^τ = context^4, Claude 4.7 1M-ctx latency fit)"]

// ── helpers ──────────────────────────────────────────────────────────────

fn _read(p: str) -> str {
    if file_exists(p) == false { return "" }
    return read_file(p)
}

fn _has(t: str, s: str) -> bool {
    if t.len() == 0 { return false }
    if s.len() == 0 { return true }
    return t.find(s) >= 0
}

fn _any(t: str, ss: [str]) -> bool {
    for s in ss { if _has(t, s) { return true } }
    return false
}

let mut RUN = 0
let mut FAIL = 0
let mut FAILURES = []

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    } else {
        FAIL = FAIL + 1
        FAILURES.push(label + " :: " + detail)
        println("  [FAIL] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    }
}

// ── checks ───────────────────────────────────────────────────────────────

// Check 1: τ(6) = 4 (arithmetic identity from divisor count of 6)
fn check_tau_value() {
    _check(TAU_6 == 4,
           "τ(6) = 4 (divisors of 6: {1,2,3,6})",
           "TAU_6 = " + str(TAU_6))
}

// Check 2: closed-form exponent equals τ(6)
fn check_exponent_is_tau() {
    let exp_n6 = EXP_N6_X10 / 10
    _check(exp_n6 == TAU_6,
           "n=6 closed-form exponent = τ(6) = 4",
           "exp = " + str(exp_n6))
}

// Check 3: ladder ordering — linear < approx < naïve < n6
fn check_exponent_ladder() {
    let ok = (EXP_LINEAR_X10 < EXP_APPROX_X10) &&
             (EXP_APPROX_X10 < EXP_NAIVE_X10) &&
             (EXP_NAIVE_X10  < EXP_N6_X10)
    _check(ok,
           "exponent ladder: 1.0 < 1.5 < 2.0 < 4.0 (linear < approx < naïve < n6)",
           "lin=" + str(EXP_LINEAR_X10) +
           " apx=" + str(EXP_APPROX_X10) +
           " nv=" + str(EXP_NAIVE_X10) +
           " n6=" + str(EXP_N6_X10) + " (×10)")
}

// Check 4: n6 exponent is strict upper bound: gap from naïve = 4 - 2 = 2 (≥ 1)
fn check_n6_strict_upper() {
    let gap_x10 = EXP_N6_X10 - EXP_NAIVE_X10
    _check(gap_x10 >= 10,
           "n6 exponent strict upper bound vs naïve O(n²): gap ≥ 1.0",
           "gap = " + str(gap_x10) + " ×10 = " + str(gap_x10 / 10) + ".0")
}

// Check 5: 1M context = 1024^2 — power-of-2 arithmetic for KV-cache scaling
fn check_1m_context_power_of_2() {
    let mut k = 1
    let mut i = 0
    while i < 20 { k = k * 2; i = i + 1 }
    // k = 2^20 = 1_048_576 ≈ 1M. Spec calls this "1M context".
    _check(k > 1000000 && k < 1100000,
           "1M context window = 2^20 = 1_048_576 tokens (power-of-2)",
           "computed 2^20 = " + str(k))
}

// Check 6: KV cache memory at 1M context > 80GB (spec line ≈ 163.84GB)
//   163.84 GB = 64 (kv) · 2 (k+v) · 1280 (heads·dim) · 1M tokens · 1 byte fp8
//   simpler: spec asserts > 80e9. We just verify spec ships that boundary.
fn check_kv_cache_anchor() {
    let txt = _read(DOC_SPEC)
    let ok_1m   = _any(txt, ["1M context", "1M-ctx", "1M ctx", "1M tok"])
    let ok_kv   = _has(txt, "KV cache") || _has(txt, "KV-cache")
    let ok_80gb = _any(txt, [">80GB", "> 80GB", "80GB", "80e9", "163.84GB"])
    _check(ok_1m && ok_kv && ok_80gb,
           "spec ships 1M-ctx + KV-cache + > 80GB infeasibility anchors",
           "1m=" + str(ok_1m) + " kv=" + str(ok_kv) + " 80gb=" + str(ok_80gb))
}

// Check 7: spec anchor — ai-inference-cost.md ships attention-complexity tokens
fn check_spec_attention_tokens() {
    let txt = _read(DOC_SPEC)
    let ok_attn  = _has(txt, "Attention") || _has(txt, "attention")
    let ok_n2    = _any(txt, ["O(n^2)", "O(n²)", "n^2"])
    let ok_long  = _any(txt, ["FlashAttention", "linear attention", "PagedAttention"])
    _check(ok_attn && ok_n2 && ok_long,
           "spec ships attention + O(n²) + linear/Paged/Flash tokens",
           "attn=" + str(ok_attn) + " n2=" + str(ok_n2) + " engines=" + str(ok_long))
}

// Check 8: σ·τ = 48 serving-channel anchor present in spec Mk.V line
//   spec: "σ·τ=48 serving channels = n=6 EXACT convergence"
fn check_sigma_tau_48() {
    let txt = _read(DOC_SPEC)
    let lhs = SIGMA_6 * TAU_6
    let arith_ok = lhs == 48
    let spec_ok = _any(txt, ["σ·τ=48", "σ·τ = 48", "sigma·tau=48", "48 serving"])
    _check(arith_ok && spec_ok,
           "σ·τ = 48 serving-channel anchor (arithmetic + spec)",
           "12·4 = " + str(lhs) + " spec=" + str(spec_ok))
}

// Check 9: J₂ = σ·τ·φ/τ … wait, simpler: J₂ = σ·φ = 24, half of σ·τ=48.
//   Cross-check: σ·τ / J₂ = 48/24 = 2 = φ(6).
fn check_serving_lattice_crosslink() {
    let serving = SIGMA_6 * TAU_6     // 48
    let ratio   = serving / J2        // 48/24 = 2
    _check(ratio == PHI_6,
           "(σ·τ)/J₂ = φ(6) = 2 — serving-channel ↔ training-cost lattice link",
           "48/24 = " + str(ratio) + " = φ(6) = " + str(PHI_6))
}

// ── main ─────────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  hexa-codex F-CODEX-2 inference-cost calculator (T1 algebraic)")
    println("  inference_cost ∝ context^τ = context^4  (strict upper bound, x4 ladder)")
    println("========================================================================")
    println("  spec: " + DOC_SPEC)
    println("")

    check_tau_value()
    check_exponent_is_tau()
    check_exponent_ladder()
    check_n6_strict_upper()
    check_1m_context_power_of_2()
    println("")
    check_kv_cache_anchor()
    check_spec_attention_tokens()
    check_sigma_tau_48()
    check_serving_lattice_crosslink()

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  FAILURES:")
        for f in FAILURES { println("    ✗ " + f) }
        println("__HEXA_CODEX_CALC_INFER_COST__ FAIL")
        exit(1)
    }
    println("  F-CODEX-2 T1 algebraic floor: closed.")
    println("__HEXA_CODEX_CALC_INFER_COST__ PASS")
    exit(0)
}
