#!hexa strict
// SPDX-License-Identifier: MIT
// @allow-silent-exit-file
// @allow-bare-exec-file
// hexa-codex/verify/numerics_rlhf_t4_parity.hexa
//
// T4 live forge empirical parity verifier for the rlhf verb.
//
// STAGE 0 STUB. Real parity logic activates once forge T4 PRs land
// under outbox/hexa-codex/rlhf/. Until then this verifier emits
// a PENDING sentinel and explains what it will check.
//
// Pattern source:   verify/numerics_alignment_parity.hexa  (T3 layer)
// F-CODEX bind:     substrate input (no single F-CODEX bind; DPO yield)
// Forge landing:    ~/core/hexa-forge/outbox/hexa-codex/rlhf/
// Verb spec:        rlhf/youth-ai-labeling-rlhf-hub.md  (S7 VERIFY tol band)
//
// Sentinels:
//   PASS    = T4 parity holds (forge nums inside substrate tolerance)
//   PENDING = no forge PR for this verb yet (v0.1.2 default)
//   FAIL    = T4 anomaly (forge nums contradict substrate floor)
//
// Per plan-decisions-pending.md D-023:
//   T4 anomaly does NOT auto-tombstone the F-CODEX arithmetic floor.
//   Open a paired decision in this ledger instead.

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()
let VERB = "rlhf"
let VERB_UPPER = "RLHF"
let F_CODEX = "substrate input (DPO yield + judge quality; no single F-CODEX bind)"
let OUTBOX = HOME + "/core/hexa-forge/outbox/hexa-codex/" + VERB

// Expected numeric fields per ~/core/hexa-forge/tool/emit_t4.py load_measured():
let EXPECTED_FIELDS = "dpo_pair_count, judge_quality_pass_rate, pair_source_breakdown"

let FALSIFIERS = ["rlhf substrate T4 (forge empirical DPO yield + judge-quality pass rate)"]

fn sentinel_pending() {
    println("__HEXA_CODEX_T4_" + VERB_UPPER + "_PARITY__ PENDING")
    println("  reason: no forge T4 PR found at outbox/hexa-codex/" + VERB + "/")
    println("  expected fields (per ~/core/hexa-forge/tool/emit_t4.py): " + EXPECTED_FIELDS)
    println("  F-CODEX bind: " + F_CODEX)
    println("  lift trigger: forge v0.1.3 DPO pair builder lands (D-023)")
    println("  T3 archival floor: none (rlhf is substrate input, not a primary F-CODEX pillar)")
}

fn sentinel_pass(run_id: str) {
    println("__HEXA_CODEX_T4_" + VERB_UPPER + "_PARITY__ PASS")
    println("  forge run: " + run_id)
    println("  F-CODEX bind: " + F_CODEX)
    println("  closure_pct: substrate input row +T4 layer")
}

fn sentinel_fail(run_id: str, reason: str) {
    println("__HEXA_CODEX_T4_" + VERB_UPPER + "_PARITY__ FAIL")
    println("  forge run: " + run_id)
    println("  reason: " + reason)
    println("  follow-up: open paired decision in plan-decisions-pending.md per D-023")
}

fn check_t4_parity() {
    // STAGE 0: stub returns PENDING. No forge T4 PR exists yet.
    // STAGE 1 (post forge DPO build): scan outbox/hexa-codex/rlhf/*.md,
    //   parse the Numbers table, verify dpo_pair_count >= spec minimum and
    //   judge_quality_pass_rate against substrate floor (see
    //   rlhf/youth-ai-labeling-rlhf-hub.md S7 VERIFY for thresholds).
    sentinel_pending()
}

fn main() {
    println("========================================================================")
    println("  hexa-codex T4 parity verifier (stage 0 stub) verb: " + VERB)
    println("  F-CODEX bind: " + F_CODEX)
    println("  Outbox watch: " + OUTBOX + "/")
    println("========================================================================")
    check_t4_parity()
    exit(0)
}
