#!hexa strict
// hexa-codex/verify/numerics_interpret.hexa — F-CODEX-4 T2 numerical re-derivation.
//
// Beyond `verify/calc_interpret.hexa` (integer arithmetic only), this script
// works with float64 distributions of motif counts. The closed form is:
//
//     motif_count = σ(6) − φ(6) = 10
//
// In a real SAE-class observation (sparse-autoencoder feature clustering on
// a frontier model), the count drifts. F-CODEX-4 says drift ≤ 3 PASSes.
// Here we verify on simulated observations the statistical properties:
//
//   · mean of 6 observations [10, 9, 11, 10, 8, 12] ≈ 10
//   · stddev finite + within reasonable bound
//   · all observations land within ±3 of predicted (drift tolerance)
//   · density ratio motif_count / σ = 10/12 = 5/6 ≈ 0.833
//   · ratio motif_count / J₂ = 10/24 = 5/12 ≈ 0.417
//   · σ-φ float consistency: 12.0 − 2.0 = 10.0 within 1e-12
//   · accumulation stability for sum of 6 observations
//   · log identity: log(σ−φ) = log(σ) + log(1 − φ/σ) within 1e-9
//
// Recipe T2 floor (recipe §4 invariants 1-5 satisfied).
//
// T3 (live SAE feature counts on a frontier model — Anthropic's
// dictionary-learning toolchain) follows.
//
// Run:
//   hexa run verify/numerics_interpret.hexa
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local verifier; integer + float arithmetic only.")

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()

// ── n=6 lattice (float copies) ────────────────────────────────────────────
let SIGMA_6 = 12.0
let PHI_6   = 2.0
let TAU_6   = 4.0
let J2      = 24.0
let N6      = 6.0

let PREDICTED_MOTIFS = SIGMA_6 - PHI_6     // 10.0
let DRIFT_TOL        = 3.0                  // ±3 motifs

// ── 6 simulated SAE-class observations (mean = 10 by construction) ───────
//   sum = 10 + 9 + 11 + 10 + 8 + 12 = 60 ; /6 = 10.0 EXACT.
let OBS = [10.0, 9.0, 11.0, 10.0, 8.0, 12.0]

// FALSIFIERS list (recipe §4 invariant 3).
let FALSIFIERS = ["F-CODEX-4 (motif count = σ − φ = 10, drift ≤ 3, T2 numerical re-derivation, math_pure)"]

// ── helpers ──────────────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0
let mut FAILURES = []

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    } else {
        FAIL = FAIL + 1
        FAILURES.push(label + " :: " + detail)
        println("  [FAIL] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    }
}

fn _abs(x: float) -> float {
    return abs_pure(x)
}

fn _sum(v: [float]) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < len(v) {
        s = s + v[i]
        i = i + 1
    }
    return s
}

fn _mean(v: [float]) -> float {
    return _sum(v) / (len(v) * 1.0)
}

// Population stddev: sqrt( Σ (x_i − mean)² / N ).
fn _stddev(v: [float]) -> float {
    let m = _mean(v)
    let mut acc = 0.0
    let mut i = 0
    while i < len(v) {
        let d = v[i] - m
        acc = acc + d * d
        i = i + 1
    }
    return sqrt_pure(acc / (len(v) * 1.0))
}

fn _max(v: [float]) -> float {
    let mut mx = v[0]
    let mut i = 1
    while i < len(v) {
        if v[i] > mx { mx = v[i] }
        i = i + 1
    }
    return mx
}

fn _min(v: [float]) -> float {
    let mut mn = v[0]
    let mut i = 1
    while i < len(v) {
        if v[i] < mn { mn = v[i] }
        i = i + 1
    }
    return mn
}

// ── checks ───────────────────────────────────────────────────────────────

// Check 1: σ−φ float identity → 10.0 within 1e-12
fn check_sigma_minus_phi_float() {
    let v = SIGMA_6 - PHI_6
    let drift = _abs(v - 10.0)
    _check(drift < 1.0e-12,
           "σ−φ = 10.0 (float identity)",
           "computed=" + to_string(v) + " drift=" + to_string(drift))
}

// Check 2: 6 observation mean = 10.0 (constructed)
fn check_obs_mean() {
    let m = _mean(OBS)
    let drift = _abs(m - PREDICTED_MOTIFS)
    _check(drift < 1.0e-12,
           "mean of 6 observations = predicted (10.0)",
           "mean=" + to_string(m) + " drift=" + to_string(drift))
}

// Check 3: every observation within ±3 of predicted
fn check_obs_within_tolerance() {
    let mut all_ok = true
    let mut i = 0
    while i < len(OBS) {
        let d = _abs(OBS[i] - PREDICTED_MOTIFS)
        if d > DRIFT_TOL { all_ok = false }
        i = i + 1
    }
    _check(all_ok,
           "all 6 observations within drift tolerance (±3)",
           "OBS = [10, 9, 11, 10, 8, 12]; max drift = 2 ≤ 3")
}

// Check 4: stddev finite + within reasonable bound (≤ 2 for these obs)
//   Var = ((10-10)² + (9-10)² + (11-10)² + (10-10)² + (8-10)² + (12-10)²)/6
//       = (0 + 1 + 1 + 0 + 4 + 4) / 6 = 10/6 ≈ 1.667
//   Stddev = sqrt(1.667) ≈ 1.291
fn check_obs_stddev() {
    let s = _stddev(OBS)
    let expected = sqrt_pure(10.0 / 6.0)
    let drift = _abs(s - expected)
    _check(drift < 1.0e-9,
           "stddev = √(10/6) ≈ 1.291 (analytic)",
           "computed=" + to_string(s) + " expected=" + to_string(expected))
}

// Check 5: max - min spread (range = 12 - 8 = 4) ≤ 2·tol = 6
fn check_obs_range() {
    let mx = _max(OBS)
    let mn = _min(OBS)
    let range = mx - mn
    let bound = 2.0 * DRIFT_TOL
    _check(range <= bound,
           "obs range (max − min) ≤ 2·tol = 6",
           "max=" + to_string(mx) + " min=" + to_string(mn) +
           " range=" + to_string(range))
}

// Check 6: density ratio motif/σ = 10/12 = 5/6 ≈ 0.833
fn check_density_ratio() {
    let r = PREDICTED_MOTIFS / SIGMA_6
    let expected = 5.0 / 6.0
    let drift = _abs(r - expected)
    _check(drift < 1.0e-12,
           "density ratio motif/σ = 5/6 ≈ 0.833",
           "computed=" + to_string(r) + " expected=" + to_string(expected))
}

// Check 7: ratio motif/J₂ = 10/24 = 5/12 ≈ 0.417
fn check_motif_j2_ratio() {
    let r = PREDICTED_MOTIFS / J2
    let expected = 5.0 / 12.0
    let drift = _abs(r - expected)
    _check(drift < 1.0e-12,
           "motif/J₂ = 5/12 ≈ 0.417",
           "computed=" + to_string(r) + " expected=" + to_string(expected))
}

// Check 8: log identity log(σ−φ) = log(σ) + log(1 − φ/σ) within 1e-9
//   log(10) = log(12) + log(1 − 2/12) = log(12) + log(10/12)
fn check_log_decomposition() {
    let lhs = log_pure(PREDICTED_MOTIFS)
    let rhs = log_pure(SIGMA_6) + log_pure(1.0 - PHI_6 / SIGMA_6)
    let drift = _abs(lhs - rhs)
    _check(drift < 1.0e-9,
           "log decomposition: log(σ−φ) = log(σ) + log(1 − φ/σ)",
           "lhs=" + to_string(lhs) + " rhs=" + to_string(rhs) +
           " drift=" + to_string(drift))
}

// Check 9: accumulation stability — sum of 6 obs = 60.0 within 1e-13
fn check_accumulation_stability() {
    let s = _sum(OBS)
    let drift = _abs(s - 60.0)
    _check(drift < 1.0e-13,
           "Σ 6 obs = 60.0 within 1e-13",
           "sum=" + to_string(s) + " drift=" + to_string(drift))
}

// Check 10: F-CODEX-3/4 cross-link in float
//   σ axes (12) − σ−φ motifs (10) = φ (2) within 1e-12
fn check_falsifier_3_4_link_float() {
    let diff = SIGMA_6 - PREDICTED_MOTIFS
    let drift = _abs(diff - PHI_6)
    _check(drift < 1.0e-12,
           "F-CODEX-3 σ − F-CODEX-4 motif = φ (float)",
           "12.0 − 10.0 = " + to_string(diff) + " ; φ = " + to_string(PHI_6))
}

// ── main ─────────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  hexa-codex F-CODEX-4 interpret numerics (T2 numerical, math_pure)")
    println("  motif_count = σ − φ = 10 ; drift tol ±3 over 6 simulated obs")
    println("========================================================================")
    println("  observations: [10, 9, 11, 10, 8, 12]")
    println("  predicted motifs: " + to_string(PREDICTED_MOTIFS))
    println("  drift tolerance: " + to_string(DRIFT_TOL))
    println("")

    check_sigma_minus_phi_float()
    check_obs_mean()
    check_obs_within_tolerance()
    check_obs_stddev()
    check_obs_range()
    println("")
    check_density_ratio()
    check_motif_j2_ratio()
    check_log_decomposition()
    check_accumulation_stability()
    check_falsifier_3_4_link_float()

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  FAILURES:")
        for f in FAILURES { println("    ✗ " + f) }
        println("__HEXA_CODEX_NUMERICS_INTERPRET__ FAIL")
        exit(1)
    }
    println("  F-CODEX-4 T2 numerical floor: closed.")
    println("__HEXA_CODEX_NUMERICS_INTERPRET__ PASS")
    exit(0)
}
