}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_codex_cli", "hexa_codex_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        cmd_help()
        return
    }

    if sub == "help" { cmd_help(); return }
    if sub == "list" { cmd_list(a); return }
    if sub == "selftest" { cmd_selftest(a); return }

    // runnable-surface subcommands (delegate to python verify/ + tests/)
    if sub == "verify"    { cmd_verify(a);    return }
    if sub == "calc"      { cmd_calc(a);      return }
    if sub == "test"      { cmd_test(a);      return }
    if sub == "inventory" { cmd_inventory(a); return }
    if sub == "lattice"   { cmd_lattice(a);   return }
    if sub == "status"    { cmd_status(a);    return }

    // verb dispatch
    if verb_spec(sub) != "" {
        cmd_verb(sub, a)
        return
    }

    eprintln("hexa-codex: unknown subcommand '" + sub + "'")
    eprintln("run 'hexa-codex help' or 'hexa-codex list' for usage")
    _audit(sub, "", 2)
    exit(2)
}
