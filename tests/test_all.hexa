#!hexa strict
// hexa-codex/tests/test_all.hexa — top-level .hexa test runner.
//
// Runs every tests/test_*.hexa in the repo and aggregates exit codes.
// Python pytest harness (62 cases) is invoked separately via:
//   python3 -m pytest tests/ -m auto
//
// Run:
//   hexa run tests/test_all.hexa
//   HEXA_CODEX_ROOT=/path hexa run tests/test_all.hexa

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()
let HEXA = HOME + "/.hx/packages/hexa/hexa.real"

// (filename | expected_sentinel)
let CASES = [
    "test_selftest.hexa|test_selftest: PASS",
    "test_lattice.hexa|__HEXA_CODEX_TEST_LATTICE__ PASS",
    "test_cross_doc.hexa|__HEXA_CODEX_TEST_CROSS_DOC__ PASS",
    "test_calc_train_cost.hexa|__HEXA_CODEX_TEST_CALC_TRAIN_COST__ PASS",
    "test_calc_infer_cost.hexa|__HEXA_CODEX_TEST_CALC_INFER_COST__ PASS",
    "test_calc_alignment.hexa|__HEXA_CODEX_TEST_CALC_ALIGNMENT__ PASS",
    "test_calc_interpret.hexa|__HEXA_CODEX_TEST_CALC_INTERPRET__ PASS",
    "test_numerics_train_cost.hexa|__HEXA_CODEX_TEST_NUMERICS_TRAIN_COST__ PASS",
    "test_numerics_infer_cost.hexa|__HEXA_CODEX_TEST_NUMERICS_INFER_COST__ PASS",
    "test_numerics_alignment.hexa|__HEXA_CODEX_TEST_NUMERICS_ALIGNMENT__ PASS",
    "test_numerics_interpret.hexa|__HEXA_CODEX_TEST_NUMERICS_INTERPRET__ PASS",
    "test_numerics_train_cost_parity.hexa|__HEXA_CODEX_TEST_NUMERICS_TRAIN_COST_PARITY__ PASS",
    "test_numerics_infer_cost_parity.hexa|__HEXA_CODEX_TEST_NUMERICS_INFER_COST_PARITY__ PASS",
    "test_numerics_alignment_parity.hexa|__HEXA_CODEX_TEST_NUMERICS_ALIGNMENT_PARITY__ PASS",
    "test_numerics_interpret_parity.hexa|__HEXA_CODEX_TEST_NUMERICS_INTERPRET_PARITY__ PASS",
    "test_numerics_train_cost_solver.hexa|__HEXA_CODEX_TEST_NUMERICS_TRAIN_COST_SOLVER__ PASS",
    "test_numerics_infer_cost_solver.hexa|__HEXA_CODEX_TEST_NUMERICS_INFER_COST_SOLVER__ PASS",
]

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_one(case: str) -> bool {
    let parts = case.split("|")
    let fname = parts[0]
    let sentinel = parts[1]
    let path = ROOT + "/tests/" + fname
    let cmd = "RESOURCE_LOCAL_HEXA=1 HEXA_CODEX_ROOT=" + shq(ROOT) + " " + shq(HEXA) + " run " + shq(path)
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    let code = r[1]
    let has_sent = out.find(sentinel) >= 0
    let pass = code == 0 && has_sent
    let mark = if pass { "PASS" } else { "FAIL" }
    println("  [" + mark + "] " + fname + "  (exit=" + str(code) + ")")
    return pass
}

fn main() {
    println("========================================================================")
    println("  hexa-codex test_all — run every tests/test_*.hexa")
    println("  root: " + ROOT)
    println("========================================================================")
    let mut ok = 0
    let mut fail = 0
    for c in CASES {
        if run_one(c) { ok = ok + 1 } else { fail = fail + 1 }
    }
    println("========================================================================")
    println("  " + str(ok) + "/" + str(len(CASES)) + " test(s) PASS")
    if fail > 0 {
        eprintln("__HEXA_CODEX_TEST_ALL__ FAIL — " + str(fail) + " test(s) failed")
        exit(1)
    }
    println("__HEXA_CODEX_TEST_ALL__ PASS — full .hexa test suite green")
    exit(0)
}
