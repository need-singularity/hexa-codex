#!hexa strict
// hexa-codex/tests/test_calc_infer_cost.hexa — F-CODEX-2 T1 calc regression test.
//
// Wraps verify/calc_infer_cost.hexa and asserts: exit 0 + sentinel
// `__HEXA_CODEX_CALC_INFER_COST__ PASS` line in stdout.

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_CODEX_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-codex"
}

let ROOT = _root()
let SCRIPT = ROOT + "/verify/calc_infer_cost.hexa"
let HEXA = HOME + "/.hx/packages/hexa/hexa.real"

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn main() {
    println("[test_calc_infer_cost] script: " + SCRIPT)
    let cmd = "RESOURCE_LOCAL_HEXA=1 HEXA_CODEX_ROOT=" + shq(ROOT) + " " + shq(HEXA) + " run " + shq(SCRIPT)
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    let code = r[1]
    let has_pass = out.find("__HEXA_CODEX_CALC_INFER_COST__ PASS") >= 0
    let pass = code == 0 && has_pass
    if pass {
        println("[test_calc_infer_cost] PASS — exit 0 + sentinel found")
        println("__HEXA_CODEX_TEST_CALC_INFER_COST__ PASS")
        exit(0)
    }
    eprintln("[test_calc_infer_cost] FAIL — exit=" + str(code) + " sentinel=" + str(has_pass))
    eprintln("--- stdout ---")
    eprintln(out)
    eprintln("__HEXA_CODEX_TEST_CALC_INFER_COST__ FAIL")
    exit(1)
}
